:proxyFollowsProxyInSequenceTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy follows proxy in sequence transitive"@en,
        "proxy sigue el proxy en la secuencia transitivo"@es,
        "proxy suit le proxy dans la séquence transitif"@fr ;
    rdfs:comment """Inverse of 'proxy recedes proxy in sequence transitive' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :followsInSequenceTransitive ;
    owl:inverseOf :proxyPrecedesProxyInSequenceTransitive ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIn a owl:ObjectProperty ;
    rdfs:label "proxy in"@en,
        "es proxy en"@es,
        "proxy dans"@fr ;
    rdfs:comment """Connects a Proxy to the Record Resource in which it stands for
         (represents) another Record Resource."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRelatedTo ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Changed the range and rdfs:comment to allow any Record
               Resource, not only a Record Set."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:proxyPrecedesInSequence a owl:ObjectProperty ;
    rdfs:label "proxy precedes in sequence"@en,
        "proxy precede en la secuencia"@es,
        "proxy précède dans la séquence"@fr ;
    rdfs:comment """Connects a Proxy of a Record Resource to a Record Resource which
         the first precedes directly or indirectly in some sequence (not necessarily defined or
         characterised chronologically)."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :precedesInSequenceTransitive ;
    owl:inverseOf :followsProxyInSequence ;
    owl:propertyChainAxiom ( :proxyPrecedesProxyInSequenceTransitive :proxyPrecedesInSequence ) ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:recordResourceHoldingRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Record Resource Holding Relation"@en,
        """desempeña el papel de la Relación entre agentes y recursos
         documentales que conservan"""@es,
        """a le rôle de la Relation entre agents et ressources archivistiques
         ou instanciations conservées"""@fr ;
    rdfs:comment """Connects a RecordResourceHoldingRelation to itself. It is a
         property that can stand for an instance of the class when necessary, e.g. when you explore
         a knowledge graph."""@en ;
    rdfs:domain :RecordResourceHoldingRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResourceHoldingRelation ;
    rdfs:subPropertyOf :managementRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the RecordResourceHoldingRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-12-30" ;
            rdf:value "Fixed a typo in the French label."@en ] ;
    skos:scopeNote """This property "rolifies" the RecordResourceHoldingRelation
         class. It should be used only when you have to manage instances of the
         RecordResourceHoldingRelation class, to connect each instance to itself, in order to be
         able to infer, using OWL-RL and property paths, the two shortcuts corresponding to this
         n-ary class."""@en .

:recordResourceToInstantiationRelation_role a owl:ObjectProperty ;
    rdfs:label """has the role of the Record Resource to Instantiation
         Relation"""@en,
        """desempeña el papel de la Relación de recurso documental a
         instanciación"""@es,
        "a le rôle de la Relation d’instanciation"@fr ;
    rdfs:comment """Connects a RecordResourceToInstantiationRelation to itself. It is
         a property that can stand for an instance of the class when necessary, e.g. when you
         explore a knowledge graph."""@en ;
    rdfs:domain :RecordResourceToInstantiationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResourceToInstantiationRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the RecordResourceToInstantiationRelation
               rolified class. Declared it as reflexive. Declared it(s)
               superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the
         RecordResourceToInstantiationRelation class. It should be used only when you have to manage
         instances of the RecordResourceToInstantiationRelation class, to connect each instance to
         itself, in order to be able to infer, using OWL-RL and property paths, the two shortcuts
         corresponding to this n-ary class."""@en .

:recordResourceToRecordResourceRelation_role a owl:ObjectProperty ;
    rdfs:label """has the role of the Record Resource to Record Resource
         Relation"""@en,
        """desempeña el papel de la Relación entre recursos
         documentales"""@es,
        """a le rôle de la Relation entre ressources
         archivistiques"""@fr ;
    rdfs:comment """Connects a RecordResourceToRecordResourceRelation to itself. It is
         a property that can stand for an instance of the class when necessary, e.g. when you
         explore a knowledge graph."""@en ;
    rdfs:domain :RecordResourceToRecordResourceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResourceToRecordResourceRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the RecordResourceToRecordResourceRelation
               rolified class. Declared it as reflexive. Declared it(s)
               superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the
         RecordResourceToRecordResourceRelation class. It should be used only when you have to
         manage instances of the RecordResourceToRecordResourceRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:studyAtRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Study At Relation"@en,
        """desempeña el papel de la Relación entre institución educativa y
         estudiantes"""@es,
        """a le rôle de la Relation entre institution d’enseignement et
         étudiants"""@fr ;
    rdfs:comment """Connects a StudyAtRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :StudyAtRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :StudyAtRelation ;
    rdfs:subPropertyOf :membershipRelation_role ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2024-12-23" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:teachingRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Teaching Relation"@en,
        """desempeña el papel de la Relación académica entre profesor y
         alumno"""@es,
        "a le rôle de la Relation entre enseignants et étudiants"@fr ;
    rdfs:comment """Connects a TeachingRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :TeachingRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :TeachingRelation ;
    rdfs:subPropertyOf :knowingRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the TeachingRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the TeachingRelation class. It should
         be used only when you have to manage instances of the TeachingRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:typeRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Type Relation"@en,
        "desempeña el papel de la Tipo de relación"@es,
        "a le rôle de la Relation de catégorisation"@fr ;
    rdfs:comment """Connects a TypeRelation to itself. It is a property that can stand
         for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :TypeRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :TypeRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the TypeRelation rolified class. Declared
               it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the TypeRelation class. It should be
         used only when you have to manage instances of the TypeRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:AgentHierarchicalRelation a owl:Class ;
    rdfs:label "Akteur-Hierarchie-Akteur"@de,
        "Agent Hierarchical Relation"@en,
        "Relación jerárquica entre agentes"@es,
        "Relation hiérarchique entre agents"@fr ;
    rdfs:comment """Connects at least one Agent to at least another Agent, when the
         first one is or was hierarchically superior to the second one. The Relation is oriented
         towards the 'bottom' of the hierarchical tree: the superior Agent(s) is the source of the
         Relation, and the inferior Agent(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :agentHierarchicalRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """The hierarchical relation can be an authority relation, or a
         whole/part relation between two agents."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R045 and RiC-R045i
         relations"""@en .

:EventRelation a owl:Class ;
    rdfs:label "Ereignis-Ding"@de,
        "Event Relation"@en,
        "Relación con un evento"@es,
        "Relation impliquant un événement"@fr ;
    rdfs:comment """Connects at least one Event to at least one Thing, when the first
         is associated with the existence and lifecycle of the second one. The Event(s) is the
         source of the Relation, and the Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Event ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :eventRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Use to connect an event and an entity only if it is not possible
         to specify a narrower event relation, for example a PerformanceRelation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R057 and RiC-R057i
         relations"""@en .

:Identifier a owl:Class ;
    rdfs:label "Identifikator"@de,
        "Identifier"@en,
        "Identificador"@es,
        "Identifiant"@fr ;
    rdfs:comment """A word, number, letter, symbol, or any combination of these used
         to uniquely identify or reference an individual instance of an entity within a specific
         information domain."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Appellation ;
    skos:changeNote [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Can include Global Persistent Identifiers (globally unique and
         persistently resolvable identifier for the entity) and/or Local Identifiers. Both the
         domain within which the identifier is unique, and the rules used in forming the identifier
         value should be provided with the identifier value."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A22 (Identifier
         attribute) (see also the identifier datatype property)"""@en .

:InstantiationToInstantiationRelation a owl:Class ;
    rdfs:label "Instanz|Repräsentation-Instanz|Repräsentation"@de,
        "Instantiation to Instantiation Relation"@en,
        "Relación entre instanciaciones"@es,
        "Relation entre instanciations"@fr ;
    rdfs:comment """Connects at least two instantiations. This Relation is a generic,
         not oriented one."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationConnects ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :instantiationToInstantiationRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:KnowingRelation a owl:Class ;
    rdfs:label "Person-Bekanntschaft-Person"@de,
        "Knowing Relation"@en,
        "Relación de conocimiento directo entre personas"@es,
        "Relation de connaissance entre personnes"@fr ;
    rdfs:comment """Connects at least two Persons who directly know each other during
         their existence. This Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationConnects ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :knowingRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """The relation implies that the two persons met or at least
         corresponded with each other."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R051 and RiC—R051i
         relations"""@en .

:LeadershipRelation a owl:Class ;
    rdfs:label "Person-Führung-Person"@de,
        "Leadership Relation"@en,
        "Relación de liderazgo"@es,
        "Relation de direction"@fr ;
    rdfs:comment """Connects at least one Person and at least one Group, when the
         first one(s) lead(s) or led the second one(s). The Relation is oriented from the leading
         Person to the Group: the leading Person(s) is the source of the Relation, and the Group(s)
         is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Position ;
            owl:onProperty :leadershipWithPosition ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Group ;
            owl:onProperty :relationHasTarget ],
        :AgentControlRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :leadershipRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R042 and RiC-R042i
         relations"""@en .

:OrganicOrFunctionalProvenanceRelation a owl:Class ;
    rdfs:label "Recordressource/Instanz-Herkunft-Akteur/Funktion"@de,
        "Organic or functional provenance Relation"@en,
        "Relación de procedencia orgánica or funcional"@es,
        "Relation de provenance organique ou fonctionnelle"@fr ;
    rdfs:comment """Connects at least one Record Resource or Instantiation to at least
         one Agent or Activity, when the Agent or Activity is the provenance of the Record Resource
         or Instantiation (i.e. when the Agent created, accumulated or maintained the Record
         Resource or Instantiation, or when the Activity resulted into them). The Record Resource(s)
         or Instantiation(s) is the source of the Relation, and the Agent(s) or Activity(-ies) is
         the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Activity :Agent ) ] ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :organicOrFunctionalProvenanceRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-07" ;
            rdf:value """Renamed the relation (its name was
               ProvenanceRelation)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """This relation stands for organic and for functional
         provenance."""@en .

:OrganicProvenanceRelation a owl:Class ;
    rdfs:label "Recordressource/Instanz-Herkunft-Akteur"@de,
        "Organic Provenance Relation"@en,
        "Relación de procedencia orgánica"@es,
        "Relation de provenance organique"@fr ;
    rdfs:comment """Connects at least one Record Resource or an Instantiation to at
         least one Agent that creates or accumulates the Record Resource, receives it, or sends it.
         The Record Resource(s) or Instantiation(s) is the source of the Relation, and the Agent(s)
         is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        :OrganicOrFunctionalProvenanceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :organicProvenanceRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Renamed the relation in order to make it clearer (its name was
               AgentOriginationRelation)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """This is the most general organic provenance relation. Use it to
         connect a record resource or instantiation with an agent only if it is not possible to use
         a narrower, more specific relation, for example Creation Relation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R026 and RiC-R026i
         relations"""@en .

:PhysicalLocation a owl:Class ;
    rdfs:label "Standort"@de,
        "Physical Location"@en,
        "Localización física de lugar"@es,
        "Localisation physique"@fr ;
    rdfs:comment """A delimitation of the physical territory of a
         Place."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value """Removed the two 0.2 existing unnecessary
               restrictions."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ] ;
    skos:scopeNote """Used to describe basic human-readable text such as an address, a
         cadastral reference, or less precise information found in a record. Use the coordinates
         datatype property, or the Coordinates class to capture the geographical coordinates of the
         Place. Use spatial relations (particularly 'has or had location') to capture a relation
         between two places."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A27 (Location
         attribute)"""@en .

:TemporalRelation a owl:Class ;
    rdfs:label "Ding-Zeitfolge-Ding"@de,
        "Temporal Relation"@en,
        "Relación temporal"@es,
        "Relation temporelle"@fr ;
    rdfs:comment """Connects at least one Thing to at least one other Thing that
         follows it in chronological order. The Relation is oriented chronologically: the preceding
         Thing(s) is the source of the Relation, the following Thing(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :SequentialRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :temporalRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """There may be zero to many intermediate entities, ignored or
         unknown, in the chronological sequence between the connected entities."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R009 and RiC-R009i
         relations"""@en .

:Title a owl:Class ;
    rdfs:label "Titel"@de,
        "Title"@en,
        "Título"@es,
        "Intitulé"@fr ;
    rdfs:comment "A name that is used for a Record Resource or a Rule"@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Name ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of a specialization of RiC-A28
         (Name attribute)"""@en .

:agentControlRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Agent Control Relation"@en,
        """desempeña el papel de la Relación de control entre
         agentes"""@es,
        "a le rôle de la Relation de contrôle entre agents"@fr ;
    rdfs:comment """Connects an AgentControlRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AgentControlRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AgentControlRelation ;
    rdfs:subPropertyOf :agentHierarchicalRelation_role,
        :authorityRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AgentControlRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AgentControlRelation class. It
         should be used only when you have to manage instances of the AgentControlRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:agentTemporalRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Agent Temporal Relation"@en,
        """desempeña el papel de la Relación temporal entre
         agentes"""@es,
        "a le rôle de la Relation temporelle entre agents"@fr ;
    rdfs:comment """Connects an AgentTemporalRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AgentTemporalRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AgentTemporalRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role,
        :temporalRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AgentTemporalRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AgentTemporalRelation class. It
         should be used only when you have to manage instances of the AgentTemporalRelation class,
         to connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:descendanceRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Descendance Relation"@en,
        "desempeña el papel de la Relación de descendencia"@es,
        "a le rôle de la Relation de descendance"@fr ;
    rdfs:comment """Connects a DescendanceRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :DescendanceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :DescendanceRelation ;
    rdfs:subPropertyOf :agentTemporalRelation_role,
        :familyRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the DescendanceRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the DescendanceRelation class. It
         should be used only when you have to manage instances of the DescendanceRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:directlyFollowsInSequence a owl:ObjectProperty ;
    rdfs:label "directly follows in sequence"@en,
        "sigue directamente en la secuencia"@es,
        "suit directement dans la séquence"@fr ;
    rdfs:comment """Inverse of 'directly precedes in sequence' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :followsInSequenceTransitive ;
    owl:inverseOf :directlyPrecedesInSequence ;
    owl:propertyChainAxiom ( :hasProxy :proxyDirectlyFollowsInSequence ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to simply refer to its inverse
               property. Also added a property chain axiom relating it to use of
               rico:Proxy."""@en ],
        [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from followsInTime."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Added transitive super-property and both present direct and
               past sequential relations as well as their respective inverse relations."""@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Fixed the property chain axiom."@en ] .

:directlyPrecedesInSequence a owl:ObjectProperty ;
    rdfs:label "directly precedes in sequence"@en,
        "precede directamente en la secuencia"@es,
        "précède directement dans la séquence"@fr ;
    rdfs:comment """Connects a Thing to a Thing that it precedes directly in some
         sequence (not necessarily defined or characterised chronologically)."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :precedesInSequenceTransitive ;
    owl:inverseOf :directlyFollowsInSequence ;
    owl:propertyChainAxiom ( :directlyPrecedesProxyInSequence :proxyFor ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to try to clarify what is meant. Also
               added a property chain axiom relating it to use of rico:Proxy."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, sequential relations between things (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from precedesInTime."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ] .

:followsOrFollowed a owl:ObjectProperty ;
    rdfs:label "follows or followed"@en,
        "sigue o seguía a"@es,
        "suit ou a suivi"@fr ;
    rdfs:comment "Inverse of 'precedes or preceded' object property."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :precedesOrPreceded ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :sequentialRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "follows")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new sequentialRelation_role
               object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R008i ('follows or followed'
         relation)"""@en .

:hasConstituentProxy a owl:ObjectProperty ;
    rdfs:label "has constituent proxy"@en,
        "tiene como elemento constitutivo el proxy"@es,
        "a pour constituant le proxy"@fr ;
    rdfs:comment """Inverse of 'proxy is constituent of' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :proxyIsConstituentOf ;
    owl:propertyChainAxiom ( :hasConstituentProxy :proxyHasConstituentProxyTransitive ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value """Fixed the owl:subPropertyOf (was set to
               isPartOfTransitive)."""@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:hasEndDate a owl:ObjectProperty ;
    rdfs:label "has end date"@en,
        "tiene como fecha final"@es,
        "a pour date de fin"@fr ;
    rdfs:comment "Inverse of 'is end date of' object property."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isEndDateOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R071i ('has end date'
         relation)"""@en .

:hasFamilyAssociationWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has family association with"@en,
        "tiene asociación familiar con"@es,
        "a une relation familiale avec"@fr ;
    rdfs:comment """Connects two Persons that have some type of family link, i.e.
         belong to the same family. This relation is symmetric."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :familyRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new familyRelation_role object
               property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, textual definition (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "hasFamilyLinkWith")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ] ;
    skos:scopeNote """Use hasOrHadMember for connecting a Family and a
         Person."""@en ;
    :RiCCMCorrespondingComponent """RiC-R047 ('has family association with'
         relation)"""@en .

:hasOrHadName a owl:ObjectProperty ;
    rdfs:label "has or had name"@en,
        "tiene o tenía como nombre"@es,
        "a ou a eu pour nom"@fr ;
    rdfs:comment """Connects a Thing to one of its past or present
         Names."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Name ;
    rdfs:subPropertyOf :hasOrHadAppellation ;
    owl:inverseOf :isOrWasNameOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition, super property IRI (the name of this property in RiC-O 0.1 was
               "hasName")."""@en ] .

:hasSuccessor a owl:ObjectProperty ;
    rdfs:label "has successor"@en,
        "tiene como sucesor(a) a"@es,
        "a pour successeur"@fr ;
    rdfs:comment """Connects an Agent to another Agent that succeeds it
         chronologically."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent,
        :precedesInTime ;
    owl:inverseOf :isSuccessorOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :agentTemporalRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new agentTemporalRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI and label (changed made in order to make RiC-O
               compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "isAntecedentOf")."""@en ] ;
    skos:scopeNote """There may be zero to many intermediate Agents, ignored or
         unknown, between the two connected Agents. Can be used when there is a transfer of function
         from the first Agent to the second Agent."""@en ;
    :RiCCMCorrespondingComponent """RIC-R016 ('has successor'
         relation)"""@en .

:includesProxy a owl:ObjectProperty ;
    rdfs:label "includes proxy"@en,
        "incluye el proxy"@es,
        "inclut le proxy"@fr ;
    rdfs:comment "Inverse of 'proxy is included in' object property."@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :proxyIsIncludedIn ;
    owl:propertyChainAxiom ( :includesProxy :proxyIncludesProxyTransitive ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value """Fixed the owl:inverseOf (was set to
               isPartOfTransitive)."""@en ] .

:instantiationToInstantiationRelation_role a owl:ObjectProperty ;
    rdfs:label """has the role of the Instantiation to Instantiation
         Relation"""@en,
        "desempeña el papel de la Relación entre instanciaciones"@es,
        "a le rôle de la Relation entre instanciations"@fr ;
    rdfs:comment """Connects an InstantiationToInstantiationRelation to itself. It is
         a property that can stand for an instance of the class when necessary, e.g. when you
         explore a knowledge graph."""@en ;
    rdfs:domain :InstantiationToInstantiationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :InstantiationToInstantiationRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the InstantiationToInstantiationRelation
               rolified class. Declared it as reflexive. Declared it(s)
               superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the
         InstantiationToInstantiationRelation class. It should be used only when you have to manage
         instances of the InstantiationToInstantiationRelation class, to connect each instance to
         itself, in order to be able to infer, using OWL-RL and property paths, the two shortcuts
         corresponding to this n-ary class."""@en .

:isConstituentOfProxy a owl:ObjectProperty ;
    rdfs:label "is constituent of proxy"@en,
        "es elemento constitutivo del proxy"@es,
        "est le constituant du proxy"@fr ;
    rdfs:comment """Connects a Record or Record Part to a Proxy of a Record or Record
         Part of which it is a constituent, directly or indirectly."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :proxyHasConstituent ;
    owl:propertyChainAxiom ( :isConstituentOfProxy :proxyIsConstituentOfProxyTransitive ) ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isEndDateOf a owl:ObjectProperty ;
    rdfs:label "is end date of"@en,
        "es fecha final de"@es,
        "est la date de fin de"@fr ;
    rdfs:comment """Connects a Date to a Thing whose existence ended on that
         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasEndDate ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R071 ('is end date of'
         relation)"""@en .

:isIncludedInProxy a owl:ObjectProperty ;
    rdfs:label "is included in proxy"@en,
        "está incluido en el proxy"@es,
        "est inclus dans le proxy"@fr ;
    rdfs:comment """Connects a Record or Record Set to a Proxy of a Record Set which
         it is included in, directly or indirectly."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :proxyIncludes ;
    owl:propertyChainAxiom ( :isIncludedInProxy :proxyIsIncludedInProxyTransitive ) ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasNameOf a owl:ObjectProperty ;
    rdfs:label "is or was name of"@en,
        "es o era nombre de"@es,
        "est ou a été le nom de"@fr ;
    rdfs:comment """Connects a Name to a Thing that it designated or
         designates."""@en ;
    rdfs:domain :Name ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isOrWasAppellationOf ;
    owl:inverseOf :hasOrHadName ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition, super property IRI (the name of this property in RiC-O 0.1 was
               "isNameOf")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isSuccessorOf a owl:ObjectProperty ;
    rdfs:label "is successor of"@en,
        "es sucesor(a) de"@es,
        "est le successeur de"@fr ;
    rdfs:comment "Inverse of 'has successor' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :followsInTime,
        :isAgentAssociatedWithAgent ;
    owl:inverseOf :hasSuccessor ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :agentTemporalRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new agentTemporalRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the inverse property IRI and the text
               definition."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R016i ('is successor of'
         relation)"""@en .

:knowingRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Knowing Relation"@en,
        """desempeña el papel de la Relación de conocimiento directo entre
         personas"""@es,
        """a le rôle de la Relation de connaissance entre
         personnes"""@fr ;
    rdfs:comment """Connects a KnowingRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :KnowingRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :KnowingRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the KnowingRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the KnowingRelation class. It should be
         used only when you have to manage instances of the KnowingRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:managementRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Management Relation"@en,
        "desempeña el papel de la Relación de gestión"@es,
        "a le rôle de la Relation de gestion"@fr ;
    rdfs:comment """Connects a ManagementRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :ManagementRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ManagementRelation ;
    rdfs:subPropertyOf :authorityRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the ManagementRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the ManagementRelation class. It should
         be used only when you have to manage instances of the ManagementRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:membershipRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Membership Relation"@en,
        "desempeña el papel de la Relación de membresía"@es,
        "a le rôle de la Relation d’appartenance"@fr ;
    rdfs:comment """Connects a MembershipRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :MembershipRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :MembershipRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the MembershipRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the MembershipRelation class. It should
         be used only when you have to manage instances of the MembershipRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:precedesOrPreceded a owl:ObjectProperty ;
    rdfs:label "precedes or preceded"@en,
        "precede o precedía secuencialmente a"@es,
        "précède ou a précédé"@fr ;
    rdfs:comment """Connects a Thing to a Thing that follows or followed it in some
         sequence."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :followsOrFollowed ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :sequentialRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "precedes")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new sequentialRelation_role
               object property."""@en ] ;
    skos:scopeNote """The relation does not specify by itself what criteria are used
         for ordering the sequence. There may actually be zero to many intermediate Entities,
         ignored or unkown, in the sequence between the two connected Things. Can be used, for
         example, for specifying that some Record 'precedes' (has next) some Record within a Record
         Set."""@en ;
    :RiCCMCorrespondingComponent """RiC-R008 ('precedes or preceded'
         relation)"""@en .

:precedesProxyInSequence a owl:ObjectProperty ;
    rdfs:label "precedes proxy in sequence"@en,
        "precede el proxy en la secuencia"@es,
        "précède le proxy dans la séquence"@fr ;
    rdfs:comment """Connects a Record Resource to a Proxy of a Record Resource that it
         precedes directly or indirectly in some sequence (not necessarily defined or characterised
         chronologically)."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :precedesInSequenceTransitive ;
    owl:inverseOf :proxyFollowsInSequence ;
    owl:propertyChainAxiom ( :precedesProxyInSequence :proxyPrecedesProxyInSequenceTransitive ) ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyFollowsInSequence a owl:ObjectProperty ;
    rdfs:label "proxy follows in sequence"@en,
        "proxy sigue en la secuencia"@es,
        "proxy suit dans la séquence"@fr ;
    rdfs:comment """Inverse of 'precedes proxy in sequence' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :followsInSequenceTransitive ;
    owl:inverseOf :precedesProxyInSequence ;
    owl:propertyChainAxiom ( :proxyFollowsProxyInSequenceTransitive :proxyFollowsInSequence ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyHasConstituent a owl:ObjectProperty ;
    rdfs:label "proxy has constituent"@en,
        "proxy tiene como elemento constitutivo"@es,
        "proxy a pour constituant"@fr ;
    rdfs:comment """Inverse of 'is constituent of proxy' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :isConstituentOfProxy ;
    owl:propertyChainAxiom ( :proxyHasConstituentProxyTransitive :proxyHasConstituent ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyHasConstituentProxyTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy has constituent proxy transitive"@en,
        """proxy tiene como elemento constitutivo el proxy
         (transitivo)"""@es,
        "proxy a pour constituant le proxy (transitif)"@fr ;
    rdfs:comment """Inverse of 'proxy is constituent of proxy transitive' object
         property. This is a transitive relation."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :proxyIsConstituentOfProxyTransitive ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyIncludes a owl:ObjectProperty ;
    rdfs:label "proxy includes"@en,
        "proxy incluye"@es,
        "proxy inclut"@fr ;
    rdfs:comment "Inverse of 'is included in proxy' object property."@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :isIncludedInProxy ;
    owl:propertyChainAxiom ( :proxyIncludesProxyTransitive :proxyIncludes ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIncludesProxyTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy includes proxy transitive"@en,
        "proxy incluye el proxy (transitivo)"@es,
        "proxy inclut le proxy (transitif)"@fr ;
    rdfs:comment """Inverse of 'proxy is included in proxy transitive' object
         property. This is a transitive relation."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :proxyIsIncludedInProxyTransitive ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIsConstituentOf a owl:ObjectProperty ;
    rdfs:label "proxy is constituent of"@en,
        "proxy es un elemento constitutivo de"@es,
        "proxy est un constituant de"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Part to a Record or Record
         Part which it is a constituent of, directly or indirectly."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :hasConstituentProxy ;
    owl:propertyChainAxiom ( :proxyIsConstituentOfProxyTransitive :proxyIsConstituentOf ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIsConstituentOfProxyTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy is constituent of proxy transitive"@en,
        "proxy es elemento constitutivo del proxy (transitivo)"@es,
        "proxy est un constituant du proxy (transitif)"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Part to a Proxy of another
         Record or Record Part which it is a constituent of, directly or indirectly. This is a
         transitive relation."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :proxyHasConstituentProxyTransitive ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIsIncludedIn a owl:ObjectProperty ;
    rdfs:label "proxy is included in"@en,
        "proxy está incluido en"@es,
        "proxy est inclus dans"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Set to a Record Set which
         it is included in, directly or indirectly."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :includesProxy ;
    owl:propertyChainAxiom ( :proxyIsIncludedInProxyTransitive :proxyIsIncludedIn ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyIsIncludedInProxyTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy is included in proxy transitive"@en,
        "proxy está incluido en el proxy (transitivo)"@es,
        "proxy est inclus dans le proxy (transitif)"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Set to a Proxy of a Record
         Set which it is included in, directly or indirectly. This is a transitive
         relation."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :proxyIncludesProxyTransitive ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyPrecedesProxyInSequenceTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "proxy precedes proxy in sequence transitive"@en,
        "proxy precede el proxy en la secuencia (transitivo)"@es,
        "proxy précède le proxy dans la séquence (transitif)"@fr ;
    rdfs:comment """Connects a Proxy of a Record Resource to a Proxy of another Record
         Resource which directly or indirectly follows the first in some sequence (not necessarily
         defined or characterised chronologically). This is a transitive relation."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :precedesInSequenceTransitive ;
    owl:inverseOf :proxyFollowsProxyInSequenceTransitive ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:ruleRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Rule Relation"@en,
        "desempeña el papel de la Relación con regla"@es,
        "a le rôle de la Relation impliquant une règle"@fr ;
    rdfs:comment """Connects a RuleRelation to itself. It is a property that can stand
         for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :RuleRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RuleRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the RuleRelation rolified class. Declared
               it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the RuleRelation class. It should be
         used only when you have to manage instances of the RuleRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:sequentialRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Sequential Relation"@en,
        "desempeña el papel de la Relación secuencial"@es,
        "a le rôle de la Relation séquentielle"@fr ;
    rdfs:comment """Connects a SequentialRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :SequentialRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :SequentialRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the SequentialRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the SequentialRelation class. It should
         be used only when you have to manage instances of the SequentialRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:wholePartRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Whole Part Relation"@en,
        "desempeña el papel de la Relación entre todo y parte"@es,
        "a le rôle de la Relation partitive"@fr ;
    rdfs:comment """Connects a WholePartRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :WholePartRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :WholePartRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the WholePartRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the WholePartRelation class. It should
         be used only when you have to manage instances of the WholePartRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

skos:note a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .

:AgentTemporalRelation a owl:Class ;
    rdfs:label "Akteur-Nachfolge"@de,
        "Agent Temporal Relation"@en,
        "Relación temporal entre agentes"@es,
        "Relation temporelle entre agents"@fr ;
    rdfs:comment """Connects at least one Agent to at least another Agent that
         succeeds it chronologically for, for instance, fullfilling some functions or performing
         some activities. The Relation is oriented chronologically, from the predecessor to the
         successor: the predecessor Agent(s) is the source of the Relation, and the successor
         Agent(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        :AgentToAgentRelation,
        :TemporalRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :agentTemporalRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """There may be zero to many intermediate agents, ignored or
         unknown, between the two connected agents. Can be used when there is a transfer of function
         from the first agent to the second agent."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R016 and RiC-016i
         relations"""@en .

:Concept a owl:Class ;
    rdfs:label "Konzept"@de,
        "Concept"@en,
        "Concepto"@es,
        "Concept"@fr ;
    rdfs:comment """An idea, unit of thought, abstract cultural object or
         category"""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:CreationRelation a owl:Class ;
    rdfs:label "Recordressource/Instanz-Erstellung-Akteur"@de,
        "Creation Relation"@en,
        "Relación de creación"@es,
        "Relation de création"@fr ;
    rdfs:comment """Connects at least one Record Resource or Instantiation to at least
         one Agent, when the Agent is either responsible for all or some of the content of the
         Record Resource, or is a contributor to the genesis or production of the Instantiation. The
         Record Resource or Instantiation is the source of the Relation, and the Agent(s) is the
         target. """@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasSource ],
        :OrganicProvenanceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :creationRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed a 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    skos:scopeNote """Covers the definition of "author" in diplomatics, and any agent
         that makes a contribution to the intellectual content of a record resource. Can also be
         used for any agent that was involved in the genesis (e.g. with the role of witness,
         representative of the author etc.) or in the production (e.g. with the role of scribe,
         secretary, notary, printer etc.) of the record resource or instantiation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R027 and RiC-R027i
         relations"""@en .

:FamilyRelation a owl:Class ;
    rdfs:label "Person-Familie-Person"@de,
        "Family Relation"@en,
        "Relación familiar"@es,
        "Relation familiale"@fr ;
    rdfs:comment """Connects at least two Persons, when they have some family link,
         i.e. belong to the same family. This Relation is a generic, not oriented
         one."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationConnects ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :familyRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Use the MembershipRelation class for connecting a family and a
         person."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R047 and RiC-R047i
         relations"""@en .

:Mandate a owl:Class ;
    rdfs:label "Mandat"@de,
        "Mandate"@en,
        "Norma"@es,
        "Mandat"@fr ;
    rdfs:comment """Delegation of responsibility or authority by an Agent to another
         Agent to perform an Activity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Rule ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Objective: to
               make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-04-21" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ] ;
    skos:scopeNote """Mandate is a kind of Rule. A mandate confers the responsibility
         or authority of an agent to perform a specified activity. In addition to assigning an
         activity and delegating responsibility or authority to perform the activity to an agent, a
         mandate commonly limits the place (jurisdiction) and date (time period) within which an
         agent may perform the activity (where and when). Mandates exist in a specific social and
         cultural context, and within that context are subject to change over time. While a mandate
         may be tacit, in whole or part, it may be explicitly expressed in a variety of documentary
         sources (for example, constitutions, legislation, (legal) acts, statutes, legal codes,
         ordinances, charges, charters, or mission statements). The evidence for identifying a
         mandate may be found in its entirety in one documentary source (for example, a law or
         regulation), or may be found in two or more sources. A mandate should not be confused with
         the one or more documentary sources that serve as evidence of its identity. A documentary
         source is a record."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E17 (Mandate
         entity)"""@en .

:MembershipRelation a owl:Class ;
    rdfs:label "Gruppe-Mitgliedschaft-Person"@de,
        "Membership Relation"@en,
        "Relación de membresía"@es,
        "Relation d’appartenance"@fr ;
    rdfs:comment """Connects a Group and at least one Person, when the first one has
         or had the second one(s) among its members. The Relation is oriented from the Group to its
         members: the Group(s) is the source of the Relation, and the Person(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Position ;
            owl:onProperty :membershipWithPosition ],
        [ a owl:Restriction ;
            owl:onClass :Group ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :membershipRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R055 and RiC-R055i
         relations"""@en .

:Name a owl:Class ;
    rdfs:label "Name"@de,
        "Name"@en,
        "Nombre"@es,
        "Nom"@fr ;
    rdfs:comment """A label, title or term designating an entity in order to make it
         distinguishable from other similar entities."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Appellation ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Provides brief information about the content or other individual
         characteristics of the entity being described, necessary to distinguish it from other
         perhaps similar entities."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A28 (Name attribute)
         (see also the name datatype property)"""@en .

:accumulationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Accumulation Relation"@en,
        "desempeña el papel de la Relación de Acumulación"@es,
        "a le rôle de la Relation d’accumulation"@fr ;
    rdfs:comment """Connects an AccumulationRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AccumulationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AccumulationRelation ;
    rdfs:subPropertyOf :organicProvenanceRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AccumulationRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AccumulationRelation class. It
         should be used only when you have to manage instances of the AccumulationRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:agentHierarchicalRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Agent Hierarchical Relation"@en,
        """desempeña el papel de la Relación jerárquica entre
         agentes"""@es,
        "a le rôle de la Relation hiérarchique entre agents"@fr ;
    rdfs:comment """Connects an AgentHierarchicalRelation to itself. It is a property
         that can stand for an instance of the class when necessary, e.g. when you explore a
         knowledge graph."""@en ;
    rdfs:domain :AgentHierarchicalRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AgentHierarchicalRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AgentHierarchicalRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AgentHierarchicalRelation class. It
         should be used only when you have to manage instances of the AgentHierarchicalRelation
         class, to connect each instance to itself, in order to be able to infer, using OWL-RL and
         property paths, the two shortcuts corresponding to this n-ary class."""@en .

:beginningDate a owl:DatatypeProperty ;
    rdfs:label "beginning date"@en,
        "fecha de inicio"@es,
        "date de début"@fr ;
    rdfs:comment "Date at which something began."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:eventRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Event Relation"@en,
        "desempeña el papel de la Relación con un evento"@es,
        "a le rôle de la Relation impliquant un événement"@fr ;
    rdfs:comment """Connects an EventRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :EventRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :EventRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the EventRelation rolified class. Declared
               it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the EventRelation class. It should be
         used only when you have to manage instances of the EventRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:familyRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Family Relation"@en,
        "desempeña el papel de la Relación familiar"@es,
        "a le rôle de la Relation familiale"@fr ;
    rdfs:comment """Connects a FamilyRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :FamilyRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :FamilyRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the FamilyRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Corrected unparseable symbol in rdfs:comment"@en ] ;
    skos:scopeNote """This property "rolifies" the FamilyRelation class. It should be
         used only when you have to manage instances of the FamilyRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:followsInSequenceTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "follows in sequence transitive"@en,
        "sigue en la secuencia transitivo"@es,
        "suit dans la séquence transitif"@fr ;
    rdfs:comment """Inverse of 'precedes in sequence transitive' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :followsOrFollowed ;
    owl:inverseOf :precedesInSequenceTransitive ;
    owl:propertyChainAxiom ( :hasProxy :proxyFollowsInSequence ) ;
    skos:changeNote [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from followsInTime."""@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to simply refer to its inverse
               property. Also added a property chain axiom relating it to use of rico:Proxy.
            """@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Added transitive super-property and both present direct and
               past sequential relations as well as their respective inverse relations."""@en ] .

:hasOrHadAllMembersWithType a owl:ObjectProperty ;
    rdfs:label "has or had all members with type"@en,
        "incluye o incluía miembros, todos con tipo"@es,
        "inclut ou a inclus des membres ayant tous pour type"@fr ;
    rdfs:comment """Connects a Record Set and a Type to which all the Records or
         Record Parts that are or were included in the Record Set belong."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Type ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasTypeOfAllMembersOf ;
    skos:changeNote [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ] .

:hasOrHadAuthorityOver a owl:ObjectProperty ;
    rdfs:label "has or had authority over"@en,
        "tiene o tenía control sobre"@es,
        "a ou a eu autorité sur"@fr ;
    rdfs:comment """Connects an Agent to a Thing over which the Agent has or had some
         kind of authority."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasUnderAuthorityOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :authorityRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasAuthorityOver")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new authorityRelation_role
               object property."""@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower authority
         relation, for example is or was owner of."""@en ;
    :RiCCMCorrespondingComponent """RiC-R036 ('has or had authority over'
         relation)"""@en .

:hasOrHadSomeMembersWithType a owl:ObjectProperty ;
    rdfs:label "has or had some members with type"@en,
        "incluye o incluía algunos miembros con tipo"@es,
        "inclut ou a inclus des membres ayant pour type"@fr ;
    rdfs:comment """Connects a Record Set and a Type to which some of the Records or
         Record Parts that are or were included in the Record Set belong."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Type ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasTypeOfSomeMembersOf ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasOrHadSubject a owl:ObjectProperty ;
    rdfs:label "has or had subject"@en,
        "tiene o tenía como materia"@es,
        "a ou a eu pour sujet"@fr ;
    rdfs:comment """Connects a Record Resource to a Thing that is or was its
         subject."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasSubjectOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "hasSubject")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """The subject of a Record Set may be affected if the Record Set
         loses some of the Records."""@en ;
    :RiCCMCorrespondingComponent """RiC-R019 ('has or had subject'
         relation)"""@en .

:hasOrHadSubordinate a owl:ObjectProperty ;
    rdfs:label "has or had subordinate"@en,
        "tiene o tenía como subordinado o subordinada a"@es,
        "a ou a eu pour subalterne"@fr ;
    rdfs:comment """Connects an Agent to an Agent that is hierarchically
         inferior."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :isOrWasSubordinateTo ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :agentHierarchicalRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "isHierarchicallySuperiorTo")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               agentHierarchicalRelation_role object property."""@en ] ;
    skos:scopeNote """The hierarchical relation can be an authority relation, or a
         whole/part relation between two Agents."""@en ;
    :RiCCMCorrespondingComponent """RiC-R045 ('has or had subordinate '
         relation)"""@en .

:hasOrganicProvenance a owl:ObjectProperty ;
    rdfs:label "has organic provenance"@en,
        "tiene como procedencia orgánica"@es,
        "a pour provenance organique"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to an Agent that
         creates or accumulates the Record Resource, receives it, or sends it."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrganicOrFunctionalProvenance ;
    owl:inverseOf :isOrganicProvenanceOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :organicProvenanceRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-07" ;
            rdf:value """Made this property a subproperty of the new
               hasOrganicOrFunctionalProvenance property. Renamed it to make things clearer.
               Adjusted its labels."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               organicProvenanceRelation_role object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ] ;
    skos:scopeNote """This is the most general organic provenance relation. Use it to
         connect a Record Resource or Instantiation with an Agent only if it is not possible to use
         a narrower, more specific relation, for example has creator."""@en ;
    :RiCCMCorrespondingComponent """RiC-R026 ('has provenance'
         relation)"""@en .

:hasProxy a owl:ObjectProperty ;
    rdfs:label "has proxy"@en,
        "tiene como proxy"@es,
        "a pour proxy"@fr ;
    rdfs:comment "Inverse of 'proxy for' object property."@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :proxyFor ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1"@en ] .

:isAgentAssociatedWithPlace a owl:ObjectProperty ;
    rdfs:label "is agent associated with place"@en,
        "agente está asociado con lugar"@es,
        "est un agent associé au lieu"@fr ;
    rdfs:comment """Inverse of 'is place associated with agent' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAssociatedWithPlace ;
    owl:inverseOf :isPlaceAssociatedWithAgent ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added a rdfs:comment."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O v1.0."@en ] .

:isInstantiationAssociatedWithInstantiation a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is instantiation associated with instantiation"@en,
        "se asocia con la instanciación"@es,
        "est associée à l’instanciation"@fr ;
    rdfs:comment """Connects two Instantiations. This relation is
         symmetric."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :instantiationToInstantiationRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               instantiationToInstantiationRelation_role object property."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower
         Instantiation to Instantiation relation, for example is functionally equivalent
         to."""@en ;
    :RiCCMCorrespondingComponent """RiC-R034 ('is instantiation associated with
         instantiation' relation)"""@en .

:isOrWasSubjectOf a owl:ObjectProperty ;
    rdfs:label "is or was subject of"@en,
        "es o era materia de"@es,
        "est ou a été le sujet de"@fr ;
    rdfs:comment "Inverse of 'has or had subject' object property."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadSubject ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "isSubjectOf")."""@en ] ;
    :RiCCMCorrespondingComponent """RIc-R019i ('is or was subject of'
         relation)"""@en .

:isOrWasSubordinateTo a owl:ObjectProperty ;
    rdfs:label "is or was subordinate to"@en,
        "está o estaba subordinado(a) a"@es,
        "est ou a été le subalterne de"@fr ;
    rdfs:comment """Inverse of 'has or had subordinate' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :hasOrHadSubordinate ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :agentHierarchicalRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               agentHierarchicalRelation_role object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "isHierarchicallyInferiorTo")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R045i ('is or was subordinate to'
         relation)"""@en .

:isOrWasTypeOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was type of all members of"@en,
        "es o era lo tipo de todos los miembros de"@es,
        "est ou a été le type de tous les membres de"@fr ;
    rdfs:comment """Connects a Type and a Record Set whose all present or past Record
         or Record Part members belong to that Type."""@en ;
    rdfs:domain :Type ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadAllMembersWithType ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isOrWasTypeOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was type of some members of"@en,
        "es o era lo tipo de algunos miembros de"@es,
        "est ou a été le type de certains membres de"@fr ;
    rdfs:comment """Connects a Type and a Record Set whose some present or past Record
         or Record Part members belong to that Type."""@en ;
    rdfs:domain :Type ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadSomeMembersWithType ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ] .

:isOrWasUnderAuthorityOf a owl:ObjectProperty ;
    rdfs:label "is or was under authority of"@en,
        "está o estaba bajo control de"@es,
        "est ou a été sous l’autorité de"@fr ;
    rdfs:comment """Inverse of 'has or had authority over' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadAuthorityOver ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :authorityRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new authorityRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "isUnderAuthorityOf")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R036i ('is or was under authority of'
         relation)"""@en .

:isOrganicProvenanceOf a owl:ObjectProperty ;
    rdfs:label "is organic provenance of"@en,
        "es procedencia orgánica de"@es,
        "est la provenance organique de"@fr ;
    rdfs:comment """Inverse of 'has organic provenance' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicOrFunctionalProvenanceOf ;
    owl:inverseOf :hasOrganicProvenance ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :organicProvenanceRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2024-03-15" ;
            rdf:value "Make capitalisation of rdfs:comment consistent."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               organicProvenanceRelation_role object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Made this property a subproperty of the new
               isOrganicOrFunctionalProvenanceOf property. Renamed it to make things clearer.
               Adjusted its labels."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R026i ('is provenance of'
         relation)"""@en .

:isPlaceAssociatedWithAgent a owl:ObjectProperty ;
    rdfs:label "is place associated with agent"@en,
        "es lugar asociado con agente"@es,
        "est un lieu associé à l'agent"@fr ;
    rdfs:comment """Connects a Place to an Agent which is related to that
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isPlaceAssociatedWith ;
    owl:inverseOf :isAgentAssociatedWithPlace ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O v1.0."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value """fixed the domain and range, added a rdfs:comment and English
               and French labels."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:migrationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Migration Relation"@en,
        """desempeña el papel de la Relación de migración entre
         instanciaciones"""@es,
        "a le rôle de la Relation de migration"@fr ;
    rdfs:comment """Connects a MigrationRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :MigrationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :MigrationRelation ;
    rdfs:subPropertyOf :derivationRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the MigrationRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the MigrationRelation class. It should
         be used only when you have to manage instances of the MigrationRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:organicOrFunctionalProvenanceRelation_role a owl:ObjectProperty ;
    rdfs:label """has the role of the Organic or functional provenance
         Relation"""@en,
        """desempeña el papel de la Relación de procedencia orgánica or
         funcional"""@es,
        """a le rôle de la Relation de provenance organique ou
         fonctionnelle"""@fr ;
    rdfs:comment """Connects an OrganicOrFunctionalProvenanceRelation to itself. It is
         a property that can stand for an instance of the class when necessary, e.g. when you
         explore a knowledge graph."""@en ;
    rdfs:domain :OrganicOrFunctionalProvenanceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :OrganicOrFunctionalProvenanceRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the OrganicOrFunctionalProvenanceRelation
               rolified class. Declared it as reflexive. Declared it(s)
               superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the
         OrganicOrFunctionalProvenanceRelation class. It should be used only when you have to manage
         instances of the OrganicOrFunctionalProvenanceRelation class, to connect each instance to
         itself, in order to be able to infer, using OWL-RL and property paths, the two shortcuts
         corresponding to this n-ary class."""@en .

:performanceRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Performance Relation"@en,
        """desempeña el papel de la Relación de desarrollo
         funcional"""@es,
        "a le rôle de la Relation entre activités et agents"@fr ;
    rdfs:comment """Connects a PerformanceRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :PerformanceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :PerformanceRelation ;
    rdfs:subPropertyOf :eventRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the PerformanceRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the PerformanceRelation class. It
         should be used only when you have to manage instances of the PerformanceRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:precedesInSequenceTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes in sequence transitive"@en,
        "precede secuencialmente a transitivo"@es,
        "précède dans la séquence transitif"@fr ;
    rdfs:comment """Connects a Thing to a Thing that follows it directly or indirectly
         in some sequence (not necessarily defined or characterised chronologically). This is a
         transitive relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :precedesOrPreceded ;
    owl:inverseOf :followsInSequenceTransitive ;
    owl:propertyChainAxiom ( :precedesProxyInSequence :proxyFor ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to try to clarify what is meant. Also
               added a property chain axiom relating it to use of rico:Proxy."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from precedesInTime."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct or indirect, sequential relations between
               things (the past sequential relation also being added)."""@en ] .

:temporalRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Temporal Relation"@en,
        "desempeña el papel de la Relación temporal"@es,
        "a le rôle de la Relation temporelle"@fr ;
    rdfs:comment """Connects a TemporalRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :TemporalRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :TemporalRelation ;
    rdfs:subPropertyOf :sequentialRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the TemporalRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the TemporalRelation class. It should
         be used only when you have to manage instances of the TemporalRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:textualValue a owl:DatatypeProperty ;
    rdfs:label "textual value"@en,
        "valor textual"@es,
        "valeur textuelle"@fr ;
    rdfs:comment "A textual expression of an Appellation or Date."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Appellation :Date :Extent ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

<https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "Documentary Form Types"@en,
        "Tipos documentales"@es,
        "Types de documents"@fr ;
    dc:creator """International Coucil on Archives Expert Group on Archival
         Description (ICA EGAD)"""@en ;
    dc:language "en",
        "es",
        "fr" ;
    dc:title """International Council on Archives Records in Contexts Vocabulary for
         Documentary Form Types"""@en ;
    skos:changeNote [ dc:date "2023-12-13" ;
            rdf:value """Completed the metadata of the vocabulary: added dc:language, a
               history note and a scope note."""@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-05-14" ;
            rdf:value "Added a dcat:version property."@en ],
        [ dc:date "2025-01-30" ;
            rdf:value """Added the IIIF manifest documentary form type, with broader
               concept finding aid. Updated the scope note of the vocabulary."""@en ] ;
    skos:definition """A vocabulary that provides URIs for describing documentary form
         types of RiC Records and Record Parts."""@en ;
    skos:hasTopConcept ric-dft:AuthorityRecord,
        ric-dft:FindingAid ;
    skos:scopeNote """For now this vocabulary only defines three concepts; it should
         hopefully be completed later. The concepts defined in this vocabulary can be used in
         combination with RiC-O classes and properties, whenever necessary and appropriate, to
         assign a documentary form type to a Record or a Record Part, using the
         rico:hasDocumentaryFormType object property, or its inverse one. They also can be used to
         specify that a rico:RecordSet included or includes members whose some
         (rico:hasOrHadSomeMembersWithDocumentaryFormType) or all
         (rico:hasOrHadAllMembersWithDocumentaryFormType) have some Documentary Form Type. Each
         concept is both defined as a skos:Concept and a rico:DocumentaryFormType, so that it is
         possible to extend the classic definition of such concepts using RiC-O properties. For
         example, you can use rico:history, rico:date, or rico:isAssociatedWithPlace,
         rico:precedesInTime, if you consider a documentary form type as being a historical entity,
         known and used in some known space or time region."""@en ;
    dcat:version "1.1" .

:AuthorityRelation a owl:Class ;
    rdfs:label "Akteur-Autorität-Ding"@de,
        "Authority Relation"@en,
        "Relación de control por parte de agentes"@es,
        "Relation d’autorité"@fr ;
    rdfs:comment """Connects at least one Agent and at least one Thing over which the
         Agent has or had some authority. The Agent(s) is the source of the relation, and the
         Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :authorityRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower authority
         relation, for example OwnershipRelation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R036 and RiC-R036i
         relations"""@en .

:ContentType a owl:Class ;
    rdfs:label "Inhaltskategorie"@de,
        "Content Type"@en,
        "Tipo de contenido"@es,
        "Type de contenu"@fr ;
    rdfs:comment """The fundamental form of communication in which a Record or Record
         Part is expressed."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: added (quite the same as RiC-CM
               definition)."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Content Type should not be confused with Representation Type or
         Carrier Type that would concern a related Instantiation since the form of communication can
         be independent of the representation or carrier, for example a map (content type
         "cartographic image") may be represented as a sketch (representation type "visual")
         recorded as a physical document (carrier type "paper"). It also should not be confused with
         the Documentary Form Type of a Record, or Record Part, which describes a specific document
         form (for example a deed of sale)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A10 (Content Type
         attribute)"""@en .

:Language a owl:Class ;
    rdfs:label "Sprache"@de,
        "Language"@en,
        "Lengua"@es,
        "Langue"@fr ;
    rdfs:comment """A spoken or written human language represented in a Record
         Resource or used by an Agent."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Concept ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Changed the definition (skos:comment annotation); so that it
               conforms to the RiC-CM one."""@en ],
        [ dc:date "2020-10-23" ;
            rdf:value "Scope note from RiC-CM : deleted."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A25 (Language
         attribute)"""@en .

:LegalStatus a owl:Class ;
    rdfs:label "Rechtstatus"@de,
        "Legal Status"@en,
        "Status jurídico"@es,
        "Statut légal"@fr ;
    rdfs:comment "A status defined by law."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A26 (Legal Status
         attribute)"""@en .

:MandateRelation a owl:Class ;
    rdfs:label "Mandat-Akteur"@de,
        "Mandate Relation"@en,
        "Relación normativa"@es,
        "Relation impliquant un mandat"@fr ;
    rdfs:comment """Connects at least one Mandate and at least one Agent, when the
         first gives or gave the second one the authority or competencies to act. May also involve
         one to many Activities that the Mandate(s) assign(s) or assigned to the Agent(s). The
         Mandate(s) is the source of the Relation and the Agent(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Activity ;
            owl:onProperty :asConcernsActivity ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Mandate ;
            owl:onProperty :relationHasSource ],
        :RuleRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :mandateRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed a 0.2 existing unnecessary restriction."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R067 and RiC-R067i
         relations"""@en .

:RecordSetType a owl:Class ;
    rdfs:label "Recordgruppenkategorie"@de,
        "Record Set Type"@en,
        "Tipo de agrupación documental"@es,
        "Type d’ensemble d’objets informationnels"@fr ;
    rdfs:comment "A broad categorization of the type of Record Set."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """scope note: updated. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Four instances of Record Set Type are included for now in RiC-O;
         they also are instances of skos:Concept and, as such, part of a SKOS vocabulary. Record Set
         Type may also be used (or extended) to categorize types of Record Set that have not
         traditionally been considered archival, e.g. search result list."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A36 (Record Set Type
         attribute)"""@en .

:RecordState a owl:Class ;
    rdfs:label "Recordstatus"@de,
        "Record State"@en,
        "Estado de documento"@es,
        "État d’un objet informationnel"@fr ;
    rdfs:comment """Description of the production or reproduction status of a Record
         or Record Part."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """scope note: updated. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """IRI and label changed (RecordResourceState to RecordState), as
               well as textual definition."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Can refer both to a record's stage of creation (for example
         "draft") and its form of transmission when the record was received (for example
         "copy")."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A39 (State
         attribute)"""@en .

:creationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Creation Relation"@en,
        "desempeña el papel de la Relación de creación"@es,
        "a le rôle de la Relation de création"@fr ;
    rdfs:comment """Connects a CreationRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :CreationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CreationRelation ;
    rdfs:subPropertyOf :organicProvenanceRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the CreationRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the CreationRelation class. It should
         be used only when you have to manage instances of the CreationRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:derivationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Derivation Relation"@en,
        "desempeña el papel de la Relación de derivación"@es,
        "a le rôle de la Relation de dérivation"@fr ;
    rdfs:comment """Connects a DerivationRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :DerivationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :DerivationRelation ;
    rdfs:subPropertyOf :instantiationToInstantiationRelation_role,
        :temporalRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the DerivationRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the DerivationRelation class. It should
         be used only when you have to manage instances of the DerivationRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:hasBeginningDate a owl:ObjectProperty ;
    rdfs:label "has beginning date"@en,
        "tiene como fecha de inicio"@es,
        "a pour date de début"@fr ;
    rdfs:comment "Inverse of 'is beginning date of' object property."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isBeginningDateOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R069i ('has beginning date'
         relation)"""@en .

:hasGeneticLinkToRecordResource a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has genetic link to record resource"@en,
        "tiene vínculo de origen con recurso documental"@es,
        """a une relation génétique avec la ressource
         archivistique"""@fr ;
    rdfs:comment """Connects two Record Resources when there is a genetic link between
         them. Genetic in this sense is as defined by diplomatics, i.e. the process by which a
         Record Resource is developed. This relation is symmetric."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRecordResourceAssociatedWithRecordResource ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :recordResourceGeneticRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Added the property chain axiom so that this property is
               formally defined as a shortcut."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceGeneticRelation_role object property."""@en ] ;
    skos:scopeNote """Use to connect two Record Resources only if it is not possible
         to use a narrower, more specific, asymmetric Record Resource to Record Resource relation,
         for example is original of."""@en ;
    :RiCCMCorrespondingComponent """RiC-R023 ('has genetic link to record resource'
         relation)"""@en .

:isAssociatedWithEvent a owl:ObjectProperty ;
    rdfs:label "is associated with event"@en,
        "está asociado con evento"@es,
        "est associé à l’événement"@fr ;
    rdfs:comment """Inverse of 'is event associated with' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isEventAssociatedWith ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :eventRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new eventRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R057i ('is associated with event'
         relation)"""@en .

:isAssociatedWithRule a owl:ObjectProperty ;
    rdfs:label "is associated with rule"@en,
        "está asociado con regla"@es,
        "est associé à la règle"@fr ;
    rdfs:comment """Inverse of 'is rule associated with' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Rule ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isRuleAssociatedWith ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :ruleRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new ruleRelation_role object
               property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R062i ('is associated with rule'
         relation)"""@en .

:isBeginningDateOf a owl:ObjectProperty ;
    rdfs:label "is beginning date of"@en,
        "es fecha de inicio de"@es,
        "est la date de début de"@fr ;
    rdfs:comment """Connects a Date to a Thing that came into existence on that
         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasBeginningDate ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R069 ('is beginning date of'
         relation)"""@en .

:isEventAssociatedWith a owl:ObjectProperty ;
    rdfs:label "is event associated with"@en,
        "es evento asociado con"@es,
        "est un événement associé a"@fr ;
    rdfs:comment """Connects an Event to a Thing that is associated with the existence
         and lifecycle of the Event."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isAssociatedWithEvent ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :eventRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new eventRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use to connect an Event and an entity only if it is not possible
         to specify a narrower Event relation, for example has or had participant."""@en ;
    :RiCCMCorrespondingComponent """RiC-R057 ('is event associated with'
         relation)"""@en .

:isRuleAssociatedWith a owl:ObjectProperty ;
    rdfs:label "is rule associated with"@en,
        "es regla asociada con"@es,
        "est une règle associée à"@fr ;
    rdfs:comment """Connects a Rule to a Thing that is associated with the
         Rule."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isAssociatedWithRule ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :ruleRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new ruleRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower Rule
         relation, for example, regulates or regulated."""@en ;
    :RiCCMCorrespondingComponent """RiC-R062 ('is rule associated with'
         relation)"""@en .

:measure a owl:DatatypeProperty ;
    rdfs:label "measure"@en,
        "medida"@es,
        "mesure"@fr ;
    rdfs:comment """The extent, quantity, amount, or degree of an entity, as
         determined by measurement or calculation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:proxyFor a owl:ObjectProperty ;
    rdfs:label "proxy for"@en,
        "es proxy para"@es,
        "proxy pour"@fr ;
    rdfs:comment """Connects a Proxy to the Record Resource it stands for in the
         context of a specific Record Resource."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasProxy ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Changed the rdfs:comment to allow for a context of a Record
               Resource of any kind, not only a Record Set."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

skos:Concept a owl:Class ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .

:Coordinates a owl:Class ;
    rdfs:label "Koordinaten"@de,
        "Coordinates"@en,
        "Coordenadas de lugar"@es,
        "Coordonnées géographiques"@fr ;
    rdfs:comment """Longitudinal and latitudinal information about a
         Place."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-02-08" ;
            rdf:value """Removed the cardinality Restrictions when the range is a
               datatype property"""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A11 (Coordinates
         attribute)"""@en .

:authorityRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Authority Relation"@en,
        """desempeña el papel de la Relación de control por parte de
         agentes"""@es,
        "a le rôle de la Relation d’autorité"@fr ;
    rdfs:comment """Connects an AuthorityRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AuthorityRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AuthorityRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AuthorityRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AuthorityRelation class. It should
         be used only when you have to manage instances of the AuthorityRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:followsInTime a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "follows in time"@en,
        "sigue en el tiempo a"@es,
        "suit dans le temps"@fr ;
    rdfs:comment """Inverse of 'precedes in time' object property. This is a
         transitive relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :followsOrFollowed ;
    owl:inverseOf :precedesInTime ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :temporalRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Property made transitive."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new temporalRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R009i ('follows in time'
         relation)"""@en .

:hadPart a owl:ObjectProperty ;
    rdfs:label "had part"@en,
        "tenía como parte"@es,
        "a eu pour partie"@fr ;
    rdfs:comment """Connects a Thing to a Thing that was a constitutive or component
         part of that Thing in the past."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadPart ;
    owl:inverseOf :wasPartOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between things (the current
               partitive relations being also added, including a transitive one)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isDateAssociatedWithRelation a owl:ObjectProperty ;
    rdfs:label "is date associated with Relation"@en,
        "es fecha asociada con la relación"@es,
        "est une date associée à la relation"@fr ;
    rdfs:comment "Connects a Date to an n-ary Relation."@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :isDateAssociatedWith,
        :thingIsContextOfRelation ;
    owl:inverseOf :relationHasDate ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-03-13" ;
            rdf:value """Added French and Spanish labels; fixed the first
               rdfs:subPropertyOf and the rdfs:domain."""@en ] .

:organicProvenanceRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Organic Provenance Relation"@en,
        """desempeña el papel de la Relación de procedencia
         orgánica"""@es,
        "a le rôle de la Relation de provenance organique"@fr ;
    rdfs:comment """Connects an OrganicProvenanceRelation to itself. It is a property
         that can stand for an instance of the class when necessary, e.g. when you explore a
         knowledge graph."""@en ;
    rdfs:domain :OrganicProvenanceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :OrganicProvenanceRelation ;
    rdfs:subPropertyOf :organicOrFunctionalProvenanceRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the OrganicProvenanceRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the OrganicProvenanceRelation class. It
         should be used only when you have to manage instances of the OrganicProvenanceRelation
         class, to connect each instance to itself, in order to be able to infer, using OWL-RL and
         property paths, the two shortcuts corresponding to this n-ary class."""@en .

:precedesInTime a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "precedes in time"@en,
        "precede en el tiempo a"@es,
        "précède dans le temps"@fr ;
    rdfs:comment """Connects a Thing to a Thing that follows it in chronological
         order. This is a transitive relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :precedesOrPreceded ;
    owl:inverseOf :followsInTime ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :temporalRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new temporalRelation_role object
               property."""@en ],
        [ dc:date "2023-09-21" ;
            rdf:value "Property made transitive."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI"@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """There may actually be zero to many intermediate Entities,
         ignored or unknown, in the chronological sequence between the two connected
         Entities."""@en ;
    :RiCCMCorrespondingComponent """RiC-R009 ('precedes in time'
         relation)"""@en .

:relationHasContext a owl:ObjectProperty ;
    rdfs:label "relation has context"@en,
        "relación tiene como contexto"@es,
        "relation a pour contexte"@fr ;
    rdfs:comment """Connects an n-ary Relation to a Thing that is a secondary,
         contextual entity during the existence of the Relation."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :relationConnects ;
    owl:inverseOf :thingIsContextOfRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """The secondary entity may be, for instance, a Position or a Role
         Type."""@en .

:relationHasDate a owl:ObjectProperty ;
    rdfs:label "relation has date"@en,
        "relación tiene como fecha"@es,
        "relation a pour date"@fr ;
    rdfs:comment "Connects an n-ary Relation to a Date."@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate,
        :relationHasContext ;
    owl:inverseOf :isDateAssociatedWithRelation ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-03-13" ;
            rdf:value "Added French and Spanish labels."@en ] .

:thingIsContextOfRelation a owl:ObjectProperty ;
    rdfs:label "thing is context of relation"@en,
        "cosa es contexto de relación"@es,
        "chose est le contexte de la relation"@fr ;
    rdfs:comment """Connects a Thing (that is a secondary, contextual entity during
         the existence of the Relation) to an n-ary Relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :thingIsConnectedToRelation ;
    owl:inverseOf :relationHasContext ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:wasPartOf a owl:ObjectProperty ;
    rdfs:label "was part of"@en,
        "era parte de"@es,
        "a fait partie de"@fr ;
    rdfs:comment """Connects a Thing to a Thing of which it was a constitutive or
         component part in the past."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isOrWasPartOf ;
    owl:inverseOf :hadPart ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between things (the current
               partitive relations being also added, including a transitive one)."""@en ] .

:date a owl:DatatypeProperty ;
    rdfs:label "date"@en,
        "fecha"@es,
        "date"@fr ;
    rdfs:comment """Chronological information associated with an entity that
         contributes to its identification and contextualization."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons, like its subproperties. May be
         deprecated and removed later on. Use only if you don't use Date classes for handling
         dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property implementation of RiC-E18 (Date
         entity)"""@en .

:isAssociatedWithPlace a owl:ObjectProperty ;
    rdfs:label "is associated with place"@en,
        "está asociado con lugar"@es,
        "est associé au lieu"@fr ;
    rdfs:comment """Inverse of 'is place associated with' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isPlaceAssociatedWith ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :placeRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new placeRelation_role object
               property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R074i ('is associated with place'
         relation)"""@en .

:isPlaceAssociatedWith a owl:ObjectProperty ;
    rdfs:label "is place associated with"@en,
        "es lugar asociado con"@es,
        "est un lieu associé à"@fr ;
    rdfs:comment """Connects a Place to a Thing with whose existence and lifecycle the
         Place is associated."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isAssociatedWithPlace ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :placeRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new placeRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Use to connect a Place to an entity only if it is not possible
         to specify a narrower spatial relation, for example, is or was location
         of."""@en ;
    :RiCCMCorrespondingComponent """RiC-R074 ('is place associated with'
         relation)"""@en .

<https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> a owl:NamedIndividual,
        skos:ConceptScheme ;
    rdfs:label "Record Set Types"@en,
        "Tipos de agrupación documental"@es,
        "Types d’ensembles d’objets informationnels"@fr ;
    dc:creator """International Coucil on Archives Expert Group on Archival
         Description (ICA EGAD)"""@en ;
    dc:language "en",
        "es",
        "fr" ;
    dc:title """International Council on Archives Records in Contexts Vocabulary for
         Record Set Types"""@en ;
    skos:changeNote [ dc:date "2023-12-13" ;
            rdf:value """Completed the metadata of the vocabulary: added dc:language, a
               history note and a scope note."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-05-14" ;
            rdf:value "Added a dcat:version property."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:definition """A vocabulary that provides URIs for describing types of RiC
         Record Sets."""@en ;
    skos:hasTopConcept ric-rst:Collection,
        ric-rst:File,
        ric-rst:Fonds,
        ric-rst:Series ;
    skos:scopeNote """For now this vocabulary only defines four top concepts; it
         should hopefully be completed later. The concepts defined in this vocabulary can be used in
         combination with RiC-O classes and properties, whenever necessary and appropriate, to
         assign a record set type to a Record Set, using the rico:hasRecordSetType object property,
         or its inverse one. Each concept is both defined as a skos:Concept and a
         rico:RecordSetType, so that it is possible to extend the classic definition of such
         concepts using RiC-O properties. For example, you can use rico:history, rico:date, or
         rico:isAssociatedWithPlace, rico:precedesInTime, if you consider a record set type as being
         a historical entity, known and used in some known space or time region."""@en ;
    dcat:version "1.1" .

:DocumentaryFormType a owl:Class ;
    rdfs:label "Dokumentenkategorie"@de,
        "Documentary Form Type"@en,
        "Tipo documental"@es,
        "Type de document"@fr ;
    rdfs:comment """Categorization of a Record or Record Part with respect to its
         extrinsic and intrinsic elements that together communicate its content, administrative and
         documentary context, and authority."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Scope note: made several paragraphs.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    skos:scopeNote """Documentary Form Type plays an important role in determining the
         type of information a Record may comprise, its status of perfection, and its authenticity
         and reliability. Documentary form types exist in a specific social and cultural context,
         and within that context, are subject to change over time."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A17 (Documentary Form Type
         attribute)"""@en .

:isRecordResourceAssociatedWithRecordResource a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is record resource associated with record resource"@en,
        "es recurso documental asociado con"@es,
        """est une ressource archivistique associée avec la ressource
         archivistique"""@fr ;
    rdfs:comment """Connects two Record Resources. This relation is
         symmetric."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :recordResourceToRecordResourceRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceToRecordResourceRelation_role object property."""@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Fixed the French label."@en ] ;
    skos:scopeNote """Use to connect two Record Resources only if it is not possible
         to use a narrower, more specific relation, for example has genetic link
         to."""@en ;
    :RiCCMCorrespondingComponent """RiC-R022 ('is record resource associated with
         record resource' relation)"""@en .

:hasOrHadPart a owl:ObjectProperty ;
    rdfs:label "has or had part"@en,
        "tiene o tenía como parte"@es,
        "a ou a eu pour partie"@fr ;
    rdfs:comment """Connects a Thing to a constitutive or component part of that
         Thing."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasPartOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :wholePartRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new wholePartRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasPart")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use to connect a Thing to another Thing that is or was a part of
         the whole Thing only if it is not possible to use a narrower, more specific whole/part
         relation, for example has or had constituent. The end of existence of a whole/part relation
         may affect the integrity or nature of the domain entity."""@en ;
    :RiCCMCorrespondingComponent """RiC-R002 ('has or had part'
         relation)"""@en .

:isOrWasPartOf a owl:ObjectProperty ;
    rdfs:label "is or was part of"@en,
        "es o era parte de"@es,
        "est ou a été une partie de"@fr ;
    rdfs:comment "Inverse of 'has or had part' relation."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadPart ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :wholePartRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "isPartOf")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new wholePartRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R002i ('is or was part of'
         relation)"""@en .

:AgentToAgentRelation a owl:Class ;
    rdfs:label "Akteur-Akteur"@de,
        "Agent Relation"@en,
        "Relación entre agentes"@es,
        "Relation entre agents"@fr ;
    rdfs:comment """Connects at least two Agents. This Relation is a generic, not
         oriented one."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationConnects ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :agentToAgentRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower agent to
         agent relation, for example a WorkRelation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R044 and RiC-044i
         relations"""@en .

:agentToAgentRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Agent Relation"@en,
        "desempeña el papel de la Relación entre agentes"@es,
        "a le rôle de la Relation entre agents"@fr ;
    rdfs:comment """Connects an AgentToAgentRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AgentToAgentRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AgentToAgentRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AgentToAgentRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AgentToAgentRelation class. It
         should be used only when you have to manage instances of the AgentToAgentRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:CorporateBody a owl:Class ;
    rdfs:label "Körperschaft"@de,
        "Corporate Body"@en,
        "Institución"@es,
        "Collectivité"@fr ;
    rdfs:comment """An organized group of persons that act together as an Agent, and
         that has a recognized legal or social status."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Group ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """scope note: updated. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Corporate body is a kind of Group (RiC-E09). By exception,
         within some legal contexts, a sole trader or sole proprietor may be recognized as a
         corporate body, even when the economic enterprise does not have additional members.
         Corporate bodies often have a mandate giving them the authority to act within their area(s)
         of competence. They will also usually act within a particular jurisdiction being governed
         by legal and other rule-based frameworks. A corporate body though may be constituted in a
         more informal manner and exist as an entity by virtue of its recognition as such by its
         members."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E11 (Corporate Body
         entity)"""@en .

:Extent a owl:Class ;
    rdfs:label "Umfang "@de,
        "Extent"@en,
        "Extensión"@es,
        "Mesure"@fr ;
    rdfs:comment """Countable characteristics of the content of an entity expressed as
         a quantity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2020-10-28" ;
            rdf:value """Class added together with three subclasses and hasExtent and
               isExtentOf Object properties"""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote "Physical or logical extent of a resource"@en .

:Appellation a owl:Class ;
    rdfs:label "Bezeichnung"@de,
        "Appellation"@en,
        "Denominación"@es,
        "Appellation"@fr ;
    rdfs:comment """A concept of any kind that is used for designating an Entity and
         referring to it."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Concept ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasDirectPart a owl:ObjectProperty ;
    rdfs:label "has direct part"@en,
        "tiene directamente como parte"@es,
        "a directement pour partie"@fr ;
    rdfs:comment """Connects a Thing to a Thing that is a direct constitutive or
         component part of that Thing."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasPartTransitive ;
    owl:inverseOf :isDirectPartOf ;
    skos:changeNote [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between things (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """To be used only when the current partitive relation is direct,
         without any intermediate node between the related things."""@en .

:isDirectPartOf a owl:ObjectProperty ;
    rdfs:label "is direct part of"@en,
        "es parte directa de"@es,
        "fait directement partie de"@fr ;
    rdfs:comment """Connects a Thing to a Thing of which it is direct constitutive or
         component part."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isPartOfTransitive ;
    owl:inverseOf :hasDirectPart ;
    skos:changeNote [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between things (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] ;
    skos:scopeNote """To be used only when the current partitive relation is direct,
         without any intermediate node between the related things."""@en .

:Activity a owl:Class ;
    rdfs:label "Aktivität"@de,
        "Activity"@en,
        "Actividad"@es,
        "Activité"@fr ;
    rdfs:comment "The doing of something for some human purpose."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Event ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Objective: to
               make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Activity is a kind of Event. Activity is specifically used to
         designate purposeful human activity. Activity may be understood from two perspectives.
         First it can be understood as leading to an end. The end is the purpose of the Activity, or
         why the Activity is performed. Second, it can be understood in terms of the processes that
         lead to achieving the end, how the end is realized through coordinated actions. Purpose and
         process are complementary understandings of Activity. Together the two perspectives address
         why the Activity is performed, the expected ends or outcomes; and how the Activity fulfills
         the purpose. While activity has an intended end, it also has unintended consequences and
         results, or side-effects. By and large, these may not be the focus of the description, but
         they are, unquestionably, context. |In a corporate or government context an Activity may
         also be called a 'function'. An Activity exists in a specific social and cultural context,
         and within that context is subject to change over time. An Activity may be composed of
         other Activities."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E15 (Activity
         entity)"""@en .

:hasPartTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has part transitive"@en,
        "tiene como parte transitivo"@es,
        "a pour partie transitif"@fr ;
    rdfs:comment """Connects a Thing to a Thing that is, directly or indirectly, a
         constitutive or component part of that Thing. This is a transitive relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadPart ;
    owl:inverseOf :isPartOfTransitive ;
    skos:changeNote [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between things (the past
               partitive relation also being added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """To be used, either to infer, then query or browse, relations
         from existing direct 'hasDirectPart' relations between things, or to record a current
         partitive relation when you do not know if there are intermediate nodes between the related
         things."""@en .

:isPartOfTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is part of transitive"@en,
        "es parte de transitivo"@es,
        "est une partie de transitif"@fr ;
    rdfs:comment """Connects a Thing to a Thing of which it is a a constitutive or
         component part, directly or indirectly. This is a transitive relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isOrWasPartOf ;
    owl:inverseOf :hasPartTransitive ;
    skos:changeNote [ dc:date "2023-11-13" ;
            rdf:value "Added a French label."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-07-12" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between things (the past
               partitive relation also being added)."""@en ] ;
    skos:scopeNote """To be used, either to infer, then query or browse, relations
         from existing direct 'isDirectPartOf' relations between things, or to record a current
         partitive relation when you do not know if there are intermediate nodes between the related
         things."""@en .

:isAgentAssociatedWithAgent a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is agent associated with agent"@en,
        "agente está asociado con agente"@es,
        "est un agent associé à l’agent"@fr ;
    rdfs:comment """Connects two Agents. This object property is
         symmetric."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :agentToAgentRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new agentToAgentRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ] ;
    skos:scopeNote """Use only if it is not possible to specify a narrower Agent to
         Agent relation, for example has or had work relation with."""@en ;
    :RiCCMCorrespondingComponent """RiC-R044 ('is agent associated with agent'
         relation)"""@en .

:isAssociatedWithDate a owl:ObjectProperty ;
    rdfs:label "is associated with date"@en,
        "está asociado con fecha"@es,
        "est associé à la date"@fr ;
    rdfs:comment """Inverse of 'is date associated with' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isDateAssociatedWith ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R068i ('is associated with date'
         relation)"""@en .

:isDateAssociatedWith a owl:ObjectProperty ;
    rdfs:label "is date associated with"@en,
        "es fecha asociada con"@es,
        "est une date associée a"@fr ;
    rdfs:comment """Connects a Date to a Thing with whose existence and lifecycle the
         Date is associated."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isAssociatedWithDate ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Use to connect a date and an entity only if it is not possible
         to specify a narrower date relation, for example, is beginning date of."""@en ;
    :RiCCMCorrespondingComponent """RiC-R068 ('is date associated with'
         relation)"""@en .

:relation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Relation"@en,
        "desempeña el papel de la Relación"@es,
        "a le rôle de la Relation"@fr ;
    rdfs:comment """Connects a Relation to itself. It is a property that can stand for
         an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the Relation rolified class. Declared it
               as reflexive."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the generic Relation class. It should
         be used only when you have to manage instances of this Relation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:thingIsConnectedToRelation a owl:ObjectProperty ;
    rdfs:label "thing is connected to relation"@en,
        "cosa está conectada con relación"@es,
        "chose est connectée à la relation"@fr ;
    rdfs:comment "Connects a Thing to an n-ary Relation."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :relationConnects ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-30" ;
            rdf:value "Fixed a typo in the French label."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:Rule a owl:Class ;
    rdfs:label "Regel"@de,
        "Rule"@en,
        "Regla"@es,
        "Règle"@fr ;
    rdfs:comment """Conditions that govern the existence, responsibility, or authority
         of an Agent; or the performance of an Activity by an Agent; or that contribute to the
         distinct characteristics of things created or managed by an Agent."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Objective: to
               make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-02-11" ;
            rdf:value """Updated the definition (rdfs:comment) and scope note, as they
               were recently changed in RiC-CM 0.2 full draft."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Rule is a kind of Thing. Rule can be related directly to agent,
         activity, or anything created or managed by agents, such as a record resource or
         instantiation. A rule may be unwritten or written or otherwise documented. Unwritten rules
         may include though are not limited to the following: social mores, customs, or community
         expectations. Written rules may include though are not limited to the following:
         constitutions, legislation, acts (legal), statutes, legal codes, ordinances, charters,
         mission statements, regulations, policies, procedures, instructions, codes of conduct or
         ethics, professional standards, work assignments, or work plans. The source or sources of
         some rules governing the existence or activity of an agent may be external (for example,
         expressed in elections, social mores, customs, community expectations, laws, regulations,
         standards, and best practice codes), while others may be expressed within the immediate
         context of an agent (for example, policies, or written or verbal instructions). The
         evidence for identifying rules may be found in their entirety in one documentary source
         (for example, a law or regulation) or may be found in two or more sources. Rule should not
         be confused with the one or more documentary sources that serve as evidence of its
         identity. A documentary source is a record."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E16 (Rule
         entity)"""@en .

:hasOrHadType a owl:ObjectProperty ;
    rdfs:label "has or had type"@en,
        "tiene o tenía como tipo"@es,
        "a ou a eu pour type"@fr ;
    rdfs:comment """Connects a Thing to a Type that categorizes or categorized
         it."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Type ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasTypeOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :typeRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (the name of this property in RiC-O 0.1 was "belongsToCategory")."""@en ],
        [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new typeRelation_role object
               property."""@en ] .

:isOrWasTypeOf a owl:ObjectProperty ;
    rdfs:label "is or was type of"@en,
        "es o era lo tipo de"@es,
        "est ou a été le type de"@fr ;
    rdfs:comment """Connects a Type to a Thing that it categorizes or
         categorized."""@en ;
    rdfs:domain :Type ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadType ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :typeRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value """Changed the word 'category' into 'type' in all applicable
               properties names."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (the name of this property in RiC-O 0.1 was "isCategoryOf")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new typeRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:Position a owl:Class ;
    rdfs:label "Position"@de,
        "Position"@en,
        "Puesto"@es,
        "Poste occupé"@fr ;
    rdfs:comment "The functional role of a Person within a Group."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Agent ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Disjoint
               with: enriched. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Position is a kind of Agent. Position is the intersection of a
         Person and a Group. Position exists independently of the Person that holds the Position
         within a Group. More than one Person may hold a Position. Position is commonly defined in a
         Mandate, often called a position description or job description. The Mandate may specify
         the work to be performed (Activity) as well as the competencies for performing the
         Activity. A Position is often given a Name. A Position may be tied to a project or to a set
         of tasks and thus have a defined duration. A Position may change over time, as the Group
         that establishes it changes over time. Position is not to be confused with Occupation or
         Activity. Within the records created by a Corporate Body, a Position may be used to
         identify the record sets resulting from activities performed by one or more persons holding
         the Position over time, without necessarily identifying or describing the Person or
         persons, or identifying which records were created by each Person."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E12 (Position
         entity)"""@en .

:Type a owl:Class ;
    rdfs:label "Kategorie"@de,
        "Type"@en,
        "Tipo"@es,
        "Type"@fr ;
    rdfs:comment """A superclass for any type of some thing. A type characterizes an
         entity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Concept ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2024-10-10" ;
            rdf:value """Updated the rdfs:comment (replaced the word 'category' with
               'type')."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:relationConnects a owl:ObjectProperty ;
    rdfs:label "relation connects"@en,
        "relación conecta"@es,
        "relation connecte"@fr ;
    rdfs:comment """Connects an n-ary Relation to any of the Things
         involved."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :thingIsConnectedToRelation ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:Relation a owl:Class ;
    rdfs:label "Beziehung"@de,
        "Relation"@en,
        "Relación"@es,
        "Relation"@fr ;
    rdfs:comment """The top level relation class. It connects at least two Things. An
         instance of a Relation may have some datatype and object properties: a general description
         (datatype property) like any Thing; a certainty (for 'certain', 'quite probable',
         'uncertain','unknown'); a date (use either the date datatype property or the Date class and
         isAssociatedWithDate object property); a state (relationState); a location (use the Place
         class and isAssociatedWithPlace object property); a source of information that can be used
         as an evidence for it (use either source datatype property or hasSource object property).
         This Relation is the most generic one; it is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :relation_role ] ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value "added the equivalence to relation_role."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-02-08" ;
            rdf:value """Removed the restrictions; completed the definition and scope
               note."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """Use when direct, binary object properties are not enough, e.g.
         when you need to record a date, a location or any other descriptive element for a relation
         (till RDF-Star becomes a W3C recommendation and provides a lighter method for doing so); or
         when the relation invloves more than two entities (n-ary relation). It is recommended to
         use the subclasses of the Relation class."""@en .

:Event a owl:Class ;
    rdfs:label "Ereignis"@de,
        "Event"@en,
        "Evento"@es,
        "Événement"@fr ;
    rdfs:comment "Something that happens or occurs in time and space."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and some
               changes."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """An event may be caused by nature, an agent, or a combination of
         nature and agent. Events have temporal and spatial boundaries. An event may actively
         involve some agent(s) and affect any entity. An event may be discrete, happening at a
         specific moment in time, or may occur over an extended period of time. Events may have
         events as parts, and events may precede or follow one another. Multiple agents may
         participate in the same event, and in different roles."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E14 (Event
         entity)"""@en ;
    :closeTo "LODE Event class (http://linkedevents.org/ontology/#Event)"@en .

:thingIsTargetOfRelation a owl:ObjectProperty ;
    rdfs:label "thing is target of relation"@en,
        "cosa es objetivo de relación"@es,
        "chose est la cible de la relation"@fr ;
    rdfs:comment """Connects a Thing (that is the target of a Relation) to an n-ary
         Relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :thingIsConnectedToRelation ;
    owl:inverseOf :relationHasTarget ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:Group a owl:Class ;
    rdfs:label "Gruppe"@de,
        "Group"@en,
        "Grupo de agentes"@es,
        "Groupe d’agents"@fr ;
    rdfs:comment "Two or more Agents that act together as an Agent."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Agent ;
    owl:disjointWith :Mechanism,
        :Person,
        :Position ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs plus very few changes.
               Disjoint with: enriched."""@en ] ;
    skos:scopeNote """Group is a kind of Agent. A Group has a socially recognized
         identity. Each member of the Group plays a particular role or roles (that is has a
         particular Position) in the coordinated activity of the Group. Corporate bodies and
         families are kinds of groups, though other kinds of groups are possible. For example, the
         “electorate” -- all of the voters in a given election. Complex, large groups may be
         subdivided into other groups."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E09 (Group
         Entity)"""@en .

:thingIsSourceOfRelation a owl:ObjectProperty ;
    rdfs:label "thing is source of relation"@en,
        "cosa es fuente de relación"@es,
        "chose est la source de la relation"@fr ;
    rdfs:comment """Connects a Thing (that is the source of a Relation) to a
         Relation."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :thingIsConnectedToRelation ;
    owl:inverseOf :relationHasSource ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:Place a owl:Class ;
    rdfs:label "Geografikum"@de,
        "Place"@en,
        "Lugar"@es,
        "Lieu"@fr ;
    rdfs:comment "Bounded, named geographic area or region."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Scope note: updated and made several
               paragraphs. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """A jurisdiction is the bounded geographic area within which an
         Agent has the authority to perform specified activities constrained by rules.
         Jurisdictions, man-made structures, and natural features are historical entities. A Place
         thus may have a beginning date and ending date and changing boundaries that result from
         human or natural events. A Place may be systematically referenced to a location on the
         earth (geographic coordinates)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E22 (Place
         entity)"""@en .

:RecordPart a owl:Class ;
    rdfs:label "Recordteil"@de,
        "Record Part"@en,
        "Componente documental"@es,
        "Partie d’objet informationnel"@fr ;
    rdfs:comment """Component of a Record with independent information content that
         contributes to the intellectual completeness of the Record."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :RecordResource ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """comment: updated. Scope note: made several paragraphs.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2021-02-08" ;
            rdf:value "Removed the Restriction."@en ] ;
    skos:scopeNote """Record Part is a kind of Record Resource. A Record Part may
         itself have Record Parts."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E05 (Record Part
         entity)"""@en .

:isRelatedTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is related to"@en,
        "está relacionado con"@es,
        "est relié à"@fr ;
    rdfs:comment """The most generic relation, is related to, connects any Thing to
         any other Thing. This relation is symmetric."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :relation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """Added the property chain axiom in order to make this property a
               shortcut."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R001 ('is related to'
         relation)"""@en .

:Proxy a owl:Class ;
    rdfs:label "Proxy"@de,
        "Proxy"@en,
        "Proxy"@es,
        "Proxy"@fr ;
    rdfs:comment """A Proxy represents (stands for) a Record Resource as it exists in
         a specific other Record Resource."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :RecordResource ;
            owl:onProperty :proxyFor ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :RecordResource ;
            owl:onProperty :proxyIn ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :Concept ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Changed range of proxyIn restriction and rdfs:comment to allow
               any Record Resource, not only a Record Set. Also tweaked the scope note to refer to
               the new datatype properties rico:rankInSequence and rico:rankInHierarchy, and to
               generalise it to different kinds of Record Resources."""@en ] ;
    skos:scopeNote """Useful e.g. in conjunction with rico:rankInSequence for
         describing sequences of Records or Record Sets in the context of a Record Set, or of Record
         Parts and Records in the context of a Record; or in conjunction with rico:rankInHierarchy
         for describing hierarchies of Records and/or Record Parts in the context of a Record Set,
         Record, or Record Part. A Record Resource has only one Proxy in the context of one specific
         Record Set, Record, or Record Part. It may have many Proxies simultaneously or through
         time."""@en ;
    :closeTo "ORE Proxy (http://www.openarchives.org/ore/terms/Proxy)"@en .

:Date a owl:Class ;
    rdfs:label "Datum"@de,
        "Date"@en,
        "Fecha"@es,
        "Date"@fr ;
    rdfs:comment """Chronological information associated with an entity that
         contributes to its identification and contextualization."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value "Scope note: made separate paragraphs."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """A Date may be represented in natural language, based on a
         digital standard, or both. Digital standard dates will typically be based on ISO 8601, or
         Extended Date-Time Format (EDTF)"""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E18 (Date
         entity)"""@en .

:Record a owl:Class ;
    rdfs:label "Record"@de,
        "Record"@en,
        "Documento"@es,
        "Objet informationnel"@fr ;
    rdfs:comment """Discrete information content formed and inscribed, at least once,
         by any method on any carrier in any persistent, recoverable form by an Agent in the course
         of life or work activity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :RecordResource ;
    skos:changeNote [ dc:date "2021-02-08" ;
            rdf:value "Removed the Restriction."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: updated and made several paragraphs. Objective: to
               make RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:scopeNote """Record is a kind of Record Resource. A Record may itself contain
         one or more Records, or may consist of one or more Record Parts. A Record must have or have
         had at least one Instantiation. A Record may have more than one Instantiation. An
         Instantiation derived from another Instantiation of a Record may be considered the
         instantiation of the same Record or an instantiation of a new Record, depending on the
         context. A Record may serve a variety of purposes, though it always documents or is
         evidence of Activity."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E04 (Record
         entity)"""@en .

:relationHasTarget a owl:ObjectProperty ;
    rdfs:label "relation has target"@en,
        "relación tiene como objetivo"@es,
        "relation a pour cible"@fr ;
    rdfs:comment """Connects an n-ary Relation to a Thing that is its
         target."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :relationConnects ;
    owl:inverseOf :thingIsTargetOfRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:Person a owl:Class ;
    rdfs:label "Person"@de,
        "Person"@en,
        "Persona"@es,
        "Personne"@fr ;
    rdfs:comment "An individual human being."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Agent ;
    owl:disjointWith :Position ;
    skos:changeNote [ dc:date "2021-02-08" ;
            rdf:value "Removed one Restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Disjoint
               with: enriched. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and updated. Disjoint
               with: enriched. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:scopeNote """Person is a kind of Agent. Most commonly, a human being
         (biological person) has a single socially constructed identity or persona. Less common
         though not rare, one or more personae in addition to the original persona which emerges at
         or near birth may be associated with the human being over the course of that human being’s
         lifetime. Such "alternative personae" are most often created by the original person for
         specific purposes. The original persona may, in everyday discourse, be regarded as “the
         real person”. Under some circumstances, an alternative persona might eclipse or replace the
         original person (Mark Twain eclipsing Samuel Clemens; John Wayne eclipsing Marion Mitchell
         Morrison), that is, the alternative identity becomes the predominant identity. Less common
         is when two or more persons collaborate to create a shared persona. A persona shared by two
         or more persons constitutes a kind of group. Within the archival context, the description
         of a person commonly will focus on the original associated persona, with alternative
         personae noted. Exceptionally, an alternative persona may displace the original persona as
         the focus of the description. Under some circumstances, for example, when record resources
         are associated with two or more different personae of one person, describing the different
         personae as separate though related persons may be desirable. Alternatively, a person may
         change their identity over the course of their lifetime."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E08 (Person
         entity)"""@en .

:relationHasSource a owl:ObjectProperty ;
    rdfs:label "relation has source"@en,
        "relación tiene como fuente"@es,
        "relation a pour source"@fr ;
    rdfs:comment """Connects an n-ary Relation to a Thing that is its
         source."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :relationConnects ;
    owl:inverseOf :thingIsSourceOfRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:RecordSet a owl:Class ;
    rdfs:label "Recordgruppe"@de,
        "Record Set"@en,
        "Agrupación documental"@es,
        "Ensemble d’objets informationnels"@fr ;
    rdfs:comment """One or more records that are grouped together by an Agent based on
         the records sharing one or more attributes or relations."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :RecordResource ;
    skos:changeNote [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """comment: updated. Scope note: updated and made several
               paragraphs. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Record set is a kind of Record Resource. The member records in a
         Record Set may physically reside together, though physical proximity is not essential. In a
         particular context, an Agent (for example, administrator, records manager, archivist,
         end-user, etc.) may select the member records of a Record Set based on any shared attribute
         or attributes, or any shared relation or relations. The grouping of the records serves a
         purpose or purposes specific to the context of the Agent. For example, all member records
         of a Record Set have been accumulated by the same Agent; have the same Documentary Form
         Type; or are related to and document the same Activity. A Record Set may represent the act
         of classifying the records in accordance with a formal classification scheme that may be
         based on activity, subject, organizational structure, or other criteria; an act of archival
         arrangement (for example, based on common provenance); or some other selection and grouping
         that fulfils a particular purpose or purposes (for example, a classification that reflects
         or supports the purposes of a researcher). By exception, some records are brought together
         based on their not belonging in the context of selection to other designated groups: a
         'Miscellaneous' series, for example. A Record Sset accumulated by an Agent in the course of
         life or work activity should be described in a manner that preserves context and evidential
         value. Record Sets may also contain other Record Sets. A Record Set or Record may
         simultaneously be a member of more than one Record Set, and over the course of its
         existence, a Record Set or Record may be a member of an indeterminate number of Record Sets
         in an indeterminate number of contexts. Record Sets and Records contained within a Record
         Set may be ordered into a sequence based on a common property or relation, or common
         properties or relations (for example, alphabetical by agent or related place);
         chronological order by creation date; or some other criterion (for example, an imposed
         order by relevance)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E03 (Record Set
         entity)"""@en .

:Agent a owl:Class ;
    rdfs:label "Akteur"@de,
        "Agent"@en,
        "Agente"@es,
        "Agent"@fr ;
    rdfs:comment """A Person, or Group, or an entity created by a Person or Group
         (Mechanism), or a Position, that acts in the world."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Scope note: updated and made several
               paragraphs. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2021-02-08" ;
            rdf:value "removed the Restrictions"@en ] ;
    skos:scopeNote """An Agent may have one or more identities; an identity is a
         constellation of properties or relations that together “identify” the Agent. A Person or
         Group commonly has one identity, though each also may have one or more alternative
         identities. Such alternative identities may be shared by more than one Person or Group.
         Alternative identities include but are not limited to pseudonyms, heteronyms, DBA (Doing
         Business As), and trade identities. An alternative identity should not be confused with a
         Position in a Group, for example, presidents, prime ministers, governors, popes, royalty,
         or bishops. Nor should an alternative identity be confused with a variant name or
         identifier of the same identity. Agent also includes entities created by a Person or Group
         that act on behalf of the creating Agent in an autonomous or semi-autonomous manner.
         Examples of a Mechanism include software agents, robots, and space and underwater probes
         that generate data (records) in the course of Activity assigned to and in conformance with
         the instructions given to them by the creating Person or Group."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E07 (Agent
         entity)"""@en .

:Instantiation a owl:Class ;
    rdfs:label "Repräsentation oder Instanz"@de,
        "Instantiation"@en,
        "Instanciación"@es,
        "Instanciation"@fr ;
    rdfs:comment """The inscription of information made by an Agent on a physical
         carrier in any persistent, recoverable form as a means of communicating information through
         time and space."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restrictions."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Scope note: updated and made several
               paragraphs. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:scopeNote """A Record or Record Part must have been instantiated at least
         once, though this instantiation may no longer exist at the moment of description. An
         instantiation might also exist at the moment of description, but be destroyed at a later
         moment in time, when, for example, a derived instantiation might become the only remaining
         instantiation. A Record Set may have an instantiation, which is to say that it is not a
         necessary condition. An Instantiation may be derived from another Instantiation. A Record
         Resource may have many Instantiations simultaneously (for instance, a record printed and
         saved in the same time as DOCX and PDF/A would have 3 concurrent instantiations) or through
         time (for example, copy of a record). Depending on the context, a new instantiation may be
         seen as a new or as the same record resource. During in the process of re-instantiation
         something is lost and something is preserved, but it is up to the context and the Agent
         that produces or uses that Instantiation to assess whether the two instantiations are
         functionally equivalent or not. For instance, a postcard representing a town map from 1874
         (Instantiation 1) is digitized and kept as a JPEG file (Instantiation 2). The digital copy
         may be considered as instantiating the "same" Record by an Agent considering the
         information transmitted by the Record (e.g., the urban landscape displayed), but as a"
         different" Record by an antiquarian more focused on the materiality of the carrier.
         Successive instantiations may change the perceivable boundaries of a Record Resource. For
         instance, a case file comprising many records may be digitized and saved as one single PDF
         file, which, from management perspective, may be treated as one Record. Similarly, a large
         Record Set (a fonds or a series) may be maintained as one database. On the other hand, one
         record (main document and its annexes) may be digitized in separate files and each one may
         be managed as a discrete “physical” item. Instantiations may require mediation to
         communicate the information in the Record Resource. While a traditional Record on paper can
         simply be read by an Agent in order to understand the information, a vinyl recording, a
         video cassette or a digital file needs a device (mediator) to codify or decodify the
         information conveyed. This mediator may imply simple physical components (a turntable
         needle, for example), or a complex gallery of software and hardware elements.
         Instantiations are more than the mere informational content of Record Resource and may be
         the focus of preservation and physical management of records. The use of particular
         document types for records, such as a medieval charter, may have implications for the
         authenticity of the records. Hence, the way a Record Resource is instantiated contributes
         to the contextualizing of the content.record resource is instantiated contributes to the
         contextualizing the content. Distinguishing the message conveyed (Record Resource) and its
         physical representations (Instantiation) allows for the efficient management of their
         descriptions, and preserve information about a Record Resource even when no physical
         representation of it exists or is known to exist anymore. The relations between distinct
         instantiations can then be expressed wherever they coexist, and they can be related to the
         Record Resource they instantiate."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E06 (Instantiation
         entity)"""@en ;
    :closeTo "PREMIS Representation"@en .

:RecordResource a owl:Class ;
    rdfs:label "Recordressource"@de,
        "Record Resource"@en,
        "Recurso documental"@es,
        "Ressource archivistique"@fr ;
    rdfs:comment """Information produced or acquired and retained by an Agent in the
         course of life or work activity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Thing ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs plus very few
               changes."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-02-08" ;
            rdf:value "Removed one Restriction."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """Record resource is a kind of Thing. Producing a record resource
         may imply either its initial creation or a reuse of previous existing information by
         combination, rearrangement, selecting, reformatting, etc. Record set, record, and record
         part are kinds of record resource. A record resource is evidence of the activity of an
         agent. More than one agent may be involved in the creation of a record resource. The role
         of the agent in creating the record resource may take different forms, for example,
         authoring of an individual record, accumulating a record set, or arranging a record set.
         Though a record, record set, and record part, under most circumstances, may be easily
         distinguished from one another, identifying the boundary of each may frequently present
         particular challenges. Documentary forms provide the rules governing the structure of many
         types of records, providing criteria for identifying a record's boundary, and identifying
         its essential parts. Many records, though, do not have well-established documentary forms,
         particularly in the case of digital records, where it may be difficult to determine whether
         individual elements represented in separate bitstreams are record parts, records, or record
         sets. For example, is photographic information represented independently in a bitstream
         embedded in a text document a record or a record part? Or is the same photographic
         information attached to an email that maintains its independent representation, a record or
         a record part? Information grouped for some purpose, for example, ZIP or TAR "file
         compression" for saving storage space, presents a further challenge. One file comprises
         multiple bitstreams subjected to techniques that remove bits that can be losslessly
         recovered when decompressed. Under what circumstances is such a compressed bitstream a
         record or a record set? Determining when an information object is a record, record set, or
         record part is based on perspective and judgement exercised in a particular context. In one
         context, the agent describing an information object may designate it a record, while
         another agent in a different context may designate it a record part. Both designations are
         supported by RiC-CM, and the significance of the difference for users of the records is
         ameliorated by the fact that all of the attributes and relations employed in describing
         record and record part are shared, as are many of the attributes and relations employed in
         describing a record set."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E02 (Record Resource
         entity)"""@en .

:Thing a owl:Class ;
    rdfs:label "Ding"@de,
        "Thing"@en,
        "Cosa"@es,
        "Chose"@fr ;
    rdfs:comment """Any idea, material thing, or event within the realm of human
         experience."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value "made separate paragraphs in the scope note."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Includes all RiC entities as well as any concept, material
         thing, or event that may be the subject of a Record Resource or associated with an
         Activity. Examples of entities not explicitly addressed in RiC includes but is not limited
         to the following: abstract concepts; cultural movements, named periods and events; named
         things, objects and works; legendary, mythical or fictitious figures, characters or
         beings."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E01 (Thing
         entity)"""@en .

<https://www.ica.org/standards/RiC/ontology> a voaf:Vocabulary,
        owl:NamedIndividual,
        owl:Ontology ;
    schema:name """International Council on Archives Records in Contexts Ontology (ICA
         RiC-O) version 1.1"""@en ;
    schema:license <https://creativecommons.org/licenses/by/4.0/> ;
    dc:contributor """Regine I. Heberlein (University of Princeton, USA), member of EGAD and EGAD
         RiC-O team from 2023 to 2024""",
        """Aaron Rubinstein (University of Massachusetts Amherst, USA),
         member of EGAD and EGAD RiC-O team from 2012 to 2022"""@en,
        """Daniel Pitti (University of Virginia, USA), chair of EGAD from
         2012"""@en,
        """Florence Clavaud (Archives nationales de France), member of EGAD
         and lead of EGAD RiC-O team from 2012"""@en,
        """Ivo Zandhuis (Consultant Digital Cultural Heritage, The
         Netherlands), member of EGAD and EGAD RiC-O team from 2023"""@en,
        """Jan Krause-Bilvin (docuteam, Switzerland), member of EGAD and
         EGAD RiC-O team from 2023"""@en,
        """Miia Herrala (National Archives of Finland), member of EGAD and
         EGAD RiC-O team from 2016 to 2022"""@en,
        """Richard David Williamson (National Archives of Norway), member
         of EGAD and of EGAD RiC-O team from 2024"""@en,
        """Tobias Wildi (docuteam, Switzerland), member of EGAD and EGAD
         RiC-O team from 2019"""@en ;
    schema:creator """International Council on Archives Expert Group on Archival
         Description (ICA EGAD)"""@en ;
    schema:publisher "International Council on Archives"@en ;
    schema:rights "Copyright 2019-, International Council on Archives (ICA)"@en ;
    schema:description """
            RiC-O (Records in Contexts-Ontology) is an OWL ontology for describing archival
               record resources. As the third part of Records in Contexts standard, it is a formal
               representation of Records in Contexts Conceptual Model (RiC-CM). RiC-O provides a 
               generic vocabulary and formal rules for creating RDF datasets
               to describe any kind of archival record resource, whether natively or by transforming 
               existing metadata (or generating them from existing archival metadata). It supports
               publishing RDF datasets as Linked Data, querying them using SPARQL, and making
               inferences.

            The current version is v1.1 ; it is compliant with RiC-CM 1.0, 
            which was published by EGAD on November 30, 2023.""" ;

    dcterms:contributor <https://orcid.org/0000-0001-6743-9622>,
        <https://orcid.org/0000-0001-9375-2102>,
        <https://orcid.org/0000-0001-9938-6502>,
        <https://orcid.org/0000-0002-0803-8025>,
        <https://orcid.org/0000-0002-5681-4850>,
        <https://orcid.org/0000-0003-0165-8341>,
        <https://orcid.org/0009-0004-3219-2534> .

