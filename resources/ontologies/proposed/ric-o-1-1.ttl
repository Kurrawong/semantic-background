    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isIdentifierTypeOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
