:isOrWasLegalStatusOf a owl:ObjectProperty ;
    rdfs:label "is or was legal status of"@en,
        "es o era status jurídico de"@es,
        "est ou a été le statut légal de"@fr ;
    rdfs:comment """Connects a Legal Status to an Agent or Record Resource that it
         categorizes."""@en ;
    rdfs:domain :LegalStatus ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Agent :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasOrHadLegalStatus ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (the name of this property in RiC-O 0.1 was
               "isLegalStatusOf")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Connects a Legal Status to an Agent, Record or Record Part that
         it categorized or categorizes."""@en .

:isOrWasLegalStatusOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was legal status of all members of"@en,
        "es o era status jurídico de todos los miembros de"@es,
        "est ou a été le statut légal de tous les membres de"@fr ;
