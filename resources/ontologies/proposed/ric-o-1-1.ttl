        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ] .

:hasOrHadStudent a owl:ObjectProperty ;
    rdfs:label "has or had student"@en,
        "tiene o tenía como estudiante a"@es,
        "a ou a eu pour étudiant"@fr ;
    rdfs:comment "Inverse of 'has or had teacher' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :knows ;
    owl:inverseOf :hasOrHadTeacher ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :teachingRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new teachingRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "hasStudent")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R053i ('has or had student'
         relation)"""@en .

:hasOrHadTeacher a owl:ObjectProperty ;
    rdfs:label "has or had teacher"@en,
        "tiene o tenía como profesor(a) a"@es,
        "a ou a eu pour enseignant"@fr ;
    rdfs:comment """Connects a Person to another Person who is or was their
         teacher."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :knows ;
    owl:inverseOf :hasOrHadStudent ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :teachingRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new teachingRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "hasTeacher")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R053 ('has or had teacher'
         relation)"""@en .

:hasOrHadTitle a owl:ObjectProperty ;
    rdfs:label "has or had title"@en,
        "tiene o tenía como título"@es,
        "a ou a eu pour intitulé"@fr ;
    rdfs:comment """Connects a Record Resource, Instantiation or Rule to a title that
         is or was used for designating it."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource :Rule ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Title ;
    rdfs:subPropertyOf :hasOrHadName ;
    owl:inverseOf :isOrWasTitleOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (the name of this property in RiC-O 0.1 was
               "hasTitle")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasOriginal a owl:ObjectProperty ;
    rdfs:label "has original"@en,
        "tiene como original"@es,
        "a pour original"@fr ;
    rdfs:comment "Inverse of 'is original of' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :followsInTime,
        :hasGeneticLinkToRecordResource ;
    owl:inverseOf :isOriginalOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R010i ('is original of'
         relation)"""@en .

:hasProductionTechniqueType a owl:ObjectProperty ;
    rdfs:label "has production technique type"@en,
        "tiene como técnica de producción"@es,
        "a pour type de technique de production"@fr ;
    rdfs:comment """Connects an Instantiation to a Production Technique Type that
         categorizes its production technique."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ProductionTechniqueType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isProductionTechniqueTypeOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasPublicationDate a owl:ObjectProperty ;
    rdfs:label "has publication date"@en,
        "tiene como fecha de publicación"@es,
        "a pour date de publication"@fr ;
    rdfs:comment """Inverse of 'is publication date of' object
         property."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isPublicationDateOf ;
    skos:changeNote [ dc:date "2023-10-12" ;
            rdf:value "Added the French label"@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasPublisher a owl:ObjectProperty ;
    rdfs:label "has publisher"@en,
        "tiene como editor(a) a"@es,
        "a pour éditeur"@fr ;
    rdfs:comment """Connects a Record resource to an Agent who published
         it."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isPublisherOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI (the name of this
               property in RiC-O 0.1 was "publishedBy")."""@en ] .

:hasReceiver a owl:ObjectProperty ;
    rdfs:label "has receiver"@en,
        "tiene como receptor(a) a"@es,
        "est reçu par"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Agent that
         receives it in the course of the Agent's activities."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasAccumulator ;
    owl:inverseOf :isReceiverOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, super property
               IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "receivedBy")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R029 ('has receiver'
         relation)"""@en .

:hasRecordSetType a owl:ObjectProperty ;
    rdfs:label "has record set type"@en,
        "tiene como tipo de agrupación documental"@es,
        "a pour type d’ensemble d’objets informationnels"@fr ;
    rdfs:comment """Connects a Record Set to a Record Set Type that categorizes
         it."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSetType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isRecordSetTypeOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasRecordState a owl:ObjectProperty ;
    rdfs:label "has record state"@en,
        "tiene como estado de documento"@es,
        "a pour état"@fr ;
    rdfs:comment """Connects a Record or Record Part to a Record State that
         categorizes its state."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordState ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isRecordStateOf ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Changed the IRI (hasRecordResourceState changed to
               hasRecordState), label, textual definition and domain (RecordResource replaced by
               Record or Record Part)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasReply a owl:ObjectProperty ;
    rdfs:label "has reply"@en,
        "tiene como contestación"@es,
        "a pour réponse"@fr ;
    rdfs:comment """Connects a Record Resource to a reply, usually in the form of
         correspondence."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRecordResourceAssociatedWithRecordResource,
        :precedesInTime ;
    owl:inverseOf :isReplyTo ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "isRepliedToBy")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R013 ('has reply'
         relation)"""@en .

:hasRepresentationType a owl:ObjectProperty ;
    rdfs:label "has representation type"@en,
        "tiene como tipo de grabación"@es,
        "a pour type de représentation"@fr ;
    rdfs:comment """Connects an Instantiation to a Representation Type that
         categorizes its representation type."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RepresentationType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isRepresentationTypeOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasSender a owl:ObjectProperty ;
    rdfs:label "has sender"@en,
        "tiene como remitente a"@es,
        "a pour expéditeur"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Agent that
         sends it"""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrganicProvenance ;
    owl:inverseOf :isSenderOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """The identity of the sender is (usually) evidenced by the Record
         Resource or Instantiation itself."""@en ;
    :RiCCMCorrespondingComponent """RiC-R031 ('has sender'
         relation)"""@en .

:hasTitleType a owl:ObjectProperty ;
    rdfs:label "has title type"@en,
        "tiene como tipo de título"@es,
        "a pour type de titre"@fr ;
    rdfs:comment """Connects a Title and a Title Type that categorizes
         it."""@en ;
    rdfs:domain :Title ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :TitleType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isTitleTypeOf ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value """Object property added along with TitleType class and
               isTitleTypeOf object property. """@en ] .

:hasUnitOfMeasurement a owl:ObjectProperty ;
    rdfs:label "has unit of measurement"@en,
        "tiene como unidad de medida"@es,
        "a pour unité de mesure"@fr ;
    rdfs:comment "Connects an Extent to a Unit Of Measurement"@en ;
    rdfs:domain :Extent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :UnitOfMeasurement ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isUnitOfMeasurementOf ;
    skos:changeNote [ dc:date "2020-10-28" ;
            rdf:value """Object property created along with Extent and UnitOfMeasurement
               classes, in order to provide methods for handling extent accurately."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value """Added a new rdfs:label in French; added an xml:lang attribute
               to the rdfs:comment."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasWithin a owl:ObjectProperty ;
    rdfs:label "has within"@en,
        "tiene dentro"@es,
        "contient"@fr ;
    rdfs:comment "Inverse of 'is within' object property."@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isAssociatedWithDate,
        :isDateAssociatedWith ;
    owl:inverseOf :isWithin ;
    skos:changeNote [ dc:date "2023-10-12" ;
            rdf:value "Added the property"@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """made this property a subproperty of both isDateAssociatedWith
               and isAssociatedWithdate, and of hasOrHadPart."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R085i ('has within'
         relation)"""@en .

:included a owl:ObjectProperty ;
    rdfs:label "included"@en,
        "incluía"@es,
        "a inclus"@fr ;
    rdfs:comment """Connects a Record Set to a Record or Record Set which it included
         in the past."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hadPart,
        :includesOrIncluded ;
    owl:inverseOf :wasIncludedIn ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between Record Sets and their
               members (the current partitive relations being also added, including a transitive
               one)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-13" ;
            rdf:value "Added a French label."@en ] .

:isAccumulationDateOf a owl:ObjectProperty ;
    rdfs:label "is accumulation date of"@en,
        "es fecha de acumulación de"@es,
        "est la date d'accumulation de"@fr ;
    rdfs:comment """Connects a Date to a Record Resource or Instantiation that was or
         will be accumulated at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicProvenanceDateOf ;
    owl:inverseOf :hasAccumulationDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :accumulationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value """Connect to AccumulationRelation via a sub-property chain, and
               make a sub-property of the new 'isOrganicProvenanceDateOf' object
               property."""@en ],
        [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """When used for a Record Set (e.g. a file), it is the accumulation
         date of the Record Set itself rather than the accumulation date of the members of the
         Record Set. To record the accumulation date of members of the Record Set, use 'is or was
         accumulation date of all members of', 'is or was accumulation date of most members of’ or
         'is or was accumulation date of some members of’."""@en .

:isActivityTypeOf a owl:ObjectProperty ;
    rdfs:label "is activity type of"@en,
        "es tipo de actividad de"@es,
        "est le type d’activité de"@fr ;
    rdfs:comment """Connects an Activity Type to an Activity that it
         categorizes."""@en ;
    rdfs:domain :ActivityType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Activity ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasActivityType ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ] .

:isAddresseeOf a owl:ObjectProperty ;
    rdfs:label "is addressee of"@en,
        "es destino de"@es,
        "est le destinataire de"@fr ;
    rdfs:comment "Inverse of 'has addressee' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicProvenanceOf ;
    owl:inverseOf :hasAddressee ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-032i ('is addressee of'
         relation)"""@en .

:isAuthorOf a owl:ObjectProperty ;
    rdfs:label "is author of"@en,
        "es autor(a) de"@es,
        "est le responsable intellectuel de"@fr ;
    rdfs:comment "Inverse of 'has author' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Group :Person :Position ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Record ;
    rdfs:subPropertyOf :isCreatorOf ;
    owl:inverseOf :hasAuthor ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :authorshipRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-12-29" ;
            rdf:value """Created following the addition of RiC-R079 relation in RiC-CM
               0.2"""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new authorshipRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R079i ('is author of'
         relation)"""@en .

:isAuthorizingAgentInMandateRelation a owl:ObjectProperty ;
    rdfs:label "is authorizing agent in mandate relation"@en,
        "es el agente autorizador en la relación normativa"@es,
        """est l’agent donnant l’autorisation dans la relation impliquant un
         mandat"""@fr ;
    rdfs:comment """Connects an Agent that assigns the Mandate, to a Mandate
