            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ] .

:isPublicationDateOf a owl:ObjectProperty ;
    rdfs:label "is publication date of"@en,
        "es fecha de publicación de"@es,
        "est la date de publication de"@fr ;
    rdfs:comment """Connects a Date to a Record Resource that was or will be made
         public at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
