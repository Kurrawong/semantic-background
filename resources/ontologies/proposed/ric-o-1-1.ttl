        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R060 ('is or was performed by'
         relation)"""@en .

:isOrWasPhysicalLocationOf a owl:ObjectProperty ;
    rdfs:label "is or was physical location of"@en,
        "es o era localización física de"@es,
        "a ou a été la localisation physique de"@fr ;
