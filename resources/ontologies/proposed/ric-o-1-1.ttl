        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-19" ;
            rdf:value """Object property added along with IdentifierType class and
               hasIdentifierType object property. """@en ] .

:isLastUpdateDateOf a owl:ObjectProperty ;
    rdfs:label "is last update date of"@en,
        "es fecha de última actualización de"@es,
        "est la date de dernière mise à jour de"@fr ;
    rdfs:comment """Connects a Date and a Thing that was last modified at this
         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isModificationDateOf ;
    owl:inverseOf :wasLastUpdatedAtDate ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isMainThingRepresentedByContentOf a owl:ObjectProperty ;
    rdfs:label "is main thing represented by content of"@en,
        "es lo principal representado por el contenido de"@es,
        "est la chose principale représentée par le contenu de"@fr ;
    rdfs:comment """Inverse of 'has content which mainly represents' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasMainSubjectOf,
        :isRepresentedByContentOf ;
    owl:inverseOf :hasContentWhichMainlyRepresents ;
    skos:changeNote [ dc:date "2025-04-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isMigrationDateOf a owl:ObjectProperty ;
    rdfs:label "is migration date of"@en,
        "es fecha de migración de"@es,
        "est la date de migration de"@fr ;
    rdfs:comment """Connects a Date to an Instantiation that was or will be migrated
         at that Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isDerivationDateOf ;
    owl:inverseOf :hasMigrationDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :migrationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2025-03-01" ;
            rdf:value """Removed 'Record Resource' from the definition and made this
               property a subproperty of the new 'isDerivationDateOf' property."""@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-03-13" ;
            rdf:value "Added the property chain axiom."@en ] .

:isOrWasAccumulationDateOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was accumulation date of all members of"@en,
        "es o era fecha de acumulación de todos los miembros de"@es,
        """est ou a été la date de accumulation de tous les membres
         de"""@fr ;
    rdfs:comment """Connects a Date to a Record Set all of whose present or past
         members were or will be accumulated at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasOrHadAllMembersWithAccumulationDate ;
    skos:changeNote [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ],
        [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:isOrWasAccumulationDateOfMostMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was accumulation date of most members of"@en,
        """es o era fecha de acumulación de la mayoría de los miembros
         de"""@es,
        """est ou a été la date d'accumulation de la plupart des membres
         de"""@fr ;
    rdfs:comment """Connects a Date to a Record Set most of whose present or past
         members were or will be accumulated at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasAccumulationDateOfSomeMembersOf ;
    owl:inverseOf :hasOrHadMostMembersWithAccumulationDate ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """To be used for specifying a bulk date, i.e. the predominant date
         of the members of the record set."""@en .

:isOrWasActiveAtDate a owl:ObjectProperty ;
    rdfs:label "is or was active at date"@en,
        "está o estuvo activo en la fecha"@es,
        "est ou a été actif à la date"@fr ;
    rdfs:comment """Inverse of 'is or was activity date of' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isOrWasActivityDateOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :performanceRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2025-04-03" ;
            rdf:value """Adjusted the rdfs:comment and added French and Spanish
               labels."""@en ],
        [ dc:date "2025-03-06" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasActivityDateOf a owl:ObjectProperty ;
    rdfs:label "is or was date of activity of"@en,
        "es o era fecha de actividad de"@es,
        "est ou a été la date d’activité de"@fr ;
