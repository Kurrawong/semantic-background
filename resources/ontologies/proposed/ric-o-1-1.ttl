        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isOrWasLanguageOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was language of all members of"@en,
        "es o era lengua de todos los miembros de"@es,
