:isOrWasRecordStateOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was record state of all members of"@en,
        "es o era estado de documento de todos los miembros de"@es,
        "a ou a été l’état de tous les membres de"@fr ;
