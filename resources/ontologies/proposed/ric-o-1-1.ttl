            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isOriginalOf a owl:ObjectProperty ;
    rdfs:label "is original of"@en,
        "es original de"@es,
        "est l’original de"@fr ;
    rdfs:comment """Connects the original version of a Record to a copy or a later
         version."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasGeneticLinkToRecordResource,
        :precedesInTime ;
    owl:inverseOf :hasOriginal ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """There may be zero to many intermediate Records, ignored or
         unknown, between the two connected Records"""@en ;
    :RiCCMCorrespondingComponent """RiC-R010 (is original of
         relation)"""@en .

:isProductionTechniqueTypeOf a owl:ObjectProperty ;
    rdfs:label "is production technique type of"@en,
        "es tipo de técnica de producción de"@es,
        "est le type de technique de production de"@fr ;
