         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :isOrWasActiveAtDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :performanceRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2025-04-03" ;
            rdf:value """Renamed the property, changed its rdfs:comment, added the
               property chain axiom and French and Spanish labels."""@en ],
        [ dc:date "2025-03-06" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasAffectedBy a owl:ObjectProperty ;
    rdfs:label "is or was affected by"@en,
        "es o era afectado por"@es,
        "est ou a été affecté par"@fr ;
    rdfs:comment "Inverse of 'affects or affected' object property."@en ;
