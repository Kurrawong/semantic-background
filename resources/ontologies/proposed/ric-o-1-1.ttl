@prefix : <https://www.ica.org/standards/RiC/ontology#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ric-dft: <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes#> .
@prefix ric-rst: <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

cc:license a owl:AnnotationProperty ;
    rdfs:isDefinedBy cc: .

dc:contributor a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:creator a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:date a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:language a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:publisher a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:rights a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dc:title a owl:AnnotationProperty ;
    rdfs:isDefinedBy dc: .

dcterms:abstract a owl:AnnotationProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:contributor a owl:AnnotationProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:description a owl:AnnotationProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:publisher a owl:AnnotationProperty ;
    rdfs:isDefinedBy dcterms: .

dcterms:title a owl:AnnotationProperty ;
    rdfs:isDefinedBy dcterms: .

vann:preferredNamespacePrefix a owl:AnnotationProperty ;
    rdfs:isDefinedBy vann: .

vann:preferredNamespaceUri a owl:AnnotationProperty ;
    rdfs:isDefinedBy vann: .

rdf:value a owl:AnnotationProperty ;
    rdfs:isDefinedBy rdf: .

skos:changeNote a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    rdfs:subPropertyOf skos:note .

skos:definition a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    rdfs:subPropertyOf skos:note .

skos:example a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    rdfs:subPropertyOf skos:note .

skos:historyNote a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    rdfs:subPropertyOf skos:note .

skos:inScheme a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .

skos:scopeNote a owl:AnnotationProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    rdfs:subPropertyOf skos:note .

dcat:version a owl:DatatypeProperty ;
    rdfs:isDefinedBy <http://www.w3.org/ns/dcat> .

:CarrierExtent a owl:Class ;
    rdfs:label "Datenträgerumfang"@de,
        "Carrier Extent"@en,
        "Extensión del soporte"@es,
        "Mesure d’un support"@fr ;
    rdfs:comment """Number of physical units and/or physical dimensions of the carrier
         of an Instantiation."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Extent ;
    skos:changeNote [ dc:date "2020-10-28" ;
            rdf:value """Class added in order to handle an accurate description of a
               carrier extent"""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-11-21" ;
            rdf:value """Changed a bit the definition and added change
               notes."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """In order to manage an instantiation of a record resource it is
         necessary to note the extent of the carrier as well as that of the instantiation itself.
         Whether it is necessary to note dimensions, the number of relevant units or both depends on
         the nature of the carrier and particular business needs."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A04 (Carrier Extent)
         attribute"""@en .

:InstantiationExtent a owl:Class ;
    rdfs:label "Umfang der Instanz|Repräsentation"@de,
        "Instantiation Extent"@en,
        "Extensión de la instanciación"@es,
        "Mesure d’une instanciation"@fr ;
    rdfs:comment """Countable characteristics of an Instantiation expressed as a
         quantity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Extent ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-11-21" ;
            rdf:value """Changed a bit the definition and added change
               notes."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Class added in order to handle an accurate description of an
               instantiation extent"""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A23 (Instantiation
         Extent attribute)"""@en .

:RecordResourceExtent a owl:Class ;
    rdfs:label "Recordressourceumfang"@de,
        "Record Resource Extent"@en,
        "Extensión de recurso documental"@es,
        "Mesure d’une ressource archivistique"@fr ;
    rdfs:comment """The quantity of information content, as human experienced,
         contained in a Record Resource."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Extent ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-11-21" ;
            rdf:value """Changed a bit the definition and added change
               notes."""@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Class added in order to handle an accurate description of a
               record resource extent"""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """The method and precision of expressing the quantity of
         information represented in a Record Resource will vary according to the kind of record
         resource being described, processing economy constraints, etc. For Record Sets, quantity
         may be expressed as number of records, or, for analogue records in particular, by the
         physical storage dimensions of the members of the Record Set. For individual Records or
         Record Parts, quantity may be expressed in more precise terms."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A35 (Record Resource
         extent attribute)"""@en .

:RiCCMCorrespondingComponent a owl:AnnotationProperty ;
    rdfs:label "RiC-CM corresponding component"@en,
        "componente correspondiente en RiC-CM"@es,
        "composant correspondant dans RiC-CM"@fr ;
    rdfs:comment """When it exists, specifies the identifier and name of RiC-CM
         component that corresponds to the annotated class or property."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subPropertyOf rdfs:comment ;
    skos:changeNote [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:accruals a owl:DatatypeProperty ;
    rdfs:label "accruals"@en,
        "ingresos"@es,
        "accroissements"@fr ;
    rdfs:comment """Information on the anticipated accession(s) to the Record
         Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, skos:scopeNote, examples
               (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example """Accruing - there is an agreement with the creator that additional
         snapshots of their email directory will be accessioned at yearly intervals"""@en,
        "Non-accruing"@en,
        "Unknown"@en ;
    skos:scopeNote "See also accrualsStatus"@en ;
    :RiCCMCorrespondingComponent """corresponds to RiC-A01 (Accruals
         attribute)"""@en .

:accrualsStatus a owl:DatatypeProperty ;
    rdfs:label "accruals status"@en,
        "estado de los ingresos"@es,
        "statut des accroissements"@fr ;
    rdfs:comment "Information on the status of possible accruals"@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, description (rdfs:comment),
               skos:scopeNote."""@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """scope note : updated. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ] ;
    skos:scopeNote """A text statement or single words such as “Closed” to indicate
         that no additional Record Resource will (or is anticipated to) be added to the Record Set;
         “Open” to indicate that additional records or record sets will (or are expected to) be
         added to the Record Set; or “Unknown” to indicate that this information is not available,
         for example. See also accruals"""@en ;
    :RiCCMCorrespondingComponent """specialization of RiC-A01 (Accruals
         attribute)"""@en .

:accumulationDate a owl:DatatypeProperty ;
    rdfs:label "accumulation date"@en,
        "fecha de acumulación"@es,
        "date d’accumulation"@fr ;
    rdfs:comment """A date at which a Record Resource or Instantiation was or will be
         accumulated."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of 'hasAccumulationDate', which is
         provided for usability reasons. May be deprecated and removed later on. Use only if you
         don’t use Date classes for handling dates."""@en .

:allMembersWithAccumulationDate a owl:DatatypeProperty ;
    rdfs:label "all members with accumulation date"@en,
        "todos sus miembros como fecha de acumulación"@es,
        "des membres ayant tous pour date d’accumulation"@fr ;
    rdfs:comment """Date at which all of the present or past members of a Record Set
         were or will be accumulated."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadAllMembersWithAccumulationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en .

:allMembersWithCreationDate a owl:DatatypeProperty ;
    rdfs:label "all members with creation date"@en,
        "todos sus miembros como fecha de creación"@es,
        "des membres ayant tous pour date de création"@fr ;
    rdfs:comment """Date at which all of the present or past members of a Record Set
         were or will be created."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :beginningDate ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadAllMembersWithCreationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en ;
    :RiCCMCorrespondingComponent """RiC-R081i ('has or had all members with creation
         date' relation)."""@en .

:altimetricSystem a owl:DatatypeProperty ;
    rdfs:label "altimetric system"@en,
        "sistema altimétrico"@es,
        "système altimétrique"@fr ;
    rdfs:comment "Reference system used for altitude"@en ;
    rdfs:domain :Coordinates ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :referenceSystem ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:altitude a owl:DatatypeProperty ;
    rdfs:label "altitude"@en,
        "altitud"@es,
        "altitude"@fr ;
    rdfs:comment """The height of a Place above a reference level, especially above
         sea level."""@en ;
    rdfs:domain :Coordinates ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Property of the Coordinates class. If you don't use this class,
         use geographicalCoordinates property, a property of Place class."""@en .

:authenticityNote a owl:DatatypeProperty ;
    rdfs:label "authenticity note"@en,
        "nota de autenticidad"@es,
        "note sur l’authenticité"@fr ;
    rdfs:comment """Information on the evidence that a Record Resource or
         Instantiation is what it purports to be, was created or sent by the said Agent at the said
         time, and has not been tampered with, corrupted, or forged. """@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :note ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-01-17" ;
            rdf:value """Made this property a subproperty of the new rico:note datatype
               property. Slightly modified its definition (rdfs:comment)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """examples added. Objective: to make RiC-O compliant with RiC-CM
               v0.2."""@en ] ;
    skos:example """The deed is digitally signed by the Notary. The electronic
         signature validity cannot be assessed, but the content was not modified from the moment of
         signing."""@en,
        "The letter is unsigned."@en,
        "The record bears signatures."@en,
        "The timestamp exists but cannot be verified."@en ;
    skos:scopeNote """May be used in a Record Set description when its value is shared
         by some or all members of the Record Set. For digital records, it may include results from
         automated means of checking the validity of signatures and timestamp. In particular cases
         it may be contextually related to the state attribute, for example, a document can be an
         original or a copy, either of which can be authentic or a forgery. """@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A03 (Authenticity Note
         attribute)"""@en .

:authorizingMandate a owl:DatatypeProperty ;
    rdfs:label "authorizing mandate"@en,
        "norma de control"@es,
        "mandat"@fr ;
    rdfs:comment """Information on a Mandate that authorizes an Agent to perform an
         Activity."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :ruleFollowed ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use the Mandate class for handling
         mandates."""@en .

:birthDate a owl:DatatypeProperty ;
    rdfs:label "birth date"@en,
        "fecha de nacimiento"@es,
        "date de naissance"@fr ;
    rdfs:comment "Date at which a Person was born."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :beginningDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:carrierExtent a owl:DatatypeProperty ;
    rdfs:label "carrier extent"@en,
        "extensión del soporte"@es,
        "mesure du support"@fr ;
    rdfs:comment """Number of physical units and/or physical dimensions of the carrier
         of an Instantiation. In order to manage an Instantiation of a record resource it is
         necessary to note the extent of the carrier as well as that of the Instantiation itself.
         Whether it is necessary to note dimensions, the number of relevant units, or both, depends
         on the nature of the carrier and particular business needs."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :physicalOrLogicalExtent ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ] ;
    skos:example "1 page"@en,
        "3 GB (1 USB key)"@en,
        "32.5 x 49 cm (piece of parchment)"@en ;
    skos:scopeNote """For digital resources, it may be used to indicate the size of
         storage capacity (disk, tape, film, etc.). Carrier extent should not be confused with
         instantiation extent or record resource extent. For a given Record Resource, the
         instantiation extent may vary, based on format, density of information on the carrier, etc.
         For example, a CD with a storage capacity of 700 MB (carrier extent) might hold a record of
         1500 words (record resource extent) represented in two versions, one a Word document with
         an instantiation extent of 3 KB and the other a PDF file with an instantiation extent of 5
         KB. """@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A04 (Carrier Extent
         attribute)"""@en .

:classification a owl:DatatypeProperty ;
    rdfs:label "classification"@en,
        "clasificación"@es,
        "classification"@fr ;
    rdfs:comment """A term, number or alphanumeric string that is usually taken from
         an external classification vocabulary or scheme that qualifies a Record
         Resource."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example """BUD-01-F002 (classification number from a corporate file
         plan)"""@en,
        "digitized items"@en,
        "financial affairs"@en,
        "human resource management"@en,
        "student registration"@en ;
    skos:scopeNote """May be used in a Record Set description when its value is shared
         by some or all members of the record set. This datatype property is not to be confused with
         Identifier although, in some cases, the information may be the same."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A07 (Classification
         attribute)"""@en .

:closeTo a owl:AnnotationProperty ;
    rdfs:label "close to"@en,
        "cerca de"@es,
        "proche de"@fr ;
    rdfs:comment """An annotation property for recording a possible mapping to a
         component in another model or ontology"""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subPropertyOf rdfs:comment ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:conditionsOfAccess a owl:DatatypeProperty ;
    rdfs:label "conditions of access"@en,
        "condiciones de acceso"@es,
        "conditions d’accès"@fr ;
    rdfs:comment """Terms and circumstances affecting the availability of a Record
         Resource or an Instantiation for consultation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:example "Closed as awaiting conservation treatment"@en,
        "Closed for 30 years"@en,
        "Closed under data protection legislation"@en,
        "Open"@en,
        """Recognita software, min. version 3.0, is needed in order to open
         the file"""@en,
        """The Archives cannot provide VHS reader to access the content of
         the tape"""@en,
        "Acceso libre a través de los terminales de consulta"@es ;
    skos:scopeNote """May be used in a Record Set description when its value is shared
         by some or all members of the Record Set. The attribute provides information about the
         accessibility of a Record Resource, as well as the physical, technical or legal limitations
         that exist for providing access to it."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A08 (Conditions of Access
         attribute)"""@en .

:conditionsOfUse a owl:DatatypeProperty ;
    rdfs:label "conditions of use"@en,
        "condiciones de uso"@es,
        "conditions d’utilisation"@fr ;
    rdfs:comment """Terms and circumstances affecting the use of a Record Resource or
         an Instantiation after access has been provided. Includes conditions governing reproduction
         of the Record Resource under applicable copyright (intellectual property) and/or property
         legislation or due to conservation status."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:example """Cannot be copied using warm light copying machines or photographed
         using flashlight"""@en,
        """Permission of the copyright owner must be obtained before
         use"""@en ;
    skos:scopeNote """May be used in a Record Set description when its value is shared
         by some or all members of the Record Set."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A09 (Conditions of Use
         attribute)"""@en .

:creationDate a owl:DatatypeProperty ;
    rdfs:label "creation date"@en,
        "fecha de creación"@es,
        "date de création"@fr ;
    rdfs:comment """Date at which a Record Resource or Instantiation was or will be
         created."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :beginningDate ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value "Narrowed the domain to match 'hasCreationDate'."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:dateQualifier a owl:DatatypeProperty ;
    rdfs:label "date qualifier"@en,
        "calificador de fecha"@es,
        "qualificatif de la date"@fr ;
    rdfs:comment """A human readable qualification of a Date to indicate the level of
         precision or certainty."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """examples added. Objective: to make RiC-O compliant with RiC-CM
               v0.2."""@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-10-10" ;
            rdf:value """Updated the rdfs:comment, skos:scopeNote and examples, in order
               to make this datatype property fully compliant with RiC-CM 1.0"""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example "approximate"@en,
        "circa"@en,
        "end unknown"@en ;
    skos:scopeNote """Most often, this human readable expression of the accuracy of
         the date is used along with an ISO 8601 representation of the date. The qualifier can also
         be expressed as a machine-readable value, using the EDTF standard (thus, a specialization
         of the normalizedDateValue datatype property)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A13 (Date Qualifier
         attribute)"""@en .

:deathDate a owl:DatatypeProperty ;
    rdfs:label "death date"@en,
        "fecha de muerte"@es,
        "date de décès"@fr ;
    rdfs:comment "Date at which a Person died."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :endDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:destructionDate a owl:DatatypeProperty ;
    rdfs:label "destruction date"@en,
        "fecha de destrucción"@es,
        "date de destruction"@fr ;
    rdfs:comment """Date at which a Record Resource or Instantiation was or will be
         destructed."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :endDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed domain and definition (added \\"or will be\\")."@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Renamed deletion into destruction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:expressedDate a owl:DatatypeProperty ;
    rdfs:label "expressed date"@en,
        "fecha expresada"@es,
        "date en langage naturel"@fr ;
    rdfs:comment """Natural language expression of a date. This property is a
         specialization of the name property. In order that the precise meaning of the date can be
         understood, information such as the calendar used or other specific context should be
         included."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :name,
        :textualValue ;
    skos:changeNote [ dc:date "2023-10-10" ;
            rdf:value """Updated the rdfs:comment and skos:examples in order to make
               this property fully compliant with RiC-CM 1.0. Made it a subproperty of
               rico:name."""@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """examples added. Objective: to make RiC-O compliant with RiC-CM
               v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:example "1550-1553, 1555 (date range)"@en,
        "1925-1966 (date range)"@en,
        "All of the years 1550, 1551, 1553, 1555"@en,
        "October 24, 1999 (month day, year)"@en,
        "One of the years 1550, 1551, 1553, 1555"@en,
        "The Middle Ages"@en,
        """The second semester of 1951 to 1952 (academic reference
         system)"""@en,
        """15 thermidor an IV (calendrier révolutionnaire
         français)"""@fr,
        "8 avril 1258 (a. st., style de Pâques)"@fr,
        "XVIIe siècle"@fr,
        """Die jovis ultima mensis martii anno domini millesimo quingentesimo
         quadragesimo ante Pascha"""@la ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A19 (Expressed Date
         attribute)"""@en .

:geodesicSystem a owl:DatatypeProperty ;
    rdfs:label "geodesic system"@en,
        "sistema geodésico"@es,
        "système géodésique"@fr ;
    rdfs:comment "Reference system used for geographical coordinates."@en ;
    rdfs:domain :Coordinates ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :referenceSystem ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:geographicalCoordinates a owl:DatatypeProperty ;
    rdfs:label "geographical coordinates"@en,
        "coordenadas geográficas"@es,
        "coordonnées géographiques"@fr ;
    rdfs:comment "Longitudinal and latitudinal information about a Place. "@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), examples (skos:example)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:example """Latitude 35.89421911, Longitude 139.94637467 (ISO
         6709/F)"""@en,
        """Latitude 50°40′46,461″N, Longitude 95°48′26,533″W, Height 123,45m
         (ISO 6709/D)"""@en ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use PhysicalLocation and Coordinates classes with Place.
         Coordinates may be based on ISO 6709 Standard representation of geographic point location
         by coordinates."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A11 (Coordinates
         attribute)"""@en .

:hasOrHadCorrespondent a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has or had correspondent"@en,
        "tiene o tenía como correspondiente"@es,
        "a ou a eu pour correspondant"@fr ;
    rdfs:comment """Connects two Persons that correspond or have corresponded with
         each other. This relation is symmetric."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :knows ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :correspondenceRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new correspondenceRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, textual definition (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "hasCorrespondent")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R052 ('has or had correspondent'
         relation)"""@en .

:hasOrHadSpouse a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has or had spouse"@en,
        "tiene o tenía como cónyuge a"@es,
        "a ou a eu pour conjoint"@fr ;
    rdfs:comment """Connects two Persons who are or were married. This relation is
         symmetric."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasFamilyAssociationWith ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :spouseRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new spouseRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "hasSpouse")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R049 ('has or had spouse'
         relation)"""@en .

:hasOrHadWorkRelationWith a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has or had work relation with"@en,
        "tiene o tenía relación profesional con"@es,
        "a ou a eu une relation professionnelle avec"@fr ;
    rdfs:comment """Connects two Agents that have or had some type of work relation in
         the course of their activities. This relation is symmetric."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :workRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, text definition (changed made in order
               to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "hasWorkRelationWith")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new workRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Added the property chain axiom so that this property is
               formally defined as a shortcut."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R046 ('has or had work relation with'
         relation)"""@en .

:hasSibling a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "has sibling"@en,
        "tiene como hermano o hermana a"@es,
        "a pour frère ou sœur"@fr ;
    rdfs:comment """Connects two Persons who are siblings. This relation is
         symmetric."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasFamilyAssociationWith ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :siblingRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the super property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new siblingRelation_role object
               property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R048 ('has sibling'
         relation)"""@en .

:height a owl:DatatypeProperty ;
    rdfs:label "height"@en,
        "altura"@es,
        "hauteur"@fr ;
    rdfs:comment "Vertical dimension of an entity."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:history a owl:DatatypeProperty ;
    rdfs:label "history"@en,
        "historia"@es,
        "histoire"@fr ;
    rdfs:comment """Summary of the development of an entity throughout its
         existence."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Agent :Event :Instantiation :Place :RecordResource :Rule ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, domain, examples (skos:example)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Domains updated. Examples added. Objective: to make RiC-O
               compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example """The manuscripts are part of the collections of Robert Harley (d
         1724) and Edward Harley (d 1741), 1st and 2nd Earls of Oxford, that were brought by
         Parliament and transferred to the British Museum in 1753. Those materials were then
         separated into this collection and those for Harley Charters and Harley Rolls and became
         part of the collections of the British Library in 1972. (about a Record Set)"""@en,
        """El primer sorteo de lotería se celebró el 13 de mayo de 1771,
         siendo desarrollado por la Real Lotería General de Nueva España… (sobre una
         actividad)"""@es,
        """Nacido en Barbastro en 1892, donde realizó sus primeros estudios
         con los escolapios. Licenciado en Derecho por la Universidad de Zaragoza, aprobó las
         oposiciones al cuerpo nacional de notarios… (sobre una persona)"""@es ;
    skos:scopeNote """For a record set, may be used to summarize the history of the
         Record Set itself, or additionally to summarize the history of some or all members of the
         Record Set. Should not be confused with the scope and content property."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A21 (History
         attribute)"""@en .

:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier"@en,
        "identificador"@es,
        "identifiant"@fr ;
    rdfs:comment """A word, number, letter, symbol, or any combination of these used
         to uniquely identify or reference an individual instance of an entity within a specific
         information domain. Can include Global Persistent Identifiers (globally unique and
         persistently resolvable identifier for the entity) and/or Local Identifiers. Both the
         domain within which the identifier is unique, and the rules used in forming the identifier
         value should be provided with the identifier value."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ] ;
    skos:example """B-000091 (example of a unique identifier for an instantiation
         assigned by a repository)"""@en,
        """BUD-01-F002 (example of a classification number from a corporate
         file plan)"""@en,
        """F 1204 (example of a local identifier for a record set assigned by
         a repository)"""@en,
        """NAS1/A/1.1 (example of a local identifier for a
         record)"""@en,
        """http://isni.org/0000000073572182 (example of a persistent
         International Standard Name Identifier for a person)"""@en,
        """http://n2t.net/ark:/99166/w6tz44ht (example of an Archival
         Resource Key for a person)"""@en,
        """http://n2t.net/ark:/99166/w6v1266v (example of an Archival
         Resource Key for a record)"""@en ;
    skos:scopeNote """Use only if you don't use Identifier class for handling
         identifiers. Within a given domain (a closed system), identifiers are used to uniquely
         reference instances of an entity. Identifiers are instruments of control that facilitate
         management of the entities within the domain. The formulation of identifiers commonly is
         based on rules. In addition to an identifier needing to be unique within a domain, it is
         also highly desirable that it be persistent, that is, that the identifier uniquely
         identifies the entity over time. A variety of organizations provide rules for the formation
         of identifiers, and services designed to facilitate the persistence of identifiers. Such
         identifiers are commonly referred to as Persistent Identifiers (or PIDs). PIDs conform to
         RFC 3986, but impose additional rules. Common examples are Archival Resource Keys (ARKs)
         and Digital Object Identifiers (DOIs). Within the global environment of the Internet, there
         are special rules for the formation of identifiers to ensure that they are unique within
         the domain of the Internet. Such identifiers must conform to the Internet Engineering Task
         Force (IETF) Uniform Resource Identifier rules (RFC 3986)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A22 (Identifier
         attribute)"""@en .

:instantiationExtent a owl:DatatypeProperty ;
    rdfs:label "Instantiation extent"@en,
        "soporte de instanciación"@es,
        "mesure de l’instanciation"@fr ;
    rdfs:comment """Countable characteristics of an Instantiation expressed as a
         quantity."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :physicalOrLogicalExtent ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Scope note updated. Examples added. Objective: to make RiC-O
               compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example "234 linear metres"@en,
        "Size of PDF file: 1.5 MB"@en,
        "The register has 345 written folios"@en ;
    skos:scopeNote """Instantiation extent should not be confused with record resource
         extent or carrier extent. For a given Record Resource, the instantiation extent may vary,
         based on format, density of information on the carrier, etc. For example, a CD with a
         storage capacity of 700 MB (carrier extent) might hold a record of 1500 words (record
         resource extent) represented in two versions, one a Word document with an instantiation
         extent of 3 KB and the other a PDF file with an instantiation extent of 5
         KB."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A23 (Instantiation Extent
         attribute)"""@en .

:instantiationStructure a owl:DatatypeProperty ;
    rdfs:label "Instantiation structure"@en,
        "estructura de la instanciación"@es,
        "structure de l’instanciation"@fr ;
    rdfs:comment """Information about the physical arrangement and composition of an
         Instantiation."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :structure ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition fixed. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Specialization of RiC-A40 (Structure
         attribute)"""@en .

:integrityNote a owl:DatatypeProperty ;
    rdfs:label "integrity note"@en,
        "nota de integridad"@es,
        "note sur l'intégrité"@fr ;
    rdfs:comment """Information about the known intellectual completeness of a Record
         Resource."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :note ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Scope note and examples added. Objective: to make RiC-O
               compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2025-01-17" ;
            rdf:value """Made this property a subproperty of the new rico:note datatype
               property."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, description (rdfs:comment),
               skos:scopeNote, domain, examples (skos:example)."""@en ] ;
    skos:example """A web page (HTML, 15 images, 2 CSS, 1 javascript), with 5 images
         missing."""@en,
        """For record set: series of letters, one is missing so the integrity
         is compromised."""@en,
        """Line three of a hand-written letter was cut out and a replacement
         text was inserted by an unknown person."""@en,
        """Part of the text is missing (because a corner on the instantiation
         was cut out, which is a physical characteristic). See also the examples of
         physicalCharacteristics."""@en ;
    skos:scopeNote """May be used in a Record Set description when its value is shared
         by some or all members of the Record Set. The information about integrity may be generated
         manually or automatically. Not to be confused with the physical completeness of the
         instantiation, which is covered by the physical characteristics note attribute. The
         integrity of a Record Resource and the physical characteristics note of an Instantiation
         may be complementary. This attribute also covers any additions to or removal of original
         information."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A24 (Integrity Note
         attribute)"""@en .

:intersects a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "intersects"@en,
        "cruza"@es,
        "intersecte"@fr ;
    rdfs:comment """Connects two Dates that overlap. This relation is
         symmetric."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate,
        :isDateAssociatedWith ;
    skos:changeNote [ dc:date "2023-10-12" ;
            rdf:value "Added the property"@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """made this property a subproperty of
               isAssociatedWithdate."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R086 ('intersects'
         relation)"""@en .

:isFunctionallyEquivalentTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is functionally equivalent to"@en,
        "equivale funcionalmente a"@es,
        "est fonctionnellement équivalente à"@fr ;
    rdfs:comment """Connects two Instantiations which may be considered as equivalent.
         This relation is symmetric."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isEquivalentTo,
        :isInstantiationAssociatedWithInstantiation ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :functionalEquivalenceRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the scope note."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               functionalEquivalenceRelation_role object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Two Instantiations, from some point of view, may be considered
         as equivalent. This equivalence is usually based upon the fact that the Instantiations have
         at least the same intellectual content (they instantiate the same Record
         Resource)."""@en ;
    :RiCCMCorrespondingComponent """RiC-R035 ('is functionally equivalent to'
         relation)"""@en .

:isOrWasAdjacentTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is or was adjacent to"@en,
        "es o era un lugar contiguo a"@es,
        "est ou a été adjacent à"@fr ;
    rdfs:comment """Connects two Places that are or were geographically adjacent. This
         relation is symmetric."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAssociatedWithPlace,
        :isPlaceAssociatedWith ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, textual definition (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "isAdjacentTo")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use for connecting two adjacent geographical or administrative
         regions."""@en ;
    :RiCCMCorrespondingComponent """RiC-R077 ('is or was adjacent to'
         relation)"""@en .

:lastModificationDate a owl:DatatypeProperty ;
    rdfs:label "last modification date"@en,
        "fecha de última modificación"@es,
        "date de dernière modification"@fr ;
    rdfs:comment "Date at which an entity was last updated."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :modificationDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude"@en,
        "latitud"@es,
        "latitude"@fr ;
    rdfs:comment "Distance in degrees north or south of the equator."@en ;
    rdfs:domain :Coordinates ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Property of the Coordinates class. If you don't use this class,
         use geographicalCoordinates property, a property of Place class."""@en .

:length a owl:DatatypeProperty ;
    rdfs:label "length"@en,
        "longitud"@es,
        "longueur"@fr ;
    rdfs:comment "Length of an entity."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value """Added for enabling to describe entities that have such a
               dimension."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """May be used, among other cases, for storing the length of some
         places like streets."""@en .

:location a owl:DatatypeProperty ;
    rdfs:label "location"@en,
        "localización"@es,
        "localisation"@fr ;
    rdfs:comment """A delimitation of the physical territory of a Place. Used to
         describe basic human-readable text such as an address, a cadastral reference, or less
         precise information found in a Record."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:example "Montreal (city in Canada)"@en,
        "25 rue Saint-Denis à Paris"@fr ;
    skos:scopeNote """Use only if you don't use PhysicalLocation class with Place. Use
         the geographicalCoordinates property, or the Coordinates class, to record the geographical
         coordinates of the Place. Use the spatial relations (particularly 'has or had location') to
         capture a relation between two places."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A27 (Location
         attribute)"""@en .

:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude"@en,
        "longitud"@es,
        "longitude"@fr ;
    rdfs:comment """Distance in degrees east or west of a prime
         meridian."""@en ;
    rdfs:domain :Coordinates ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Property of the Coordinates class. If you don't use this class,
         use geographicalCoordinates property, a property of Place class."""@en .

:migrationDate a owl:DatatypeProperty ;
    rdfs:label "migration date"@en,
        "fecha de migración"@es,
        "date de migration"@fr ;
    rdfs:comment """Date at which an Instantiation was or will be
         migrated."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :derivationDate ;
    skos:changeNote [ dc:date "2025-02-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-03-01" ;
            rdf:value """Removed 'Record Resource' from the definition and made the
               property a subproperty of the new 'derivationDate' property."""@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:mostMembersWithAccumulationDate a owl:DatatypeProperty ;
    rdfs:label "most members with accumulation date"@en,
        "la mayoría de sus miembros como fecha de acumulación"@es,
        """des membres dont la plupart ont pour date
         d’accumulation"""@fr ;
    rdfs:comment """Date at which most of the present or past members of a Record Set
         were or will be accumulated."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :someMembersWithAccumulationDate ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadMostMembersWithAccumulationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en .

:mostMembersWithCreationDate a owl:DatatypeProperty ;
    rdfs:label "most members with creation date"@en,
        "la mayoría de sus miembros como fecha de creación"@es,
        "des membres dont la plupart ont pour date de création"@fr ;
    rdfs:comment """Date at which most of the present or past members of a Record Set
         were or will be created."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :someMembersWithCreationDate ;
    skos:changeNote [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadMostMembersWithCreationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en ;
    :RiCCMCorrespondingComponent """RiC-R083i ('has or had most members with creation
         date' relation)."""@en .

:normalizedDateValue a owl:DatatypeProperty ;
    rdfs:label "normalized date value"@en,
        "valor normalizado de fecha"@es,
        "valeur normalisée de la date"@fr ;
    rdfs:comment """Machine readable representation of the date based on a public
         technical standard."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :normalizedValue ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2024-09-02" ;
            rdf:value "Fixed a typo in two of the EDTF examples."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the examples
               (skos:example)."""@en ],
        [ dc:date "2023-10-10" ;
            rdf:value """Updated the rdfs:comment and examples, and added a scopeNote,
               in order to make this property fully compliant with RiC-CM 1.0."""@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Examples added. Objective: to make RiC-O compliant with RiC-CM
               v0.2."""@en ] ;
    skos:example """1550,1551,1553,1555 (a date set in EDTF, meaning one of the years
         1550, 1551, 1553, 1555)"""@en,
        "1948-03 (an ISO 8601 form of a single date)"@en,
        "1948-03-08 (an ISO 8601 form of a single date)"@en,
        """1948-03~ (a single date in ETDF, meaning March 1948
         approximately)"""@en,
        """1948/ (a date range in EDTF, starting in 1948, end
         unknown)"""@en,
        """1948/.. (an open date range in EDTF, starting in
         1948)"""@en,
        """2012-02-14/2015-03-08 (an ISO 8601 form of a date
         range)"""@en,
        "2012/2015-03 (an ISO 8601 form of a date range)"@en,
        """{1550,1551,1553,1555} (a date set in EDTF, meaning all of the
         years 1550, 1551, 1553, 1555)"""@en,
        """{1805,1815..1820} (a date set in EDTF, meaning all of the years
         1805, 1815, 1816, 1817, 1818, 1819, 1820)"""@en ;
    skos:scopeNote """Used to represent the date in a standardized format that can be
         processed programmatically. The main standard used today is ISO 8601, which is based on the
         Gregorian calendar. See also the Extended Date Time Format (EDTF), which is an extension of
         ISO 8601, and enables, among other features, to represent a date set, and to indicate the
         date is approximate."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A29 (Normalized Date
         attribute)"""@en .

:overlapsOrOverlapped a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "overlaps or overlapped"@en,
        "se superpone o superponía con"@es,
        "chevauche ou a chevauché"@fr ;
    rdfs:comment """Connects two Places that geographically overlap or overlapped.
         This relation is symmetric."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAssociatedWithPlace,
        :isPlaceAssociatedWith ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, text definition (changed made in order
               to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "overlaps")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R078 ('overlaps or overlapped'
         relation)"""@en .

:productionTechnique a owl:DatatypeProperty ;
    rdfs:label "production technique"@en,
        "técnica de produccióon"@es,
        "technique de production"@fr ;
    rdfs:comment """The method used in the representation of information on an
         Instantiation."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Examples added. Objective: to make RiC-O compliant with RiC-CM
               v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    skos:example "engraving"@en,
        "handwriting"@en,
        "magnetic recording"@en,
        "optical recording"@en ;
    skos:scopeNote """Use only if you have free text or don't have a controlled
         vocabulary for production techniques (in this case, use the ProductionTechniqueType
         class)"""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A33 (Production Technique
         attribute)"""@en .

:publicationDate a owl:DatatypeProperty ;
    rdfs:label "publication date"@en,
        "fecha de publicación"@es,
        "date de publication"@fr ;
    rdfs:comment """Date of the publication, in the past or in the future, of a Record
         Resource."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value """Changed definition (added "in the past or in the
               future")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:qualityOfRepresentationNote a owl:DatatypeProperty ;
    rdfs:label "quality of representation note"@en,
        "nota sobre la calidad de representación"@es,
        "note sur la qualité de la représentation"@fr ;
    rdfs:comment """Characteristics of an Instantiation that affect the ability to
         recover the intellectual content. Such characteristics may be related to the methods used
         in creating the Instantiation or introduced subsequent to the creation through
         accident."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :physicalCharacteristicsNote ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, description (rdfs:comment),
               skos:scopeNote, rdfs:subpropertyOf."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example """Black and white digitization may have led to loss of some
         information."""@en,
        """some loss of information due to poor quality of image
         capture"""@en,
        "some loss of text due to rodent damage"@en ;
    skos:scopeNote """Quality of representation note is a specialization of physical
         characteristics note. Quality of representation note should be used in conjunction with
         physical characteristics note when the physical characteristics impact the ability to
         recover the intellectual content."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A34 (Quality of Representation
         Note attribute)"""@en .

:quantity a owl:DatatypeProperty ;
    rdfs:label "quantity"@en,
        "cantidad"@es,
        "quantité"@fr ;
    rdfs:comment "Machine-readable quantity."@en ;
    rdfs:domain :Extent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range xsd:decimal ;
    rdfs:subPropertyOf :textualValue ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added an xml:lang attribute to the rdfs:comment."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Datatype property created along with unitOfMeasurement, Extent
               and UnitOfMeasurement classes, in order to provide methods for handling extent
               accurately."""@en ],
        [ dc:date "2020-11-21" ;
            rdf:value "Added a scope note."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Use if you use the Extent class and its properties for handling
         an accurate description of the extent of a resource."""@en .

:rankInHierarchy a owl:DatatypeProperty ;
    rdfs:label "rank in hierarchy"@en,
        "rango en la jerarquía"@es,
        "rang dans la hiérarchie"@fr ;
    rdfs:comment """The rank of a Record Resource, or of a Proxy that stands for it,
         in a hierarchy."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :RecordResource :Proxy ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range xsd:int ;
    rdfs:subPropertyOf :textualValue ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] ;
    skos:scopeNote """The object properties rico:directlyIncludes and
         rico:hasDirectConstituent, or variants of these which are sub-properties of
         rico:hasOrHadPart, should always be used to express hierarchies in RiC-O. The
         rico:rankInHierarchy datatype property should only be used in addition (never
         independently), for convenience (for example to help display or query a graph). But it
         should be ensured that it reflects and is compatible with (e.g. computed using) the
         hierarchical object properties in the intended context (e.g. a hierarchy of Record Parts in
         a given Record). Thus, if, for example, Record Part A rico:hasDirectConstituent Record Part
         B, then the rico:rankInHierarchy of Record Part B must be strictly greater than
         rico:rankInHierarchy of Record Part A, and no other Record Part in that context should have
         rico:rankInHierarchy between that of Record Part A and Record Part B. For a given Record
         Resource, rico:rankInHierarchy should never be used more than once. If a Record Resource
         belongs to more than one hierarchy, a rico:Proxy of the Record Resource should be
         introduced, and rico:rankInHierarchy have source such a proxy, in all cases except
         (possibly) the first."""@en .

:rankInSequence a owl:DatatypeProperty ;
    rdfs:label "rank in sequence"@en,
        "rango en la secuencia"@es,
        "rang dans la séquence"@fr ;
    rdfs:comment """The rank of a Record Resource, or of a Proxy that stands for it,
         in a sequence."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :RecordResource :Proxy ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range xsd:int ;
    rdfs:subPropertyOf :textualValue ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] ;
    skos:scopeNote """The object property rico:precedesOrPreceded or one of its
         sub-properties should always be used to express sequences in RiC-O. The rico:rankInSequence
         datatype property should only be used in addition (never independently), for convenience
         (for example to help display or query a graph). But it should be ensured that it reflects
         and is compatible with (e.g. computed using) the sequential object properties in the
         intended context (e.g. the Records in a given Record Set). Thus, if, for example, Record
         Resource A rico:precedesOrPreceded Record Resource B, then the rico:rankInSequence of
         Record Resource B must be strictly greater than rico:rankInSequence of Record Resource A,
         and no other Record Resource in that context should have rico:rankInSequence between that
         of Record Resource A and Record Resource B. For a given Record Resource,
         rico:rankInSequence should never be used more than once. If a Record Resource belongs to
         more than one sequence, a rico:Proxy of the Record Resource should be introduced, and
         rico:rankInSequence have source such a proxy, in all cases except (possibly) the
         first."""@en .

:recordResourceExtent a owl:DatatypeProperty ;
    rdfs:label "Record Resource Extent"@en,
        "soporte de recurso documental"@es,
        "mesure de la ressource archivistique"@fr ;
    rdfs:comment """The quantity of information content, as human experienced,
         contained in a Record Resource. The method and precision of expressing the quantity of
         information represented in a Record Resource will vary according to the kind of Record
         Resource being described, processing economy constraints, etc. For record sets, quantity
         may be expressed as number of records, or, for analogue records in particular, by the
         physical storage dimensions of the members of the Record Set. For individual records or
         record parts, quantity may be expressed in more precise terms. """@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :physicalOrLogicalExtent ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition and scope note updated. Examples added.
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Fix capitalisation in English label."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-21" ;
            rdf:value """Updated the scope note, as a RecordResourceExtent class has
               been created."""@en ] ;
    skos:example "1,500 words"@en,
        "2 films"@en,
        "2.065.735 characters"@en,
        "3 minutes and 24 seconds"@en,
        "6 maps"@en,
        "6 photographs"@en ;
    skos:scopeNote """Use if you don't use RecordResourceExtent class and its
         properties for handling such information. Record resource extent should not be confused
         with instantiation extent or carrier extent. The number, size or duration of the
         information content unit(s) remains the same even if the information is instantiated in
         various carriers. For example, a CD with a storage capacity of 700 MB (carrier extent)
         might hold a record of 1,500 words (record resource extent) represented in two versions,
         one a Word document with an instantiation extent of 3 KB and the other a PDF file with an
         instantiation extent of 5 KB."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A35 (Record Resource Extent
         attribute)"""@en .

:recordResourceSourceOfInformation a owl:DatatypeProperty ;
    rdfs:label "Record Resource source of information"@en,
        "fuente de información de recurso documental"@es,
        "source d’information de la ressource archivistique"@fr ;
    rdfs:comment """Information about some source on which the content of a Record
         Resource is based."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2025-01-16" ;
            rdf:value """Datatype property added in RiC-O 1.1. It replaces, as concerns
               Record Resources, the former 'source' datatype property, that was available in RiC-0
               0.1 and RiC-O 0.2, and was removed in RiC-O 1.0."""@en ] ;
    skos:example """Dardy-Cretin (Michèle), Histoire administrative du ministère de la
         culture et de la communication (1959-2012). Paris: Collection du Comité d’histoire du
         ministère de la culture et de la communication, 2012."""@fr ;
    skos:scopeNote """Can be used, for example, for Records having documentary form
         type Authority Record or Finding Aid. Use only if you don't use the
         'recordResourceHasSourceOfInformation' object property."""@en .

:recordResourceStructure a owl:DatatypeProperty ;
    rdfs:label "Record Resource structure"@en,
        "estructura de recurso documental"@es,
        "structure de la ressource archivistique"@fr ;
    rdfs:comment """Information about the intellectual arrangement and composition of
         a Record Resource. For Record and Record Part, it encompasses information about the
         intellectual composition of the record, the presence of record parts and their functions.
         For Record Set, it encompasses information about the methodology or criteria used for
         arranging the Record Set members or Record members within the containing Record
         Set"""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :structure ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:example """Inside each file, the records are arranged
         chronologically."""@en,
        """The database has 3 related tables: names, addresses, and passport
         numbers."""@en,
        """The record has 2 appendixes, comprising a full account of the
         income from car taxes and real estate taxes."""@en,
        """The series have the files arranged according to the alphabetical
         order of the places concerned."""@en ;
    :RiCCMCorrespondingComponent """Specialization of RiC-A40 (Structure
         attribute)"""@en .

:relationCertainty a owl:DatatypeProperty ;
    rdfs:label "relation certainty "@en,
        "certeza de la relación"@es,
        "degré de certitude de la relation"@fr ;
    rdfs:comment """Qualifies the level of certitude of the accuracy of a
         Relation."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-27" ;
            rdf:value """Renamed the datatype property (was 'certainty') and reduced its
               domain to Relation (the dmain was the union of Event and Relation). Consequently
               updated the labels."""@en ],
        [ dc:date "2023-10-14" ;
            rdf:value """Reintroduced this datatype property, with the definition
               assigned to it in RiC-CM 1.0, apart from its domain that also includes
               Event."""@en ] ;
    skos:example "certain"@en,
        "uncertain"@en,
        "unknown"@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-RA01 (Certainty of Relation
         attribute)"""@en .

:relationSource a owl:DatatypeProperty ;
    rdfs:label "relation source"@en,
        "fuente de la relación"@es,
        "source de la relation"@fr ;
    rdfs:comment """A source of information used for identifying and describing a
         Relation."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-12-27" ;
            rdf:value """Renamed the datatype property (was 'source') and reduced its
               domain to Relation (the domain was the union of Record Resource and Relation).
               Consequently updated the rdfs:comment, labels and scope note. Added a
               rico:RiCCMCorrespondingComponent annotation."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Use only if you don't use the 'isEvidencedBy' object
         property."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-RA05 (Source of Relation
         attribute)."""@en .

:relationState a owl:DatatypeProperty ;
    rdfs:label "relation state"@en,
        "estado de la relación"@es,
        "statut de la relation"@fr ;
    rdfs:comment """Used to qualify the state of a Relation (e. g. present, past,
         ongoing, unknown)."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:sentimentOrEmotionExpressed a owl:DatatypeProperty ;
    rdfs:label "sentiment or emotion expressed"@en,
        "sentimiento o emoción expresados"@es,
        "sentiment ou émotion exprimés"@fr ;
    rdfs:comment """Specification of, or information about, the sentiment(s) or
         emotion(s) expressed by the content of a Record or a Record Part."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :scopeAndContent ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] ;
    skos:scopeNote """Can in particular be used for textual or visual Records or
         Record Parts."""@en .

:technicalCharacteristics a owl:DatatypeProperty ;
    rdfs:label "technical characteristics"@en,
        "características técnicas"@es,
        "caractéristiques techniques"@fr ;
    rdfs:comment """Describes any relevant physical or software feature of any device
         involved in the creation or management of a Record Resource."""@en ;
    rdfs:domain :Mechanism ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Scope note and examples added. Objective: to make RiC-O
               compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:example """Hubble Space Telescope had until 2002 a flawed mirror that
         introduced severe spherical aberration for the images."""@en ;
    skos:scopeNote """Does not include references to the workflow that the Mechanism
         is involved in, which is described under the Activity entity. It emphasizes those features
         that provide a better understanding of the impact of the Mechanism on the
         records."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A41 (Technical Characteristics
         attribute)"""@en .

:title a owl:DatatypeProperty ;
    rdfs:label "title"@en,
        "título"@es,
        "intitulé"@fr ;
    rdfs:comment """An identifying name of a Record Resource, Instantiation or
         Rule."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource :Rule ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :name ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use only if you don't use Title class for handling
         titles."""@en ;
    :RiCCMCorrespondingComponent """Specialization of RiC-A28 (Name
         attribute)"""@en .

:type a owl:DatatypeProperty ;
    rdfs:label "type"@en,
        "tipo"@es,
        "type"@fr ;
    rdfs:comment "A term used to characterize an entity."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Type subclasses for handling
         categories."""@en .

:unitOfMeasurement a owl:DatatypeProperty ;
    rdfs:label "unit of measurement"@en,
        "unidad de medida"@es,
        "unité de mesure"@fr ;
    rdfs:comment """A definite magnitude of a quantity, defined and adopted by
         convention or by law, that is used as a standard for measurement of the same kind of
         quantity. Can be spacial units (cm, m), weight (g, kg), time (s, h), storage (MB, TB) or
         more informal units used in the archival context like number of boxes, pages or
         words."""@en ;
    rdfs:domain :Extent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Datatype property created along with quantity, Extent and
               UnitOfMeasurement classes, in order to provide methods for handling extent
               accurately."""@en ],
        [ dc:date "2020-11-21" ;
            rdf:value "Added a scope note."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added an xml:lang attribute to the rdfs:comment."@en ] ;
    skos:scopeNote """Use if you do not use the UnitOfMeasurement class for handling
         units of measurement along with Extent."""@en .

:usedFromDate a owl:DatatypeProperty ;
    rdfs:label "used from date"@en,
        "usado desde la fecha"@es,
        "utilisé à partir de"@fr ;
    rdfs:comment "Date at which an Appellation was first used."@en ;
    rdfs:domain :Appellation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :beginningDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Made this property a subproperty of beginningDate."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:usedToDate a owl:DatatypeProperty ;
    rdfs:label "used to date"@en,
        "usado hasta la fecha"@es,
        "utilisé jusqu’à"@fr ;
    rdfs:comment "Date until an Appellation was used."@en ;
    rdfs:domain :Appellation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :endDate ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Made this property a subproperty of endDate."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:width a owl:DatatypeProperty ;
    rdfs:label "width"@en,
        "anchura"@es,
        "largeur"@fr ;
    rdfs:comment "Horizontal dimension of an entity."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :measure ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

voaf:Vocabulary a owl:Class ;
    rdfs:isDefinedBy <http://purl.org/vocommons/voaf> .

skos:broader a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    owl:inverseOf skos:narrower .

skos:hasTopConcept a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    owl:inverseOf skos:topConceptOf .

skos:narrower a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    owl:inverseOf skos:broader .

skos:topConceptOf a owl:ObjectProperty ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
    owl:inverseOf skos:hasTopConcept .

:activityIsContextOfRelation a owl:ObjectProperty ;
    rdfs:label "activity is context of relation"@en,
        "actividad es contexto de relación"@es,
        "activité est le contexte de la relation"@fr ;
    rdfs:comment """Connects an Activity to an Agent Temporal Relation (when the
         Activity is transferred from an Agent to another one) or a Mandate Relation (the Mandate
         assigns the Activity to the Agent or defines it)."""@en ;
    rdfs:domain :Activity ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :AgentTemporalRelation :MandateRelation ) ] ;
    rdfs:subPropertyOf :thingIsContextOfRelation ;
    owl:inverseOf :asConcernsActivity ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:affectsOrAffected a owl:ObjectProperty ;
    rdfs:label "affects or affected"@en,
        "afecta o afectaba a"@es,
        "affecte ou a affecté"@fr ;
    rdfs:comment """Connects an Event to a Thing on which the Event has or had some
         significant impact."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadParticipant ;
    owl:inverseOf :isOrWasAffectedBy ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               and corresponding CM component (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "affects")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R059 ('affects or affected'
         relation)"""@en .

:agentHasOrHadLocation a owl:ObjectProperty ;
    rdfs:label "agent has or had location"@en,
        "agente tiene o tenía como localización"@es,
        "agent a ou a eu pour localisation"@fr ;
    rdfs:comment """Inverse of 'is or was location of agent' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :hasOrHadLocation,
        :isAgentAssociatedWithPlace ;
    owl:inverseOf :isOrWasLocationOfAgent ;
    skos:changeNote [ dc:date "2023-10-26" ;
            rdf:value "Added a rdfs:comment."@en ],
        [ dc:date "2023-10-20" ;
            rdf:value "Property created for RiC-0 1.0."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:authorizedBy a owl:ObjectProperty ;
    rdfs:label "authorized by"@en,
        "controlado por"@es,
        "autorisé par"@fr ;
    rdfs:comment "Inverse of 'authorizes' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Mandate ;
    rdfs:subPropertyOf :isAssociatedWithRule ;
    owl:inverseOf :authorizes ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :mandateRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new mandateRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R067i ('authorizedBy'
         relation)"""@en .

:authorizes a owl:ObjectProperty ;
    rdfs:label "authorizes"@en,
        "controla"@es,
        "autorise"@fr ;
    rdfs:comment """Connects a Mandate to the Agent that the Mandate gives the
         authority or competencies to act."""@en ;
    rdfs:domain :Mandate ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRuleAssociatedWith ;
    owl:inverseOf :authorizedBy ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :mandateRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new mandateRelation_role object
               property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "fixed the CM corresponding component name."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R067 ('authorizes'
         relation)"""@en .

:authorizingAgent a owl:ObjectProperty ;
    rdfs:label "authorizing agent"@en,
        "autorización dada por el agente"@es,
        "autorisation donnée par l’agent"@fr ;
    rdfs:comment """Connects a Mandate Relation to an Agent that assigns the
         Mandate."""@en ;
    rdfs:domain :MandateRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :relationHasContext ;
    owl:inverseOf :isAuthorizingAgentInMandateRelation ;
    skos:changeNote [ dc:date "2023-11-13" ;
            rdf:value "Fixed the rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:contained a owl:ObjectProperty ;
    rdfs:label "contained"@en,
        "contenía"@es,
        "a contenu"@fr ;
    rdfs:comment """Connects a Place to a Place that it contained in the
         past."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :containsOrContained,
        :hadPart ;
    owl:inverseOf :wasContainedBy ;
    skos:changeNote [ dc:date "2023-09-05" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between places (the current
               partitive relations being also added, including a transitive one)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels, description (rdfs:comment)."@en ] .

:creationWithRole a owl:ObjectProperty ;
    rdfs:label "creation with role"@en,
        "creación con el rol de"@es,
        "création avec pour rôle"@fr ;
    rdfs:comment """Connects a Creation Relation to the Role Type that the creator
         Agent(s) has in the creation process"""@en ;
    rdfs:domain :CreationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RoleType ;
    rdfs:subPropertyOf :relationHasContext ;
    owl:inverseOf :roleIsContextOfCreationRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:derivationDate a owl:DatatypeProperty ;
    rdfs:label "derivation date"@en,
        "fecha de derivación"@es,
        "date de dérivation"@fr ;
    rdfs:comment """Date at which an Instantiation was or will be derived from another
         Instantiation."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2025-03-01" ;
            rdf:value "Added in RiC-O 1.1."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:describesOrDescribed a owl:ObjectProperty ;
    rdfs:label "describes or described"@en,
        "describe o describía"@es,
        "décrit ou a décrit"@fr ;
    rdfs:comment """Connects a Record Resource to a Thing that it describes or
         described."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSubject ;
    owl:inverseOf :isOrWasDescribedBy ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "describes")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Can be used, among other situations, for specifying that some
         finding aid (a Record that has Documentary Form Type Finding Aid) describes some Record
         Set."""@en ;
    :RiCCMCorrespondingComponent """RiC-R021 ('describes or described'
         relation)"""@en .

:directlyContains a owl:ObjectProperty ;
    rdfs:label "contains directly"@en,
        "contiene directamente"@es,
        "contient directement"@fr ;
    rdfs:comment """Connects a Place to another Place that it directly
         contains."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :containsTransitive,
        :hasDirectPart ;
    owl:inverseOf :isDirectlyContainedBy ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-09-05" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between places (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:directlyFollowsProxyInSequence a owl:ObjectProperty ;
    rdfs:label "directly follows proxy in sequence"@en,
        "sigue directamente el proxy en la secuencia"@es,
        "suit directement le proxy dans la séquence"@fr ;
    rdfs:comment "Inverse of 'proxy directly precedes in sequence' object property. "@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :directlyFollowsInSequence,
        :followsProxyInSequence ;
    owl:inverseOf :proxyDirectlyPrecedesInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:directlyIncludes a owl:ObjectProperty ;
    rdfs:label "directly includes"@en,
        "incluye directamente"@es,
        "inclut directement"@fr ;
    rdfs:comment """Connects a Record Set to a Record or Record Set which it includes
         directly."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hasDirectPart,
        :includesTransitive ;
    owl:inverseOf :isDirectlyIncludedIn ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between Record Sets
               and their members (the possibly indirect, transitive relation, superproperty of this
               one, being also added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels, description (rdfs:comment)."@en ] .

:directlyIncludesProxy a owl:ObjectProperty ;
    rdfs:label "directly includes proxy"@en,
        "incluye directamente el proxy"@es,
        "inclut directement le proxy"@fr ;
    rdfs:comment """Inverse of 'proxy is directly included in' object
         property."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasDirectPart,
        :includesProxy ;
    owl:inverseOf :proxyIsDirectlyIncludedIn ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:documentedBy a owl:ObjectProperty ;
    rdfs:label "documented by"@en,
        "se documenta en"@es,
        "est documenté par"@fr ;
    rdfs:comment "Inverse of 'documents' object property."@en ;
    rdfs:domain :Activity ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicOrFunctionalProvenanceOf,
        :resultsOrResultedIn ;
    owl:inverseOf :documents ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :activityDocumentationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               activityDocumentationRelation_role object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Made this property a subproperty of the new
               isOrganicOrFunctionalProvenanceOf property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the inverse property IRI, the superproperty IRI and the
               corresponding CML component name"""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R033i ('documented by'
         relation)"""@en .

:documents a owl:ObjectProperty ;
    rdfs:label "documents"@en,
        "documenta"@es,
        "documente"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Activity
         that generates the Record Resource or Instantiation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Activity ;
    rdfs:subPropertyOf :hasOrganicOrFunctionalProvenance,
        :resultsOrResultedFrom ;
    owl:inverseOf :documentedBy ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :activityDocumentationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               activityDocumentationRelation_role object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, superproperty IRI, corresponding CM
               component name (changed made in order to make RiC-O compliant with RiC-CM 0.2; the
               name of this property in RiC-O 0.1 was "isDocumentationOf")."""@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Made this property a subproperty of the new
               hasOrganicOrFunctionalProvenance property."""@en ] ;
    skos:scopeNote """To be used to describe the functional provenance of a Record
         Resource or Instantiation."""@en ;
    :RiCCMCorrespondingComponent """RiC-R033 ('documents'
         relation)"""@en .

:evidences a owl:ObjectProperty ;
    rdfs:label "evidences"@en,
        "evidencia"@es,
        "atteste de"@fr ;
    rdfs:comment """Connects a Record Resource to a Relation, when the first is used
         for proving the existence of the second one, or for describing it."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Relation ;
    rdfs:subPropertyOf :thingIsConnectedToRelation ;
    owl:inverseOf :isEvidencedBy ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-27" ;
            rdf:value """Renamed the object property (was 'is source of') and reduced
               its domain to Record Resource (the domain was the union of Record Resource and Agent)
               and its range to Relation (the range was the union of Record Resource and Relation).
               Consequently updated the superproperty, the labels, and added a
               rico:RiCCMCorrespondingComponent. Same for the inverse object property."""@en ] ;
    :RiCCMCorrespondingComponent """Inverse of 'is evidenced by' object
         property."""@en .

:existsOrExistedIn a owl:ObjectProperty ;
    rdfs:label "exists or existed in"@en,
        "existe o existía en"@es,
        "existe ou a existé dans"@fr ;
    rdfs:comment """Connects a Position to a Group in which that Position exists or
         existed, or that is defined by that Group's organizational structure."""@en ;
    rdfs:domain :Position ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :hasOrHadPosition ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :positionToGroupRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "existsIn")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new positionToGroupRelation_role
               object property."""@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Corrected unparseable symbol in rdfs:comment"@en ] ;
    :RiCCMCorrespondingComponent """RiC-R056 ('exists or existed in'
         relation)"""@en .

:expressesOrExpressed a owl:ObjectProperty ;
    rdfs:label "expresses or expressed"@en,
        "expresa o expresaba"@es,
        "exprime ou a exprimé"@fr ;
    rdfs:comment """Inverse of 'is or was expressed by' object
         property."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Rule ;
    rdfs:subPropertyOf :isAssociatedWithRule ;
    owl:inverseOf :isOrWasExpressedBy ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "expresses")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R064i ('expresses or expressed'
         relation)"""@en .

:followedInSequence a owl:ObjectProperty ;
    rdfs:label "followed in sequence"@en,
        "seguía en la secuencia transitivo"@es,
        "a suivi dans la séquence"@fr ;
    rdfs:comment """Connects a Thing to a Thing that it followed in some sequence (not
         necessarily defined or characterised chronologically) in the past."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :followsOrFollowed ;
    owl:inverseOf :precededInSequence ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to try to clarify what is
               meant."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Added transitive super-property and both present direct and
               past sequential relations as well as their respective inverse relations."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from followsInTime."""@en ] .

:generalDescription a owl:DatatypeProperty ;
    rdfs:label "general description"@en,
        "descripción general"@es,
        "description générale"@fr ;
    rdfs:comment """General information about an entity. General description may be
         used to describe any entity. There are different appropriate uses for general description.
         First, while it is recommended that more specific properties be used in describing an
         entity, it may be desirable, for economic or other reasons, to describe two or more
         specific properties together. Second, general description may be used to describe one or
         more characteristics that are not otherwise accommodated in RiC-O. Third, it may be used to
         provide a succinct summary or abstract description in addition to more detailed specific
         description."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, description (rdfs:comment), examples
               (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:example """The Senate is the academic governing body of the University of
         Strathclyde and is responsible for all academic matters including academic standards and
         quality. Meetings of the Senate are chaired by the Principal and the membership is drawn
         entirely from within the University, comprising academic and research staff. (about a
         corporate body, University of Strathclyde Senate)"""@en,
        """This activity involves regulating the nursing profession by
         conducting examinations and on-going education for nurses, maintaining rolls of those
         qualified as enrolled or registered nurses, midwives, psychiatric, and other specialised
         nurses. It also covers hearing disciplinary charges against nurses (and where necessary,
         removing them temporarily or permanently from the registers), as well as promoting the
         nursing profession. (about an activity, Nursing Profession Regulation)"""@en,
        """Le massif du Mont-Blanc est un massif des Alpes partagé entre la
         France, l'Italie et la Suisse. Il abrite le mont Blanc, plus haut sommet d'Europe
         occidentale qui culmine à 4 809 mètres (altitude relevée en 2015). Il est traversé par le
         tunnel du Mont-Blanc, entre Chamonix dans la vallée de l'Arve et Courmayeur dans la vallée
         d'Aoste."""@fr,
        """Thomas Blaikie (1750-1838) est un botaniste et jardinier écossais.
         Il a dessiné notamment les jardins de Malmaison et Bagatelle."""@fr ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A43 (General Description
         attribute)"""@en .

:hadComponent a owl:ObjectProperty ;
    rdfs:label "had component"@en,
        "tenía como componente"@es,
        "a eu pour composant"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation that was its
         component in the past."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hadPart,
        :hasOrHadComponent ;
    owl:inverseOf :wasComponentOf ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between instantiations (the
               current partitive relations being also added, including a transitive
               one)."""@en ] .

:hadConstituent a owl:ObjectProperty ;
    rdfs:label "had constituent"@en,
        "tenía como elemento constitutivo"@es,
        "a eu pour constituant"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         that was its constituent in the past."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hadPart,
        :hasOrHadConstituent ;
    owl:inverseOf :wasConstituentOf ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between Record and Record or
               Record Part (the current partitive relations being also added, including a transitive
               one)."""@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the domain."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:hadSubdivision a owl:ObjectProperty ;
    rdfs:label "had subdivision"@en,
        "tenía como subdivisión"@es,
        "a eu pour subdivision"@fr ;
    rdfs:comment "Connects a Group to one of its past subdivisions."@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :hadPart,
        :hadSubordinate,
        :hasOrHadSubdivision ;
    owl:inverseOf :wasSubdivisionOf ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between groups (the current
               partitive relations being also added, including a transitive one)."""@en ] .

:hadSubevent a owl:ObjectProperty ;
    rdfs:label "had subevent"@en,
        "tenía como parte de evento"@es,
        "a été constitué de l’événement"@fr ;
    rdfs:comment """Connects a past Event to one of a series of past Events that
         constituted that original, broader, past Event."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :hadPart,
        :hasOrHadSubevent ;
    owl:inverseOf :wasSubeventOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express partitive relations between past Events (the partitive
               relations between ongoing events being also added, including a transitive
               one)."""@en ] .

:hasAccumulationDate a owl:ObjectProperty ;
    rdfs:label "has accumulation date"@en,
        "tiene como fecha de acumulación"@es,
        "a pour date d'accumulation"@fr ;
    rdfs:comment """Inverse of 'is accumulation date of' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasOrganicProvenanceDate ;
    owl:inverseOf :isAccumulationDateOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :accumulationRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value """Connect to AccumulationRelation via a sub-property chain, and
               make a sub-property of the new object property
               'hasOrganicProvenanceDate'."""@en ],
        [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:hasActivityType a owl:ObjectProperty ;
    rdfs:label "has activity type"@en,
        "tiene como tipo de actividad"@es,
        "a pour type d’activité"@fr ;
    rdfs:comment """Connects an Activity to an Activity Type that categorizes
         it."""@en ;
    rdfs:domain :Activity ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ActivityType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isActivityTypeOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Fixed the Spanish label."@en ] .

:hasAddressee a owl:ObjectProperty ;
    rdfs:label "has addressee"@en,
        "se dirige a"@es,
        "a pour destinataire"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Agent that
         it is addressed to."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrganicProvenance ;
    owl:inverseOf :isAddresseeOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "added a scope note"@en ] ;
    skos:scopeNote """The identity of the addressee is (usually) evidenced by the
         Record Resource or Instantiation itself."""@en ;
    :RiCCMCorrespondingComponent """RiC-R032 ('has addressee'
         relation)"""@en .

:hasAuthor a owl:ObjectProperty ;
    rdfs:label "has author"@en,
        "tiene como autor a"@es,
        "a pour responsable intellectuel"@fr ;
    rdfs:comment """Connects a Record to the Group, Person or Position that is
         responsible for conceiving and formulating the information contained in the
         Record."""@en ;
    rdfs:domain :Record ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Group :Person :Position ) ] ;
    rdfs:subPropertyOf :hasCreator ;
    owl:inverseOf :isAuthorOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :authorshipRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2020-12-29" ;
            rdf:value """Created following the addition of RiC-R079 relation in RiC-CM
               0.2"""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new authorshipRelation_role
               object property."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ] ;
    skos:scopeNote """To be used for a Person, Group or Position that makes any
         contribution to the content of a record. Includes the Person, Group or Position in whose
         name or by whose command the content may have been formulated and first instantiated (for
         example the Person who signed the Record)."""@en ;
    :RiCCMCorrespondingComponent """RiC-R079 ('has author'
         relation)"""@en .

:hasBirthDate a owl:ObjectProperty ;
    rdfs:label "has birth date"@en,
        "tiene como fecha de nacimiento"@es,
        "a pour date de naissance"@fr ;
    rdfs:comment "Inverse of 'is birth date of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasBeginningDate ;
    owl:inverseOf :isBirthDateOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R070i ('has birth date'
         relation)"""@en .

:hasBirthPlace a owl:ObjectProperty ;
    rdfs:label "has birth place"@en,
        "tiene como lugar de nacimiento"@es,
        "a pour lieu de naissance"@fr ;
    rdfs:comment "Inverse of 'is birth place of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAgentAssociatedWithPlace ;
    owl:inverseOf :isBirthPlaceOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment)."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O 1.0."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Fixed the domain of the property."@en ] .

:hasCarrierType a owl:ObjectProperty ;
    rdfs:label "has carrier type"@en,
        "tiene como tipo de soporte"@es,
        "a pour type de support"@fr ;
    rdfs:comment """Connects an Instantiation to a Carrier Type which categorizes its
         carrier."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CarrierType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isCarrierTypeOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasChild a owl:ObjectProperty ;
    rdfs:label "has child"@en,
        "tiene como hijo o hija a"@es,
        "a pour enfant"@fr ;
    rdfs:comment "Connects a Person to one of their children."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasDescendant ;
    owl:inverseOf :isChildOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :childRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "changed the inverse property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new childRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R018 ('has child'
         relation)"""@en .

:hasCollector a owl:ObjectProperty ;
    rdfs:label "has collector"@en,
        "tiene como coleccionista a"@es,
        "est collecté par"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Agent that
         collects it intentionally, i.e., the Agent is a collector."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasAccumulator ;
    owl:inverseOf :isCollectorOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property and super property
               IRI, text definition, domain (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "collectedBy")."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R030 ('has collector'
         relation)"""@en .

:hasContentOfType a owl:ObjectProperty ;
    rdfs:label "has content of type"@en,
        "tiene como tipo de contenido"@es,
        "a pour type de contenu"@fr ;
    rdfs:comment """Connects a Record or a Record Part to a Content Type which
         categorizes its content."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ContentType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isContentTypeOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the text definition and superproperty IRI."@en ] .

:hasContentWhichMainlyRepresents a owl:ObjectProperty ;
    rdfs:label "has content which mainly represents"@en,
        "tiene contenido que representa principalmente"@es,
        "a un contenu qui représente principalement"@fr ;
    rdfs:comment """Connects a Record or a Record Part to a Thing that its content
         mainly represents."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasContentWhichRepresents,
        :hasOrHadMainSubject ;
    owl:inverseOf :isMainThingRepresentedByContentOf ;
    skos:changeNote [ dc:date "2025-04-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] ;
    skos:scopeNote """A common use case would be to connect a photograph of a person
         (a portrait) and the person represented."""@en .

:hasCopy a owl:ObjectProperty ;
    rdfs:label "has copy"@en,
        "tiene como copia"@es,
        "a pour copie"@fr ;
    rdfs:comment """Connects a Record Resource to a copy of that Record
         Resource."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :hasGeneticLinkToRecordResource,
        :precedesInTime ;
    owl:inverseOf :isCopyOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Is both a temporal and genetic relation between the two Record
         Resources."""@en ;
    :RiCCMCorrespondingComponent """RiC-R012 ('has copy'
         relation)"""@en .

:hasCreationDate a owl:ObjectProperty ;
    rdfs:label "has creation date"@en,
        "tiene como fecha de creación"@es,
        "a pour date de création"@fr ;
    rdfs:comment "Inverse of 'is creation date of' object property"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasBeginningDate,
        :hasOrganicProvenanceDate ;
    owl:inverseOf :isCreationDateOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :creationRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value """Connect to CreationRelation via a sub-property chain, and make
               a sub-property of the new object property 'hasOrganicProvenanceDate'."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R080i ('has creation date'
         relation)"""@en .

:hasDateType a owl:ObjectProperty ;
    rdfs:label "has date type"@en,
        "tiene como tipo de fecha"@es,
        "a pour type de date"@fr ;
    rdfs:comment "Connects a Date to its Date Type."@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :DateType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isDateTypeOf ;
    skos:changeNote [ dc:date "2023-10-10" ;
            rdf:value "Added a rdfs:comment and a French rdfs:label."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ] .

:hasDeathDate a owl:ObjectProperty ;
    rdfs:label "has death date"@en,
        "tiene como fecha de muerte"@es,
        "a pour date de décès"@fr ;
    rdfs:comment "Inverse of 'is death date of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasEndDate ;
    owl:inverseOf :isDeathDateOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R072i ('has death date'
         relation)"""@en .

:hasDeathPlace a owl:ObjectProperty ;
    rdfs:label "has death place"@en,
        "tiene como lugar de muerte"@es,
        "a pour lieu de décès"@fr ;
    rdfs:comment "Inverse of 'is death place of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAgentAssociatedWithPlace ;
    owl:inverseOf :isDeathPlaceOf ;
    skos:changeNote [ dc:date "2023-11-13" ;
            rdf:value "Added a rdfs:comment."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Fixed the domain of the property."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O v1.0."@en ] .

:hasDestructionDate a owl:ObjectProperty ;
    rdfs:label "has destruction date"@en,
        "tiene como fecha de destrucción"@es,
        "a pour date de destruction"@fr ;
    rdfs:comment """Inverse of 'is destruction date of' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasEndDate ;
    owl:inverseOf :isDestructionDateOf ;
    skos:changeNote [ dc:date "2023-10-14" ;
            rdf:value "Added a rdfs:comment; same to the inverse property."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed domain."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Renamed deletion into destruction"@en ] .

:hasDirectComponent a owl:ObjectProperty ;
    rdfs:label "has direct component"@en,
        "tiene directamente como componente"@es,
        "a directement pour composant"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation that is its
         direct component."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasComponentTransitive,
        :hasDirectPart ;
    owl:inverseOf :isDirectComponentOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between
               instantiations (the possibly indirect, transitive relation, superproperty of this
               one, being also added)."""@en ] .

:hasDirectConstituent a owl:ObjectProperty ;
    rdfs:label "has direct constituent"@en,
        "tiene directamente como elemento constitutivo"@es,
        "a directement pour constituant"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         that is its direct constituent."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasConstituentTransitive,
        :hasDirectPart ;
    owl:inverseOf :isDirectConstituentOf ;
    owl:propertyChainAxiom ( :hasDirectConstituentProxy :proxyFor ) ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-03" ;
            rdf:value "Fixed the property chain axiom."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Added a property chain axiom relating it to use of
               rico:Proxy."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between records and
               other records or record parts (the possibly indirect, transitive relation,
               superproperty of this one, being also added)."""@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the domain."@en ] .

:hasDirectSubdivision a owl:ObjectProperty ;
    rdfs:label "has direct subdivision"@en,
        "tiene directamente como subdivisión"@es,
        "a directement pour subdivision"@fr ;
    rdfs:comment "Connects a Group to one of its direct subdivisions."@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :hasDirectPart,
        :hasDirectSubordinate,
        :hasSubdivisionTransitive ;
    owl:inverseOf :isDirectSubdivisionOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between groups (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasDirectSubevent a owl:ObjectProperty ;
    rdfs:label "has direct subevent"@en,
        "tiene directamente como parte de evento"@es,
        "est directement constitué de l’événement"@fr ;
    rdfs:comment """Connects an ongoing Event to one of a series of Events that
         directly constitute that broader, ongoing Event."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :hasDirectPart,
        :hasSubeventTransitive ;
    owl:inverseOf :isDirectSubeventOf ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between ongoing
               events (the possibly indirect, transitive relation, superproperty of this one, being
               also added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:hasDocumentaryFormType a owl:ObjectProperty ;
    rdfs:label "has documentary form type"@en,
        "tiene como tipo documental"@es,
        "a pour type d’objet informationnel"@fr ;
    rdfs:comment """Connects a Record or Record Part to its Documentary Form
         Type."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :DocumentaryFormType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isDocumentaryFormTypeOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2023-12-30" ;
            rdf:value "Fixed a typo in the French label."@en ] .

:hasDraft a owl:ObjectProperty ;
    rdfs:label "has draft"@en,
        "tiene como borrador"@es,
        "a pour ébauche"@fr ;
    rdfs:comment "Inverse of 'is draft of' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :followsInTime,
        :hasGeneticLinkToRecordResource ;
    owl:inverseOf :isDraftOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-011i ('has draft'
         relation)"""@en .

:hasEventType a owl:ObjectProperty ;
    rdfs:label "has event type"@en,
        "tiene como tipo de evento"@es,
        "a pour type d’événement"@fr ;
    rdfs:comment """Connects an Event to an Event Type which categorizes
         it."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :EventType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isEventTypeOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ] .

:hasExtent a owl:ObjectProperty ;
    rdfs:label "has extent"@en,
        "tiene como extensión"@es,
        "a pour mesure"@fr ;
    rdfs:comment """Connects a Record Resource or Instantiation to an
         Extent"""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Extent ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isExtentOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value """Added a new rdfs:label in French; added an xml:lang attribute
               to the rdfs:comment."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value """Changed the domain (was Instantiation or RecordResource) to
               Thing; changed the definition accordingly."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Object property created along with the Extent class and its
               subclasses, in order to provide methods for handling extent accurately."""@en ] .

:hasExtentType a owl:ObjectProperty ;
    rdfs:label "has extent type"@en,
        "tiene como tipo de extensión"@es,
        "a pour type de mesure"@fr ;
    rdfs:comment """Connects an Extent to an Extent Type that categorizes what is
         being measured."""@en ;
    rdfs:domain :Extent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ExtentType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isExtentTypeOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value """Added a new rdfs:label in French; added an xml:lang attribute
               to the rdfs:comment."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Object property added along with the Extent Type
               class."""@en ] .

:hasFamilyType a owl:ObjectProperty ;
    rdfs:label "has family type"@en,
        "tiene como tipo de familia"@es,
