:isOrWasJurisdictionOf a owl:ObjectProperty ;
    rdfs:label "is or was jurisdiction of"@en,
        "es o era jurisdicción de"@es,
        "est ou a été le ressort de"@fr ;
    rdfs:comment """Connects a Place to an Agent that has or had jurisdiction over the
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isPlaceAssociatedWithAgent ;
    owl:inverseOf :hasOrHadJurisdiction ;
    skos:changeNote [ dc:date "2024-09-02" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "isJurisdictionOf")."""@en ],
        [ dc:date "2023-10-19" ;
            rdf:value """Made subproperty of new property isPlaceAssociatedWithAgent
               instead of its parent isPlaceAssociatedWith."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R076 ('is or was jurisdiction of'
         relation)"""@en .

:isOrWasLanguageOf a owl:ObjectProperty ;
    rdfs:label "is or was language of"@en,
        "es o era lengua de"@es,
        "est ou a été la langue de"@fr ;
    rdfs:comment """Connects a Language to an Agent, Record or Record Part that uses
         or used it."""@en ;
