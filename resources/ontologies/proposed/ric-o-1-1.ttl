        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "describedBy")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R021i ('is or was described by'
         relation)"""@en .

:isOrWasDigitalInstantiationOf a owl:ObjectProperty ;
    rdfs:label "is or was digital instantiation of"@en,
        "es o era instanciación digital de"@es,
        "est ou a été une instanciation numérique de"@fr ;
    rdfs:comment """Inverse of 'has or had digital instantiation' object
         property."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isOrWasInstantiationOf ;
    owl:inverseOf :hasOrHadDigitalInstantiation ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-29" ;
            rdf:value "Added the property."@en ] .

:isOrWasDocumentaryFormTypeOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was documentary form type of all members of"@en,
        "es o era tipo documental de todos los miembros de"@es,
        "est ou a été le type de document de tous les membres de"@fr ;
    rdfs:comment """Connects a Documentary Form Type and a Record Set whose all past
         or present Record or Record Part members have that Documentary Form Type."""@en ;
    rdfs:domain :DocumentaryFormType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasTypeOfAllMembersOf ;
    owl:inverseOf :hasOrHadAllMembersWithDocumentaryFormType ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isOrWasDocumentaryFormTypeOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was documentary form type of some members of"@en,
        "es o era tipo documental de algunos miembros de"@es,
        "est ou a été le type de document de certains membres de"@fr ;
    rdfs:comment """Connects a Documentary Form Type and a Record Set whose some past
         or present Record or Record Part members have that Documentary Form Type."""@en ;
    rdfs:domain :DocumentaryFormType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasTypeOfSomeMembersOf ;
    owl:inverseOf :hasOrHadSomeMembersWithDocumentaryFormType ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isOrWasEmployerOf a owl:ObjectProperty ;
    rdfs:label "is or was employer of"@en,
        "es o era empleador(a) de"@es,
        "a ou a été l'employeur de"@fr ;
    rdfs:comment """Connects a Corporate Body or a Person to a Person who is or was
         their employee."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :CorporateBody :Person ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isOrWasControllerOf ;
    owl:inverseOf :hasOrHadEmployer ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Adder for RiC-O v1.0."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value """Changed the domain and range of the property. Added a
               rdfs:comment. Removed the 'has or had member' super-property."""@en ] .

:isOrWasEnforcedBy a owl:ObjectProperty ;
    rdfs:label "is or was enforced by"@en,
        "es o era una regla aplicada por"@es,
        "est ou a été imposé par"@fr ;
    rdfs:comment """Connects a Rule to an Agent that enforces or enforced the
         Rule."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRuleAssociatedWith ;
    owl:inverseOf :isOrWasResponsibleForEnforcing ;
    skos:changeNote [ dc:date "2024-09-02" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "enforcedBy")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R066 ('is or was enforced by'
         relation)"""@en .

:isOrWasExpressedBy a owl:ObjectProperty ;
    rdfs:label "is or was expressed by"@en,
        "es o era una regla expresada en"@es,
        "est ou a été exprimé par"@fr ;
    rdfs:comment """Connects a Rule to a Record Resource that expresses or expressed
         the Rule."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRuleAssociatedWith ;
    owl:inverseOf :expressesOrExpressed ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "expressedBy")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R064 ('is or was expressed by'
         relation)"""@en .

:isOrWasHolderOf a owl:ObjectProperty ;
    rdfs:label "is or was holder of"@en,
        "es o era conservador de"@es,
        "détient ou a détenu"@fr ;
    rdfs:comment """Connects an Agent to a Record Resource or Instantiation that the
         Agent holds or held."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrWasManagerOf ;
    owl:inverseOf :hasOrHadHolder ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :recordResourceHoldingRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, super = property
               IRI and text definition (changed made in order to make RiC-O compliant with RiC-CM
               0.2; the name of this property in RiC-O 0.1 was "isHolderOf")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceHoldingRelation_role object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R039 ('is or was holder of'
         relation)"""@en .

:isOrWasHolderOfIntellectualPropertyRightsOf a owl:ObjectProperty ;
    rdfs:label "is or was holder of intellectual property rights of"@en,
        """es o era conservador de derechos de propiedad intelectual
         de"""@es,
        """détient ou a détenu les droits de propriété intellectuelle
         sur"""@fr ;
    rdfs:comment """Connects an Agent to a Record Resource or Instantiation on which
         the Agent has or had some intellectual property rights."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Group :Person :Position ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :hasOrHadAuthorityOver ;
    owl:inverseOf :hasOrHadIntellectualPropertyRightsHolder ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :intellectualPropertyRightsRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               intellectualPropertyRightsRelation_role object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI and textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasIntellectualPropertyRightsOn")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R040 ('is or was holder of intellectual
         property rights of' relation)"""@en .

:isOrWasIdentifierOf a owl:ObjectProperty ;
    rdfs:label "is or was identifier of"@en,
        "es o era identificador de"@es,
        "est ou a été l’identifiant de"@fr ;
    rdfs:comment """Connects an Identifier to a Thing that it identified or
