    :RiCCMCorrespondingComponent """RiC-R031i ('is sender of'
         relation)"""@en .

:isSourceOfInformationOfRecordResource a owl:ObjectProperty ;
    rdfs:label "is source of information of Record Resource"@en,
        "es fuente de información de recurso documental"@es,
        """est une source d’information de la ressource
         archivistique"""@fr ;
    rdfs:comment """Connects a Record Resource to a Record Resource, when the first is
         used as a source of information for producing the content of the second one."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :recordResourceHasSourceOfInformation ;
    skos:changeNote [ dc:date "2025-01-17" ;
            rdf:value """Object property added in RiC-O 1.1, with its inverse one. It
               replaces, as concerns Record Resources, the former 'isSourceOf' object property, that
               was available in RiC-0 0.1 and RiC-O 0.2, and was removed in RiC-O 1.0."""@en ] ;
    skos:scopeNote """Can be used, for example, for a Record Resource used to produce
         a Record having documentary form type Authority Record or Finding Aid. Not to be confused
         with the 'hasGeneticLinkToRecordResource' object property."""@en .

:isTitleTypeOf a owl:ObjectProperty ;
    rdfs:label "is title type of"@en,
        "es tipo de título de"@es,
        "est le type de titre de"@fr ;
    rdfs:comment """Connects a Title Type and a Title that it
         categorizes."""@en ;
    rdfs:domain :TitleType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Title ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasTitleType ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value """Object property added along with TitleType class and
               hasTitleType object property. """@en ] .

:isToUseDateOf a owl:ObjectProperty ;
    rdfs:label "is to use date of"@en,
        "es fecha hasta la que se usa"@es,
        "est la date jusqu’à laquelle est utilisé"@fr ;
    rdfs:comment """Connects a Date to an Appellation, when it is the date till which
         the Appellation was used."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Appellation ;
    rdfs:subPropertyOf :isEndDateOf ;
    owl:inverseOf :wasUsedToDate ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Made this property a subPropertyOf isEndDateOf."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isUnitOfMeasurementOf a owl:ObjectProperty ;
    rdfs:label "is unit of measurement of"@en,
        "es unidad de medida de"@es,
        "est l’unité de mesure de"@fr ;
    rdfs:comment """Inverse of 'has unit of measurement' object
         property."""@en ;
    rdfs:domain :UnitOfMeasurement ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Extent ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasUnitOfMeasurement ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value """Added a new rdfs:label in French; added an xml:lang attribute
               to the rdfs:comment."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Object property created along with Extent and UnitOfMeasurement
               classes, in order to provide methods for handling extent accurately."""@en ] .

:isWithin a owl:ObjectProperty ;
    rdfs:label "is within"@en,
        "está dentro"@es,
        "est contenu dans"@fr ;
    rdfs:comment "Connects a Date to a Date in which it is contained."@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate,
        :isDateAssociatedWith,
        :isOrWasPartOf ;
    owl:inverseOf :hasWithin ;
    skos:changeNote [ dc:date "2023-10-12" ;
            rdf:value "Added the property"@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """made this property a subproperty of both isDateAssociatedWith
               and isAssociatedWithdate, and of isOrWasPartOf."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R085 ('is within'
         relation)"""@en .

:issuedBy a owl:ObjectProperty ;
    rdfs:label "issued by"@en,
        "emitido por"@es,
        "rendue publique par"@fr ;
    rdfs:comment """Connects a Rule to the Agent that issued or published the
         Rule."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isRuleAssociatedWith ;
    owl:inverseOf :isResponsibleForIssuing ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R065 ('issued by'
         relation)"""@en .

:knownBy a owl:ObjectProperty ;
    rdfs:label "known by"@en,
        "conocido por"@es,
        "est connue par"@fr ;
    rdfs:comment "Inverse of 'knows of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :knowsOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :knowingOfRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new knowingOfRelation_role
               object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R050i ('known by'
         relation)"""@en .

:knowsOf a owl:ObjectProperty ;
    rdfs:label "knows of"@en,
        "conoce indirectamente a"@es,
        "a connaissance de la personne"@fr ;
    rdfs:comment """Connects a Person to another Person they have some knowledge of
         through time or space."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :knownBy ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :knowingOfRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new knowingOfRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R050 ('knows of'
         relation)"""@en .

:migratedFrom a owl:ObjectProperty ;
    rdfs:label "migrated from"@en,
        "migrado desde"@es,
        "a été produite par migration de"@fr ;
    rdfs:comment "Inverse of 'migrated into' object property."@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isOrWasDerivedFromInstantiation ;
    owl:inverseOf :migratedInto ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :migrationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-29" ;
            rdf:value """Updated subpropertyOf; this in order to make the specification
               compliant with RiC-CM 1.0."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new migrationRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "createdByMigrationFromInstantiation")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R015i ('migrated from'
         relation)"""@en .

:migratedInto a owl:ObjectProperty ;
    rdfs:label "migrated into"@en,
        "migrado a"@es,
        "a été migrée vers"@fr ;
    rdfs:comment """Connects an Instantiation to a version it has been migrated
         into."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasOrHadDerivedInstantiation ;
    owl:inverseOf :migratedFrom ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :migrationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label and inverse property IRI (changed made
               in order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O
               0.1 was "isMigratedIntoInstantiation")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new migrationRelation_role
               object property."""@en ],
        [ dc:date "2023-08-29" ;
            rdf:value """Updated subpropertyOf; this in order to make the specification
               compliant with RiC-CM 1.0."""@en ] ;
    skos:scopeNote "Use for digital instantiations."@en ;
    :RiCCMCorrespondingComponent """RiC-R015 ('migrated into'
         relation)"""@en .

:modificationDate a owl:DatatypeProperty ;
    rdfs:label "modification date"@en,
        "fecha de modificación"@es,
        "date de modification"@fr ;
    rdfs:comment "Date of the modification of an entity."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:normalizedValue a owl:DatatypeProperty ;
    rdfs:label "normalized value"@en,
        "valor normalizado"@es,
        "valeur normalisée"@fr ;
    rdfs:comment """Value representation based on a standard, preferably
         machine-readable."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Appellation :Date ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :textualValue ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:occupiesOrOccupied a owl:ObjectProperty ;
    rdfs:label "occupies or occupied"@en,
        "ocupa u ocupaba"@es,
        "occupe ou a occupé"@fr ;
    rdfs:comment """Connects a Person to a Position they occupy or
         occupied."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Position ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :isOrWasOccupiedBy ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :positionHoldingRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "occupies")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new positionHoldingRelation_role
               object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R054 ('occupies or occupied'
         relation)"""@en .

:occurredAtDate a owl:ObjectProperty ;
    rdfs:label "occurred at date"@en,
        "tiene como fecha de ocurrencia"@es,
        "a pour date d'occurrence"@fr ;
    rdfs:comment """Inverse of 'is date of occurrence of' object
         property."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate,
        :isEventAssociatedWith ;
    owl:inverseOf :isDateOfOccurrenceOf ;
    skos:changeNote [ dc:date "2023-10-13" ;
            rdf:value """Renamed the property to correct a spelling mistake. Also
               corrected the annotations when necessary."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-17" ;
            rdf:value """Made this property a subproperty of
               isEventAssociatedWith"""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R084i ('occurred at date'
         relation)"""@en .

:performsOrPerformed a owl:ObjectProperty ;
    rdfs:label "performs or performed"@en,
        "desarrolla o desarrollaba"@es,
        "exerce ou a exercé"@fr ;
    rdfs:comment """Inverse of 'is or was performed by' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Activity ;
    rdfs:subPropertyOf :isOrWasParticipantIn ;
    owl:inverseOf :isOrWasPerformedBy ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :performanceRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "performs")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new performanceRelation_role
               object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R060i ('performs or performed'
         relation)"""@en .

:physicalCharacteristicsNote a owl:DatatypeProperty ;
    rdfs:label "physical characteristics note"@en,
        "nota sobre las características físicas"@es,
        "note sur les caractéristiques physiques"@fr ;
    rdfs:comment """Information about the physical features, completeness, or
         conservation status of an Instantiation. Includes information about the physical nature and
         condition such as conservation status or the deterioration of an Instantiation (for example
         its carrier) affecting the ability to recover information. """@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :note ;
    skos:changeNote [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the IRI, mapping to RiC-CM
               (rico:RiCCMCorrespondingComponent), labels, description (rdfs:comment),
               skos:scopeNote, examples (skos:example)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-01-17" ;
            rdf:value """Made this property a subproperty of the new rico:note datatype
               property."""@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ] ;
    skos:example """A web page (HTML, 15 images, 2 CSS, 1 JavaScript), with 1 CSS
         missing."""@en,
        "British Library binding"@en,
        "Digital file format: JPEG-2000"@en,
        """For carrier: hard drives on which the author wrote physically
         (using a pen)."""@en,
        """Letter physical characteristics: corner without text missing – the
         carrier is damaged, but no information of the content is missing"""@en,
        "The charter is missing the seal."@en,
        "Watermarked"@en,
        "carrier heavily foxed"@en,
        "some loss of text due to rodent damage"@en ;
    skos:scopeNote """Not to be confused with the intellectual completeness of a
         Record Resource and its sub-entities, which is covered by the Integrity attribute. May
         include digital file fixity. """@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A31 (Physical Characteristics
         Note attribute)"""@en .

:positionIsContextOfLeadershipRelation a owl:ObjectProperty ;
    rdfs:label "position is context of leadership relation"@en,
        "puesto es contexto de relación de liderazgo"@es,
        "poste est le contexte de la relation de direction"@fr ;
    rdfs:comment """Connects a Position to a Leadership Relation (the leading Person
         occupies that Position)."""@en ;
    rdfs:domain :Position ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :LeadershipRelation ;
    rdfs:subPropertyOf :thingIsContextOfRelation ;
    owl:inverseOf :leadershipWithPosition ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:positionIsContextOfMembershipRelation a owl:ObjectProperty ;
    rdfs:label "position is context of membership relation"@en,
        "puesto es contexto de relación de membresía"@es,
        "poste est le contexte de la relation d'appartenance"@fr ;
    rdfs:comment """Connects a Position to a Membership Relation (the member Person
         occupies that Position)."""@en ;
    rdfs:domain :Position ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :MembershipRelation ;
    rdfs:subPropertyOf :thingIsContextOfRelation ;
    owl:inverseOf :membershipWithPosition ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:precededInSequence a owl:ObjectProperty ;
    rdfs:label "preceded in sequence"@en,
        "precedía secuencialmente a"@es,
        "a précédé dans la séquence"@fr ;
    rdfs:comment """Connects a Thing to a Thing that followed it in some sequence (not
         necessarily defined or characterised chronologically) in the past."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :precedesOrPreceded ;
    owl:inverseOf :followedInSequence ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past sequential relations between things (the current
               sequential relations being also added, including a transitive one)."""@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Tweaked the rdfs:comment to try to clarify what is
               meant."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value """Renamed the property and modified its definition (rdfs:comment)
               in order to better distinguish it from precedesInTime."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:proxyDirectlyFollowsProxyInSequence a owl:ObjectProperty ;
    rdfs:label "proxy directly follows proxy in sequence"@en,
        "proxy sigue directamente el proxy en la secuencia"@es,
        "proxy suit directement le proxy dans la séquence"@fr ;
    rdfs:comment """Inverse of 'proxy directly precedes proxy in sequence' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :directlyFollowsInSequence,
        :proxyFollowsProxyInSequenceTransitive ;
    owl:inverseOf :proxyDirectlyPrecedesProxyInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyDirectlyIncludes a owl:ObjectProperty ;
    rdfs:label "proxy directly includes"@en,
        "proxy incluye directamente"@es,
        "proxy inclut directement"@fr ;
    rdfs:comment """Inverse of 'is directly included in proxy' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hasDirectPart,
        :proxyIncludes ;
    owl:inverseOf :isDirectlyIncludedInProxy ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyDirectlyIncludesProxy a owl:ObjectProperty ;
    rdfs:label "proxy directly includes proxy"@en,
        "proxy incluye directamente el proxy"@es,
        "proxy inclut directement le proxy"@fr ;
    rdfs:comment """Inverse of 'proxy is directly included in' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasDirectPart,
        :proxyIncludesProxyTransitive ;
    owl:inverseOf :proxyIsDirectlyIncludedInProxy ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyDirectlyPrecedesInSequence a owl:ObjectProperty ;
    rdfs:label "proxy directly precedes in sequence"@en,
        "proxy precede directamente en la secuencia"@es,
        "proxy précède directement dans la séquence"@fr ;
    rdfs:comment """Connects a Proxy of a Record Resource to a Record Resource which
         it precedes directly in some sequence (not necessarily defined or characterised
         chronologically)."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :directlyPrecedesInSequence,
        :proxyPrecedesInSequence ;
    owl:inverseOf :directlyFollowsProxyInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyDirectlyPrecedesProxyInSequence a owl:ObjectProperty ;
    rdfs:label "proxy directly precedes proxy in sequence"@en,
        "proxy precede directamente el proxy en la secuencia"@es,
        "proxy précède directement le proxy dans la séquence"@fr ;
    rdfs:comment """Connects a Proxy of a Record Resource to a Proxy of another Record
         Resource that it precedes directly in some sequence (not necessarily defined or
         characterised chronologically)."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :directlyPrecedesInSequence,
        :proxyPrecedesProxyInSequenceTransitive ;
    owl:inverseOf :proxyDirectlyFollowsProxyInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-01" ;
            rdf:value """Added a second owl:subPropertyOf with target
               'proxyPrecedesProxyInSequenceTransitive'."""@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyHasDirectConstituent a owl:ObjectProperty ;
    rdfs:label "proxy has direct constituent"@en,
        "proxy tiene como directo elemento constitutivo"@es,
        "proxy a pour constituant direct"@fr ;
    rdfs:comment """Inverse of 'is direct constituent of proxy' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasDirectPart,
        :proxyHasConstituent ;
    owl:inverseOf :isDirectConstituentOfProxy ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyHasDirectConstituentProxy a owl:ObjectProperty ;
    rdfs:label "proxy has direct constituent proxy"@en,
        "proxy tiene como directo elemento constitutivo el proxy"@es,
        "proxy a pour constituant direct le proxy"@fr ;
    rdfs:comment """Inverse of 'proxy is direct constituent of' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasDirectPart,
        :proxyHasConstituentProxyTransitive ;
    owl:inverseOf :proxyIsDirectConstituentOfProxy ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:proxyInRecord a owl:ObjectProperty ;
    rdfs:label "proxy in record"@en,
        "proxy en el documento"@es,
        "proxy dans l’objet informationnel"@fr ;
    rdfs:comment """Connects a Proxy to a Record in which it stands for (represents) a
         Record Part or another Record."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Record ;
    rdfs:subPropertyOf :proxyIn ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyInRecordSet a owl:ObjectProperty ;
    rdfs:label "proxy in record set"@en,
        "proxy en la agrupación documental"@es,
        "proxy dans l’ensemble d’objets informationnels"@fr ;
    rdfs:comment """Connects a Proxy to a Record Set in which it stands for
         (represents) a Record or another Record Set."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :proxyIn ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyIsDirectConstituentOf a owl:ObjectProperty ;
    rdfs:label "proxy is direct constituent of"@en,
        "proxy es elemento constitutivo directo de"@es,
        "proxy est un constituant direct de"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Part to another Record or
         Record Part which the first is a direct constituent of."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isDirectPartOf,
        :proxyIsConstituentOf ;
    owl:inverseOf :hasDirectConstituentProxy ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value """Fixed the owl:inverseOf property (was hasConstituentProxy).
               Added the French and Spanish labels."""@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyIsDirectConstituentOfProxy a owl:ObjectProperty ;
    rdfs:label "proxy is direct constituent of proxy"@en,
        "proxy es elemento constitutivo directo del proxy"@es,
        "proxy est un constituant direct du proxy"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Part to a Proxy of another
         Record or Record Part of which the first is a direct constituent."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isDirectPartOf,
        :proxyIsConstituentOfProxyTransitive ;
    owl:inverseOf :proxyHasDirectConstituentProxy ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyIsDirectlyIncludedIn a owl:ObjectProperty ;
    rdfs:label "proxy is directly included in"@en,
        "proxy está directamente incluido en"@es,
        "proxy est directement inclus dans"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Set to another Record Set
         which the first is directly included in."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isDirectPartOf,
        :proxyIsIncludedIn ;
    owl:inverseOf :directlyIncludesProxy ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:proxyIsDirectlyIncludedInProxy a owl:ObjectProperty ;
    rdfs:label "proxy is directly included in proxy"@en,
        "proxy está directamente incluido en el proxy"@es,
        "proxy est directement inclus dans le proxy"@fr ;
    rdfs:comment """Connects a Proxy of a Record or Record Set to a Proxy of a Record
         Set which it is directly included in."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isDirectPartOf,
        :proxyIsIncludedInProxyTransitive ;
    owl:inverseOf :proxyDirectlyIncludesProxy ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:recordResourceHasSourceOfInformation a owl:ObjectProperty ;
    rdfs:label "Record Resource has source of information"@en,
        "recurso documental tiene como fuente de información"@es,
        """est une ressource archivistique qui a pour source
         d’information"""@fr ;
    rdfs:comment """Connects a Record Resource to a Record Resource, when the second
         one is used as a source of information for producing the content of the first
         one."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :isSourceOfInformationOfRecordResource ;
    skos:changeNote [ dc:date "2025-01-17" ;
            rdf:value """Object property added in RiC-O 1.1, with its inverse one. It
               replaces, as concerns Record Resources, the former 'hasSource' object property, that
               was available in RiC-0 0.1 and RiC-O 0.2, and was removed in RiC-O 1.0."""@en ] ;
    skos:scopeNote """Can be used, for example, to connect a Record that has
         documentary form type Authority Record or Finding Aid, and a Record Resource used as a
         source of information for it. Not to be confused with the 'hasGeneticLinkToRecordResource'
         object property."""@en .

:regulatesOrRegulated a owl:ObjectProperty ;
    rdfs:label "regulates or regulated"@en,
        "regula o regulaba"@es,
        "régule ou a régulé"@fr ;
    rdfs:comment """Connects a Rule to a Thing that it regulates or
         regulated."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRuleAssociatedWith ;
    owl:inverseOf :isOrWasRegulatedBy ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI (changed made in
               order to make RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1
               was "regulates")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R063 ('regulates or regulated'
         relation)"""@en .

:resultedFromTheMergerOf a owl:ObjectProperty ;
    rdfs:label "resulted from the merger of"@en,
        "resultado de la fusión de"@es,
        "résulte de la fusion de"@fr ;
    rdfs:comment "Inverse of 'was merged into' object property."@en ;
    rdfs:domain :CorporateBody ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorporateBody ;
    rdfs:subPropertyOf :isSuccessorOf ;
    owl:inverseOf :wasMergedInto ;
    skos:changeNote [ dc:date "2023-06-21" ;
            rdf:value """Object property created in order to enable an accurate
               representation of mergers between corporate bodies."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Make capitalisation of rdfs:comment consistent."@en ] .

:resultedFromTheSplitOf a owl:ObjectProperty ;
    rdfs:label "resulted from the split of"@en,
        "resultado de la separación de"@es,
        "résulte de la séparation de"@fr ;
    rdfs:comment "Inverse of 'was split into' object property."@en ;
    rdfs:domain :CorporateBody ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorporateBody ;
    rdfs:subPropertyOf :isSuccessorOf ;
    owl:inverseOf :wasSplitInto ;
    skos:changeNote [ dc:date "2023-06-21" ;
            rdf:value """Object property created in order to enable an accurate
               representation of the split of a corporate body into two or more new corporate
               bodies."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:roleIsContextOfCreationRelation a owl:ObjectProperty ;
    rdfs:label "role is context of creation relation"@en,
        "rol es contexto de relación de creación"@es,
        "rôle est le contexte de la relation de création"@fr ;
    rdfs:comment """Connects a Role Type to a Creation Relation (this Role Type being
         the specific role played by the creating Person in the context of this
         Relation)."""@en ;
    rdfs:domain :RoleType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CreationRelation ;
    rdfs:subPropertyOf :thingIsContextOfRelation ;
    owl:inverseOf :creationWithRole ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:ruleFollowed a owl:DatatypeProperty ;
    rdfs:label "rule followed"@en,
        "regla aplicada"@es,
        "règle suivie"@fr ;
    rdfs:comment """The rule or conditions that govern the existence or lifecycle of a
         Thing."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use the Rule class for handling rules."""@en .

:scopeAndContent a owl:DatatypeProperty ;
    rdfs:label "scope and content"@en,
        "alcance y contenido"@es,
        "portée et contenu"@fr ;
    rdfs:comment """Summary of the scope (such as time periods, geography) and content
         (such as subject matter, administrative processes) of a Record Resource. Provides a more
         complete summary of the informational content of the Record Resource highlighting the
         information conveyed in the Record Resource, why it was created, received, and/or
         maintained, and the agents connected to it. It may include description of relations with
         agents, activities, dates and places, or with other record resources."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :generalDescription ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, rdfs:subpropertyOf, examples
               (skos:example)."""@en ] ;
    skos:example "Among the witnesses, the Duke of Normandy."@en,
        """Includes a detailed list of the lands and villages given by the
         King to the Abbey."""@en,
        """Letter from Vlad the Impaler (Dracula) to the Council of Kronstadt
         asking them to send military support against the Ottomans, within the framework of their
         alliance treaty."""@en,
        """The author explains why he does not agree with the decision made
         and adds that it cannot be applied."""@en,
        """Se hace referencia a construcción del Gran Hotel, iniciada en 1899
         bajo el nombre de Casa Celestino. Tras su interrupción en 1902, continuó la obra ya con su
         nombre actual."""@es ;
    skos:scopeNote """Scope and content is a specialization of general description.
         For a Record Set, may be used to summarize the scope and content of the Record Set itself,
         or additionally to summarize the scope and content of some or all members of the Record
         Set. It is not to be confused with the history dataytpe property which focuses on the
         origination and subsequent changes to a Record Resource. """@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A38 (Scope and Content
         attribute)"""@en .

:someMembersWithAccumulationDate a owl:DatatypeProperty ;
    rdfs:label "some members with accumulation date"@en,
        "algunos de sus miembros como fecha de acumulación"@es,
        "des membres ayant pour date d’accumulation"@fr ;
    rdfs:comment """Date at which some of the present or past members of a Record Set
         were or will be accumulated."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadSomeMembersWithAccumulationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en .

:someMembersWithCreationDate a owl:DatatypeProperty ;
    rdfs:label "some members with creation date"@en,
        "algunos de sus miembros como fecha de creación"@es,
        "des membres ayant pour date de création"@fr ;
    rdfs:comment """Date at which some of the present or past members of a Record Set
         were or will be created."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :beginningDate ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] ;
    skos:scopeNote """Datatype property analogue of
         'hasOrHadSomeMembersWithCreationDate', which is provided for usability reasons. May be
         deprecated and removed later on. Use only if you don’t use Date classes for handling
         dates."""@en ;
    :RiCCMCorrespondingComponent """RiC-R082i ('has or had some members with creation
         date' relation)."""@en .

:studiesOrStudiedAt a owl:ObjectProperty ;
    rdfs:label "studies or studied at"@en,
        "estudia o estudió en"@es,
        "étudie ou a étudié à"@fr ;
    rdfs:comment """Connects a Person to an educational institution at which they
         studied or study. Both 'institution' and 'at' can be interpreted broadly."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isOrWasMemberOf ;
    owl:inverseOf :isOrWasAttendedByStudent ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :studyAtRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2024-12-23" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:wasComponentOf a owl:ObjectProperty ;
    rdfs:label "was component of"@en,
        "era componente de"@es,
        "a été le composant de"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation of which it was
         a component in the past."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isOrWasComponentOf,
        :wasPartOf ;
    owl:inverseOf :hadComponent ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between instantiations (the
               current partitive relations being also added, including a transitive
               one)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:wasConstituentOf a owl:ObjectProperty ;
    rdfs:label "was constituent of"@en,
        "era elemento constitutivo de"@es,
        "a été un constituant de"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         of which it was a constituent in the past."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasConstituentOf,
        :wasPartOf ;
    owl:inverseOf :hadConstituent ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the range."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between Record and Record or
               Record Part (the current partitive relations being also added, including a transitive
               one)."""@en ] .

:wasContainedBy a owl:ObjectProperty ;
    rdfs:label "was contained by"@en,
        "estaba contenido en"@es,
        "a été contenu par"@fr ;
    rdfs:comment """Connects a Place to a Place within which it was
         contained."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isOrWasContainedBy,
        :wasPartOf ;
    owl:inverseOf :contained ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between places (the current
               partitive relations being also added, including a transitive one)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:wasIncludedIn a owl:ObjectProperty ;
    rdfs:label "was included in"@en,
        "estaba incluido en"@es,
        "a été inclus dans"@fr ;
    rdfs:comment """Connects a Record to a Record or Record Set in which it was
         included in the past."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasIncludedIn,
        :wasPartOf ;
    owl:inverseOf :included ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between Record Sets and their
               members (the current partitive relations being also added, including a transitive
               one)."""@en ] .

:wasLastUpdatedAtDate a owl:ObjectProperty ;
    rdfs:label "was last updated at date"@en,
        "fue actualizado por última vez en fecha"@es,
        "a pour date de dernière mise à jour"@fr ;
    rdfs:comment """Connects a Thing to the Date when it was last
         modified."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasModificationDate ;
    owl:inverseOf :isLastUpdateDateOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:wasMergedInto a owl:ObjectProperty ;
    rdfs:label "was merged into"@en,
        "se fusionó en"@es,
        "a été fusionné dans"@fr ;
    rdfs:comment """Connects a Corporate Body to another Corporate Body that is the
         result of a merger of the previous one with one to many other corporate
         bodies."""@en ;
    rdfs:domain :CorporateBody ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorporateBody ;
    rdfs:subPropertyOf :hasSuccessor ;
    owl:inverseOf :resultedFromTheMergerOf ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-06-21" ;
            rdf:value """Object property created in order to enable an accurate
               representation of mergers between corporate bodies."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:wasSplitInto a owl:ObjectProperty ;
    rdfs:label "was split into"@en,
        "se separó en"@es,
        "a été séparé en"@fr ;
    rdfs:comment """Connects a Corporate Body to one of the Corporate Bodies that
         results from the split of the previous one into two to many corporate
         bodies."""@en ;
    rdfs:domain :CorporateBody ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorporateBody ;
    rdfs:subPropertyOf :hasSuccessor ;
    owl:inverseOf :resultedFromTheSplitOf ;
    skos:changeNote [ dc:date "2023-06-21" ;
            rdf:value """Object property created in order to enable an accurate
               representation of the split of a corporate body into two or more new corporate
               bodies."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:wasSubdivisionOf a owl:ObjectProperty ;
    rdfs:label "was subdivision of"@en,
        "era subdivisión de"@es,
        "a été une subdivision de"@fr ;
    rdfs:comment """Connects a subdivision to the Group it was a part of in the
         past."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isOrWasSubdivisionOf,
        :wasPartOf,
        :wasSubordinateTo ;
    owl:inverseOf :hadSubdivision ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past partitive relations between Groups (the current
               partitive relations being also added, including a transitive one)."""@en ] .

:wasSubeventOf a owl:ObjectProperty ;
    rdfs:label "was subevent of"@en,
        "era parte de evento de"@es,
        "a été un événement constitutif de l'événement"@fr ;
    rdfs:comment """Connects a past Event to the broader Event of which it was a
         part."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isOrWasSubeventOf,
        :wasPartOf ;
    owl:inverseOf :hadSubevent ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express partitive relations between past Events (the partitive
               relations between ongoing events being also added, including a transitive
               one)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:wasUsedFromDate a owl:ObjectProperty ;
    rdfs:label "was used from date"@en,
        "fue usado desde"@es,
        "a été utilisé à partir de la date"@fr ;
    rdfs:comment """Connects an Appellation to the Date from which it was
         used."""@en ;
    rdfs:domain :Appellation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasBeginningDate ;
    owl:inverseOf :isFromUseDateOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Made this property subPropertyOf hasBeginningDate."@en ] .

:wasUsedToDate a owl:ObjectProperty ;
    rdfs:label "was used to date"@en,
        "fue usado hasta"@es,
        "a été utilisé jusqu’à la date"@fr ;
    rdfs:comment """Connects an Appellation to the Date till when it was
         used."""@en ;
    rdfs:domain :Appellation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasEndDate ;
    owl:inverseOf :isToUseDateOf ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Made this property subPropertyOf hasEndDate."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

ric-dft:AuthorityRecord a owl:NamedIndividual,
        skos:Concept,
        :DocumentaryFormType ;
    rdfs:label "authority record"@en,
        "registro de autoridad"@es,
        "notice d’autorité"@fr ;
    skos:changeNote [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:definition """This category can be used for records that describe an
         entity."""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> .

ric-dft:IIIFManifest a owl:NamedIndividual,
        skos:Concept,
        :DocumentaryFormType ;
    rdfs:label "IIIF manifest"@en,
        "manifeste IIIF"@fr ;
    skos:broader ric-dft:FindingAid ;
    skos:changeNote [ dc:date "2025-01-30" ;
            rdf:value "Added to RiC-O 1.1."@en ] ;
    skos:definition """Can be used to categorize records which describe collections of
         cultural heritage objects, or of a single cultural object, and whose instantiations are
         compliant to the IIIF Presentation API."""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> .

ric-rst:Collection a owl:NamedIndividual,
        skos:Concept,
        :RecordSetType ;
    rdfs:label "collection"@en,
        "colección"@es,
        "collection"@fr ;
    skos:changeNote [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:definition """An artificial assemblage of documents accumulated on the basis
         of some common characteristic without regard to the provenance of those documents. Not to
         be confused with an archival fonds. (From ICA ISAD(G))"""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> .

ric-rst:File a owl:NamedIndividual,
        skos:Concept,
        :RecordSetType ;
    rdfs:label "file"@en,
        "expediente"@es,
        "dossier"@fr ;
    skos:changeNote [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:definition """An organized unit of documents grouped together either for
         current use by the creator or in the process of archival arrangement, because they relate
         to the same subject, activity, or transaction. A file is usually the basic unit within a
         record series. (From ICA ISAD(G))"""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> .

ric-rst:Fonds a owl:NamedIndividual,
        skos:Concept,
        :RecordSetType ;
    rdfs:label "fonds"@en,
        "fondo"@es,
        "fonds"@fr ;
    skos:changeNote [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:definition """The whole of the records, regardless of form or medium,
         organically created and/or accumulated and used by a particular person, family, or
         corporate body in the course of that creator's activities and functions. (From ICA
         ISAD(G))"""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> .

ric-rst:Series a owl:NamedIndividual,
        skos:Concept,
        :RecordSetType ;
    rdfs:label "series"@en,
        "serie"@es,
        "série organique"@fr ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:definition """Documents arranged in accordance with a filing system or
         maintained as a unit because they result from the same accumulation or filing process, or
         the same activity; have a particular form; or because of some other relationship arising
         out of their creation, receipt, or use. A series is also known as a records series. (From
         ICA ISAD(G))"""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/recordSetTypes> .

skos:ConceptScheme a owl:Class ;
    rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> .

:AccumulationRelation a owl:Class ;
    rdfs:label "Recordressource/Instanz-Akteur-Bestandsbildung"@de,
        "Accumulation Relation"@en,
        "Relación de acumulación"@es,
        "Relation d’accumulation"@fr ;
    rdfs:comment """Connects at least one Record Resource or Instantiation to at least
         one Agent, when the Record Resource or Instantiation is or was accumulated by the Agent, be
         it intentionally (collecting it) or not (receiving it in the course of its activities). The
         Record Resource(s) or Instantiation(s) is the source of the Relation, and the Agent(s) is
         the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        :OrganicProvenanceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :accumulationRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R028 and RiC-R028i
         relations"""@en .

:ActivityDocumentationRelation a owl:Class ;
    rdfs:label "Recordressource/Instanz-Aktivität"@de,
        "Activity Documentation Relation"@en,
        "Relación de procedencia funcional"@es,
        "Relation entre activités et ressources archivistiques"@fr ;
    rdfs:comment """Connects at least one Record Resource or Instantiation to at least
         one Activity, when the Record Resource or Instantiation results from the Activity. The
         Record Resource(s) or Instantiation(s) is the source of the Relation, and the
         Activity(-ies) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Activity ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasSource ],
        :EventRelation,
        :OrganicOrFunctionalProvenanceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :activityDocumentationRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value "Made this relation a subclass of EventRelation."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Aligned with RiC-CM 1.0: updated the ."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R033 and RiC-R033
         relations"""@en .

:AgentName a owl:Class ;
    rdfs:label "Akteursname"@de,
        "Agent Name"@en,
        "Nombre de Agente"@es,
        "Nom d’agent"@fr ;
    rdfs:comment """A label, title or term designating an Agent in order to make it
         distinguishable from other similar entities."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Name ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of a specialization of RiC-A28
         (Name attribute)"""@en .

:AppellationRelation a owl:Class ;
    rdfs:label "Bezeichnung-Ding"@de,
        "Appellation Relation"@en,
        "Relación de denominación"@es,
        "Relation d’appellation"@fr ;
    rdfs:comment """Connects an Appellation and at least one Thing that the
         Appellation designates or designated. The Appellation is the source of the Relation and the
         Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:onClass :Appellation ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :appellationRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:AuthorshipRelation a owl:Class ;
    rdfs:label "Record-Autor-Akteur"@de,
        "Authorship Relation"@en,
        "Relación de autoría"@es,
        "Relation de responsabilité intellectuelle"@fr ;
    rdfs:comment """Connects at least one Record to at least one Person, Group or
         Position that is or was responsible for conceiving and formulating the information
         contained in the Record. The Record is the source of the Relation and the Person(s),
         Group(s) or Position(s) is the target. """@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Record ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Group :Person :Position ) ] ;
            owl:onProperty :relationHasTarget ],
        :CreationRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :authorshipRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-12-29" ;
            rdf:value """Created following the addition of RiC-R079 relation in RiC-CM
               0.2"""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """To be used for a person, group or position that makes any
         contribution to the content of a record. Includes the person, group or position in whose
         name or by whose command the content may have been formulated and first instantiated (for
         example the person who signed the record). """@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R079 and RiC-R079i
         relations"""@en .

:CarrierType a owl:Class ;
    rdfs:label "Datenträgerkategorie"@de,
        "Carrier Type"@en,
        "Tipo de soporte"@es,
        "Type de support"@fr ;
    rdfs:comment """Categorization of physical material on which information is
         represented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Scope note: updated (quite the same as RiC-CM definition).
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """In order to manage an instantiation of a record resource, it is
         necessary to note the type of carrier on which the record resource is instantiated as its
         nature will determine the environmental storage conditions and the prerequisites for and
         possible ways of accessing and using the record resource."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A05 (Carrier Type
         attribute)"""@en .

:ChildRelation a owl:Class ;
    rdfs:label "Person-Kind"@de,
        "Child Relation"@en,
        "Relación de filiación"@es,
        "Relation de filiation"@fr ;
    rdfs:comment """Connects at least one Person to at least another Person, when the
         first has(ave) child(s) the second one(s). The Relation is oriented from the parent to the
         child: the parent is the source of the relation, and the child(ren) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        :DescendanceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :childRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R018 and RiC-R018i
         relations"""@en .

:CorporateBodyType a owl:Class ;
    rdfs:label "Körperschaftskategorie"@de,
        "Corporate Body Type"@en,
        "Tipo de institución"@es,
        "Type de collectivité"@fr ;
    rdfs:comment "Categorization of a Corporate Body."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A12 (Corporate Body Type
         attribute)"""@en .

:CorrespondenceRelation a owl:Class ;
    rdfs:label "Person-Korrespondenz-Person"@de,
        "Correspondence Relation"@en,
        "Relación entre personas por correspondencia"@es,
        "Relation épistolaire"@fr ;
    rdfs:comment """Connects at least two Persons, when they correspond or
         corresponded to each other. This Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationConnects ],
        :KnowingRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :correspondenceRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R052 and Ri052i
         relations"""@en .

:DateType a owl:Class ;
    rdfs:label "Datumskategorie"@de,
        "Date Type"@en,
        "Tipo de fecha"@es,
        "Type de date"@fr ;
    rdfs:comment "Categorization of a Date."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote. Added a label in Spanish."""@en ],
        [ dc:date "2023-10-10" ;
            rdf:value """Added the rdfs:comment, a French rdfs:label, and adjusted the
               rico:RiCCMCorrespondingComponent annotation."""@en ] ;
    skos:scopeNote """May be used to categorize a Date as a single date, a date range
         or a date set or sub-categories of these broad types. This attribute should not be confused
         with the date relations defined to connect a Date entity and any other entity (such as
         RiC-R069 ‘is beginning date of’)."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A42 (Date Type attribute) (new
         in RiC-CM 1.0)."""@en .

:EventType a owl:Class ;
    rdfs:label "Ereigniskategorie"@de,
        "Event Type"@en,
        "Tipo de evento"@es,
        "Type d’événement"@fr ;
    rdfs:comment "Categorization of an Event."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Scope note: updated and made several paragraphs. Objective: to
               make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ] ;
    skos:scopeNote """Events of all kinds can be categorized. Curation event types
         include creation; acquisition; transfer; arrangement; description; digitization, etc.
         Biographical event types include birth, marriage, death, etc."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A18 (Event Type
         attribute)"""@en .

:ExtentType a owl:Class ;
    rdfs:label "Umfangskategorie"@de,
        "Extent Type"@en,
        "Tipo de Extensión"@es,
        "Type de mesure"@fr ;
    rdfs:comment """Categorization of the extent that is being
         measured."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Added to specify the dimension that is being
               measured"""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added an xml:lang attribute to the rdfs:comment."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:Family a owl:Class ;
    rdfs:label "Familie"@de,
        "Family"@en,
        "Familia"@es,
        "Famille"@fr ;
    rdfs:comment """Two or more persons related by birth, or through marriage,
         adoption, civil union, or other social conventions that bind them together as a socially
         recognized familial group."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Group ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Scope note: made separate paragraphs and some
               changes."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Family is a kind of Group. “Family” is used here as a general
         term that encompasses a wide variety of familial groups. Other types of familial groups
         include Dynasty, Clan, House, Tribe and others. Though family may be a recognized legal
         group in specific contexts, the term may also be used for groups that are socially
         recognized as families. A family may be a group of persons related either by consanguinity
         or affinity or cohabitation or other social conventions. In some context, a Family may be
         legally recognized as Corporate Body. For example, certain North American peoples (tribes)
         retain self-government rights and have jurisdiction over defined tribal
         lands."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E10 (Family
         entity)"""@en .

:FamilyType a owl:Class ;
    rdfs:label "Familienkategorie"@de,
        "Family Type"@en,
        "Tipo de familia"@es,
        "Type de famille"@fr ;
    rdfs:comment "Categorization of a Family."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value "Comment: slighty changed."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Encompasses a wide variety of familial groups related by
         consanguinity, affinity, cohabitation, or other social conventions."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A20 (Family Type
         attribute)"""@en .

:FunctionalEquivalenceRelation a owl:Class ;
    rdfs:label "Repräsentation-Äquivalent-Repräsentation"@de,
        "Functional Equivalence Relation"@en,
        "Relación de equivalencia funcional"@es,
        "Relation d’équivalence fonctionnelle"@fr ;
    rdfs:comment """Connects at least two Instantiations which may be considered as
         equivalent. This Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationConnects ],
        :InstantiationToInstantiationRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :functionalEquivalenceRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """Two instantiations, from some point of view, may be considered
         as equivalent. This equivalence is usually based upon the fact that the instantiations have
         at least the same intellectual content (they instantiate the same record
         resource)."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R035 and RiC-R035i
         relations"""@en .

:GroupSubdivisionRelation a owl:Class ;
    rdfs:label "Gruppe-Untergruppe"@de,
        "Group Subdivision Relation"@en,
        "Relación de subdivisión entre grupos de agentes"@es,
        "Relation de subdivision entre groupes d’agents"@fr ;
    rdfs:comment """Connects a Group and at least another Group, when the first one
         has or had the second one(s) among its subdivisions. The Relation is oriented from the
         Group to its subdivision(s): the parent Group is the source and the subdivision Group(s) is
         the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Group ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:onClass :Group ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :AgentHierarchicalRelation,
        :WholePartRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :groupSubdivisionRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R005 and RiC-R005i
         relations"""@en .

:IdentifierType a owl:Class ;
    rdfs:label "Identifikatorenkategorie"@de,
        "Identifier Type"@en,
        "Tipo de identificador"@es,
        "Type d’identifiant"@fr ;
    rdfs:comment "Categorization of an Identifier."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2020-10-19" ;
            rdf:value """Class added along with hasIdentifierType and isIdentifierTypeOf
               object properties."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """For example, 'old identifier' ; 'ISNI' (for a person or
         corporate body), etc."""@en .

:IntellectualPropertyRightsRelation a owl:Class ;
    rdfs:label "Akteur-Urheberschaft-Recordressource/Instanz"@de,
        "Intellectual Property Rights Relation"@en,
        "Relación de propiedad intelectual"@es,
        "Relation de propriété intellectuelle"@fr ;
    rdfs:comment """Connects at least one Agent and one Record Resource or
         Instantiation on which the Agent has or had some intellectual property rights. The Agent(s)
         is the source of the Relation and the Record Resource(s) or Instantiation(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Group :Person :Position ) ] ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasTarget ],
        :AuthorityRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :intellectualPropertyRightsRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """Can be used, when the record resource is a work, for specifying
         the connection between the record resource and its author(s)."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R040 and RiC-R040i
         relations"""@en .

:KnowingOfRelation a owl:Class ;
    rdfs:label "Person-Kenntnis-Person"@de,
        "Knowing Of Relation"@en,
        "Relación de conocimieto indirecto entre personas"@es,
        "Relation de connaissance à propos d’une personne"@fr ;
    rdfs:comment """Connects at least one Person to at least another one, when the
         first one has some knowledge of the second one through time or space. The first Person is
         the source of the Relation, and the second one is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :knowingOfRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R050 and RiC-R050i
         relations"""@en .

:MandateType a owl:Class ;
    rdfs:label "Mandatkategorie"@de,
        "Mandate Type"@en,
        "Tipo de norma"@es,
        "Type de mandat"@fr ;
    rdfs:comment "Categorization of a Mandate."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :RuleType ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Added in RiC-0 1.0 as it has been added to RiC-CM
               1.0."""@en ] ;
    skos:scopeNote """For example : charter, treaty, contract, letter of appointment,
         papal mandate, episcopal mandate, ciurt mandate, election mandate, popular mandate, federal
         mandate, etc."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A44 (Mandate Type
         attribute)."""@en .

:Mechanism a owl:Class ;
    rdfs:label "Mechanismus"@de,
        "Mechanism"@en,
        "Mecanismo"@es,
        "Système"@fr ;
    rdfs:comment """A process or system created by a Person or Group that performs an
         Activity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Agent ;
    owl:disjointWith :Person,
        :Position ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """scope note: made separate paragraphs. Disjoint with:
               enriched."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Mechanism is a kind of Agent. A mechanism may have both
         mechanical and software components or may be exclusively software. A mechanism acts in the
         world producing physical or social effects and may generate or modify records. A mechanism
         performs activities based on rules determined by the agent that designed and created it. A
         mechanism has an essential, derivative relation with the designing and creating
         agent."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-E13 (Mechanism
         entity)"""@en .

:MigrationRelation a owl:Class ;
    rdfs:label "Repräsentation-Migration-Repräsentation"@de,
        "Migration Relation"@en,
        "Relación de migración entre instanciaciones"@es,
        "Relation de migration"@fr ;
    rdfs:comment """Connects an Instantiation and at least another Instantiation it
         has been migrated into. The Relation is oriented chronologically, from the first
         Instantiation in time (the migrated one) to the one which results from its migration: the
         first Instantiation in time is the source of the Relation, and the resulting Instantiation
         is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :DerivationRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :migrationRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote "Use for digital instantiations."@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R015 and RiC-R015i
         relations"""@en .

:OccupationType a owl:Class ;
    rdfs:label "Beschäftigungskategorie"@de,
        "Occupation Type"@en,
        "Tipo de ocupación"@es,
        "Type d’occupation"@fr ;
    rdfs:comment """Categorization of a profession, trade, or craft pursued by a
         Person in fulfilment of an Activity."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :ActivityType,
        :DemographicGroup ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value "scope note: added."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """The pursuit of an occupation involves the performance of an
         Activity. Successful performance of the Activity is based on the ability to perform related
         competencies successfully. Such competencies may be acquired through education or
         experience, or a combination of both. The authority of the Person to pursue the occupation
         may be derived tacitly or explicitly from an external Agent, based on a demonstrated
         mastery of the competency. An occupation may be pursued independently by a Person or a
         Group, thereby contributing to the fulfilment of the function (activity) of the group.
         Should not be confused with Position where, for example, an agent with the occupation type
         "lawyer" holds the position of "legal counsel" in an agency. Related to but should not be
         confused with the domain or field of activity, such as an archivist who works in the domain
         of archival science."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A30 (Occupation Type
         attribute)"""@en .

:OwnershipRelation a owl:Class ;
    rdfs:label "Gruppe/Person/Position-Besitz-Ding"@de,
        "Ownership Relation"@en,
        "Relación de posesión"@es,
        "Relation de propriété"@fr ;
    rdfs:comment """Connects at least one Group, Person or Position and at least a
         Thing that these Agent(s) own(s) or owned. The Group(s), Person(s) or Position(s) is the
         source of the Relation, and the Agent(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Group :Person :Position ) ] ;
            owl:onProperty :relationHasSource ],
        :AuthorityRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :ownershipRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Among other probably more rare use cases for archival
         description, can be used between agents (a person owns a corporate body, a corporate body
         owns a mechanism), or between agents and record resources."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R037 and RiC-R037i
         relations"""@en .

:PerformanceRelation a owl:Class ;
    rdfs:label "Aktivität-Ausführung-Akteur"@de,
        "Performance Relation"@en,
        "Relación de desarrollo funcional"@es,
        "Relation entre activités et agents"@fr ;
    rdfs:comment """Connects at least one Activity to at least one Agent that performs
         or performed the activity. The Activity(-ies) is the source of the Relation and the
         Agent(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Activity ;
            owl:onProperty :relationHasSource ],
        :EventRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :performanceRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R060 and RiC-R060i
         relations"""@en .

:PlaceName a owl:Class ;
    rdfs:label "Geografikumsname"@de,
        "Place Name"@en,
        "Nombre de lugar"@es,
        "Nom de lieu"@fr ;
    rdfs:comment """A label, title or term designating a Place in order to make it
         distinguishable from other similar entities."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Name ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of a specialization of RiC-A28
         (Name attribute)"""@en .

:PlaceRelation a owl:Class ;
    rdfs:label "Geografikum-Ding"@de,
        "Place Relation"@en,
        "Relación con lugar"@es,
        "Relation impliquant un lieu"@fr ;
    rdfs:comment """Connects a Place and at least one Thing when the first is
         associated with the existence and lifecycle of the second one. The Place is the source of
         the Relation and the Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :Place ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :placeRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R074 and RiC-R074i
         relations"""@en .

:PlaceType a owl:Class ;
    rdfs:label "Geografikumskategorie"@de,
        "Place Type"@en,
        "Tipo de lugar"@es,
        "Type de lieu"@fr ;
    rdfs:comment "Categorization of a Place."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ] ;
    skos:scopeNote """Broadly, a Place may be a member of three broad categories:
         jurisdiction, manmade structure, or a natural feature. Each of these three categories can
         subdivided into narrower categories."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A32 (Place Type
         attribute)"""@en .

:PositionHoldingRelation a owl:Class ;
    rdfs:label "Person-Position"@de,
        "Position Holding Relation"@en,
        "Relación de ocupación entre una persona y un puesto"@es,
        "Relation entre une personne et un poste"@fr ;
    rdfs:comment """Connects at least one Person and at least one Position that the
         Person(s) occupies or occupied. The Person is the source of the Relation and the Position
         is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Position ;
            owl:onProperty :relationHasTarget ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :positionHoldingRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R054 and RiC-R054i
         relations"""@en .

:PositionToGroupRelation a owl:Class ;
    rdfs:label "Position-Gruppe"@de,
        "Position to Group Relation"@en,
        "Relación de ocupación entre un grupo y un puesto"@es,
        "Relation entre un poste et un groupe"@fr ;
    rdfs:comment """Connects at least one Position and a Group in which the
         position(s) exist(s) or existed, or that is (are) defined by that group's organizational
         structure. The Position(s) is the source of the Relation and the Group is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :Group ;
            owl:onProperty :relationHasTarget ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Position ;
            owl:onProperty :relationHasSource ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :positionToGroupRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R056 and RiC-R056i
         relations"""@en .

:ProductionTechniqueType a owl:Class ;
    rdfs:label "Herstellungstechnikkategorie"@de,
        "Production Technique Type"@en,
        "Tipo de técnica de producción"@es,
        "Type de technique de production"@fr ;
    rdfs:comment """The method used in the representation of information on an
         instantiation."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Objective: to make RiC-O compliant with
               RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-A33 (Production
         Technique attribute)"""@en .

:RecordResourceGeneticRelation a owl:Class ;
    rdfs:label "Recordressource-Entstehungszusammenhang-Recordressource"@de,
        "Record Resource Genetic Relation"@en,
        "Relación genética entre recursos documentales"@es,
        "Relation génétique entre des ressources archivistiques"@fr ;
    rdfs:comment """Connects two or more record resources when there is a genetic link
         between them. Genetic in this sense is as defined by diplomatics, i.e., the process by
         which a record resource is developed. This Relation is a generic, not oriented
         one."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :RecordResource ;
            owl:onProperty :relationConnects ],
        :RecordResourceToRecordResourceRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :recordResourceGeneticRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R023 and RiC-023i
         relations"""@en .

:RecordResourceHoldingRelation a owl:Class ;
    rdfs:label "Akteur-Aufbewahrung-Recordressource/Instanz"@de,
        "Record Resource Holding Relation"@en,
        """Relación entre agentes y recursos documentales que
         conservan"""@es,
        """Relation entre agents et ressources archivistiques ou instanciations
         conservées"""@fr ;
    rdfs:comment """Connects at least one Agent and one or more Record Resource or
         Instantiation that the Agent(s) hold(s) or held. The Agent(s) is the source of the Relation
         and the Record Resource(s) or Instantiation is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        :ManagementRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :recordResourceHoldingRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-12-30" ;
            rdf:value "Fixed a typo in the French label."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R039 and RiC-039i
         relations"""@en .

:RecordResourceToInstantiationRelation a owl:Class ;
    rdfs:label "Recordressource-Repräsentation"@de,
        "Record Resource to Instantiation Relation"@en,
        "Relación de recurso documental a instanciación"@es,
        "Relation d’instanciation"@fr ;
    rdfs:comment """Connects a Record Resource to one or more Instantiations that
         instantiate it, and which either may exist or may have been lost or destroyed. The Record
         Resource is the source of the Relation and the Instantiation(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :RecordResource ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :recordResourceToInstantiationRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ] ;
    skos:scopeNote """In some situations, it may be useful or necessary to connect a
         record resource to an instantiation that no longer exists or has been lost, when some of
         its characteristics are known from a source, such as an old finding aid."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R025 and RiC-R025i
         relations"""@en .

:RepresentationType a owl:Class ;
    rdfs:label "Repräsentationskategorie"@de,
        "Representation Type"@en,
        "Tipo de grabación"@es,
        "Type de représentation"@fr ;
    rdfs:comment """Method of recording the content type of an
         Instantiation"""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Comment and scope note: updated. Objective: to make RiC-O
               compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Can be unmediated (which allows humans to receive the message
         communicated without an intermediation of a device) and mediated (which needs a device to
         decode the message). A lot of contemporary mediated types are digital. Each representation
         type may present specific features: bit rate for audio, resolution for digital images,
         encoding format for video etc. Depending on the type, specific attributes may be added to
         describe their characteristics."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A37 (Representation Type
         attribute)"""@en .

:RoleType a owl:Class ;
    rdfs:label "Rollenkategorie"@de,
        "Role Type"@en,
        "Tipo de rol"@es,
        "Type de rôle"@fr ;
    rdfs:comment """The role an Agent plays in some context (usually in some creation
         relation). Not to be confused with a Position (position of an agent in some group). For
         example, a Person who is the head of some Corporate Body may play the role of annotator (of
         a record) in a creation relation."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:SiblingRelation a owl:Class ;
    rdfs:label "Person-Geschwister"@de,
        "Sibling Relation"@en,
        "Relación familiar entre hermanos"@es,
        "Relation de fratrie"@fr ;
    rdfs:comment """Connects at least two Persons, when they are siblings. This
         Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationConnects ],
        :FamilyRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :siblingRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R048 and RiC-R048i
         relations"""@en .

:SpouseRelation a owl:Class ;
    rdfs:label "Person-Ehepartner"@de,
        "Spouse Relation"@en,
        "Relación matrimonial entre personas"@es,
        "Relation matrimoniale"@fr ;
    rdfs:comment """Connects at least two Persons, when they are spouses. This
         Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationConnects ],
        :FamilyRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :spouseRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R049 and RiC-R049i
         relations"""@en .

:StudyAtRelation a owl:Class ;
    rdfs:label "Studium-An-Beziehung"@de,
        "Study At Relation"@en,
        "Relación entre institución educativa y estudiantes"@es,
        "Relation entre institution d’enseignement et étudiants"@fr ;
    rdfs:comment """Connects a Group (as an educational institution) to at least one
         Person who studied or study at this group. Both 'institution' and 'at' can be interpreted
         broadly. The Relation is oriented from the educational institution to the student(s): the
         former is the source of the Relation, and the latter is/are the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:onClass :Group ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :MembershipRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :studyAtRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2024-12-23" ;
            rdf:value """Fixed details in the definition. Added the French and Spanish
               labels."""@en ] .

:TeachingRelation a owl:Class ;
    rdfs:label "Person-Student"@de,
        "Teaching Relation"@en,
        "Relación académica entre profesor y alumno"@es,
        "Relation entre enseignants et étudiants"@fr ;
    rdfs:comment """Connects at least one Person to at least another Person who is or
         was their student. The Relation is oriented from the teacher(s) to the student(s): the
         teacher Person(s) is the source of the Relation, and the student Person(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        :KnowingRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :teachingRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R053 and RiC-R053i
         relations"""@en .

:TitleType a owl:Class ;
    rdfs:label "Titelkategorie"@de,
        "Title Type"@en,
        "Tipo de título"@es,
        "Type de titre"@fr ;
    rdfs:comment "Categorization of a Title."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2024-10-04" ;
            rdf:value """Class added along with hasTitleType and isTitleTypeOf object
               properties."""@en ] ;
    skos:scopeNote """For example, 'obsolete title' ; 'title on the original' ;
         'anonimised title'"""@en .

:TypeRelation a owl:Class ;
    rdfs:label "Kategorie-Ding"@de,
        "Type Relation"@en,
        "Tipo de relación"@es,
        "Relation de catégorisation"@fr ;
    rdfs:comment """Connects a category (a Type) and at least one Thing that belongs
         to this category. The Type(s) is the source of the Relation, and the Thing(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :Type ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :typeRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """May be useful at least for some types (e.g. demographic
         group)"""@en .

:UnitOfMeasurement a owl:Class ;
    rdfs:label "Masseinheit"@de,
        "Unit Of Measurement"@en,
        "Unidad de medida"@es,
        "Unité de mesure"@fr ;
    rdfs:comment """A definite magnitude of a quantity, defined and adopted by
         convention or by law, that is used as a standard for measurement of the same kind of
         quantity. Can be spacial units (cm, m), weight (g, kg), time (s, h), storage (MB, TB) or
         more informal units used in the archival context like number of boxes, pages or
         words."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Concept ;
    skos:changeNote [ dc:date "2020-10-28" ;
            rdf:value """Class added in order to be able to handle units of measurement
               as full entities."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added an xml:lang attribute to the rdfs:comment."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] .

:WorkRelation a owl:Class ;
    rdfs:label "Akteur-Arbeit-Akteur"@de,
        "Work Relation"@en,
        "Relación profesional"@es,
        "Relation de travail"@fr ;
    rdfs:comment """Connects at least two Agents that have or had some type of work
         relation in the course of their activities. This Relation is not oriented."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationConnects ],
        :AgentToAgentRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :workRelation_role ] ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R046 and RiR046i
         relations"""@en .

:asConcernsActivity a owl:ObjectProperty ;
    rdfs:label "as concerns activity"@en,
        "en cuanto a actividad"@es,
        "en ce qui concerne l’activité"@fr ;
    rdfs:comment """Connects an Agent Temporal Relation or Mandate Relation, to an
         Activity that is, either transferred from an Agent to another one, or assigned by a Mandate
         to an Agent."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :AgentTemporalRelation :MandateRelation ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Activity ;
    rdfs:subPropertyOf :relationHasContext ;
    owl:inverseOf :activityIsContextOfRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:containsTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains transitive"@en,
        "contiene transitivo"@es,
        "contient transitif"@fr ;
    rdfs:comment """Connects a Place to a Place that it contains, directly or
         indirectly. This is a transitive relation."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :containsOrContained,
        :hasPartTransitive ;
    owl:inverseOf :isContainedByTransitive ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-05" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between places (the past
               partitive relation also being added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ] .

:correspondenceRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Correspondence Relation"@en,
        """desempeña el papel de la Relación entre personas por
         correspondencia"""@es,
        "a le rôle de la Relation épistolaire"@fr ;
    rdfs:comment """Connects a CorrespondenceRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :CorrespondenceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorrespondenceRelation ;
    rdfs:subPropertyOf :knowingRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the CorrespondenceRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the CorrespondenceRelation class. It
         should be used only when you have to manage instances of the CorrespondenceRelation class,
         to connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:directlyPrecedesProxyInSequence a owl:ObjectProperty ;
    rdfs:label "directly precedes proxy in sequence"@en,
        "precede directamente el proxy en la secuencia"@es,
        "précède directement le proxy dans la séquence"@fr ;
    rdfs:comment """Connects a Record Resource to a Proxy of a Record Resource that it
         precedes directly in some sequence (not necessarily defined or characterised
         chronologically)."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :directlyPrecedesInSequence,
        :precedesProxyInSequence ;
    owl:inverseOf :proxyDirectlyFollowsInSequence ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:followsProxyInSequence a owl:ObjectProperty ;
    rdfs:label "follows proxy in sequence"@en,
        "sigue el proxy en la secuencia"@es,
        "suit le proxy dans la séquence"@fr ;
    rdfs:comment """Inverse of 'proxy precedes in sequence' object
         property."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :followsInSequenceTransitive ;
    owl:inverseOf :proxyPrecedesInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:functionalEquivalenceRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Functional Equivalence Relation"@en,
        """desempeña el papel de la Relación de equivalencia
         funcional"""@es,
        "a le rôle de la Relation d’équivalence fonctionnelle"@fr ;
    rdfs:comment """Connects a FunctionalEquivalenceRelation to itself. It is a
         property that can stand for an instance of the class when necessary, e.g. when you explore
         a knowledge graph."""@en ;
    rdfs:domain :FunctionalEquivalenceRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :FunctionalEquivalenceRelation ;
    rdfs:subPropertyOf :instantiationToInstantiationRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the FunctionalEquivalenceRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the FunctionalEquivalenceRelation
         class. It should be used only when you have to manage instances of the
         FunctionalEquivalenceRelation class, to connect each instance to itself, in order to be
         able to infer, using OWL-RL and property paths, the two shortcuts corresponding to this
         n-ary class."""@en .

:hadSubordinate a owl:ObjectProperty ;
    rdfs:label "had subordinate"@en,
        "tenía como subordinado o subordinada a"@es,
        "a eu pour subalterne"@fr ;
    rdfs:comment """Connects an Agent to an Agent that was hierarchically inferior in
         the past."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrHadSubordinate ;
    owl:inverseOf :wasSubordinateTo ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past subordination relations between Agents (the current
               subordination relations being also added, including a transitive one)."""@en ] .

:hasAncestor a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has ancestor"@en,
        "tiene como ancestro a"@es,
        "a pour ancêtre"@fr ;
    rdfs:comment """Inverse of 'has descendant' object property. This is a transitive
         relation."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasFamilyAssociationWith,
        :isSuccessorOf ;
    owl:inverseOf :hasDescendant ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :descendanceRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value "made property transitive"@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new descendanceRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRIs."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R017i (has ancestor
         relation)"""@en .

:hasComponentTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has component transitive"@en,
        "tiene como componente transitivo"@es,
        "a pour composant transitif"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation that is,
         directly or indirectly, a component of that Instantiation. This is a transitive
         relation."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasOrHadComponent,
        :hasPartTransitive ;
    owl:inverseOf :isComponentOfTransitive ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between instantiations (the
               past partitive relation also being added)."""@en ] .

:hasConstituentTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has constituent transitive"@en,
        "tiene como elemento constitutivo transitivo"@es,
        "a pour constituant transitif"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         that is its constituent, directly or indirectly. This is a transitive
         relation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasOrHadConstituent,
        :hasPartTransitive ;
    owl:inverseOf :isConstituentOfTransitive ;
    owl:propertyChainAxiom ( :hasConstituentProxy :proxyHasConstituent ) ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the domain."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment) and labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Added a property chain axiom relating it to use of
               rico:Proxy."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between records and other
               records or record parts (the past partitive relation also being added)."""@en ] .

:hasContentWhichRepresents a owl:ObjectProperty ;
    rdfs:label "has content which represents"@en,
        "tiene contenido que representa"@es,
        "a un contenu qui représente"@fr ;
    rdfs:comment """Connects a Record or a Record Part to a Thing that its content
         represents."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSubject ;
    owl:inverseOf :isRepresentedByContentOf ;
    skos:changeNote [ dc:date "2025-04-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] ;
    skos:scopeNote """Can be used for visual Records or Record Parts, like
         photographs, drawings, engravings, miniatures..."""@en .

:hasCreator a owl:ObjectProperty ;
    rdfs:label "has creator"@en,
        "tiene como creador a"@es,
        "a pour créateur"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to an Agent that is
         either responsible for all or some of the content of the Record Resource or is a
         contributor to the genesis or production of an Instantiation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrganicProvenance ;
    owl:inverseOf :isCreatorOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :creationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-12-29" ;
            rdf:value """Added the property chain axiom, that had been
               forgotten."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI and label (changed made in order to make RiC-O
               compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "createdBy")."""@en ] ;
    skos:scopeNote """Covers the definition of author in diplomatics, and any
         contribution to the intellectual content of a Record Resource."""@en ;
    :RiCCMCorrespondingComponent """RiC-R027 ('has creator'
         relation)"""@en .

:hasDerivationDate a owl:ObjectProperty ;
    rdfs:label "has derivation date"@en,
        "tiene como fecha de derivación"@es,
        "a pour date de dérivation"@fr ;
    rdfs:comment "Inverse of 'is derivation date of' object property."@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isDerivationDateOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :derivationRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2025-03-01" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-03-13" ;
            rdf:value "Added the property chain axiom."@en ] .

:hasDescendant a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has descendant"@en,
        "tiene como descendiente a"@es,
        "a pour descendant"@fr ;
    rdfs:comment """Connects a Person to one of their descendants. This is a
         transitive relation."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasFamilyAssociationWith,
        :hasSuccessor ;
    owl:inverseOf :hasAncestor ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :descendanceRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperties IRIs."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new descendanceRelation_role
               object property."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value "made property transitive"@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """There may be zero to many intermediate persons, ignored or
         unknown, between the two connected persons."""@en ;
    :RiCCMCorrespondingComponent """RiC-R017 ('has descendant'
         relation)"""@en .

:hasDirectConstituentProxy a owl:ObjectProperty ;
    rdfs:label "has direct constituent proxy"@en,
        "tiene como directo elemento constitutivo el proxy"@es,
        "a pour constituant direct le proxy"@fr ;
    rdfs:comment """Inverse of 'proxy is direct constituent of' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :hasConstituentProxy,
        :hasDirectPart ;
    owl:inverseOf :proxyIsDirectConstituentOf ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasDirectSubordinate a owl:ObjectProperty ;
    rdfs:label "has direct subordinate"@en,
        "tiene directamente como subordinado o subordinada a"@es,
        "a directement pour subalterne"@fr ;
    rdfs:comment """Connects an Agent to an Agent that is its direct
         subordinate."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasSubordinateTransitive ;
    owl:inverseOf :isDirectSubordinateTo ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, subordination relations between agents
               (the possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasModificationDate a owl:ObjectProperty ;
    rdfs:label "has modification date"@en,
        "tiene como fecha de modificación"@es,
        "a pour date de modification"@fr ;
    rdfs:comment """Inverse of 'is modification date of' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isModificationDateOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R073i ('has modification date'
         relation)"""@en .

:hasOrHadAllMembersWithSubject a owl:ObjectProperty ;
    rdfs:label "has or had all members with subject"@en,
        "incluye o incluía miembros, todos con matería"@es,
        "inclut ou a inclus des membres ayant tous pour sujet"@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is the subject of all the
         Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSubject ;
    owl:inverseOf :isOrWasSubjectOfAllMembersOf ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasOrHadDemographicGroup a owl:ObjectProperty ;
    rdfs:label "has or had demographic group"@en,
        "tiene o tenía como grupo demográfico"@es,
        "a ou a eu pour groupe démographique"@fr ;
    rdfs:comment """Connects a Person or a Group to a Demographic Group to which it
         belongs or belonged."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Group :Person ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :DemographicGroup ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isOrWasDemographicGroupOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               domain (the name of this property in RiC-O 0.1 was
               "belongsToDemographicGroup")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2024-10-10" ;
            rdf:value """Changed the French and Spanish labels (replaced 'catégorie' and
               'categoria' with 'groupe' and 'grupo')."""@en ] .

:hasOrHadDerivedInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had derived instantiation"@en,
        "tiene o tenía como instanciación derivada"@es,
        "a ou a eu pour instanciation dérivée"@fr ;
    rdfs:comment """Connects an instantiation to an instantiation that is derived from
         it, whether it exists or has been lost or destroyed."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isInstantiationAssociatedWithInstantiation,
        :precedesInTime ;
    owl:inverseOf :isOrWasDerivedFromInstantiation ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :derivationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-29" ;
            rdf:value """Updated the IRI, inverse property, definition, labels and
               RiCMCorrespondingComponent, and added a skos:scopeNote; this in order to make the
               specification compliant with RiC-CM 1.0. The name of the property in RiC-O 0.2 was
               'has derived instantiation'."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new derivationRelation_role
               object property."""@en ] ;
    skos:scopeNote """In some situations, it may be useful or necessary to connect an
         instantiation to an instantiation that was derived from it but no longer exists or or has
         been lost."""@en ;
    :RiCCMCorrespondingComponent """RiC-R014 ('has or had derived instantiation'
         relation)"""@en .

:hasOrHadLocation a owl:ObjectProperty ;
    rdfs:label "has or had location"@en,
        "tiene o tenía como localización"@es,
        "a ou a eu pour localisation"@fr ;
    rdfs:comment "Inverse of 'is or was location of' object property."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAssociatedWithPlace ;
    owl:inverseOf :isOrWasLocationOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI and textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasLocation")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R075i ('has or had location'
         relation)"""@en .

:hasOrHadManager a owl:ObjectProperty ;
    rdfs:label "has or had manager"@en,
        "tiene o tenía como gestor a"@es,
        "a ou a eu pour gestionnaire"@fr ;
    rdfs:comment "Inverse of 'is or was manager of' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isOrWasUnderAuthorityOf ;
    owl:inverseOf :isOrWasManagerOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :managementRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new managementRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "managedBy")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R038i ('is or was managed by'
         relation)"""@en .

:hasOrHadMember a owl:ObjectProperty ;
    rdfs:label "has or had member"@en,
        "tiene o tenía como miembro a"@es,
        "a ou a eu pour membre"@fr ;
    rdfs:comment """Connects a Group to a Person that is or was a member of that
         Group."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :isOrWasMemberOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :membershipRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI and textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasMember")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new membershipRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R055 ('has or had member'
         relation)"""@en .

:hasOrHadRuleType a owl:ObjectProperty ;
    rdfs:label "has or had rule type"@en,
        "tiene o tenía como tipo de regla"@es,
        "a ou a eu pour type de règle"@fr ;
    rdfs:comment """Connects a Rule to a Rule Type that categorized or categorizes
         it."""@en ;
    rdfs:domain :Rule ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RuleType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isOrWasRuleTypeOf ;
    skos:changeNote [ dc:date "2020-10-19" ;
            rdf:value """Object property added along with RuleType class and
               isRuleTypeOf object property. """@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (the name of this property in RiC-O 0.1 was
               "hasRuleType")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasOrHadSomeMembersWhoseContentRepresents a owl:ObjectProperty ;
    rdfs:label "has or had some members whose content represents"@en,
        """incluye o incluía algunos miembros cuyo contenido
         representa"""@es,
        """inclut ou a inclus des membres dont le contenu
         représente"""@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is represented by the
         content of some of the Records or Record Parts that are or were included in the Record
         Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSomeMembersWithSubject ;
    owl:inverseOf :isOrWasRepresentedByContentOfSomeMembersOf ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasOrHadSomeMembersWithAccumulationDate a owl:ObjectProperty ;
    rdfs:label "has or had some members with accumulation date"@en,
        """incluye o incluía algunos miembros con fecha de
         acumulación"""@es,
        """inclut ou a inclus des membres ayant pour date
         d'accumulation"""@fr ;
    rdfs:comment """Inverse of 'is or was accumulation date of some members of' object
         property."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isOrWasAccumulationDateOfSomeMembersOf ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ] .

:hasOrHadSomeMembersWithCreationDate a owl:ObjectProperty ;
    rdfs:label "has or had some members with creation date"@en,
        """incluye o incluía algunos miembros con fecha de
         creación"""@es,
        """inclut ou a inclus des membres ayant pour date de
         création"""@fr ;
    rdfs:comment """Inverse of 'is or was creation date of some members of' object
         property."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasBeginningDate ;
    owl:inverseOf :isOrWasCreationDateOfSomeMembersOf ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """Renamed the property in order to take the past members of the
               record set into account. Adjusted the annotations accordingly."""@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Added the French label"@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R082i ('has or had some members with creation
         date' relation)"""@en .

:hasOrHadSomeMembersWithMainSubject a owl:ObjectProperty ;
    rdfs:label "has or had some members with main subject"@en,
        """incluye o incluía algunos miembros con matería
         principal"""@es,
        """inclut ou a inclus des membres ayant pour sujet
         principal"""@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is the main subject of some
         of the Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSomeMembersWithSubject ;
    owl:inverseOf :isOrWasMainSubjectOfSomeMembersOf ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasSubdivisionTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has subdivision transitive"@en,
        "tiene como subdivisión transitivo"@es,
        "a pour subdivision transitif"@fr ;
    rdfs:comment """Connects a Group to another Group that is one of its direct or
         indirect subdivisions. This is a transitive relation."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :hasOrHadSubdivision,
        :hasPartTransitive,
        :hasSubordinateTransitive ;
    owl:inverseOf :isSubdivisionOfTransitive ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between groups (the past
               partitive relation also being added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:hasSubeventTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has subevent transitive"@en,
        "tiene como parte de evento transitivo"@es,
        "est constitué de l’événement transitif"@fr ;
    rdfs:comment """Connects an ongoing Event to one of a series of Events that
         directly or indirectly constitute that broader, ongoing Event. This is a transitive
         relation."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :hasOrHadSubevent,
        :hasPartTransitive ;
    owl:inverseOf :isSubeventOfTransitive ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2024-10-21" ;
            rdf:value "Fixed the Spanish label."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express partitive relations between ongoing events (the past
               partitive relation also being added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:includesTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "includes transitive"@en,
        "incluye transitivo"@es,
        "inclut transitif"@fr ;
    rdfs:comment """Connects a Record Set to a Record or Record Set which it includes
         directly or indirectly. This is a transitive relation."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hasPartTransitive,
        :includesOrIncluded ;
    owl:inverseOf :isIncludedInTransitive ;
    owl:propertyChainAxiom ( :includesProxy :proxyIncludes ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value """Added a property chain axiom relating it to use of
               rico:Proxy"""@en ],
        [ dc:date "2023-11-13" ;
            rdf:value "Added two labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between Record Sets and their
               members (the past partitive relation also being added)."""@en ] .

:isComponentOfTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is component of transitive"@en,
        "es componente de transitivo"@es,
        "est un composant de transitif"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation of which it is,
         directly or indirectly, a component. This is a transitive relation."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isOrWasComponentOf,
        :isPartOfTransitive ;
    owl:inverseOf :hasComponentTransitive ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between instantiations (the
               past partitive relation also being added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:isConstituentOfTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is constituent of transitive"@en,
        "es elemento constitutivo de transitivo"@es,
        "est le constituant de transitif"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         of which it is a constituent, directly or indirectly. This is a transitive
         relation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasConstituentOf,
        :isPartOfTransitive ;
    owl:inverseOf :hasConstituentTransitive ;
    owl:propertyChainAxiom ( :isConstituentOfProxy :proxyIsConstituentOf ),
        ( :hasProxy :proxyInRecord ) ;
    skos:changeNote [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the range."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Added two property chain axioms relating it to use of
               rico:Proxy."""@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between records and other
               records or record parts (the past partitive relation also being added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:isContainedByTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is contained by transitive"@en,
        "está contenido en transitivo"@es,
        "est contenu par transitif"@fr ;
    rdfs:comment """Connects a Place to a Place that is, directly or indirectly,
         contained by it. This is a transitive relation."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isOrWasContainedBy,
        :isPartOfTransitive ;
    owl:inverseOf :containsTransitive ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between places (the past
               partitive relation also being added)."""@en ] .

:isCreatorOf a owl:ObjectProperty ;
    rdfs:label "is creator of"@en,
        "es creador(a) de"@es,
        "est le créateur de"@fr ;
    rdfs:comment "Inverse of 'has creator' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicProvenanceOf ;
    owl:inverseOf :hasCreator ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :creationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "change the inverse property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new creationRelation_role object
               property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R027i ('is creator of
         'relation')"""@en .

:isDerivationDateOf a owl:ObjectProperty ;
    rdfs:label "is derivation date of"@en,
        "es fecha de derivación de"@es,
        "est la date de dérivation de"@fr ;
    rdfs:comment """Connects a Date to an Instantiation from which a new Instantiation
         was or will be derived at that Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasDerivationDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :derivationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2025-03-13" ;
            rdf:value "Added the property chain axiom."@en ],
        [ dc:date "2025-03-01" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:isDirectConstituentOfProxy a owl:ObjectProperty ;
    rdfs:label "is direct constituent of proxy"@en,
        "es elemento constitutivo directo del proxy"@es,
        "est un constituant direct du proxy"@fr ;
    rdfs:comment """Connects a Record or Record Part to a Proxy of a Record or Record
         Part which it is a direct constituent of."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isConstituentOfProxy,
        :isDirectPartOf ;
    owl:inverseOf :proxyHasDirectConstituent ;
    skos:changeNote [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isDirectSubordinateTo a owl:ObjectProperty ;
    rdfs:label "is direct subordinate to"@en,
        "está directamente subordinado(a) a"@es,
        "est directement subalterne de"@fr ;
    rdfs:comment """Connects an Agent to an Agent that is directly hierarchically
         superior."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isSubordinateToTransitive ;
    owl:inverseOf :hasDirectSubordinate ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, subordination relations between agents
               (the possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isIncludedInTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is included in transitive"@en,
        "está incluido en transitivo"@es,
        "est inclus dans transitif"@fr ;
    rdfs:comment """Connects a Record to a Record or Record Set in which it is
         directly or indirectly included. This is a transitive relation."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasIncludedIn,
        :isPartOfTransitive ;
    owl:inverseOf :includesTransitive ;
    owl:propertyChainAxiom ( :isIncludedInProxy :proxyIsIncludedIn ),
        ( :hasProxy :proxyInRecordSet ) ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value """Added two property chain axioms relating it to use of
               rico:Proxy."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between Record Sets and their
               members (the past partitive relation also being added)."""@en ],
        [ dc:date "2023-11-13" ;
            rdf:value "Added a French label."@en ] .

:isModificationDateOf a owl:ObjectProperty ;
    rdfs:label "is modification date of"@en,
        "es fecha de modificación de"@es,
        "est une date de modification de"@fr ;
    rdfs:comment """Connects a Date to a Thing that was modified on that
         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasModificationDate ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R073 ('is modification date of'
         relation)"""@en .

:isOrWasAccumulationDateOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was accumulation date of some members of"@en,
        "es o era fecha de acumulación de algunos miembros de"@es,
        """est ou a été la date d'accumulation de certains membres
         de"""@fr ;
    rdfs:comment """Connects a Date to a Record Set some of whose present or past
         members were or will be accumulated at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasOrHadSomeMembersWithAccumulationDate ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ] .

:isOrWasCreationDateOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was creation date of some members of"@en,
        "es o era fecha de creación de algunos miembros de"@es,
        "est ou a été la date de création de certains membres de"@fr ;
    rdfs:comment """Connects a Date to a Record Set some of whose present or past
         members were or will be created at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isBeginningDateOf ;
    owl:inverseOf :hasOrHadSomeMembersWithCreationDate ;
    skos:changeNote [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """Renamed the property in order to take the past members of the
               record set into account. Adjusted the annotations accordingly."""@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Added the French label and the rdfs:comment"@en ] ;
    :RiCCMCorrespondingComponent """RiC-R082 ('is or was creation date of some members
         of' relation)"""@en .

:isOrWasDemographicGroupOf a owl:ObjectProperty ;
    rdfs:label "is or was demographic group of"@en,
        "es o era grupo demográfico de"@es,
        "est ou a été le groupe démographique de"@fr ;
    rdfs:comment """Connects a Demographic Group to a Person or Group which belongs or
         belonged to it."""@en ;
    rdfs:domain :DemographicGroup ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Group :Person ) ] ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasOrHadDemographicGroup ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               range (the name of this property in RiC-O 0.1 was
               "isDemographicGroupOf")."""@en ],
        [ dc:date "2024-10-10" ;
            rdf:value """Changed the French label (replaced 'catégorie' with
               'groupe')."""@en ] .

:isOrWasDerivedFromInstantiation a owl:ObjectProperty ;
    rdfs:label "is or was derived from instantiation"@en,
        "es o era un derivado de instanciación"@es,
        "est ou a été une instanciation dérivée de"@fr ;
    rdfs:comment """Inverse of 'has or had derived instantiation' object
         property."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :followsInTime,
        :isInstantiationAssociatedWithInstantiation ;
    owl:inverseOf :hasOrHadDerivedInstantiation ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :derivationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new derivationRelation_role
               object property."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Added the property chain axiom so that this property is
               formally defined as a shortcut (the inverse property already was)."""@en ],
        [ dc:date "2023-08-29" ;
            rdf:value """Updated the IRI, inverse property, definition, labels and
               RiCMCorrespondingComponent; this in order to make the specification compliant with
               RiC-CM 1.0. The name of the property in RiC-O 0.2 was 'is derived from
               instantiation'."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R014i ('is or was derived from instantiation'
         relation)"""@en .

:isOrWasLocationOf a owl:ObjectProperty ;
    rdfs:label "is or was location of"@en,
        "es o era localización de"@es,
        "est ou a été la localisation de"@fr ;
    rdfs:comment """Connects a Place to a Thing that is or was located in the
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isPlaceAssociatedWith ;
    owl:inverseOf :hasOrHadLocation ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "isLocationOf")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R075 ('is or was location of'
         relation)"""@en .

:isOrWasMainSubjectOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was main subject of some members of"@en,
        "es o era la materia principal de algunos miembros de"@es,
        "est ou a été le sujet principal de certains membres de"@fr ;
    rdfs:comment """Inverse of 'has or had some members with main subject' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasSubjectOfSomeMembersOf ;
    owl:inverseOf :hasOrHadSomeMembersWithMainSubject ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasManagerOf a owl:ObjectProperty ;
    rdfs:label "is or was manager of"@en,
        "es o era gestor de"@es,
        "est ou a été le gestionnaire de"@fr ;
    rdfs:comment """Connects an Agent to a Record Resource or Instantiation that the
         Agent managed or manages."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :hasOrHadAuthorityOver ;
    owl:inverseOf :hasOrHadManager ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :managementRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, super property
               IRI, textual definition (changed made in order to make RiC-O compliant with RiC-CM
               0.2; the name of this property in RiC-O 0.1 was "isManagerOf")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new managementRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R038 ('is or was manager of'
         relation)"""@en .

:isOrWasMemberOf a owl:ObjectProperty ;
    rdfs:label "is or was member of"@en,
        "es o era miembro de"@es,
        "est ou a été membre de"@fr ;
    rdfs:comment "Inverse of 'has or had member' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :hasOrHadMember ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :membershipRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new membershipRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "isMemberOf")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R055i ('is or was member of'
         relation)"""@en .

:isOrWasRepresentedByContentOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was represented by content of some members of"@en,
        """es o era representado por el contenido de algunos miembros
         de"""@es,
        """est ou a été représenté par le contenu de certains membres
         de"""@fr ;
    rdfs:comment """Inverse of 'has or had some members whose content represents'
         object property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasSubjectOfSomeMembersOf ;
    owl:inverseOf :hasOrHadSomeMembersWhoseContentRepresents ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasRuleTypeOf a owl:ObjectProperty ;
    rdfs:label "is or was rule type of"@en,
        "es o era tipo de regla de"@es,
        "est ou a été le type de règle de"@fr ;
    rdfs:comment """Connects a Rule Type to a Rule that it categorized or
         categorizes."""@en ;
    rdfs:domain :RuleType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Rule ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasOrHadRuleType ;
    skos:changeNote [ dc:date "2020-10-19" ;
            rdf:value """Object property added along with RuleType class and hasRuleType
               object property. """@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property URI (the name of this property in RiC-O 0.1 was
               "isRuleTypeOf")."""@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Make capitalisation of rdfs:comment consistent."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isOrWasSubjectOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was subject of all members of"@en,
        "es o era la matería de todos los miembros de"@es,
        "est ou a été le sujet de tous les membres de"@fr ;
    rdfs:comment """Inverse of 'has or had all members with subject' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasSubjectOf ;
    owl:inverseOf :hasOrHadAllMembersWithSubject ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isRepresentedByContentOf a owl:ObjectProperty ;
    rdfs:label "is represented by content of"@en,
        "es representado por el contenido de"@es,
        "est représenté par le contenu de"@fr ;
    rdfs:comment """Inverse of 'has content which represents' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasSubjectOf ;
    owl:inverseOf :hasContentWhichRepresents ;
    skos:changeNote [ dc:date "2025-04-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isSubdivisionOfTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is subdivision of transitive"@en,
        "es subdivisión de transitivo"@es,
        "est une subdivision de transitif"@fr ;
    rdfs:comment """Connects a Group to the Group it is a direct or indirect
         subdivision of. This is a transitive relation."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isOrWasSubdivisionOf,
        :isPartOfTransitive,
        :isSubordinateToTransitive ;
    owl:inverseOf :hasSubdivisionTransitive ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current partitive relations between groups (the past
               partitive relation also being added)."""@en ] .

:isSubeventOfTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is subevent of transitive"@en,
        "es elemento constitutivo de transitivo"@es,
        "est un événement constituant de transitif"@fr ;
    rdfs:comment """Connects an ongoing Event to an Event of which it is a direct or
         indirect part. This is a transitive relation."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isOrWasSubeventOf,
        :isPartOfTransitive ;
    owl:inverseOf :hasSubeventTransitive ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express partitive relations between ongoing events (the past
               partitive relation also being added)."""@en ] .

:leadershipWithPosition a owl:ObjectProperty ;
    rdfs:label "leadership with position"@en,
        "liderazgo en puesto"@es,
        "relation de direction dans le cadre du poste"@fr ;
    rdfs:comment """Connects a Leadership Relation to the Position occupied by the
         leading Person."""@en ;
    rdfs:domain :LeadershipRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Position ;
    rdfs:subPropertyOf :relationHasContext ;
    owl:inverseOf :positionIsContextOfLeadershipRelation ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:membershipWithPosition a owl:ObjectProperty ;
    rdfs:label "membership with position"@en,
        "membresía en puesto"@es,
        "relation d’appartenance dans le cadre du poste"@fr ;
    rdfs:comment """Connects a Membership Relation to the Position occupied by the
         member Person(s)."""@en ;
    rdfs:domain :MembershipRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Position ;
    rdfs:subPropertyOf :relationHasContext ;
    owl:inverseOf :positionIsContextOfMembershipRelation ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:name a owl:DatatypeProperty ;
    rdfs:label "name"@en,
        "nombre"@es,
        "nom"@fr ;
    rdfs:comment """A label, title or term designating an entity in order to make it
         distinguishable from other similar entities."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Examples added. Objective: to make
               RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote, examples (skos:example)."""@en ] ;
    skos:example "D-Day (about a Date or Event)"@en,
        """Digital copy of the Pomarius archival inventory from 1575 (about
         an Instantiation)"""@en,
        """Fundraising, University of Glasgow (about an
         Activity)"""@en,
        "Halloween 2016 (about a Date)"@en,
        "Nelson Mandela (about a Person)"@en,
        """Papers of the Earls of Liverpool (about a Record
         Set)"""@en,
        "Paris (about a Place)"@en,
        "Prime Minister (about a Position)"@en,
        "Providing hearing services (about an Activity)"@en,
        "Sketch Map of the Qatar Peninsula (about a Record)"@en,
        """The Letter of Neacsu from Campulung to the Mayor of Brasov (about
         a Record)"""@en ;
    skos:scopeNote """Use only if you don't use Name class for handling names.
         Provides brief information about the content or other individual characteristics of the
         entity being described, necessary to distinguish it from other perhaps similar
         entities."""@en ;
    :RiCCMCorrespondingComponent """Corrresponds to RiC-A28 (Name
         attribute)"""@en .

:proxyDirectlyFollowsInSequence a owl:ObjectProperty ;
    rdfs:label "proxy directly follows in sequence"@en,
        "proxy sigue directamente en la secuencia"@es,
        "proxy suit directement dans la séquence"@fr ;
    rdfs:comment """Inverse of 'directly precedes proxy in sequence' object
         property."""@en ;
    rdfs:domain :Proxy ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :directlyFollowsInSequence,
        :proxyFollowsInSequence ;
    owl:inverseOf :directlyPrecedesProxyInSequence ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:recordResourceGeneticRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Record Resource Genetic Relation"@en,
        """desempeña el papel de la Relación genética entre recursos
         documentales"""@es,
        """a le rôle de la Relation génétique entre des ressources
         archivistiques"""@fr ;
    rdfs:comment """Connects a RecordResourceGeneticRelation to itself. It is a
         property that can stand for an instance of the class when necessary, e.g. when you explore
         a knowledge graph."""@en ;
    rdfs:domain :RecordResourceGeneticRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResourceGeneticRelation ;
    rdfs:subPropertyOf :recordResourceToRecordResourceRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the RecordResourceGeneticRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the RecordResourceGeneticRelation
         class. It should be used only when you have to manage instances of the
         RecordResourceGeneticRelation class, to connect each instance to itself, in order to be
         able to infer, using OWL-RL and property paths, the two shortcuts corresponding to this
         n-ary class."""@en .

:referenceSystem a owl:DatatypeProperty ;
    rdfs:label "reference system"@en,
        "sistema de referencia"@es,
        "système de référence"@fr ;
    rdfs:comment """Framework or standard used to represent an
         information."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:resultsOrResultedFrom a owl:ObjectProperty ;
    rdfs:label "results or resulted from"@en,
        "resulta o resultaba"@es,
        "résulte ou a résulté de"@fr ;
    rdfs:comment """Inverse of 'results or resulted in' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isAssociatedWithEvent ;
    owl:inverseOf :resultsOrResultedIn ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "resultsFrom")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R061i ('results or resulted from'
         relation)"""@en .

:resultsOrResultedIn a owl:ObjectProperty ;
    rdfs:label "results or resulted in"@en,
        "tiene o tenía como resultado a"@es,
        "a ou a eu pour résultat"@fr ;
    rdfs:comment """Connects an Event to a Thing that results or resulted from the
         Event."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isEventAssociatedWith ;
    owl:inverseOf :resultsOrResultedFrom ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "resultsIn")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R061 ('results or resulted in'
         relation)"""@en .

:siblingRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Sibling Relation"@en,
        """desempeña el papel de la Relación familiar entre
         hermanos"""@es,
        "a le rôle de la Relation de fratrie"@fr ;
    rdfs:comment """Connects a SiblingRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :SiblingRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :SiblingRelation ;
    rdfs:subPropertyOf :familyRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the SiblingRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the SiblingRelation class. It should be
         used only when you have to manage instances of the SiblingRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:spouseRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Spouse Relation"@en,
        """desempeña el papel de la Relación matrimonial entre
         personas"""@es,
        "a le rôle de la Relation matrimoniale"@fr ;
    rdfs:comment """Connects a SpouseRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :SpouseRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :SpouseRelation ;
    rdfs:subPropertyOf :familyRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the SpouseRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the SpouseRelation class. It should be
         used only when you have to manage instances of the SpouseRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:structure a owl:DatatypeProperty ;
    rdfs:label "structure"@en,
        "estructura"@es,
        "structure"@fr ;
    rdfs:comment """Information about the intellectual arrangement and composition of
         a Record Resource or the physical arrangement and composition of an Instantiation. For
         Record and Record Part, it encompasses information about the intellectual composition of
         the record, the presence of record parts and their functions. For Record Set, it
         encompasses information about the methodology or criteria used for arranging the Record Set
         members or Record members within the containing Record Set. For Instantiation, it may
         comprise information about the composition of the physical elements of the
         instantiation"""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2020-11-01" ;
            rdf:value """Text definition updated. Objective: to make RiC-O compliant
               with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-11" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the skos:scopeNote, examples
               (skos:example)."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:example """Inside each file, the records are arranged chronologically (about
         a record set)"""@en,
        """The database has three related tables: names, addresses, and
         passport numbers (about a record)"""@en,
        """The record has two appendices, comprising a full account of the
         income from car taxes and real estate taxes"""@en,
        """The series have the files arranged according to the alphabetical
         order of the places concerned"""@en ;
    skos:scopeNote """Use only if you cannot use the subproperties (particularly if
         the same free text is being used in your current metadata for describing the record
         resource and the instantiation structure). For a Record Set, may be used to summarize the
         structure of the Record Set itself, or additionally to summarize the structure of some or
         all members of the Record Set. Should not be confused with the classification datatype
         property, which provides information about the category which the Record Set belongs to
         within a classification scheme. """@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A40 (Structure
         attribute)"""@en .

:wasSubordinateTo a owl:ObjectProperty ;
    rdfs:label "was subordinate to"@en,
        "estaba subordinado(a) a"@es,
        "a été subalterne de"@fr ;
    rdfs:comment """Connects an Agent to an Agent that was hierarchically superior in
         the past."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isOrWasSubordinateTo ;
    owl:inverseOf :hadSubordinate ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express past subordination relations between Agents (the current
               subordination relations being also added, including a transitive one)."""@en ] .

:workRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Work Relation"@en,
        "desempeña el papel de la Relación profesional"@es,
        "a le rôle de la Relation de travail"@fr ;
    rdfs:comment """Connects a WorkRelation to itself. It is a property that can stand
         for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :WorkRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :WorkRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the WorkRelation rolified class. Declared
               it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the WorkRelation class. It should be
         used only when you have to manage instances of the WorkRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

ric-dft:FindingAid a owl:NamedIndividual,
        skos:Concept,
        :DocumentaryFormType ;
    rdfs:label "finding aid"@en,
        "instrumento de descripción"@es,
        "instrument de recherche"@fr ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-25" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-01-30" ;
            rdf:value """Added a skos:narrower with object the IIIF Manifest
               concept."""@en ] ;
    skos:definition """This documentary form type can be used for records that
         aggregate and organizes metadata on some record(s) or record set(s)."""@en ;
    skos:inScheme <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> ;
    skos:narrower ric-dft:IIIFManifest ;
    skos:topConceptOf <https://www.ica.org/standards/RiC/vocabularies/documentaryFormTypes> .

:ActivityType a owl:Class ;
    rdfs:label "Aktivitätskategorie"@de,
        "Activity Type"@en,
        "Tipo de actividad"@es,
        "Type d’activité"@fr ;
    rdfs:comment "Categorization of an Activity."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2020-10-23" ;
            rdf:value """Scope note: updated (different from RiC-CM scope note).
               Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ] ;
    skos:scopeNote """Can be extended with any number of subclasses, e.g.
         “function/action” and “activity domain”. This allows for a faceted approach that enables an
         Activity to be categorized using a combination of components, general or more specific. For
         example, “monitoring” can be used in combination with “election polls” or “water
         resources”."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A02 (Activity Type
         attribute)"""@en .

:AgentControlRelation a owl:Class ;
    rdfs:label "Akteur-Kontrolle-Akteur"@de,
        "Agent Control Relation"@en,
        "Relación de control entre agentes"@es,
        "Relation de contrôle entre agents"@fr ;
    rdfs:comment """Connects at least one Agent, to at least another Agent, when the
         first one(s) control(s) or controlled in a way the activities of the second one(s). The
         Relation is oriented from the controlling agent to the controlled one: the controlling
         Agent(s) is the source of the Relation, and the controlled Agent(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasTarget ],
        :AgentHierarchicalRelation,
        :AuthorityRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :agentControlRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R041 and RiC-R041i
         relations"""@en .

:DemographicGroup a owl:Class ;
    rdfs:label "Demographische Gruppe"@de,
        "Demographic Group"@en,
        "Grupo demográfico"@es,
        "Groupe démographique"@fr ;
    rdfs:comment """Categorization of a Person or Group based on shared
         characteristics."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2024-10-10" ;
            rdf:value """Changed the French and Spanish labels (replaced 'catégorie' and
               'categoria' with 'groupe' and 'grupo')."""@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2020-10-23" ;
            rdf:value """Comment: updated. Scope note: updated and made several
               paragraphs. Objective: to make RiC-O compliant with RiC-CM v0.2."""@en ],
        [ dc:date "2021-02-08" ;
            rdf:value "Removed the Restriction."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """Can be extended with any number of specific subclasses. Among
         possible specific demographic groups are gender, (biological) sex, education, identity,
         place, ancestry, ethnic/cultural identification, and religion."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A15 (Demographic Group
         attribute)"""@en .

:DerivationRelation a owl:Class ;
    rdfs:label "Instanz-Derivat-Instanz"@de,
        "Derivation Relation"@en,
        "Relación de derivación"@es,
        "Relation de dérivation"@fr ;
    rdfs:comment """Connects an Instantiation to at least one Instantiation that is
         derived from it, whether it exists or has been lost or destroyed. The Relation is oriented
         chronologically, from the first Instantiation in time to the derived Instantiation: the
         first Instantiation is the source of the Relation, and the derived Instantiation(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Instantiation ;
            owl:onProperty :relationHasTarget ],
        :InstantiationToInstantiationRelation,
        :TemporalRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :derivationRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    skos:scopeNote """In some situations, it may be useful or necessary to connect an
         instantiation to an instantiation that was derived from it but no longer exists or has been
         lost."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R014 and RiR014i
         relations"""@en .

:DescendanceRelation a owl:Class ;
    rdfs:label "Person-Nachkommen"@de,
        "Descendance Relation"@en,
        "Relación de descendencia"@es,
        "Relation de descendance"@fr ;
    rdfs:comment """Connects at least one Person to at least another Person, when the
         first has/have descendant the second one(s). The Relation is oriented from the ascendant to
         the descendant: the ascendant Person(s) is the source of the Relation, and the descendant
         Person(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Person ;
            owl:onProperty :relationHasTarget ],
        :AgentTemporalRelation,
        :FamilyRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :descendanceRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R017 and RiC-R017i
         relations"""@en .

:ManagementRelation a owl:Class ;
    rdfs:label "Akteur-Management-Recordressource/Instanz"@de,
        "Management Relation"@en,
        "Relación de gestión"@es,
        "Relation de gestion"@fr ;
    rdfs:comment """Connects at least one Agent and at least one Record Resource or
         Instantiation that the Agent manages or managed. The Agent(s) is the source of the
         Relation, and the Record Resource(s) or Instantiation(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Agent ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :Instantiation :RecordResource ) ] ;
            owl:onProperty :relationHasTarget ],
        :AuthorityRelation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :managementRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R038 and RiC-R038i
         relations"""@en .

:RecordResourceToRecordResourceRelation a owl:Class ;
    rdfs:label "Recordressource-Recordressource"@de,
        "Record Resource to Record Resource Relation"@en,
        "Relación entre recursos documentales"@es,
        "Relation entre ressources archivistiques"@fr ;
    rdfs:comment """Connects at least two Record Resources. This Relation is a
         generic, not oriented one."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onClass :RecordResource ;
            owl:onProperty :relationConnects ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :recordResourceToRecordResourceRelation_role ] ;
    skos:changeNote [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ] ;
    skos:scopeNote """Use to connect two record resources only if it is not possible
         to use a narrower, more specific relation, for example
         RecordResourceGeneticRelation."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R022 and RiC-022i
         relations"""@en .

:RuleRelation a owl:Class ;
    rdfs:label "Regel-Ding"@de,
        "Rule Relation"@en,
        "Relación con regla"@es,
        "Relation impliquant une règle"@fr ;
    rdfs:comment """Connects at least one Rule to at least one Thing when it is
         associated with existence and lifecycle of the Thing. The Rule(s) is the source of the
         Relation, and the Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Rule ;
            owl:onProperty :relationHasSource ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :ruleRelation_role ] ;
    skos:changeNote [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R062 and RiC-R062i
         relations"""@en .

:RuleType a owl:Class ;
    rdfs:label "Regelkategorie"@de,
        "Rule Type"@en,
        "Tipo de regla"@es,
        "Type de règle"@fr ;
    rdfs:comment "Categorization of a Rule."@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf :Type ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-04-19" ;
            rdf:value "Removed the 0.2 existing unnecessary restriction."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: added a
               rico:RiCCMCorrespondingComponent."""@en ],
        [ dc:date "2020-10-19" ;
            rdf:value """Class added along with hasRuleType and isRuleTypeOf object
               properties."""@en ] ;
    skos:scopeNote """For example, for rules that can be applied to record resources :
         access rule, use rule, etc."""@en ;
    :RiCCMCorrespondingComponent """Corresponds to RiC-A45 (Rule Type
         attribute)."""@en .

:SequentialRelation a owl:Class ;
    rdfs:label "Ding-Abfolge-Ding"@de,
        "Sequential Relation"@en,
        "Relación secuencial"@es,
        "Relation séquentielle"@fr ;
    rdfs:comment """Connects at least one Thing to at least one other Thing that
         follows or followed it in some sequence. The Relation is oriented from the first Thing(s)
         in the sequence to the following one(s): the first Thing(s) is the source, and the
         following Thing(s) is the target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasSource ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :sequentialRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ] ;
    skos:scopeNote """The relation does not specify the criteria used for ordering the
         sequence. There may be zero to many intermediate entities, ignored or unknown, in the
         sequence between the two connected things. Can be used, for example, for specifying that a
         record "has next" another record within a record set."""@en ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R008 and RiC-R008i
         relations"""@en .

:WholePartRelation a owl:Class ;
    rdfs:label "Teil-Ganzes-Beziehung"@de,
        "Whole Part Relation"@en,
        "Relación entre todo y parte"@es,
        "Relation partitive"@fr ;
    rdfs:comment """Connects a Thing to at least one other Thing that is or was a
         portion or division of the whole Thing. The Relation is oriented from the Thing to its
         part(s): the Thing is the source of the Relation, and the part Thing(s) is the
         target."""@en ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasTarget ],
        [ a owl:Restriction ;
            owl:onClass :Thing ;
            owl:onProperty :relationHasSource ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :Relation ;
    owl:equivalentClass [ a owl:Restriction ;
            owl:hasSelf true ;
            owl:onProperty :wholePartRelation_role ] ;
    skos:changeNote [ dc:date "2023-12-06" ;
            rdf:value """Improved the description of the Relation class (rdfs:comment)
               by clearly specifying how it is directed."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: added an
               equivalentClass object property; replaced the specific object properties by the
               generic ones in the subClassOf declarations."""@en ],
        [ dc:date "2025-04-08" ;
            rdf:value "Added a new rdfs:label in German."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Class implementation of RiC-R002 and RiC-R002i
         relations"""@en .

:activityDocumentationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Activity Documentation Relation"@en,
        """desempeña el papel de la Relación de procedencia
         funcional"""@es,
        """a le rôle de la Relation entre activités et ressources
         archivistiques"""@fr ;
    rdfs:comment """Connects an ActivityDocumentationRelation to itself. It is a
         property that can stand for an instance of the class when necessary, e.g. when you explore
         a knowledge graph."""@en ;
    rdfs:domain :ActivityDocumentationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ActivityDocumentationRelation ;
    rdfs:subPropertyOf :eventRelation_role,
        :organicOrFunctionalProvenanceRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the ActivityDocumentationRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the ActivityDocumentationRelation
         class. It should be used only when you have to manage instances of the
         ActivityDocumentationRelation class, to connect each instance to itself, in order to be
         able to infer, using OWL-RL and property paths, the two shortcuts corresponding to this
         n-ary class."""@en .

:appellationRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Appellation Relation"@en,
        "desempeña el papel de la Relación de denominación"@es,
        "a le rôle de la Relation d’appellation"@fr ;
    rdfs:comment """Connects an AppellationRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AppellationRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AppellationRelation ;
    rdfs:subPropertyOf :relation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AppellationRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AppellationRelation class. It
         should be used only when you have to manage instances of the AppellationRelation class, to
         connect each instance to itself, in order to be able to infer, using OWL-RL and property
         paths, the two shortcuts corresponding to this n-ary class."""@en .

:authorshipRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Authorship Relation"@en,
        "desempeña el papel de la Relación de autoría"@es,
        """a le rôle de la Relation de responsabilité
         intellectuelle"""@fr ;
    rdfs:comment """Connects an AuthorshipRelation to itself. It is a property that
         can stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :AuthorshipRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AuthorshipRelation ;
    rdfs:subPropertyOf :creationRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the AuthorshipRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the AuthorshipRelation class. It should
         be used only when you have to manage instances of the AuthorshipRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:childRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Child Relation"@en,
        "desempeña el papel de la Relación de filiación"@es,
        "a le rôle de la Relation de filiation"@fr ;
    rdfs:comment """Connects a ChildRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :ChildRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ChildRelation ;
    rdfs:subPropertyOf :descendanceRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the ChildRelation rolified class. Declared
               it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the ChildRelation class. It should be
         used only when you have to manage instances of the ChildRelation class, to connect each
         instance to itself, in order to be able to infer, using OWL-RL and property paths, the two
         shortcuts corresponding to this n-ary class."""@en .

:containsOrContained a owl:ObjectProperty ;
    rdfs:label "contains or contained"@en,
        "contiene o contenía"@es,
        "contient ou a contenu"@fr ;
    rdfs:comment """Connects a Place to a region that is or was within
         it."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isAssociatedWithPlace,
        :isPlaceAssociatedWith ;
    owl:inverseOf :isOrWasContainedBy ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name ; added a scope note (changed made in order to make
               RiC-O compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "contains")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use for connecting two geographical or administrative
         regions."""@en ;
    :RiCCMCorrespondingComponent """RiC-R007 ('contains or contained'
         relation)"""@en .

:endDate a owl:DatatypeProperty ;
    rdfs:label "end date"@en,
        "fecha final"@es,
        "date de fin"@fr ;
    rdfs:comment "Date at which something ended."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    rdfs:subPropertyOf :date ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons. May be deprecated and removed
         later on. Use only if you don't use Date classes for handling dates."""@en ;
    :RiCCMCorrespondingComponent """Datatype property specialized implementation of
         RiC-E18 (Date entity)"""@en .

:groupSubdivisionRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Group Subdivision Relation"@en,
        """desempeña el papel de la Relación de subdivisión entre grupos de
         agentes"""@es,
        """a le rôle de la Relation de subdivision entre groupes
         d’agents"""@fr ;
    rdfs:comment """Connects a GroupSubdivisionRelation to itself. It is a property
         that can stand for an instance of the class when necessary, e.g. when you explore a
         knowledge graph."""@en ;
    rdfs:domain :GroupSubdivisionRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :GroupSubdivisionRelation ;
    rdfs:subPropertyOf :agentHierarchicalRelation_role,
        :wholePartRelation_role ;
    skos:changeNote [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the GroupSubdivisionRelation rolified
               class. Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ] ;
    skos:scopeNote """This property "rolifies" the GroupSubdivisionRelation class. It
         should be used only when you have to manage instances of the GroupSubdivisionRelation
         class, to connect each instance to itself, in order to be able to infer, using OWL-RL and
         property paths, the two shortcuts corresponding to this n-ary class."""@en .

:hasAccumulator a owl:ObjectProperty ;
    rdfs:label "has accumulator"@en,
        "tiene como acumulador a"@es,
        "est accumulé par"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to the Agent that
         accumulates it, be it intentionally (collecting) or not (receiving in the course of its
         activities)."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrganicProvenance ;
    owl:inverseOf :isAccumulatorOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :accumulationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               and corresponding CM component (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "accumulatedBy")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new accumulationRelation_role
               object property."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R028 ('has accumulator'
         relation)"""@en .

:hasOrHadAppellation a owl:ObjectProperty ;
    rdfs:label "has or had appellation"@en,
        "tiene o tenía como denominación"@es,
        "a ou a eu pour appellation"@fr ;
    rdfs:comment """Connects a Thing to an Appellation that is or was used for
         designating it."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Appellation ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasAppellationOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :appellationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (the name of this property in RiC-O 0.1 was "hasAppellation")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new appellationRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasOrHadComponent a owl:ObjectProperty ;
    rdfs:label "has or had component"@en,
        "tiene o tenía como componente"@es,
        "a ou a eu pour composant"@fr ;
    rdfs:comment """Connects an Instantiation to one of its present or past component
         instantiations."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isInstantiationAssociatedWithInstantiation ;
    owl:inverseOf :isOrWasComponentOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasComponent")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R004 ('has or had component'
         relation)"""@en .

:hasOrHadConstituent a owl:ObjectProperty ;
    rdfs:label "has or had constituent"@en,
        "tiene o tenía como elemento constitutivo"@es,
        "a ou a eu pour constituant"@fr ;
    rdfs:comment """Connects a Record or Record Part to a Record or Record part that
         is or was a constituent of that Record or Record Part."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :isOrWasConstituentOf ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Added Record Part to the domain."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasConstituent")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R003 ('has or had constituent'
         relation)"""@en .

:hasOrHadController a owl:ObjectProperty ;
    rdfs:label "has or had controller"@en,
        "tiene o tenía como controlador"@es,
        "est ou a été contrôlé par"@fr ;
    rdfs:comment """Inverse of 'is or was controller of' object
         property."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isOrWasSubordinateTo,
        :isOrWasUnderAuthorityOf ;
    owl:inverseOf :isOrWasControllerOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :agentControlRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2024-09-02" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new agentControlRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "controlledBy")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R041i ('has or had controller'
         relation)"""@en .

:hasOrHadInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had instantiation"@en,
        "tiene o tenía como instanciación"@es,
        "a ou a eu pour instanciation"@fr ;
    rdfs:comment """Connects a Record Resource to an Instantiation, which either may
         exist or may have been lost or destroyed."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasInstantiationOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :recordResourceToInstantiationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceToInstantiationRelation_role object property."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-29" ;
            rdf:value """Updated the IRI, inverse property, definition, labels and
               RiCMCorrespondingComponent, and added a skos:scopeNote; this in order to make the
               specification compliant with RiC-CM 1.0. The name of the property in RiC-O 0.2 was
               'has instantiation'."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the inverse property IRI."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """In some situations, it may be useful or necessary to connect a
         record resource to an instantiation that no longer exists or or has been lost, when some of
         its characteristics are known from some source, like an old finding aid."""@en ;
    :RiCCMCorrespondingComponent """RiC-R025 ('has or had instantiation'
         relation)"""@en .

:hasOrHadMainSubject a owl:ObjectProperty ;
    rdfs:label "has or had main subject"@en,
        "tiene o tenía como matería principal"@es,
        "a ou a eu pour sujet principal"@fr ;
    rdfs:comment """Connects a Record Resource to a Thing that is or was its main
         subject."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSubject ;
    owl:inverseOf :isOrWasMainSubjectOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI and textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "hasMainSubject")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Use for specifying, for example, that a Record Set of type
         personal file has main subject some person, which would help end users to retrieve the main
         archival resources about this person."""@en ;
    :RiCCMCorrespondingComponent """RiC-R020 ('has or had main subject'
         relation)"""@en .

:hasOrHadParticipant a owl:ObjectProperty ;
    rdfs:label "has or had participant"@en,
        "tiene o tenía como participante"@es,
        "a ou a eu pour participant"@fr ;
    rdfs:comment """Connects an Event to a Thing that is or was actively or passively
         involved in it."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isEventAssociatedWith ;
    owl:inverseOf :isOrWasParticipantIn ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "involves")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R058 ('has or had participant'
         relation)"""@en .

:hasOrHadSomeMembersWithSubject a owl:ObjectProperty ;
    rdfs:label "has or had some members with subject"@en,
        "incluye o incluía algunos miembros con matería"@es,
        "inclut ou a inclus des membres ayant pour sujet"@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is the subject of some of
         the Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasSubjectOfSomeMembersOf ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ] .

:hasOrHadSubdivision a owl:ObjectProperty ;
    rdfs:label "has or had subdivision"@en,
        "tiene o tenía como subdivisión"@es,
        "a ou a eu pour subdivision"@fr ;
    rdfs:comment """Connects a Group to one of its present or past
         subdivisions."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :hasOrHadPart,
        :hasOrHadSubordinate ;
    owl:inverseOf :isOrWasSubdivisionOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :groupSubdivisionRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               groupSubdivisionRelation_role object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRIs (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "hasSubdivision")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R005 ('has or had subdivision'
         relation)"""@en .

:hasOrHadSubevent a owl:ObjectProperty ;
    rdfs:label "has or had subevent"@en,
        "tiene o tenía como parte de evento"@es,
        "est ou a été constitué de l’événement"@fr ;
    rdfs:comment """Connects an Event to one of a series of Events that constitute the
         original, broader, past or ongoing Event."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isAssociatedWithEvent,
        :isEventAssociatedWith ;
    owl:inverseOf :isOrWasSubeventOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "hasSubEvent")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """Since an Activity is a kind of Event, this Relation can also be
         used for Activity."""@en ;
    :RiCCMCorrespondingComponent """RiC-R006 ('has or had subevent'
         relation)"""@en .

:hasOrganicOrFunctionalProvenance a owl:ObjectProperty ;
    rdfs:label "has organic or functional provenance"@en,
        "tiene como procedencia orgánica o funcional"@es,
        "a pour provenance organique ou fonctionnelle"@fr ;
    rdfs:comment """Connects a Record Resource or an Instantiation to an Agent that
         creates or accumulates it, receives it, or sends it, or to an Activity that generates
         it."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Activity :Agent ) ] ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrganicOrFunctionalProvenanceOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :organicOrFunctionalProvenanceRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               organicOrFunctionalProvenanceRelation_role object property."""@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Property added as a superproperty of hasProvenance and
               documents, along with its inverse property. Shortcut also added."""@en ] .

:hasOrganicProvenanceDate a owl:ObjectProperty ;
    rdfs:label "has organic provenance date"@en,
        "tiene como fecha de procedencia orgánica"@es,
        "a pour date de provenance organique"@fr ;
    rdfs:comment """Inverse of 'is date associated with organic provenance of' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isOrganicProvenanceDateOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :organicProvenanceRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2025-03-13" ;
            rdf:value "Added French and Spanish labels."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:hasSubordinateTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "has subordinate transitive"@en,
        "tiene como subordinado o subordinada a transitivo"@es,
        "a pour subalterne transitif"@fr ;
    rdfs:comment """Connects an Agent to an Agent that is directly or indirectly
         hierarchically inferior. This is a transitive relation."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrHadSubordinate ;
    owl:inverseOf :isSubordinateToTransitive ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current subordination relations between agents (the past
               subordination relation also being added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:includesOrIncluded a owl:ObjectProperty ;
    rdfs:label "includes or included"@en,
        "incluye o incluía"@es,
        "inclut ou a inclus"@fr ;
    rdfs:comment """Connects a Record Set to a Record or Record Set it aggregates, or
         aggregated in the past."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:subPropertyOf :hasOrHadPart,
        :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :isOrWasIncludedIn ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "includes")."""@en ],
        [ dc:date "2023-06-05" ;
            rdf:value """Made this object property a subproperty of
               hasOrHadPart."""@en ] ;
    skos:scopeNote """A Record or Record Set can be aggregated in one or many Record
         Sets simultaneously or through time."""@en ;
    :RiCCMCorrespondingComponent """RiC-R024 ('includes or included'
         relation)"""@en .

:intellectualPropertyRightsRelation_role a owl:ObjectProperty ;
    rdfs:label """has the role of the Intellectual Property Rights
         Relation"""@en,
        """desempeña el papel de la Relación de propiedad
         intelectual"""@es,
        "a le rôle de la Relation de propriété intellectuelle"@fr ;
    rdfs:comment """Connects an IntellectualPropertyRightsRelation to itself. It is a
         property that can stand for an instance of the class when necessary, e.g. when you explore
         a knowledge graph."""@en ;
    rdfs:domain :IntellectualPropertyRightsRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :IntellectualPropertyRightsRelation ;
    rdfs:subPropertyOf :authorityRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the IntellectualPropertyRightsRelation
               rolified class. Declared it as reflexive. Declared it(s)
               superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the IntellectualPropertyRightsRelation
         class. It should be used only when you have to manage instances of the
         IntellectualPropertyRightsRelation class, to connect each instance to itself, in order to
         be able to infer, using OWL-RL and property paths, the two shortcuts corresponding to this
         n-ary class."""@en .

:isAccumulatorOf a owl:ObjectProperty ;
    rdfs:label "is accumulator of"@en,
        "es acumulador(a) de"@es,
        "accumule"@fr ;
    rdfs:comment "Inverse of 'has accumulator' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isOrganicProvenanceOf ;
    owl:inverseOf :hasAccumulator ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :accumulationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new accumulationRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               and corresponding CM component (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "accumulates")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R028i ('is accumulator of'
         relation)"""@en .

:isOrWasAppellationOf a owl:ObjectProperty ;
    rdfs:label "is or was appellation of"@en,
        "es o era la denominación de"@es,
        "est ou a été l’appellation de"@fr ;
    rdfs:comment """Connects an Appellation to a Thing that it designates or
         designated."""@en ;
    rdfs:domain :Appellation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadAppellation ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :appellationRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Added the property chain axiom so that this property is
               formally defined as a shortcut (the inverse property already was)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new appellationRelation_role
               object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (the name of this property in RiC-O 0.1 was "isAppellationOf")."""@en ] .

:isOrWasComponentOf a owl:ObjectProperty ;
    rdfs:label "is or was component of"@en,
        "es o era componente de"@es,
        "est ou a été un composant de"@fr ;
    rdfs:comment "Inverse of 'has or had component' object property."@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isInstantiationAssociatedWithInstantiation,
        :isOrWasPartOf ;
    owl:inverseOf :hasOrHadComponent ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "isComponentOf")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R004i ('is or was component of'
         relation)"""@en .

:isOrWasConstituentOf a owl:ObjectProperty ;
    rdfs:label "is or was constituent of"@en,
        "es o era elemento constitutivo de"@es,
        "est ou a été un constituant de"@fr ;
    rdfs:comment """Inverse of 'has or had constituent' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasPartOf,
        :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :hasOrHadConstituent ;
    skos:changeNote [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the range."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "isConstituentOf")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R003i ('is or was constituent of'
         relation)"""@en .

:isOrWasContainedBy a owl:ObjectProperty ;
    rdfs:label "is or was contained by"@en,
        "está o estaba contenido en"@es,
        "est ou a été contenu par"@fr ;
    rdfs:comment "Inverse of 'contains or contained' object property."@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isAssociatedWithPlace,
        :isOrWasPartOf,
        :isPlaceAssociatedWith ;
    owl:inverseOf :containsOrContained ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "containedBy")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R007i ('is or was contained by'
         relation)"""@en .

:isOrWasControllerOf a owl:ObjectProperty ;
    rdfs:label "is or was controller of"@en,
        "es o era controlador de"@es,
        "contrôle ou a contrôlé"@fr ;
    rdfs:comment """Connects an Agent to another Agent it controls or
         controlled."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrHadAuthorityOver,
        :hasOrHadSubordinate ;
    owl:inverseOf :hasOrHadController ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :agentControlRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment)."""@en ],
        [ dc:date "2024-09-02" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new agentControlRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               corresponding CM component name (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "controls")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R041 ('is or was controller of'
         relation)"""@en .

:isOrWasIncludedIn a owl:ObjectProperty ;
    rdfs:label "is or was included in"@en,
        "está o estaba incluido en"@es,
        "est ou a été inclus dans"@fr ;
    rdfs:comment "Inverse of 'includes or included' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasPartOf,
        :isRecordResourceAssociatedWithRecordResource ;
    owl:inverseOf :includesOrIncluded ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "includedIn")."""@en ],
        [ dc:date "2023-06-05" ;
            rdf:value """Made this object property a subproperty of
               isOrWasPartOf."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R024i ('is or was included in'
         relation)"""@en .

:isOrWasInstantiationOf a owl:ObjectProperty ;
    rdfs:label "is or was instantiation of"@en,
        "es o era instanciación de"@es,
        "est ou a été une instanciation de"@fr ;
    rdfs:comment """Inverse of 'has or had instantiation' object
         property."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadInstantiation ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :recordResourceToInstantiationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceToInstantiationRelation_role object property."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI and label (changed made in order to make RiC-O
               compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "instantiates")."""@en ],
        [ dc:date "2023-08-29" ;
            rdf:value """Updated the IRI, inverse property, definition, labels and
               RiCMCorrespondingComponent; this in order to make the specification compliant with
               RiC-CM 1.0. The name of the property in RiC-O 0.2 was 'is instantiation
               of'."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R025i ('is or was instantiation of'
         relation)"""@en .

:isOrWasMainSubjectOf a owl:ObjectProperty ;
    rdfs:label "is or was main subject of"@en,
        "es o era la materia principal de"@es,
        "est ou a été le sujet principal de"@fr ;
    rdfs:comment """Inverse of 'has or had main subject' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :isOrWasSubjectOf ;
    owl:inverseOf :hasOrHadMainSubject ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, super property
               IRI, textual definition (changed made in order to make RiC-O compliant with RiC-CM
               0.2; the name of this property in RiC-O 0.1 was "isMainSubjectOf")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R020i ('is or was main subject of'
         relation)"""@en .

:isOrWasParticipantIn a owl:ObjectProperty ;
    rdfs:label "is or was participant in"@en,
        "es o era participante de"@es,
        "participe ou a participé à"@fr ;
    rdfs:comment """Inverse of 'has or had participant' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isAssociatedWithEvent ;
    owl:inverseOf :hasOrHadParticipant ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "involvedIn")."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R058i ('is or was participant in'
         relation)"""@en .

:isOrWasSubdivisionOf a owl:ObjectProperty ;
    rdfs:label "is or was subdivision of"@en,
        "es o era subdivisión de"@es,
        "est ou a été une subdivision de"@fr ;
    rdfs:comment """Inverse of 'has or had subdivision' object
         property."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isOrWasPartOf,
        :isOrWasSubordinateTo ;
    owl:inverseOf :hasOrHadSubdivision ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :groupSubdivisionRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               groupSubdivisionRelation_role object property."""@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRIs (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "isSubdivisionOf")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R005i ('is or was subdivision'
         relation)"""@en .

:isOrWasSubeventOf a owl:ObjectProperty ;
    rdfs:label "is or was subevent of"@en,
        "es o era parte de evento de"@es,
        "est ou a été un événement constituant de"@fr ;
    rdfs:comment "Inverse of 'has or had subevent' object property."@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isAssociatedWithEvent,
        :isEventAssociatedWith,
        :isOrWasPartOf ;
    owl:inverseOf :hasOrHadSubevent ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property URI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "isSubEventOf")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R006i ('is or was subevent of'
         relation)"""@en .

:isOrWasSubjectOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was subject of some members of"@en,
        "es o era la matería de algunos miembros de"@es,
        "est ou a été le sujet de certains membres de"@fr ;
    rdfs:comment """Inverse of 'has or had some members with subject' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrHadSomeMembersWithSubject ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrganicOrFunctionalProvenanceOf a owl:ObjectProperty ;
    rdfs:label "is organic or functional provenance of"@en,
        "es procedencia orgánica o funcional de"@es,
        "est la provenance organique ou fonctionnelle de"@fr ;
    rdfs:comment """Inverse of 'has organic or functional provenance' object
         property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Activity :Agent ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasOrganicOrFunctionalProvenance ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :organicOrFunctionalProvenanceRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               organicOrFunctionalProvenanceRelation_role object property."""@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Property added as a superproperty of isProvenance and
               documentedBy, along with its inverse property. Shortcut also added."""@en ] .

:isOrganicProvenanceDateOf a owl:ObjectProperty ;
    rdfs:label "is organic provenance date of"@en,
        "es la fecha de procedencia orgánica de"@es,
        "est la date de provenance organique de"@fr ;
    rdfs:comment """Connects a Date associated with the organic provenance of a Record
         Resource or Instantiation to that Record Resource or Instantiation."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isDateAssociatedWith ;
    owl:inverseOf :hasOrganicProvenanceDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :organicProvenanceRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2025-03-13" ;
            rdf:value "Added French and Spanish labels."@en ],
        [ dc:date "2024-12-19" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:isSubordinateToTransitive a owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "is subordinate to transitive"@en,
        "está subordinado(a) a transitivo"@es,
        "est subalterne de transitif"@fr ;
    rdfs:comment """Connects an Agent to an Agent that is directly or indirectly
         hierarchically superior. This is a transitive relation."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isOrWasSubordinateTo ;
    owl:inverseOf :hasSubordinateTransitive ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current subordination relations between agents (the past
               subordination relation also being added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:knowingOfRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Knowing Of Relation"@en,
        """desempeña el papel de la Relación de conocimieto indirecto entre
         personas"""@es,
        """a le rôle de la Relation de connaissance à propos d’une
         personne"""@fr ;
    rdfs:comment """Connects a KnowingOfRelation to itself. It is a property that can
         stand for an instance of the class when necessary, e.g. when you explore a knowledge
         graph."""@en ;
    rdfs:domain :KnowingOfRelation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :KnowingOfRelation ;
    rdfs:subPropertyOf :agentToAgentRelation_role ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: created
               the object property, with domain and range the KnowingOfRelation rolified class.
               Declared it as reflexive. Declared it(s) superproperty(ies)."""@en ],
        [ dc:date "2024-08-02" ;
            rdf:value """Removed global reflexivity (leads to
               inconsistency)."""@en ] ;
    skos:scopeNote """This property "rolifies" the KnowingOfRelation class. It should
         be used only when you have to manage instances of the KnowingOfRelation class, to connect
         each instance to itself, in order to be able to infer, using OWL-RL and property paths, the
         two shortcuts corresponding to this n-ary class."""@en .

:knows a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "knows"@en,
        "conoce a"@es,
        "connaît"@fr ;
    rdfs:comment """Connects two Persons that directly know each other during their
         existence. This relation is symmetric."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:propertyChainAxiom ( :thingIsConnectedToRelation :knowingRelation_role :relationConnects ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the description
               (rdfs:comment), skos:scopeNote."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new knowingRelation_role object
               property."""@en ] ;
    skos:scopeNote """The relation implies that the two Persons met or at least
         corresponded with each other."""@en ;
    :RiCCMCorrespondingComponent """RiC-R051 ('knows'
         relation)"""@en .

:leadershipRelation_role a owl:ObjectProperty ;
    rdfs:label "has the role of the Leadership Relation"@en,
        "desempeña el papel de la Relación de liderazgo"@es,
