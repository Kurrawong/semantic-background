            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasOrHadAllMembersWithLegalStatus a owl:ObjectProperty ;
    rdfs:label "has or had all members with legal status"@en,
