:hasOrHadAllMembersWithMainSubject a owl:ObjectProperty ;
    rdfs:label "has or had all members with main subject"@en,
        "incluye o incluía miembros, todos con matería principal"@es,
        """inclut ou a inclus des membres ayant tous pour principal
         sujet"""@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is the main subject of all
         the Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadAllMembersWithSubject,
        :hasOrHadMainSubject ;
    owl:inverseOf :isOrWasMainSubjectOfAllMembersOf ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasOrHadAllMembersWithRecordState a owl:ObjectProperty ;
    rdfs:label "has or had all members with record state"@en,
        """incluye o incluía miembros, todos con estado de
         documento"""@es,
        "inclut ou a inclus des membres ayant tous pour état"@fr ;
    rdfs:comment """Connects a Record Set and a Record State that categorizes all the
         Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordState ;
    rdfs:subPropertyOf :hasOrHadAllMembersWithType ;
    owl:inverseOf :isOrWasRecordStateOfAllMembersOf ;
