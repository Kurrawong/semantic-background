:isOrWasLanguageOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was language of some members of"@en,
        "es o era lengua de algunos miembros de"@es,
        "est ou a été la langue de certains membres de"@fr ;
    rdfs:comment """Connects a Language and a Record Set whose some present or past
         Record or Record Part members use that Language."""@en ;
    rdfs:domain :Language ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
