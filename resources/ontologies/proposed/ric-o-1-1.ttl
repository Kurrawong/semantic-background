        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasIdentifierType a owl:ObjectProperty ;
    rdfs:label "has identifier type"@en,
        "tiene como tipo de identificador"@es,
        "a pour type d’identifiant"@fr ;
    rdfs:comment """Connects an Identifier and an Identifier Type that categorizes
         it."""@en ;
    rdfs:domain :Identifier ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
