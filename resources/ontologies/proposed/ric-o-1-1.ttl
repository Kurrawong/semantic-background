:hasMigrationDate a owl:ObjectProperty ;
    rdfs:label "has migration date"@en,
        "tiene como fecha de migración"@es,
        "a pour date de migration"@fr ;
    rdfs:comment "Inverse of 'is migration date of' object property."@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasDerivationDate ;
    owl:inverseOf :isMigrationDateOf ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :migrationRelation_role :relationHasDate ) ;
    skos:changeNote [ dc:date "2025-03-01" ;
            rdf:value """Made this property a subproperty of the new 'hasDerivationDate'
               property."""@en ],
        [ dc:date "2025-03-13" ;
            rdf:value "Added the property chain axiom."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Added in RiC-O 1.1."@en ] .

:hasOrHadAgentName a owl:ObjectProperty ;
    rdfs:label "has or had agent name"@en,
        "tiene o tenía como nombre de agente"@es,
        "a ou a eu pour nom d’agent"@fr ;
    rdfs:comment """Connects an Agent and (one of) its present or past Agent
         Name."""@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :AgentName ;
    rdfs:subPropertyOf :hasOrHadName ;
    owl:inverseOf :isOrWasAgentNameOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (the name of this property in RiC-O 0.1 was "hasAgentName")."""@en ] .

:hasOrHadAllMembersWithAccumulationDate a owl:ObjectProperty ;
    rdfs:label "has or had all members with accumulation date"@en,
        """incluye o incluía miembros, todos como fecha de
         acumulación"""@es,
        """inclut ou a inclus des membres ayant tous pour date
         d'accumulation"""@fr ;
    rdfs:comment """Inverse of 'is or was accumulation date of all members of' object
         property."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isAssociatedWithDate ;
    owl:inverseOf :isOrWasAccumulationDateOfAllMembersOf ;
    skos:changeNote [ dc:date "2024-10-04" ;
            rdf:value "Added in RiC-O 1.1."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ] .

:hasOrHadAllMembersWithContentType a owl:ObjectProperty ;
    rdfs:label "has or had all members with content type"@en,
        "incluye o incluía miembros, todos con tipo de contenido"@es,
        """inclut ou a inclus des membres ayant tous pour type de
         contenu"""@fr ;
    rdfs:comment """Connects a Record Set and a Content Type that categorizes all the
         Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ContentType ;
    rdfs:subPropertyOf :hasOrHadAllMembersWithType ;
    owl:inverseOf :isOrWasContentTypeOfAllMembersOf ;
    skos:changeNote [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasOrHadAllMembersWithCreationDate a owl:ObjectProperty ;
    rdfs:label "has or had all members with creation date"@en,
        "incluye o incluía miembros, todos con fecha de creación"@es,
        """inclut ou a inclus des membres ayant tous pour date de
         création"""@fr ;
    rdfs:comment """Inverse of 'is or was creation date of all members of' object
         property."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :hasBeginningDate ;
    owl:inverseOf :isOrWasCreationDateOfAllMembersOf ;
    skos:changeNote [ dc:date "2023-10-12" ;
            rdf:value "Added the French label"@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """Renamed the property in order to take the past members of the
               record set into account. Adjusted the annotations accordingly."""@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R081i ('has or had all members with creation
         date' relation)"""@en .

