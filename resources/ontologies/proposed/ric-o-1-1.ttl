        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isOrWasLeaderOf a owl:ObjectProperty ;
    rdfs:label "is or was leader of"@en,
        "es o era líder de"@es,
        "est ou a été le dirigeant de"@fr ;
    rdfs:comment """Connects a Person to the Group that Person leads or led in the
         past."""@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isOrWasControllerOf ;
    owl:inverseOf :hasOrHadLeader ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :leadershipRelation_role :relationHasTarget ) ;
