:isOrWasTitleOf a owl:ObjectProperty ;
    rdfs:label "is or was title of"@en,
        "es o era título de"@es,
        "est ou a été l’intitulé de"@fr ;
    rdfs:comment """Connects a Title to a Record Resource, Instantiation or Rule that
         it designated or designates."""@en ;
    rdfs:domain :Title ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource :Rule ) ] ;
    rdfs:subPropertyOf :isOrWasNameOf ;
