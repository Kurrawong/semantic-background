        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isFromUseDateOf a owl:ObjectProperty ;
    rdfs:label "is from use date of"@en,
        "es fecha desde la que se usa de"@es,
        "est la date à partir de laquelle est utilisé"@fr ;
    rdfs:comment """Connects a Date to an Appellation, when it is the date at which
         the Appellation was first used."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Appellation ;
    rdfs:subPropertyOf :isBeginningDateOf ;
    owl:inverseOf :wasUsedFromDate ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Made this property subPropertyOf isBeginningDateOf."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isIdentifierTypeOf a owl:ObjectProperty ;
    rdfs:label "is identifier type of"@en,
        "es tipo de identificador de"@es,
        "est le type d’identifiant de"@fr ;
    rdfs:comment """Connects an Identifier Type and an Identifier that it
