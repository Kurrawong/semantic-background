:isOrWasContentTypeOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was content type of all members of"@en,
        "es o era tipo de contenido de todos los miembros de"@es,
        "est ou a été le type de contenu de tous les membres de"@fr ;
