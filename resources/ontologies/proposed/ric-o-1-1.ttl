        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:hasOrHadAnalogueInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had analogue instantiation"@en,
        "tiene o tenía como instanciación analogica"@es,
        "a ou a eu pour instanciation analogique"@fr ;
    rdfs:comment """Connects a record resource to one of its analogue instantiations,
         whether it exists or has been lost or destroyed."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasOrHadInstantiation ;
    owl:inverseOf :isOrWasAnalogueInstantiationOf ;
    skos:changeNote [ dc:date "2023-08-29" ;
            rdf:value "Added the property."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """In some situations, it may be useful or necessary to connect a
         record resource to an analogue instantiation that no longer exists or has been
         lost."""@en .

:hasOrHadCoordinates a owl:ObjectProperty ;
    rdfs:label "has or had coordinates"@en,
        "tiene como coordenadas de lugar"@es,
        "a ou a eu pour coordonnées"@fr ;
    rdfs:comment """Connects a Physical Location to its past or present coordinates in
         a reference system."""@en ;
    rdfs:domain :PhysicalLocation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Coordinates ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :isOrWasCoordinatesOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-29" ;
            rdf:value "fixed the English label (added the past tense.)"@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (the name of this property in RiC-O 0.1 was "hasCoordinates")."""@en ] .

:hasOrHadCorporateBodyType a owl:ObjectProperty ;
    rdfs:label "has or had corporate body type"@en,
        "tiene o tenía como tipo de institucion"@es,
        "a ou a eu pour type de collectivité"@fr ;
    rdfs:comment """Connects a Corporate Body to a Corporate Body Type which
         categorizes or categorized it."""@en ;
    rdfs:domain :CorporateBody ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :CorporateBodyType ;
    rdfs:subPropertyOf :hasOrHadType ;
    owl:inverseOf :isOrWasCorporateBodyTypeOf ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (the name of this property in RiC-O 0.1 was
               "hasCorporateBodyType")."""@en ] .

:hasOrHadDigitalInstantiation a owl:ObjectProperty ;
    rdfs:label "has or had digital instantiation"@en,
        "tiene o tenía como instanciación digital"@es,
        "a ou a eu pour instanciation numérique"@fr ;
    rdfs:comment """Connects a record resource to one of its digital instantiations,
         whether it exists or has been lost or destroyed."""@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :hasOrHadInstantiation ;
    owl:inverseOf :isOrWasDigitalInstantiationOf ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-29" ;
            rdf:value "Added the property."@en ] ;
    skos:scopeNote """This property can be used, among other cases, when you want to
         convert findings aids encoded in EAD/XML and need a simple and accurate migration path to
         process dao or daogrp EAD elements. Also, in some situations, it may be useful or necessary
         to connect a record resource to a digital instantiation that no longer exists or or has
         been lost."""@en .

:hasOrHadEmployer a owl:ObjectProperty ;
    rdfs:label "has or had employer"@en,
        "tiene o tenía como empleador"@es,
        "a ou a eu pour employeur"@fr ;
    rdfs:comment "Inverse of 'is or was employer of' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :CorporateBody :Person ) ] ;
    rdfs:subPropertyOf :hasOrHadController ;
    owl:inverseOf :isOrWasEmployerOf ;
    skos:changeNote [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O 1.0."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value """Changed the domain and range of the property. Added a
               rdfs:comment. Removed the isOrWasMemberOf super-property."""@en ],
        [ dc:date "2023-10-13" ;
            rdf:value "Fixed the lang of the French label."@en ] .

:hasOrHadHolder a owl:ObjectProperty ;
    rdfs:label "has or had holder"@en,
        "tiene o tenía como conservador a"@es,
        "est ou a été détenu par"@fr ;
    rdfs:comment "Inverse of 'is or was holder of' object property."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrHadManager ;
    owl:inverseOf :isOrWasHolderOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :recordResourceHoldingRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               recordResourceHoldingRelation_role object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (changed made in order to make RiC-O compliant with RiC-CM 0.2;
               the name of this property in RiC-O 0.1 was "heldBy")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R039i ('has or had holder'
         relation)"""@en .

:hasOrHadIdentifier a owl:ObjectProperty ;
    rdfs:label "has or had identifier"@en,
        "tiene o tenía como identificador"@es,
        "a ou a eu pour identifiant"@fr ;
    rdfs:comment """Connects a Thing to one of its past or present
         Identifiers."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Identifier ;
    rdfs:subPropertyOf :hasOrHadAppellation ;
    owl:inverseOf :isOrWasIdentifierOf ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition,
               super property IRI (the name of this property in RiC-O 0.1 was
               "identifiedBy")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:hasOrHadIntellectualPropertyRightsHolder a owl:ObjectProperty ;
    rdfs:label "has or had intellectual property rights holder"@en,
        """tiene o tenía como titular de derechos de propiedad intelectual
         a"""@es,
        """a ou a eu comme détenteur des droits de propriété
         intellectuelle"""@fr ;
    rdfs:comment """Inverse of 'is or was holder of intellectual property rights of'
         object property."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Group :Person :Position ) ] ;
    rdfs:subPropertyOf :isOrWasUnderAuthorityOf ;
    owl:inverseOf :isOrWasHolderOfIntellectualPropertyRightsOf ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :intellectualPropertyRightsRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name
               of this property in RiC-O 0.1 was "intellectualPropertyRightsHeldBy")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new
               intellectualPropertyRightsRelation_role object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2024-09-02" ;
            rdf:value "Fixed the French label."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R040i ('has or had intellectual property rights
         holder ' relation)"""@en .

:hasOrHadJurisdiction a owl:ObjectProperty ;
