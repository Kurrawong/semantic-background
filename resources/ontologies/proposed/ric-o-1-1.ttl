:hasOrHadSomeMembersWhoseContentMainlyRepresents a owl:ObjectProperty ;
    rdfs:label "has or had some members whose content mainly represents"@en,
        """incluye o incluía algunos miembros cuyo contenido representa
         principalmente"""@es,
        """inclut ou a inclus des membres dont le contenu représente
         principalement"""@fr ;
    rdfs:comment """Connects a Record Set and a Thing that is the main element
         represented by the content of some of the members of the Records or Record Parts that are
         or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadSomeMembersWhoseContentRepresents,
        :hasOrHadSomeMembersWithMainSubject ;
    owl:inverseOf :isOrWasMainThingRepresentedByContentOfSomeMembersOf ;
    skos:changeNote [ dc:date "2025-04-06" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:hasOrHadSomeMembersWithContentType a owl:ObjectProperty ;
    rdfs:label "has or had some members with content type"@en,
        """incluye o incluía algunos miembros con tipo de
         contenido"""@es,
        """inclut ou a inclus des membres ayant pour type de
         contenu"""@fr ;
    rdfs:comment """Connects a Record Set and a Content Type that categorizes some of
         the Records or Record Parts that are or were included in the Record Set."""@en ;
    rdfs:domain :RecordSet ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :ContentType ;
    rdfs:subPropertyOf :hasOrHadSomeMembersWithType ;
    owl:inverseOf :isOrWasContentTypeOfSomeMembersOf ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2025-04-06" ;
            rdf:value "Adjusted the Spanish label."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-12-28" ;
            rdf:value """Object property added for handling the case where a Record Set
               is described as having all or some members that belong to some category (see RiC-CM
               0.2 attributes section, #4.4 on Record Set, Record and Record Part
               attributes)."""@en ] .

:hasOrHadSomeMembersWithDocumentaryFormType a owl:ObjectProperty ;
