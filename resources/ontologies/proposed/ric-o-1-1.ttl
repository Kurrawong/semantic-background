    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :MandateRelation ;
    rdfs:subPropertyOf :thingIsContextOfRelation ;
    owl:inverseOf :authorizingAgent ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-13" ;
            rdf:value """Added a new rdfs:label in French and fixed the Spanish
               label."""@en ] .

:isBirthDateOf a owl:ObjectProperty ;
    rdfs:label "is birth date of"@en,
        "es fecha de nacimiento de"@es,
        "est la date de naissance de"@fr ;
    rdfs:comment """Connects a Date to a Person that was born on that
         Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isBeginningDateOf ;
    owl:inverseOf :hasBirthDate ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R070 ('is birth date of'
         relation)"""@en .

:isBirthPlaceOf a owl:ObjectProperty ;
    rdfs:label "is birth place of"@en,
        "es lugar de nacimiento de"@es,
        "est le lieu de naissance de"@fr ;
    rdfs:comment """Connects a Place to a Person who was born in that
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isPlaceAssociatedWithAgent ;
    owl:inverseOf :hasBirthPlace ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment)."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Fixed the range."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Added for RiC-O v1.0."@en ] .

:isCarrierTypeOf a owl:ObjectProperty ;
    rdfs:label "is carrier type of"@en,
        "es tipo de soporte de"@es,
        "est le type de support de"@fr ;
    rdfs:comment """Connects a Carrier Type to an Instantiation whose carrier it
         categorizes."""@en ;
    rdfs:domain :CarrierType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasCarrierType ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value "Changed the super property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isChildOf a owl:ObjectProperty ;
    rdfs:label "is child of"@en,
        "es hijo o hija de"@es,
        "est l’enfant de"@fr ;
    rdfs:comment "Inverse of 'has child' object property."@en ;
    rdfs:domain :Person ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :hasAncestor ;
    owl:inverseOf :hasChild ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :childRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI and label (changed made in order to make RiC-O
               compliant with RiC-CM 0.2; the name of this property in RiC-O 0.1 was
               "hasParent")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new childRelation_role object
               property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-07" ;
            rdf:value """Added the property chain axiom so that this property is
               formally defined as a shortcut (the inverse property already was)."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R018i ('is child of'
         relation)"""@en .

:isCollectorOf a owl:ObjectProperty ;
    rdfs:label "is collector of"@en,
        "es coleccionista de"@es,
        "collecte"@fr ;
    rdfs:comment "Inverse of 'has collector' object property."@en ;
    rdfs:domain :Agent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isAccumulatorOf ;
    owl:inverseOf :hasCollector ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property and super property
               IRI, text definition, domain (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "collects")."""@en ] ;
    :RiCCMCorrespondingComponent """RiC-R030i ('is collector of'
         relation)"""@en .

:isContentTypeOf a owl:ObjectProperty ;
    rdfs:label "is content type of"@en,
        "es tipo de contenido de"@es,
        "est le type de contenu de"@fr ;
    rdfs:comment """Connects a Content Type to a Record or Record Part whose content
         it categorizes."""@en ;
    rdfs:domain :ContentType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasContentOfType ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the text definition and super property IRI."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isCopyOf a owl:ObjectProperty ;
    rdfs:label "is copy of"@en,
        "es copia de"@es,
        "est la copie de"@fr ;
    rdfs:comment "Inverse of 'has copy' object property."@en ;
    rdfs:domain :RecordResource ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :followsInTime,
        :hasGeneticLinkToRecordResource ;
    owl:inverseOf :hasCopy ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R012i ('is copy of'
         relation)"""@en .

:isCreationDateOf a owl:ObjectProperty ;
    rdfs:label "is creation date of"@en,
        "es fecha de creación de"@es,
        "est la date de création de"@fr ;
    rdfs:comment """Connects a Date to a Record Resource or Instantiation that was or
         will be created at this Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isBeginningDateOf,
        :isOrganicProvenanceDateOf ;
    owl:inverseOf :hasCreationDate ;
    owl:propertyChainAxiom ( :isDateAssociatedWithRelation :creationRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2024-12-19" ;
            rdf:value """Connect to CreationRelation via a sub-property chain, and make
               a sub-property of the new 'isOrganicProvenanceDateOf' object property."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\")."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Added the French label"@en ] ;
    skos:scopeNote """When used for a Record Set (e.g. a file), it is the creation
         date of the Record Set itself rather than the creation date of the members of the Record
         Set. To record the creation date of members of the Record Set, use 'is or was creation date
         of all members of', 'is or was creation date of most members of’ or 'is or was creation
         date of some members of’."""@en ;
    :RiCCMCorrespondingComponent """RiC-R080 ('is creation date of'
         relation)"""@en .

:isDateOfOccurrenceOf a owl:ObjectProperty ;
    rdfs:label "is date of occurrence of"@en,
        "es fecha de ocurrencia de"@es,
        "est la date d'occurrence de"@fr ;
    rdfs:comment """Connects a Date to an Event that occurred at this Date. An event
         or activity can be recurrent, which implies that one single event can be related to several
         dates."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isAssociatedWithEvent,
        :isDateAssociatedWith ;
    owl:inverseOf :occurredAtDate ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-13" ;
            rdf:value """Renamed the property to correct a spelling mistake. Also
               corrected the annotations when necessary."""@en ],
        [ dc:date "2023-10-17" ;
            rdf:value """Made this property a subproperty of
               isAssociatedWithEvent"""@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Added the property"@en ] ;
    :RiCCMCorrespondingComponent """RiC-R084 ('is date of occurrence of'
         relation)"""@en .

:isDateTypeOf a owl:ObjectProperty ;
    rdfs:label "is date type of"@en,
        "es tipo de fecha de"@es,
        "est le type de date de"@fr ;
    rdfs:comment "Connects a Date Type to a Date that it categorizes."@en ;
    rdfs:domain :DateType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Date ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasDateType ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-10" ;
            rdf:value "Added a rdfs:comment and a French rdfs:label."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ] .

:isDeathDateOf a owl:ObjectProperty ;
    rdfs:label "is death date of"@en,
        "es fecha de muerte de"@es,
        "est la date de décès de"@fr ;
    rdfs:comment "Connects a Date to a Person who died on that Date."@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isEndDateOf ;
    owl:inverseOf :hasDeathDate ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R072 ('is death date of'
         relation)"""@en .

:isDeathPlaceOf a owl:ObjectProperty ;
    rdfs:label "is death place of"@en,
        "es lugar de muerte de"@es,
        "est le lieu de décès de"@fr ;
    rdfs:comment """Connects a Place to a Person who died in that
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isPlaceAssociatedWithAgent ;
    owl:inverseOf :hasDeathPlace ;
    skos:changeNote [ dc:date "2023-10-26" ;
            rdf:value """Fixed the range and the French label of the
               property."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-19" ;
            rdf:value "Property added to RiC-0 1.0"@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the description (rdfs:comment)."@en ] .

:isDestructionDateOf a owl:ObjectProperty ;
    rdfs:label "is destruction date of"@en,
        "es fecha de destrucción de"@es,
        "est la date de destruction de"@fr ;
    rdfs:comment """Connects a Date to a Record Resource or Instantiation that was or
         will be destructed at that Date."""@en ;
    rdfs:domain :Date ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:subPropertyOf :isEndDateOf ;
    owl:inverseOf :hasDestructionDate ;
    skos:changeNote [ dc:date "2023-10-14" ;
            rdf:value "Added a rdfs:comment; same to the inverse property."@en ],
        [ dc:date "2023-10-12" ;
            rdf:value "Renamed deletion into destruction."@en ],
        [ dc:date "2023-09-22" ;
            rdf:value "Added in RiC-O 1.0."@en ],
        [ dc:date "2025-02-19" ;
            rdf:value "Changed definition (added \\"or will be\\") and range."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isDirectComponentOf a owl:ObjectProperty ;
    rdfs:label "is direct component of"@en,
        "es componente directo de"@es,
        "est le composant direct de"@fr ;
    rdfs:comment """Connects an Instantiation to another Instantiation of which it is
         a direct component."""@en ;
    rdfs:domain :Instantiation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Instantiation ;
    rdfs:subPropertyOf :isComponentOfTransitive,
        :isDirectPartOf ;
    owl:inverseOf :hasDirectComponent ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            skos:changeNote """Object property added, along with its inverse property,
               in order to enable to express current, direct, partitive relations between
               instantiations (the possibly indirect, transitive relation, superproperty of this
               one, being also added)."""@en ] .

:isDirectConstituentOf a owl:ObjectProperty ;
    rdfs:label "is direct constituent of"@en,
        "es elemento constitutivo directo de"@es,
        "est un constituant direct de"@fr ;
    rdfs:comment """Connects a Record or Record Part to another Record or Record Part
         of which it is a direct constituent."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isConstituentOfTransitive,
        :isDirectPartOf ;
    owl:inverseOf :hasDirectConstituent ;
    owl:propertyChainAxiom ( :isDirectConstituentOfProxy :proxyFor ) ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between records and
               other records or record parts (the possibly indirect, transitive relation,
               superproperty of this one, being also added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Added RecordPart to the range."@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2025-03-04" ;
            rdf:value """Added a property chain axiom relating it to use of
               rico:Proxy."""@en ] .

:isDirectSubdivisionOf a owl:ObjectProperty ;
    rdfs:label "is direct subdivision of"@en,
        "es subdivisión directa de"@es,
        "est la subdivision directe de"@fr ;
    rdfs:comment """Connects a Group to the Group it is a direct subdivision
         of."""@en ;
    rdfs:domain :Group ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Group ;
    rdfs:subPropertyOf :isDirectPartOf,
        :isDirectSubordinateTo,
        :isSubdivisionOfTransitive ;
    owl:inverseOf :hasDirectSubdivision ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between groups (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:isDirectSubeventOf a owl:ObjectProperty ;
    rdfs:label "is direct subevent of"@en,
        "es parte directa de evento de"@es,
        "est un événement constituant directement l’événement"@fr ;
    rdfs:comment """Connects an ongoing Event to the Event it is a direct part
         of."""@en ;
    rdfs:domain :Event ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isDirectPartOf,
        :isSubeventOfTransitive ;
    owl:inverseOf :hasDirectSubevent ;
    skos:changeNote [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between ongoing
               events (the possibly indirect, transitive relation, superproperty of this one, being
               also added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isDirectlyContainedBy a owl:ObjectProperty ;
    rdfs:label "is directly contained by"@en,
        "está directamente contenido en"@es,
        "est directement contenu par"@fr ;
    rdfs:comment """Connects a Place to a Place that directly contains
         it."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Place ;
    rdfs:subPropertyOf :isContainedByTransitive,
        :isDirectPartOf ;
    owl:inverseOf :directlyContains ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between places (the
               possibly indirect, transitive relation, superproperty of this one, being also
               added)."""@en ],
        [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ] .

:isDirectlyIncludedIn a owl:ObjectProperty ;
    rdfs:label "is directly included in"@en,
        "está directamente incluido en"@es,
        "est directement inclus dans"@fr ;
    rdfs:comment """Connects a Record to a Record or Record Set in which it is
         directly included."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isDirectPartOf,
        :isIncludedInTransitive ;
    owl:inverseOf :directlyIncludes ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value "Updated the labels."@en ],
        [ dc:date "2023-09-08" ;
            rdf:value """Object property added, along with its inverse property, in
               order to enable to express current, direct, partitive relations between Record Sets
               and their members (the possibly indirect, transitive relation, superproperty of this
               one, being also added)."""@en ],
        [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isDirectlyIncludedInProxy a owl:ObjectProperty ;
    rdfs:label "is directly included in proxy"@en,
        "está directamente incluido en el proxy"@es,
        "est directement inclus dans le proxy"@fr ;
    rdfs:comment """Connects a Record or Record Set to a Proxy of a Record Set which
         it is directly included in."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordSet ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Proxy ;
    rdfs:subPropertyOf :isDirectPartOf,
        :isIncludedInProxy ;
    owl:inverseOf :proxyDirectlyIncludes ;
    skos:changeNote [ dc:date "2025-03-04" ;
            rdf:value "Introduced in RiC-O 1.1."@en ],
        [ dc:date "2025-04-02" ;
            rdf:value "Added the French and Spanish labels."@en ] .

:isDocumentaryFormTypeOf a owl:ObjectProperty ;
    rdfs:label "is documentary form type of"@en,
        "es tipo documental de"@es,
        "est le type de document de"@fr ;
    rdfs:comment """Connects a Documentary Form Type to a Record or Record Part that
         it categorizes."""@en ;
    rdfs:domain :DocumentaryFormType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasDocumentaryFormType ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ] .

:isDraftOf a owl:ObjectProperty ;
    rdfs:label "is draft of"@en,
        "es borrador de"@es,
        "est l’ébauche de"@fr ;
    rdfs:comment "Connects a draft to the final version of a Record."@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range [ a owl:Class ;
            owl:unionOf ( :Record :RecordPart ) ] ;
    rdfs:subPropertyOf :hasGeneticLinkToRecordResource,
        :precedesInTime ;
    owl:inverseOf :hasDraft ;
    skos:changeNote [ dc:date "2023-11-12" ;
            rdf:value """Aligned with RiC-CM 1.0: updated the
               skos:scopeNote."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    skos:scopeNote """There may be zero to many intermediate records, ignored or
         unknown, between the two connected Records."""@en ;
    :RiCCMCorrespondingComponent """RiC-R011 ('is draft of'
         relation)"""@en .

:isEquivalentTo a owl:ObjectProperty,
        owl:SymmetricProperty ;
    rdfs:label "is equivalent to"@en,
        "equivale a"@es,
        "est l’équivalent de"@fr ;
    rdfs:comment "Connects two Things that are considered equivalent."@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] .

:isEventTypeOf a owl:ObjectProperty ;
    rdfs:label "is event type of"@en,
        "es tipo de evento de"@es,
        "est le type d’événement de"@fr ;
    rdfs:comment """Connects an Event Type to an Event that it
         categorizes."""@en ;
    rdfs:domain :EventType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Event ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasEventType ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value "changed the superproperty IRI."@en ],
        [ dc:date "2024-03-15" ;
            rdf:value "Fixed typo in rdfs:comment"@en ] .

:isEvidencedBy a owl:ObjectProperty ;
    rdfs:label "is evidenced by"@en,
        "se evidencia en"@es,
        "est attestée par"@fr ;
    rdfs:comment """Connects a Relation to a Record Resource that is used for proving
         is existence or describing it."""@en ;
    rdfs:domain :Relation ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordResource ;
    rdfs:subPropertyOf :relationConnects ;
    owl:inverseOf :evidences ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-12-27" ;
            rdf:value """Renamed the object property (was 'has source') and reduced its
               domain to Relation (the domain was the union of Record Resource and Relation) and its
               range to Record Resource (the range was the union of Agent and Record Resource).
               Consequently updated the superproperty, the labels, and added a
               rico:RiCCMCorrespondingComponent. Same for the inverse object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """Object property implementation of RiC-RA05 (Source
         of Relation attribute)."""@en .

:isExtentOf a owl:ObjectProperty ;
    rdfs:label "is extent of"@en,
        "es extensión de"@es,
        "est la mesure de"@fr ;
    rdfs:comment "Connects an Extent to a Thing"@en ;
    rdfs:domain :Extent ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :isRelatedTo ;
    owl:inverseOf :hasExtent ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value """Added a new rdfs:label in French; added an xml:lang attribute
               to the rdfs:comment."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value """Changed the range (was Instantiation or RecordResource) to
               Thing ; changed the definition accordingly"""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value "Fixed the range."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-10-28" ;
            rdf:value """Object property created along with the Extent class and its
               subclasses, in order to provide methods for handling extent accurately."""@en ] .

:isExtentTypeOf a owl:ObjectProperty ;
    rdfs:label "is extent type of"@en,
        "es tipo de extensión de"@es,
        "est le type de mesure de"@fr ;
    rdfs:comment """Connects an Extent Type to an Extent that it
         categorizes."""@en ;
    rdfs:domain :ExtentType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Extent ;
    rdfs:subPropertyOf :isOrWasTypeOf ;
    owl:inverseOf :hasExtentType ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2020-11-01" ;
            rdf:value """Object property added along with the Extent Type
               class."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2020-11-21" ;
            rdf:value "Added a rdfs:comment."@en ] .

:isFamilyTypeOf a owl:ObjectProperty ;
    rdfs:label "is family type of"@en,
        "es tipo de familia de"@es,
        "est le type de famille de"@fr ;
    rdfs:comment """Connects a Family Type to a Family that it
