:isOrWasLocationOfAgent a owl:ObjectProperty ;
    rdfs:label "is or was location of agent"@en,
        "es o era localización de agente"@es,
        "est ou a été la localisation de l'agent"@fr ;
    rdfs:comment """Connects a Place to an Agent that is or was located in this
         Place."""@en ;
    rdfs:domain :Place ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :isOrWasLocationOf,
        :isPlaceAssociatedWithAgent ;
    owl:inverseOf :agentHasOrHadLocation ;
    skos:changeNote [ dc:date "2023-11-27" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-10-20" ;
            rdf:value "Added for RiC-O 1.0."@en ],
        [ dc:date "2023-10-26" ;
            rdf:value "Renamed the property and added an rdfs:comment."@en ] .

:isOrWasMainSubjectOfAllMembersOf a owl:ObjectProperty ;
    rdfs:label "is or was main subject of all members of"@en,
        "es o era la materia principal de todos los miembros de"@es,
        "est ou a été le sujet principal de tous les membres de"@fr ;
    rdfs:comment """Inverse of 'has or had all members with main subject' object
         property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasMainSubjectOf,
        :isOrWasSubjectOfAllMembersOf ;
    owl:inverseOf :hasOrHadAllMembersWithMainSubject ;
    skos:changeNote [ dc:date "2025-04-05" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasMainThingRepresentedByContentOfSomeMembersOf a owl:ObjectProperty ;
    rdfs:label """is or was main thing represented by content of some members
         of"""@en,
        """es o era lo principal representado por el contenido de algunos
         miembros de"""@es,
        """est ou a été la chose principale représentée par le contenu de
         certains membres de"""@fr ;
    rdfs:comment """Inverse of 'has or had some members whose content mainly
         represents' object property."""@en ;
    rdfs:domain :Thing ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :RecordSet ;
    rdfs:subPropertyOf :isOrWasMainSubjectOfSomeMembersOf,
        :isOrWasRepresentedByContentOfSomeMembersOf ;
    owl:inverseOf :hasOrHadSomeMembersWhoseContentMainlyRepresents ;
    skos:changeNote [ dc:date "2025-04-06" ;
            rdf:value "Introduced in RiC-O 1.1."@en ] .

:isOrWasMandateTypeOf a owl:ObjectProperty ;
    rdfs:label "is or was mandate type of"@en,
        "es o era tipo de norma de"@es,
        "est ou a été le type de mandat de"@fr ;
    rdfs:comment """Connects a Mandate Type to a Mandate that it categorized or
         categorizes."""@en ;
    rdfs:domain :MandateType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Mandate ;
    rdfs:subPropertyOf :isOrWasRuleTypeOf ;
    owl:inverseOf :hasOrHadMandateType ;
    skos:changeNote [ dc:date "2024-03-15" ;
            rdf:value "Make capitalisation of rdfs:comment consistent."@en ],
        [ dc:date "2023-11-13" ;
            rdf:value """Added the property, and its inverse one, following the creation
               of the MandateType class, that corresponds to the new Mandate Type attribute in
               RiC-CM 1.0."""@en ] .

:isOrWasOccupationTypeOf a owl:ObjectProperty ;
    rdfs:label "is or was occupation type of"@en,
        "es o era tipo de ocupación de"@es,
        "est ou a été le type d’occupation de"@fr ;
    rdfs:comment """Connects an Occupation Type to a Person whose occupation is or was
         categorized by it."""@en ;
    rdfs:domain :OccupationType ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isOrWasDemographicGroupOf ;
    owl:inverseOf :hasOrHadOccupationOfType ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition, super property IRI (the name of this property in RiC-O 0.1 was
               "isOccupationTypeOf")."""@en ] .

:isOrWasOccupiedBy a owl:ObjectProperty ;
    rdfs:label "is or was occupied by"@en,
        "está o estaba ocupado por"@es,
        "est ou a été occupé par"@fr ;
    rdfs:comment "Inverse of 'occupies or occupied' object property."@en ;
    rdfs:domain :Position ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Person ;
    rdfs:subPropertyOf :isAgentAssociatedWithAgent ;
    owl:inverseOf :occupiesOrOccupied ;
    owl:propertyChainAxiom ( :thingIsTargetOfRelation :positionHoldingRelation_role :relationHasSource ) ;
    skos:changeNote [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, text definition
               (changed made in order to make RiC-O compliant with RiC-CM 0.2; the name of this
               property in RiC-O 0.1 was "occupiedBy")."""@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new positionHoldingRelation_role
               object property."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R054i ('is or was occupied by'
         relation)"""@en .

:isOrWasOwnerOf a owl:ObjectProperty ;
    rdfs:label "is or was owner of"@en,
        "es o era poseedor(a) de"@es,
        "est ou a été propriétaire de"@fr ;
    rdfs:comment """Connects a Group, Person or Position to a Thing that this Agent
         owns or owned."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Group :Person :Position ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Thing ;
    rdfs:subPropertyOf :hasOrHadAuthorityOver ;
    owl:inverseOf :hasOrHadOwner ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :ownershipRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
               the property chain axiom so that it now involves the new ownershipRelation_role
               object property."""@en ],
        [ dc:date "2023-08-28" ;
            rdf:value "Added a new rdfs:label in French."@en ],
        [ dc:date "2021-01-22" ;
            rdf:value """changed the IRI, label, inverse property IRI, textual
               definition, super property IRI (changed made in order to make RiC-O compliant with
               RiC-CM 0.2; the name of this property in RiC-O 0.1 was "isOwnerOf")."""@en ],
        [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ] ;
    :RiCCMCorrespondingComponent """RiC-R037 ('is or was owner of'
         relation)"""@en .

:isOrWasPerformedBy a owl:ObjectProperty ;
    rdfs:label "is or was performed by"@en,
        "es o fue desarrollado por"@es,
        "est ou a été réalisée par"@fr ;
    rdfs:comment """Connects an Activity to an Agent that performed or performs the
         Activity."""@en ;
    rdfs:domain :Activity ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range :Agent ;
    rdfs:subPropertyOf :hasOrHadParticipant ;
    owl:inverseOf :performsOrPerformed ;
    owl:propertyChainAxiom ( :thingIsSourceOfRelation :performanceRelation_role :relationHasTarget ) ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-11-08" ;
            rdf:value """In order to get a system of rolified Relation classes: modified
