:physicalOrLogicalExtent a owl:DatatypeProperty ;
    rdfs:label "physical or logical extent"@en,
        "soporte físico o lógico"@es,
        "importance physique ou logique"@fr ;
    rdfs:comment """Countable characteristics of the content of an entity expressed as
         a quantity."""@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Instantiation :RecordResource ) ] ;
    rdfs:isDefinedBy <https://www.ica.org/standards/RiC/ontology> ;
    rdfs:range rdfs:Literal ;
    skos:changeNote [ dc:date "2023-11-02" ;
            rdf:value "Added a new rdfs:label in Spanish."@en ],
        [ dc:date "2023-08-25" ;
            rdf:value "Added a new rdfs:label in French."@en ] ;
    skos:scopeNote """Provided for usability reasons. Use only if you cannot use the
         subproperties (particularly if the same free text is being used in your current metadata
         for describing the record resource, carrier and instantiation extent)."""@en .

:placeRelation_role a owl:ObjectProperty ;
