PREFIX dc: <http://purl.org/dc/elements/1.1/>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX geo: <http://www.opengis.net/ont/geosparql#>
PREFIX geometry: <https://linked.data.gov.au/def/csdm/geometry/>
PREFIX ont: <https://linked.data.gov.au/def/csdm/geometry>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

geo:MultiSolid
    rdfs:subClassOf geometry:AbstractSolidGeometry ;
.

geo:Shell
    rdfs:subClassOf geometry:AbstractSolidGeometry ;
.

geo:asGMLTopo
    a owl:DatatypeProperty ;
    dc:description "The GML serialization of feature relationship topology"@en ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:gmlLiteral ;
    rdfs:subPropertyOf geo:hasSerialization ;
    skos:scopeNote "The Feature topology should be described using GML with references to the GML objects in the feature's hasGeometry property"@en ;
    schema:description "The GML serialization of topology" ;
    schema:name "asGMLTopo" ;
.

geo:touchesInward
    a owl:ObjectProperty ;
    rdfs:domain geometry:BoundaryFeature ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:Feature ;
    rdfs:subPropertyOf geo:sfTouches ;
    skos:editorialNote "Property chain axioms could be defined stating that if A hasGeometry G and A geo:touchesInward X and A geo:touchesOutward Y then X touches Y, X hasBoundary G, Y hasBoundary G. " ;
    schema:description "the subject features touches the object feature in the inward direction relative to the orientation of the geometry specified by the subject features hasGeometry subject." ;
    schema:name
        "touches inward" ;
.

geo:touchesOutward
    a owl:ObjectProperty ;
    rdfs:domain geometry:BoundaryFeature ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:Feature ;
    rdfs:subPropertyOf geo:sfTouches ;
    schema:description "the subject feature touches the object feature in the outward direction relative to the orientation of the subject feature hasGeometry subject." ;
    schema:name "touches outward" ;
.

skos:extrusion
    a owl:ObjectProperty ;
    rdfs:isDefinedBy ont: ;
    skos:editorialNote "A extrusion description may be limited to an orientation flag (isOutward) in which case local system rules may define the effective limit, if any. Alternatively a text description of specific requirements may be provided.  Implementations may extend this with explit models of rules for extrusion." ;
    schema:description "Description of extrusion requirements, typically a distance." ;
    schema:name "extrusion" ;
.

geometry:3DSpatialUnit
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geo:Feature ;
    foaf:depiction <https://surroundbitbucket.bitbucket.io/3d-cadastre/spec/3DSpatialUnit.png> ;
    schema:description "A 3D spatial unit is a feature that may be described by one or more geometries from which a 3D extent may be inferred. This caters for the cases of 3D objects described by planar or linear geometries and extents.  This recognises that although Cadastral Parcels are the core concern here, in general such 3D spatial units may be described for multiple purposes.  " ;
    skos:scopeNote "A general 3D spatial unit is an abstract represented a closed solid or multi-solid or other valid geometry from which a solid can be derived." ;
    schema:name "3D Spatial Unit" ;
    schema:workExample
        [
            a schema:ImageObject ;
            sh:order 0 ;
            schema:caption "Diagram for 3D Spatial Unit." ;
            schema:contentUrl "https://icsm-au.github.io/3d-csdm-design/2022/spec_files/3DSpatialUnit.png"^^xsd:anyURI ;
        ] ;
.

geometry:BoundaryEdge
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geometry:BoundaryFeature ;
    schema:description "A Boundary Line is a feature whose geometry is a connected set of lines representing the common part of two polygons share this set of oriented lines.  As a feature it can participate in topological relationships between features that may, or may not, have planar geometry representations, and observations about the nature of the boundary can be made. The inner and outer features may be swapped by inverting the orientation of the geometry primitive, thus a single orientable boundary line may be used to partially define boundaries of both touching features. An oriented linear ring geometry representation for the planar extend of a bounded feature may be calculated from the geometries of the set of boundary features, using the inward or outward topology to adjust orientation accordingly. " ;
    schema:name "Boundary Edge" ;
.

geometry:BoundaryFace
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geometry:BoundaryFeature ;
    skos:scopeNote "Note the outward feature may be absent, and if absent the optional boolean flag \"isTruncated\" may be set to true indicate that the geometry is a nominal closure for either an unbounded or impractically large extent." ;
    foaf:depiction <https://surroundbitbucket.bitbucket.io/3d-cadastre/spec/boundary_face.png> ;
    schema:description "A Boundary Face is a feature whose geometry is the orientable (possibly composite) surface where two solids touch.  As a feature it can participate in topological relationships between features that may, or may not, have solid geometry representations, and observations about the nature of the face can be made. The inner and outer features may be swapped by inverting the orientation of the geometry primitive, thus a single orientable boundary face may be used to define boundary faces of both touching features. The  shell of a feature may be computed from the set of faces defining boundaries. " ;
    schema:name "Boundary Face" ;
    schema:workExample 
        [
            a schema:TextObject ;
            schema:encodingFormat "text/turtle" ;
            schema:text """
      surveyobs_examples:blue_top_boundary
        a geometry:BoundaryFace ;
        geo:hasGeometry surveyobs_examples:blue_top ;
        geo:touchesInward examples:cp1 ;
        rdfs:label "blue_top boundary" ;
        skos:editorialNote "Example of a vertically unbounded boundary with a nominal solid geometry." ;
        geometry:isTruncated true ;
      .""" ;
        ] ,
        [
            a schema:ImageObject ;
            sh:order 0 ;
            schema:caption "Diagram for Boundary Face." ;
            schema:contentUrl "https://icsm-au.github.io/3d-csdm-design/2022/spec_files/face2.png"^^xsd:anyURI ;
        ] ,
        [
            a schema:ImageObject ;
            sh:order 0 ;
            schema:caption "Diagram for Boundary Face." ;
            schema:contentUrl "https://icsm-au.github.io/3d-csdm-design/2022/spec_files/boundary_face.png"^^xsd:anyURI ;
        ] ,
        [
            a schema:ImageObject ;
            sh:order 0 ;
            schema:caption "Diagram for Boundary Face." ;
            schema:contentUrl "https://icsm-au.github.io/3d-csdm-design/2022/spec_files/face.png"^^xsd:anyURI ;
        ] ;
.

geometry:BoundaryNode
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geometry:BoundaryFeature ;
    skos:editorialNote "Statement required regarding the topology here - are we interest in the touching features or the edges of those features - those edges may not be separately represented so it should be the bounded features.  If so - how does one identify the edges when building a topology?" ;
    schema:description "A Boundary Node is a feature whose geometry is a single Point representing the touching of two or more features at a single node.  As a feature it can participate in topological relationships between features that may, or may not, have planar geometry representations. " ;
    schema:name "Boundary Node" ;
.

geometry:ExtensionRule
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf 
        [
            a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty geo:isOutward ;
        ] ,
        [
            a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty geo:extension ;
        ] ,
        [
            a owl:Restriction ;
            owl:maxCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onProperty dc:description ;
        ] ,
        geometry:AbstractSolidGeometry ;
    schema:description "The description of an a limit for extension of a geometric object to form object of higher dimensionality (e.g. solid from a surface, line or point, line from a point).  Implementations must provide a conversion function to an equivalent higher dimensional object bounded by appropriate horizons." ;
    schema:name "Extension Rule" ;
.

geometry:ExtrudedCurve
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf
        geo:OrientableCurve ,
        geometry:ExtrudedGeometry ;
    schema:description "A volume defined by a Curve extended in 2 additional dimensions." ;
    schema:name "Extruded Curve" ;
.

geometry:ExtrudedSurface
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf
        geo:OrientableSurface ,
        geometry:ExtrudedGeometry ;
    foaf:depiction <https://surroundbitbucket.bitbucket.io/3d-cadastre/spec/face_truncated.png> ;
    schema:description "Is this a plane only - assumption is its extended from a surface, and that surface can be defined as a plane if this is the intended implementation." ;
    schema:name "Extruded Surface" ;
.

geometry:FeatureCollection
    a owl:Class ;
    dcterms:description "A Feature containing a collection of subsidiary features, possibly defining some common characteristics." ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geo:Feature ;
    schema:description "Implementable using GeoJSON FeatureCollection schema" ;
    schema:name "Feature Collection" ;
.

geometry:baseSurface
    a owl:ObjectProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:OrientableSurface ;
    schema:name "base surface" ;
.

geometry:boundary
    a owl:ObjectProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:CompositeCurve ;
    rdfs:subPropertyOf geo:hasGeometry ;
    schema:description "The boundary line for a surface footprint of a potentially 3D object. The surface is arbitrary and specific to the application domain." ;
    skos:scopeNote "Typically surface would be a nominal ground surface.  Note a simple LinearRing is a subclass of the CompositeCurve range of this property and may have coordinateDimension 2 or 3. " ;
    schema:name "boundary" ;
.

geometry:exterior
    a owl:ObjectProperty ;
    rdfs:domain owl:Thing ;
    rdfs:isDefinedBy ont: ;
    schema:name "exterior" ;
.

geometry:hasGeometryPart
    a owl:ObjectProperty ;
    rdfs:domain geo:Feature ;
    rdfs:isDefinedBy
        geo: ,
        <http://www.opengis.net/spec/geosparql/1.0/> ;
    rdfs:range geo:Geometry ;
    skos:scopeNote "A component geometry part may particpate in the definition of other Features, such as shared boundary." ;
    schema:description "A component of a Feature's geometry." ;
    schema:name "has geometry part" ;
.

geometry:hasTopology
    a owl:ObjectProperty ;
    dc:description "Topological representation of feature relationships using ISO19107 topology primitives" ;
    rdfs:domain geo:Feature ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geometry:BoundaryFeature ;
    schema:description "Representation of topological relationships to other features" ;
    schema:name "has topology" ;
.

geometry:isTruncated
    a owl:AnnotationProperty ;
    rdfs:range xsd:boolean ;
    schema:name "is truncated (nominal boundary)" ;
.

geometry:nodeFrom
    a owl:AnnotationProperty ;
    rdfs:subPropertyOf geometry:directedNode ;
    schema:description "equivalent to a GML directedNode with orientation \"+\"" ;
    schema:name "node from" ;
.

geometry:nodeTo
    a owl:AnnotationProperty ;
    rdfs:subPropertyOf geometry:directedNode ;
    schema:description "equivalent to a GML directedNode with orientation \"-\"" ;
    schema:name "node to" ;
.

geometry:solidMember
    a owl:ObjectProperty ;
    rdfs:domain geo:CompositeSolid ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:Solid ;
    schema:name "solid member" ;
.

geometry:surfaceMember
    a owl:ObjectProperty ;
    rdfs:domain geo:CompositeSurface ;
    rdfs:isDefinedBy ont: ;
    rdfs:range geo:OrientableSurface ;
    schema:name "surface member" ;
.

geo:Solid
    rdfs:subClassOf geometry:AbstractSolidGeometry ;
.

geo:extension
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:range xsd:decimal ;
    schema:description "The extension of an extruded geometry in the defined orientation, using the units of measure of the coordinate system of the base geometry." ;
    schema:name "extension" ;
.

geo:isOutward
    a owl:DatatypeProperty ;
    rdfs:isDefinedBy ont: ;
    rdfs:range xsd:boolean ;
    schema:description "true if orientation of extension is outward of oriented base geometry." ;
    schema:name "isOutward" ;
.

geometry:ExtrudedGeometry
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geometry:AbstractSolidGeometry ;
    schema:description "A higher dimension geometry generated by extending from a lower dimensional primitive." ;
    schema:name "Extruded Geometry" ;
.

geometry:directedNode
    a owl:AnnotationProperty ;
    schema:name "directed node" ;
.

geometry:AbstractSolidGeometry
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geo:Geometry ;
    foaf:depiction <https://surroundbitbucket.bitbucket.io/3d-cadastre/spec/SolidGeometry.png> ;
    schema:description "Abstract superclass for the set of 3-Dimensional Geometric Primitives  which may be used to define 3D geometries and calculate alternative representations of interior, face and topology of an object in 3D cartesian space." ;
    schema:name "Abstract Solid Geometry" ;
.

geometry:BoundaryFeature
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf geo:Feature ;
    schema:description "A Boundary Feature is a topological concept - an object relates to a specific geometry type and adds information about the orientation of the geometry relative to topologically connected features. Note that a Feature defined without specifying the underlying geometry if required, allowing for example the geometry to be measured or calculated by operations on the geometries of related features." ;
    schema:name "Boundary Feature" ;
.

ont:
    a owl:Ontology ;
    owl:versionInfo "This is a candidate extension for GeoSPARQL 1.1 to support topology in 3D features." ;
    foaf:depiction <https://surroundbitbucket.bitbucket.io/3d-cadastre/spec/geosparql3D.png> ;
    schema:description "This extends GeoSPARQL to provide a names subset of ISO 19107 concepts for 3D solids and support 3D topology amongst features. It is a companion to the Simple Features model for interoperability between 3D applications." ;
    schema:name "Geometry Primitives Model" ;
.

