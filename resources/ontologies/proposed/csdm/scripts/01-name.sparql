PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

DELETE {
    ?x rdfs:label ?l .
    ?x skos:prefLabel ?l .
}
INSERT {
    ?x schema:name ?l_str
}
WHERE {
    ?x rdfs:label|skos:prefLabel ?l .

    BIND (STR(?l) AS ?l_str)
}