PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>

DELETE {
    ?x rdfs:comment ?l .
    ?x skos:definition ?l .
}
INSERT {
    ?x schema:description ?l_str
}
WHERE {
    ?x rdfs:comment|skos:definition ?l .

    BIND (STR(?l) AS ?l_str)
}