PREFIX : <http://www.w3.org/ns/org#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX foaf: <http://xmlns.com/foaf/0.1/>
PREFIX gr: <http://purl.org/goodrelations/v1#>
PREFIX ont: <http://www.w3.org/ns/org>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

gr:BusinessEntity
    rdfs:subClassOf :FormalOrganization ;
.

:Head
    a :Role ;
    rdfs:isDefinedBy ont: ;
    :roleProperty :headOf ;
    schema:description "A role corresponding to the `org:headOf` property" ;
    schema:name "head" ;
.

:OrganizationalCollaboration
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :Organization ;
    owl:equivalentClass
        [
            owl:intersectionOf (
                :Organization
                
                [
                    a owl:Restriction ;
                    owl:allValuesFrom :Organization ;
                    owl:onProperty :hasMember ;
                ]
            ) ;
        ] ;
    schema:description "A collaboration between two or more Organizations such as a project. It meets the criteria for being an Organization in that it has an identity and defining purpose independent of its particular members but is neither a formally recognized legal entity nor a sub-unit within some larger organization. Might typically have a shorter lifetime than the Organizations within it, but not necessarily. All members are `org:Organization`s rather than individuals and those Organizations can play particular roles within the venture. Alternative names: _Project_ _Venture_  _Endeavour_ _Consortium_ _Endeavour_" ;
    schema:name "Endeavour" ;
.

:basedAt
    a owl:ObjectProperty ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Site ;
    schema:description "Indicates the site at which a person is based. We do not restrict the possibility that a person is based at multiple sites." ;
    schema:name "based At" ;
.

:classification
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range skos:Concept ;
    schema:description "Indicates a classification for this Organization within some classification scheme. Extension vocabularies may wish to specialize this property to have a range corresponding to a specific `skos:ConceptScheme`. This property is under discussion and may be revised or removed - in many cases organizations are best categorized by defining a sub-class hierarchy in an extension vocabulary." ;
    schema:name "classification" ;
.

:hasRegisteredSite
    a owl:ObjectProperty ;
    rdfs:domain :FormalOrganization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Site ;
    rdfs:subPropertyOf :hasPrimarySite ;
    schema:description "Indicates the legally registered site for the organization, in many legal jurisdictions there is a requirement that FormalOrganizations such as Companies or Charities have such a primary designed site. " ;
    schema:name "registered Site" ;
.

:holds
    a owl:ObjectProperty ;
    rdfs:domain foaf:Agent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Post ;
    owl:inverseOf :heldBy ;
    schema:description "Indicates a Post held by some Agent." ;
    schema:name "holds" ;
.

:linkedTo
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    schema:description "Indicates an arbitrary relationship between two organizations. Specializations of this can be used to, for example, denote funding or supply chain relationships." ;
    schema:name "linked to" ;
.

:location
    a
        rdf:Property ,
        owl:DatatypeProperty ;
    rdfs:domain foaf:Person ;
    rdfs:isDefinedBy ont: ;
    rdfs:range xsd:string ;
    schema:description "Gives a location description for a person within the organization, for example a _Mail Stop_ for internal posting purposes." ;
    schema:name "location" ;
.

:memberDuring
    a owl:ObjectProperty ;
    rdfs:domain :Membership ;
    rdfs:isDefinedBy ont: ;
    schema:description "Optional property to indicate the interval for which the membership is/was valid." ;
    schema:name "member During" ;
.

:organization
    a
        rdf:Property ,
        owl:FunctionalProperty ,
        owl:ObjectProperty ;
    rdfs:domain :Membership ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    schema:description "Indicates Organization in which the Agent is a member." ;
    schema:name "organization" ;
.

:postIn
    a owl:ObjectProperty ;
    rdfs:domain :Post ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    owl:inverseOf :hasPost ;
    schema:description "Indicates the Organization in which the Post exists." ;
    schema:name "post in" ;
.

:purpose
    a rdf:Property ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    schema:description "Indicates the purpose of this Organization. There can be many purposes at different levels of abstraction but the nature of an organization is to have a reason for existence and this property is a means to document that reason. An Organization may have multiple purposes. It is recommended that the purpose be denoted by a controlled term or code list, ideally a `skos:Concept`. However, the range is left open to allow for other types of descriptive schemes. It is expected that specializations or application profiles of this vocabulary will constrain the range of the purpose. Alternative names: _remit_ _responsibility_ (esp. if applied to OrganizationalUnits such as Government Departments)." ;
    schema:name "purpose" ;
.

:remuneration
    a owl:ObjectProperty ;
    rdfs:domain :Role ;
    rdfs:isDefinedBy ont: ;
    schema:description "Indicates a salary or other reward associated with the role. Typically this will be denoted using an existing representation scheme such as `gr:PriceSpecification` but the range is left open to allow applications to specialize it (e.g. to remunerationInGBP)." ;
    schema:name "remuneration" ;
.

:reportsTo
    a owl:ObjectProperty ;
    rdfs:domain
        [
            owl:unionOf (
                foaf:Agent
                :Post
            ) ;
        ] ;
    rdfs:isDefinedBy ont: ;
    rdfs:range
        [
            owl:unionOf (
                foaf:Agent
                :Post
            ) ;
        ] ;
    schema:description "Indicates a reporting relationship as might be depicted on an organizational chart. The precise semantics of the reporting relationship will vary by organization but is intended to encompass both direct supervisory relationships (e.g. carrying objective and salary setting authority) and more general reporting or accountability relationships (e.g. so called _dotted line_ reporting)." ;
    schema:name "reports to" ;
.

:role
    a owl:ObjectProperty ;
    rdfs:domain
        [
            owl:unionOf (
                :Membership
                :Post
            ) ;
        ] ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Role ;
    schema:description "Indicates the Role that the Agent plays in a Membership relationship with an Organization." ;
    schema:name "role" ;
.

:roleProperty
    a
        rdf:Property ,
        owl:AnnotationProperty ;
    rdfs:domain :Role ;
    rdfs:isDefinedBy ont: ;
    rdfs:range rdf:Property ;
    schema:description "This is a metalevel property which is used to annotate an `org:Role` instance with a sub-property of `org:memberOf` that can be used to directly indicate the role for easy of query. The intended semantics is a Membership relation involving the Role implies the existence of a direct property relationship through an inference rule of the form:  `{ [] org:member ?p; org:organization ?o; org:role [org:roleProperty ?r] } -> {?p ?r ?o}`." ;
    schema:name "role (property)" ;
.

:siteAddress
    a owl:ObjectProperty ;
    rdfs:domain :Site ;
    rdfs:isDefinedBy ont: ;
    schema:description "Indicates an address for the site in a suitable encoding. Use of vCard (using the http://www.w3.org/TR/vcard-rdf/ vocabulary) is encouraged but the range is left open to allow other encodings to be used. The address may include email, telephone, and geo-location information and is not restricted to a physical address. " ;
    schema:name "site Address" ;
.

prov:wasDerivedFrom
    rdfs:isDefinedBy ont: ;
    owl:propertyChainAxiom (
        :resultedFrom
        :originalOrganization
    ) ;
.

:changedBy
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :ChangeEvent ;
    owl:inverseOf :originalOrganization ;
    schema:description "Indicates a change event which resulted in a change to this organization. Depending on the event the organization may or may not have continued to exist after the event. Inverse of `org:originalOrganization`." ;
    schema:name "changed by" ;
.

:hasMembership
    a owl:ObjectProperty ;
    rdfs:domain foaf:Agent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Membership ;
    owl:inverseOf :member ;
    schema:description "Indicates a membership relationship that the Agent plays. Inverse of `org:member`." ;
    schema:name "membership" ;
.

:hasPost
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Post ;
    schema:description "Indicates a Post which exists within the Organization." ;
    schema:name "post" ;
.

:hasPrimarySite
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Site ;
    rdfs:subPropertyOf :hasSite ;
    schema:description "Indicates a primary site for the Organization, this is the default means by which an Organization can be contacted and is not necessarily the formal headquarters." ;
    schema:name "primary Site" ;
.

:hasUnit
    a owl:ObjectProperty ;
    rdfs:domain :FormalOrganization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :OrganizationalUnit ;
    rdfs:subPropertyOf :hasSubOrganization ;
    owl:inverseOf :unitOf ;
    schema:description "Indicates a unit which is part of this Organization, e.g. a Department within a larger FormalOrganization. Inverse of `org:unitOf`." ;
    schema:name "has Unit" ;
.

:headOf
    a owl:ObjectProperty ;
    rdfs:domain foaf:Agent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    rdfs:subPropertyOf :memberOf ;
    schema:description "Indicates that a person is the leader or formal head of the Organization. This will normally mean that they are the root of the `org:reportsTo` (acyclic) graph, though an organization may have more than one head." ;
    schema:name "head of" ;
.

:heldBy
    a owl:ObjectProperty ;
    rdfs:domain :Post ;
    rdfs:isDefinedBy ont: ;
    rdfs:range foaf:Agent ;
    schema:description "Indicates an Agent which holds a Post." ;
    schema:name "held by" ;
.

:identifier
    a
        rdf:Property ,
        owl:DatatypeProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:subPropertyOf skos:notation ;
    schema:description "Gives an identifier, such as a company registration number, that can be used to used to uniquely identify the organization. Many different national and international identier schemes are available. The org ontology is neutral to which schemes are used. The particular identifier scheme should be indicated by the datatype of the identifier value.  Using datatypes to distinguish the notation scheme used is consistent with recommended best practice for `skos:notation` of which this property is a specialization." ;
    schema:name "identifier" ;
.

:member
    a
        rdf:Property ,
        owl:FunctionalProperty ,
        owl:ObjectProperty ;
    rdfs:domain :Membership ;
    rdfs:isDefinedBy ont: ;
    rdfs:range foaf:Agent ;
    owl:inverseOf :hasMembership ;
    schema:description "Indicates the Person (or other Agent including Organization) involved in the Membership relationship. Inverse of `org:hasMembership`" ;
    schema:name "member" ;
.

:resultingOrganization
    a owl:ObjectProperty ;
    rdfs:domain :ChangeEvent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    owl:inverseOf :resultedFrom ;
    schema:description "Indicates an organization which was created or changed as a result of the event. Inverse of `org:resultedFrom`." ;
    schema:name "resulted in" ;
.

:siteOf
    a owl:ObjectProperty ;
    rdfs:domain :Site ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    owl:inverseOf :hasSite ;
    schema:description "Indicates an Organization which has some presence at the given site. This is the inverse of `org:hasSite`." ;
    schema:name "site Of" ;
.

:transitiveSubOrganizationOf
    a
        rdf:Property ,
        owl:ObjectProperty ,
        owl:TransitiveProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    schema:description "The transitive closure of subOrganizationOf, giving a representation of all organizations that contain this one. Note that technically this is a super property of the transitive closure so it could contain additional assertions but such usage is discouraged." ;
    schema:name "transitive sub-organization" ;
.

:unitOf
    a owl:ObjectProperty ;
    rdfs:domain :OrganizationalUnit ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :FormalOrganization ;
    rdfs:subPropertyOf :subOrganizationOf ;
    owl:inverseOf :hasUnit ;
    schema:description "Indicates an Organization of which this Unit is a part, e.g. a Department within a larger FormalOrganization. This is the inverse of `org:hasUnit`." ;
    schema:name "unit Of" ;
.

:OrganizationalUnit
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf :Organization ;
    schema:description "An Organization such as a University Support Unit which is part of some larger FormalOrganization and only has full recognition within the context of that FormalOrganization, it is not a Legal Entity in its own right. Units can be large and complex containing other Units and even FormalOrganizations. Alternative names: _OU_ _Unit_ _Department_" ;
    schema:name "OrganizationalUnit" ;
.

:hasMember
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range foaf:Agent ;
    owl:equivalentProperty foaf:member ;
    owl:inverseOf :memberOf ;
    schema:description "Indicates a person who is a member of the subject Organization. Inverse of `org:memberOf`, see that property for further clarification. Provided for compatibility with `foaf:member`." ;
    schema:name "has member" ;
.

:hasSite
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Site ;
    owl:inverseOf :siteOf ;
    schema:description "Indicates a site at which the Organization has some presence even if only indirect (e.g. virtual office or a professional service which is acting as the registered address for a company). Inverse of `org:siteOf`." ;
    schema:name "has site" ;
.

:hasSubOrganization
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    owl:inverseOf :subOrganizationOf ;
    schema:description "Represents hierarchical containment of Organizations or Organizational Units; indicates an organization which is a sub-part or child of this organization.  Inverse of `org:subOrganizationOf`." ;
    schema:name "has SubOrganization" ;
.

:memberOf
    a owl:ObjectProperty ;
    rdfs:domain foaf:Agent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    owl:inverseOf :hasMember ;
    schema:description "Indicates that a person is a member of the Organization with no indication of the nature of that membership or the role played. Note that the choice of property name is not meant to limit the property to only formal membership arrangements, it is also indended to cover related concepts such as affilliation or other involvement in the organization. Extensions can specialize this relationship to indicate particular roles within the organization or more nuanced relationships to the organization. Has an optional inverse, `org:hasmember`." ;
    schema:name "member of" ;
.

:originalOrganization
    a owl:ObjectProperty ;
    rdfs:domain :ChangeEvent ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    rdfs:subPropertyOf prov:used ;
    owl:inverseOf :changedBy ;
    schema:description "Indicates one or more organizations that existed before the change event. Depending on the event they may or may not have continued to exist after the event. Inverse of `org:changedBy`." ;
    schema:name "original organization" ;
.

:resultedFrom
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :ChangeEvent ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    owl:inverseOf :resultingOrganization ;
    schema:description "Indicates an event which resulted in this organization. Inverse of `org:resultingOrganization`." ;
    schema:name "resulted from" ;
.

:subOrganizationOf
    a owl:ObjectProperty ;
    rdfs:domain :Organization ;
    rdfs:isDefinedBy ont: ;
    rdfs:range :Organization ;
    rdfs:subPropertyOf :transitiveSubOrganizationOf ;
    owl:inverseOf :hasSubOrganization ;
    schema:description "Represents hierarchical containment of Organizations or OrganizationalUnits; indicates an Organization which contains this Organization. Inverse of `org:hasSubOrganization`." ;
    schema:name "subOrganization of" ;
.

:FormalOrganization
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf
        :Organization ,
        foaf:Organization ;
    schema:description "An Organization which is recognized in the world at large, in particular in legal jurisdictions, with associated rights and responsibilities. Examples include a Corporation, Charity, Government or Church. Note that this is a super class of `gr:BusinessEntity` and it is recommended to use the GoodRelations vocabulary to denote Business classifications such as DUNS or NAICS." ;
    schema:name "Formal Organization" ;
.

:Role
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf skos:Concept ;
    owl:disjointWith
        :ChangeEvent ,
        :Membership ,
        :Site ;
    schema:description "Denotes a role that a Person or other Agent can take in an organization. Instances of this class describe the abstract role; to denote a specific instance of a person playing that role in a specific organization use an instance of `org:Membership`. It is common for roles to be arranged in some taxonomic structure and we use SKOS to represent that. The normal SKOS lexical properties should be used when labelling the Role. Additional descriptive properties for the Role, such as a Salary band, may be added by extension vocabularies." ;
    schema:name "Role" ;
.

:Membership
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    owl:disjointWith
        :ChangeEvent ,
        :Site ;
    schema:description "Indicates the nature of an Agent's membership of an organization. Represents an n-ary relation between an Agent, an Organization and a Role. It is possible to directly indicate membership, independent of the specific Role, through use of the `org:memberOf` property." ;
    schema:name "Membership" ;
.

:Post
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    schema:description "A Post represents some position within an organization that exists independently of the person or persons filling it. Posts may be used to represent situations where a person is a member of an organization ex officio (for example the Secretary of State for Scotland is part of UK Cabinet by virtue of being Secretary of State for Scotland, not as an individual person). A post can be held by multiple people and hence can be treated as a organization in its own right." ;
    schema:name "Post" ;
.

:ChangeEvent
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf prov:Activity ;
    schema:description "Represents an event which resulted in a major change to an organization such as a merger or complete restructuring. It is intended for situations where the resulting organization is sufficient distinct from the original organizations that it has a distinct identity and distinct URI. Extension vocabularies should define sub-classes of this to denote particular categories of event. The instant or interval at which the event occurred should be given by `prov:startAtTime` and `prov:endedAtTime`, a description should be given by `dct:description`. " ;
    schema:name "Change Event" ;
.

:Site
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    owl:disjointWith :ChangeEvent ;
    schema:description "An office or other premise at which the organization is located. Many organizations are spread across multiple sites and many sites will host multiple locations. In most cases a Site will be a physical location. However, we don't exclude the possibility of non-physical sites such as a virtual office with an associated post box and phone reception service. Extensions may provide subclasses to denote particular types of site." ;
    schema:name "Site" ;
.

:Organization
    a owl:Class ;
    rdfs:isDefinedBy ont: ;
    rdfs:subClassOf foaf:Agent ;
    owl:disjointWith
        :ChangeEvent ,
        :Membership ,
        :Role ,
        :Site ;
    owl:equivalentClass foaf:Organization ;
    owl:hasKey (
        :identifier
    ) ;
    schema:description "Represents a collection of people organized together into a community or other social, commercial or political structure. The group has some common purpose or reason for existence which goes beyond the set of people belonging to it and can act as an Agent. Organizations are often decomposable into hierarchical structures.  It is recommended that SKOS lexical labels should be used to label the Organization. In particular `skos:prefLabel` for the primary (possibly legally recognized name), `skos:altLabel` for alternative names (trading names, colloquial names) and `skos:notation` to denote a code from a code list. Alternative names: _Collective_ _Body_ _Org_ _Group_" ;
    schema:name "Organization" ;
.

ont:
    a owl:Ontology ;
    owl:versionInfo "0.8" ;
    schema:citation "http://www.w3.org/TR/vocab-org/"^^xsd:anyURI ;
    dcterms:contributor
        [
            foaf:mbox "giorgia.lodi@agid.gov.it" ;
            foaf:name "Giorgia Lodi" ;
        ] ,
        [
            foaf:mbox "ogiraldo@fi.upm.es" ;
            foaf:name "Olga Ximena Giraldo" ;
        ] ,
        [
            foaf:homepage <http://www.asahi-net.or.jp/~ax2s-kmtn/> ;
            foaf:name "Shuji Kamitsuna" ;
        ] ,
        [
            foaf:mbox "antonio.maccioni@agid.gov.it" ;
            foaf:name "Antonio Maccioni" ;
        ] ,
        [
            foaf:mbox "dave@epimorphics.com" ;
            foaf:name "Dave Reynolds" ;
        ] ,
        [
            foaf:mbox "dguardiola@quinode.fr" ;
            foaf:name "Dominique Guardiola" ;
        ] ,
        [
            foaf:mbox "emontiel@fi.upm.es" ;
            foaf:name "Elena Montiel Ponsoda" ;
        ] ,
        [
            foaf:mbox "mpoveda@fi.upm.es" ;
            foaf:name "María Poveda Villalón" ;
        ] ,
        [
            foaf:mbox "lupe@fi.upm.es" ;
            foaf:name "Guadalupe Aguado de Cea" ;
        ] ;
    schema:creator <https://www.w3.org> ;
    schema:dateCreated "2010-05-28"^^xsd:date ;
    schema:dateIssued "2014-01-16"^^xsd:date ;
    schema:dateModified "2014-04-12"^^xsd:date ;
    schema:description "Vocabulary for describing organizational structures, specializable to a broad variety of types of organization." ;
    schema:license <http://www.opendatacommons.org/licenses/pddl/1.0/> ;
    schema:name "Organization Ontology" ;
    schema:publisher <https://www.w3.org> ;
.
