PREFIX : <https://linked.data.gov.au/def/bcp/validator/>
PREFIX ont: <https://linked.data.gov.au/def/bcp/validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<http://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:affiliation <https://kurrawong.ai> ;
    schema:email "nick@kurrawong.ai"^^xsd:anyURI ;
    schema:name "Nicholas J Car" ;
.

<https://kurrawong.ai>
    a schema:Organization ;
    schema:name "KurrawongAI" ;
    schema:url "https://kurrawong.ai"^^xsd:anyURI ;
.

:DC-created-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement D-created: Each catalogue MUST have exactly one created date indicated using the schema:dateCreated predicate with a literal value of either xsd:date, xsd:dateTime or xsd:dateTimeStamp type" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
        
        [
            sh:datatype xsd:gYear ;
        ]
    ) ;
    sh:path schema:dateCreated ;
    schema:description "Check that the Data Catalogue has a created date" ;
    schema:name "Data Catalog created date property" ;
.

:DC-creator-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-creator: Each catalogue MUST indicate one or more agents with the schema:creator predicate, typed as an schema:Person or schema:Organization" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path schema:creator ;
    schema:description "Check that the Data Catalogue has a creator" ;
    schema:name "Data Catalog creator property" ;
.

:DC-desc-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Each catalogue MUST have one and description which is to be a text literal, indicated using the schema:description predicate" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:description ;
    schema:description "Check that the Data Catalogue has a description" ;
    schema:name "Data Catalog description property" ;
.

:DC-exists-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Each graph MUST have at least one catalogue instance" ;
    sh:minCount 1 ;
    sh:path
        [
            sh:inversePath rdf:type ;
        ] ;
    schema:description "Check that the Data Catalogue exists" ;
    schema:name "Data Catalog exists property" ;
.

:DC-license-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement D-license: Each catalogue MUST indicate a license that defines conditions for its use with the schema:license predicate with the value indicated coming from either the RDF Licenses dataset or being locally-defined odrl:Policy instance" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path schema:license ;
    schema:description "Check that the Data Catalogue has a license" ;
    schema:name "Data Catalog license property" ;
.

:DC-modified-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
    ) ;
    sh:path schema:dateModified ;
    schema:description "Check that the Data Catalogue has a modified date" ;
    schema:name "Data Catalog date modified property" ;
.

:DC-name-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:name ;
    schema:description "Check that the Data Catalogue has a name" ;
    schema:name "Data Catalog name property" ;
.

:DC-publisher-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-publisher: Each catalogue MUST indicate one or more agents with the schema:publisher predicate, typed as an schema:Person or schema:Organization" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path schema:publisher ;
    schema:description "Check that the Data Catalogue has a publisher" ;
    schema:name "Data Catalog publisher property" ;
.

:Requirement-DC-created
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-created-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a created date" ;
    schema:name "Data Catalog created date" ;
.

:Requirement-DC-creator
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-creator-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a creator" ;
    schema:name "Data Catalog creator" ;
.

:Requirement-DC-desc
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-desc-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a description" ;
    schema:name "Data Catalog description" ;
.

:Requirement-DC-exists
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-exists-property ;
    sh:targetNode schema:DataCatalog ;
    schema:description "Check that the Data Catalogue exists" ;
    schema:name "Data Catalog exists" ;
.

:Requirement-DC-history
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-history: Each catalogue SHOULD indicate how it was produced or its origin by use of one of the following predicates: skos:historyNote, schema:citation, prov:wasDerivedFrom" ;
    sh:or (
        :provenance-properties-01
        :provenance-properties-02
        :provenance-properties-03
    ) ;
    sh:severity sh:Warning ;
    sh:targetClass schema:DataCatalog ;
    schema:name "Data Catalog history" ;
.

:Requirement-DC-license
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-license-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a license" ;
    schema:name "Data Catalog license" ;
.

:Requirement-DC-modified
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-modified: Each catalogue MUST have exactly one created date indicated using the schema:dateModified predicate with a literal value of either xsd:date, xsd:dateTime or xsd:dateTimeStamp type" ;
    sh:property :DC-modified-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a modified date" ;
    schema:name "Data Catalog modified date" ;
.

:Requirement-DC-name
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Each catalogue MUST have one and only one name which is to be a text literal, indicated using the schema:name predicate" ;
    sh:property :DC-name-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a name" ;
    schema:name "Data Catalog name" ;
.

:Requirement-DC-publisher
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :DC-publisher-property ;
    sh:targetClass schema:DataCatalog ;
    schema:description "Check that the Data Catalogue has a publisher" ;
    schema:name "Data Catalog publisher" ;
.

:provenance-properties-01
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "prov:wasDerivedFrom must indicate an IRI" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path prov:wasDerivedFrom ;
    schema:name "Data Catalog provenance property 01" ;
.

:provenance-properties-02
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "schema:citation must indicate a URL or a string" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:anyURI ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:citation ;
    schema:name "Data Catalog provenance property 02" ;
.

:provenance-properties-03
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "skos:historyNote must indicate a string, with or without language indicated" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path skos:historyNote ;
    schema:name "Data Catalog provenance property 03" ;
.

<https://linked.data.gov.au/org/dcceew>
    a schema:Organization ;
    schema:name "Department of Climate Change, energy, the Environment and Water" ;
    schema:url "https://www.dcceew.gov.au/"^^xsd:anyURI ;
.

ont:
    a owl:Ontology ;
    schema:creator <http://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2025-05-30"^^xsd:date ;
    schema:dateModified "2026-04-07"^^xsd:date ;
    schema:description "The Basic Catalogue Profile validator" ;
    schema:hasPart
        :Requirement-DC-created ,
        :Requirement-DC-creator ,
        :Requirement-DC-desc ,
        :Requirement-DC-exists ,
        :Requirement-DC-history ,
        :Requirement-DC-license ,
        :Requirement-DC-modified ,
        :Requirement-DC-name ,
        :Requirement-DC-publisher ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "Basic Catalogue Profile Validator" ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    schema:version "6" ;
.
