PREFIX : <https://linked.data.gov.au/def/addr/validator-qld/>
PREFIX addr: <https://linked.data.gov.au/def/addr/>
PREFIX cn: <https://linked.data.gov.au/def/cn/>
PREFIX sg: <https://linked.data.gov.au/def/addr/validator-qld>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

sg:
    a owl:Ontology ;
    owl:imports addr:validator ;
    owl:versionIRI :1.0.4 ;
    owl:versionInfo "1.0.4" ;
    skos:historyNote "This model validator was made for the Queensland Department of Resources, Spatial Information unit to assist with future Address database design." ;
    schema:codeRepository "https://github.com/icsm-au/addr-model"^^xsd:anyURI ;
    schema:copyrightHolder <https://linked.data.gov.au/org/qsi> ;
    schema:copyrightNotice "(c) The State of Queensland (Department of Natural Resources and Mines, Manufacturing and Regional and Rural Development) 2026" ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2021-12-16"^^xsd:date ;
    schema:dateIssued "2023-06-30"^^xsd:date ;
    schema:dateModified "2026-07-09"^^xsd:date ;
    schema:description "This validator is a Shapes Constraint Language (SHACL) resource that can be used to check the conformance of RDF data to the ANZ ICSM Address Model with extensions for Queensland" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "Address Model Validator for Qld" ;
    schema:publisher <https://linked.data.gov.au/org/qsi> ;
.

:state-is-qld
    a sh:NodeShape ;
    rdfs:isDefinedBy sg: ;
    sh:message "Each ACT Address must indicate an Address Part with the ASGS IRI for Queensland" ;
    sh:property
        [
            sh:hasValue <https://linked.data.gov.au/dataset/asgsed3/STE/3> ;
            sh:path (
                schema:hasPart
                schema:value
            ) ;
        ] ;
    sh:targetClass addr:Address ;
    schema:name "State is Qld" ;
.

<https://kurrawong.ai>
    a schema:Organization ;
    schema:name "KurrawongAI" ;
    schema:url "https://kurrawong.ai"^^xsd:anyURI ;
.

:1.0.4
    schema:name "1.0.4" ;
.

<https://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:email "nick@kurrawong.ai"^^xsd:anyURI ;
    schema:memberOf <https://kurrawong.ai> ;
    schema:name "Nicholas J. Car" ;
.

<https://linked.data.gov.au/org/qsi>
    a schema:Organization ;
    schema:name "Spatial Information Queensland" ;
    schema:url "https://qldspatial.information.qld.gov.au"^^xsd:anyURI ;
.
