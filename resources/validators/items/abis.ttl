PREFIX : <https://linked.data.gov.au/def/abis/validator/>
PREFIX ont: <https://linked.data.gov.au/def/abis/validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX tern: <https://w3id.org/tern/ontologies/tern/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:collection-obs
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :collection-obs-property ;
    sh:targetClass tern:ObservationCollection ;
    schema:description "Checks the Observation Sollection's members" ;
    schema:name "ObservationCollection's Observations" ;
.

:collection-obs-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:class tern:Observation ;
    sh:message "Each Observation Collection must have at least one Observation indicated via sosa:member" ;
    sh:minCount 1 ;
    sh:path sosa:hasMember ;
    schema:name "ObservationCollection's Observations property" ;
.

<https://linked.data.gov.au/org/ausbigg>
    a schema:Organization ;
    schema:name "Australian Biodiversity Information Governance Group" ;
    schema:url "https://github.com/AusBIGG/"^^xsd:anyURI ;
.

<https://linked.data.gov.au/org/bdr-team>
    a schema:Organization ;
    schema:name "BDR Team" ;
    schema:url "https://bdr.gov.au/"^^xsd:anyURI ;
.

ont:
    a owl:Ontology ;
    owl:imports 
        <https://linked.data.gov.au/def/vocpub/validator> ,
        <https://w3id.org/tern/shapes/tern/> ,
        <https://linked.data.gov.au/def/bdr-pr/sosa-validator> ,
        <http://www.opengis.net/def/geosparql/validator> ;
    owl:versionIRI :1.1 ;
    owl:versionInfo """1.1 2026-04 simplified imports

1.0 First version""" ;
    schema:copyrightNotice "(c) 2024 AusBIGG" ;
    schema:creator <https://linked.data.gov.au/org/bdr-team> ;
    schema:dateCreated "2022-05-11"^^xsd:date ;
    schema:dateModified "2025-04-07"^^xsd:date ;
    schema:description "SHACL validator for the Australian Biodiveristy Information Standard, ABIS" ;
    schema:hasPart :collection-obs ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "ABIS Validator" ;
    schema:publisher <https://linked.data.gov.au/org/ausbigg> ;
    schema:version "1.1" ;
.
