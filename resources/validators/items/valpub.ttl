sg:
    a owl:Ontology ;
    owl:versionIRI :1.4 ;
    owl:versionInfo """1.4 2026-07: differentiation of messages from property and node shapes

1.3 2026-04: Align schema:license allowed types with VocPub

1.2 2026-02: Changes a couple of Violations to Warnings

1.1 2026-02: Made ValPub compliant; move all Property Shapes to IRIs, not BNs

1.0 2025-12: Created based on OntPub Validator & the SHACL Profiling deaft recommendation""" ;
    skos:historyNote "This validator was made to improve teh consistency of Australian ontology formulation, initially by CSIRO and then handed to the AGLDWG" ;
    schema:codeRepository "https://github.com/agldwg/valpub-profile"^^xsd:anyURI ;
    schema:copyrightHolder <https://kurrawong.ai> ;
    schema:copyrightYear "2025"^^xsd:gYear ;
    schema:creator <https://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2025-12-15"^^xsd:date ;
    schema:dateIssued "2026-02-09"^^xsd:date ;
    schema:dateModified "2026-07-09"^^xsd:date ;
    schema:description "SHACL Shapes to validate ontologies of SHACL shapes according to the Validator Publications Profile" ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "Validator Publication Profile Validator" ;
    schema:publisher <https://kurrawong.ai> ;
    schema:version "1.4" ;
.
