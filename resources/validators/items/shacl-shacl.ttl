PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shsh: <http://www.w3.org/ns/shacl-shacl#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shsh:EntailmentShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:nodeKind sh:IRI ;
    sh:targetObjectsOf sh:entailment ;
    schema:description "Entailment Shape" ;
    schema:name "Entailment Shape" ;
.

shsh:ShapesGraphShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:nodeKind sh:IRI ;
    sh:targetObjectsOf sh:shapesGraph ;
    schema:description "Shapes Graph Shape" ;
    schema:name "Shapes Graph Shape" ;
.

shsh:ShapesListShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:property
        [
            sh:node shsh:ShapeShape ;
            sh:path (
                
                [
                    sh:zeroOrMorePath rdf:rest ;
                ]
                rdf:first
            ) ;
        ] ;
    sh:targetObjectsOf
        sh:and ,
        sh:or ,
        sh:xone ;
    schema:description "Shapes List Shape" ;
    schema:name "Shapes List Shape" ;
.

shsh:1.0.1
    schema:name "1.0.1" ;
.

shsh:ListNodeShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:or (
        
        [
            sh:hasValue () ;
            sh:property 
                [
                    sh:maxCount 0 ;
                    sh:path rdf:first ;
                ] ,
                [
                    sh:maxCount 0 ;
                    sh:path rdf:rest ;
                ] ;
        ]
        
        [
            sh:not
                [
                    sh:hasValue () ;
                ] ;
            sh:property 
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path rdf:first ;
                ] ,
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path rdf:rest ;
                ] ;
        ]
    ) ;
    schema:description "Defines constraints on what it means for a node to be a node within a well-formed RDF list. Note that this does not check whether the rdf:rest items are also well-formed lists as this would lead to unsupported recursion." ;
    schema:name "List node shape" ;
.

shsh:NodeShapeShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:property 
        [
            sh:maxCount 0 ;
            sh:path sh:minCount ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:maxCount ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:lessThan ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:uniqueLang ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:path ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:qualifiedValueShape ;
        ] ,
        [
            sh:maxCount 0 ;
            sh:path sh:lessThanOrEquals ;
        ] ;
    sh:targetObjectsOf sh:node ;
    schema:description "Node Shape Shape" ;
    schema:name "Node Shape Shape" ;
.

shsh:PathNodeShape
    sh:xone (
        
        [
            sh:nodeKind sh:IRI ;
        ]
        
        [
            sh:node shsh:PathListWithAtLeast2Members ;
            sh:nodeKind sh:BlankNode ;
        ]
        
        [
            sh:closed true ;
            sh:nodeKind sh:BlankNode ;
            sh:property
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:node shsh:PathListWithAtLeast2Members ;
                    sh:path sh:alternativePath ;
                ] ;
        ]
        
        [
            sh:closed true ;
            sh:nodeKind sh:BlankNode ;
            sh:property
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path sh:inversePath ;
                ] ;
        ]
        
        [
            sh:closed true ;
            sh:nodeKind sh:BlankNode ;
            sh:property
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path sh:zeroOrMorePath ;
                ] ;
        ]
        
        [
            sh:closed true ;
            sh:nodeKind sh:BlankNode ;
            sh:property
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path sh:oneOrMorePath ;
                ] ;
        ]
        
        [
            sh:closed true ;
            sh:nodeKind sh:BlankNode ;
            sh:property
                [
                    sh:maxCount 1 ;
                    sh:minCount 1 ;
                    sh:path sh:zeroOrOnePath ;
                ] ;
        ]
    ) ;
    schema:description "Path Node Shape" ;
    schema:name "Path Node Shape" ;
.

shsh:PathShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    rdfs:seeAlso <https://www.w3.org/TR/shacl/#property-paths> ;
    sh:property
        [
            sh:node shsh:PathNodeShape ;
            sh:path
                [
                    sh:zeroOrMorePath
                        [
                            sh:alternativePath (
                                 (
                                
                                [
                                    sh:zeroOrMorePath rdf:rest ;
                                ]
                                rdf:first
                            )
                                 (
                                sh:alternativePath
                                
                                [
                                    sh:zeroOrMorePath rdf:rest ;
                                ]
                                rdf:first
                            )
                                sh:inversePath
                                sh:zeroOrMorePath
                                sh:oneOrMorePath
                                sh:zeroOrOnePath
                            ) ;
                        ] ;
                ] ;
        ] ;
    schema:description "A shape that can be used to validate the syntax rules of well-formed SHACL paths." ;
    schema:name "Path shape" ;
.

shsh:PropertyShapeShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:property
        [
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:node shsh:PathShape ;
            sh:path sh:path ;
        ] ;
    sh:targetObjectsOf sh:property ;
    schema:description "Property Shape Shape" ;
    schema:name "Property Shape Shape" ;
.

shsh:ShapeShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:or (
        
        [
            sh:not
                [
                    sh:class rdfs:Class ;
                    sh:or (
                        
                        [
                            sh:class sh:NodeShape ;
                        ]
                        
                        [
                            sh:class sh:PropertyShape ;
                        ]
                    ) ;
                ] ;
        ]
        
        [
            sh:nodeKind sh:IRI ;
        ]
    ) ;
    sh:property 
        [
            sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:path sh:uniqueLang ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:qualifiedMaxCount ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:path sh:qualifiedValueShape ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:maxCount ;
        ] ,
        [
            sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:path sh:closed ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path (
                sh:ignoredProperties
                
                [
                    sh:zeroOrMorePath rdf:rest ;
                ]
                rdf:first
            ) ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:class ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:qualifiedMinCount ;
        ] ,
        [
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sh:pattern ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:targetSubjectsOf ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:lessThan ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path sh:severity ;
        ] ,
        [
            sh:in (
                true
                false
            ) ;
            sh:maxCount 1 ;
            sh:path sh:deactivated ;
        ] ,
        [
            sh:in (
                sh:BlankNode
                sh:IRI
                sh:Literal
                sh:BlankNodeOrIRI
                sh:BlankNodeOrLiteral
                sh:IRIOrLiteral
            ) ;
            sh:maxCount 1 ;
            sh:path sh:nodeKind ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:targetObjectsOf ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:minLength ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:equals ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:lessThanOrEquals ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:targetClass ;
        ] ,
        [
            sh:datatype xsd:string ;
            sh:path (
                sh:languageIn
                
                [
                    sh:zeroOrMorePath rdf:rest ;
                ]
                rdf:first
            ) ;
        ] ,
        [
            sh:nodeKind sh:IRI ;
            sh:path sh:disjoint ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:path sh:datatype ;
        ] ,
        [
            sh:datatype xsd:string ;
            sh:maxCount 1 ;
            sh:path sh:flags ;
        ] ,
        [
            sh:or (
                
                [
                    sh:datatype xsd:string ;
                ]
                
                [
                    sh:datatype rdf:langString ;
                ]
            ) ;
            sh:path sh:message ;
        ] ,
        [
            sh:node shsh:ListShape ;
            sh:path sh:and ;
        ] ,
        [
            sh:nodeKind sh:IRIOrLiteral ;
            sh:path sh:targetNode ;
        ] ,
        [
            sh:datatype xsd:boolean ;
            sh:maxCount 1 ;
            sh:path sh:qualifiedValueShapesDisjoint ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path sh:minExclusive ;
        ] ,
        [
            sh:node shsh:ListShape ;
            sh:path sh:or ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path sh:minInclusive ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:node shsh:ListShape ;
            sh:path sh:languageIn ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:node shsh:ListShape ;
            sh:path sh:in ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:node shsh:ListShape ;
            sh:path sh:ignoredProperties ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path sh:maxInclusive ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:minCount ;
        ] ,
        [
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:path sh:maxExclusive ;
        ] ,
        [
            sh:datatype xsd:integer ;
            sh:maxCount 1 ;
            sh:path sh:maxLength ;
        ] ,
        [
            sh:node shsh:ListShape ;
            sh:path sh:xone ;
        ] ;
    sh:targetClass
        sh:NodeShape ,
        sh:PropertyShape ;
    sh:targetObjectsOf
        sh:node ,
        sh:not ,
        sh:property ,
        sh:qualifiedValueShape ;
    sh:targetSubjectsOf
        sh:and ,
        sh:class ,
        sh:closed ,
        sh:datatype ,
        sh:disjoint ,
        sh:equals ,
        sh:flags ,
        sh:hasValue ,
        sh:ignoredProperties ,
        sh:in ,
        sh:languageIn ,
        sh:lessThan ,
        sh:lessThanOrEquals ,
        sh:maxCount ,
        sh:maxExclusive ,
        sh:maxInclusive ,
        sh:maxLength ,
        sh:minCount ,
        sh:minExclusive ,
        sh:minInclusive ,
        sh:minLength ,
        sh:node ,
        sh:nodeKind ,
        sh:not ,
        sh:or ,
        sh:pattern ,
        sh:property ,
        sh:qualifiedMaxCount ,
        sh:qualifiedMinCount ,
        sh:qualifiedValueShape ,
        sh:qualifiedValueShapesDisjoint ,
        sh:sparql ,
        sh:targetClass ,
        sh:targetNode ,
        sh:targetObjectsOf ,
        sh:targetSubjectsOf ,
        sh:uniqueLang ,
        sh:xone ;
    sh:xone (
        shsh:NodeShapeShape
        shsh:PropertyShapeShape
    ) ;
    schema:description "A shape that can be used to validate syntax rules for other shapes." ;
    schema:name "Shape shape" ;
.

shsh:PathListWithAtLeast2Members
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    sh:node shsh:ListShape ;
    sh:property
        [
            sh:minCount 2 ;
            sh:path
                [
                    sh:oneOrMorePath rdf:rest ;
                ] ;
        ] ;
    schema:description "Path List With At Least 2 Members" ;
    schema:name "Path List With At Least 2 Members" ;
.

<https://www.w3.org>
    a schema:Organization ;
    schema:name "World Wide Web Consortium" ;
    schema:url "https://www.w3.org"^^xsd:anyURI ;
.

shsh:ListShape
    a sh:NodeShape ;
    rdfs:isDefinedBy shsh: ;
    rdfs:seeAlso <https://www.w3.org/TR/shacl/#syntax-rule-SHACL-list> ;
    sh:property
        [
            sh:hasValue () ;
            sh:node shsh:ListNodeShape ;
            sh:path
                [
                    sh:zeroOrMorePath rdf:rest ;
                ] ;
            schema:description "Each list member (including this node) must be have the shape shsh:ListNodeShape." ;
        ] ;
    schema:description "A shape describing well-formed RDF lists. Currently does not check for non-recursion. This could be expressed using SHACL-SPARQL." ;
    schema:name "List shape" ;
.

shsh:
    a owl:Ontology ;
    owl:versionIRI shsh:1.0.1 ;
    owl:versionInfo """1.0.1 2026-04: made ValPub valid

1.0 2017: As released with the initial SHACL publication""" ;
    sh:declare
        [
            sh:namespace "http://www.w3.org/ns/shacl-shacl#" ;
            sh:prefix "shsh" ;
        ] ;
    schema:creator <https://www.w3.org> ;
    schema:dateCreated "2017-07-20"^^xsd:date ;
    schema:dateModified "2026-04-08"^^xsd:date ;
    schema:description "This shapes graph can be used to validate SHACL shapes graphs against a subset of the syntax rules." ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "SHACL for SHACL" ;
    schema:publisher <https://www.w3.org> ;
    schema:version "1.0.1" ;
.
