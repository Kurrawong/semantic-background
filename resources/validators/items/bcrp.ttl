PREFIX : <https://linked.data.gov.au/def/bcrp/validator/>
PREFIX ont: <https://linked.data.gov.au/def/bcrp/validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX prov: <http://www.w3.org/ns/prov#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

<http://orcid.org/0000-0002-8742-7730>
    a schema:Person ;
    schema:affiliation <https://kurrawong.ai> ;
    schema:email "nick@kurrawong.ai"^^xsd:anyURI ;
    schema:name "Nicholas J Car" ;
.

<https://kurrawong.ai>
    a schema:Organization ;
    schema:name "KurrawongAI" ;
    schema:url "https://kurrawong.ai"^^xsd:anyURI ;
.

:CW-created-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement D-created: Each catalogued resource MUST have exactly one created date indicated using the schema:dateCreated predicate with a literal value of either xsd:date, xsd:dateTime or xsd:dateTimeStamp type" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
        
        [
            sh:datatype xsd:gYear ;
        ]
    ) ;
    sh:path schema:dateCreated ;
    schema:name "Catalogued resource created date property" ;
.

:CW-creator-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-creator: Each catalogued resource MUST indicate one or more agents with the schema:creator predicate, typed as an schema:Person or schema:Organization" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path schema:creator ;
    schema:name "Catalogued resource creator property" ;
.

:CW-desc-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Each catalogued resource MUST have one and description which is to be a text literal, indicated using the schema:description predicate" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:description ;
    schema:name "Catalogued resource description property" ;
.

:CW-exists-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Each graph MUST have at least one catalogued resource instance" ;
    sh:minCount 1 ;
    sh:path
        [
            sh:inversePath rdf:type ;
        ] ;
    schema:name "Catalogued resource exists property" ;
.

:CW-license-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement D-license: Each catalogued resource MUST indicate a license that defines conditions for its use with the schema:license predicate with the value indicated coming from either the RDF Licenses dataset or being locally-defined odrl:Policy instance" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path schema:license ;
    schema:name "Catalogued resource license property" ;
.

:CW-modified-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Requirement D-modified: Each catalogued resource MUST have exactly one created date indicated using the schema:dateModified predicate with a literal value of either xsd:date, xsd:dateTime or xsd:dateTimeStamp type" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:dateTime ;
        ]
        
        [
            sh:datatype xsd:date ;
        ]
        
        [
            sh:datatype xsd:dateTimeStamp ;
        ]
    ) ;
    sh:path schema:dateModified ;
    schema:name "Catalogued resource modified date property" ;
.

:CW-name-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:maxCount 1 ;
    sh:message "Each catalogued resource MUST have one and only one name which is to be a text literal, indicated using the schema:name predicate" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:name ;
    schema:name "Catalogued resource name property" ;
.

:CW-publisher-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-publisher: Each catalogued resource MUST indicate one or more agents with the schema:publisher predicate, typed as an schema:Person or schema:Organization" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:class schema:Organization ;
        ]
        
        [
            sh:class schema:Person ;
        ]
    ) ;
    sh:path schema:publisher ;
    schema:name "Catalogued resource publisher property" ;
.

:Requirement-CW-created
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-created-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a created date" ;
    schema:name "Catalogued resource created date" ;
.

:Requirement-CW-creator
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-creator-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a creator" ;
    schema:name "Catalogued resource creator" ;
.

:Requirement-CW-desc
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-desc-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a description" ;
    schema:name "Catalogued resource description" ;
.

:Requirement-CW-exists
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-exists-property ;
    sh:targetNode schema:CreativeWork ;
    schema:description "Check that the Catalogued resource exists" ;
    schema:name "Catalogued resource exists" ;
.

:Requirement-CW-history
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Requirement D-history: Each catalogued resource SHOULD indicate how it was produced or its origin by use of one of the following predicates: skos:historyNote, schema:citation, prov:wasDerivedFrom" ;
    sh:or (
        :provenance-properties-01
        :provenance-properties-02
        :provenance-properties-03
    ) ;
    sh:severity sh:Warning ;
    sh:targetClass schema:CreativeWork ;
    schema:name "Catalogued resource history" ;
.

:Requirement-CW-license
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-license-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a license" ;
    schema:name "Catalogued resource license" ;
.

:Requirement-CW-modified
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-modified-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a modified date" ;
    schema:name "Catalogued resource modified date" ;
.

:Requirement-CW-name
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-name-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a name" ;
    schema:name "Catalogued resource name" ;
.

:Requirement-CW-publisher
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    sh:property :CW-publisher-property ;
    sh:targetClass schema:CreativeWork ;
    schema:description "Check that the Catalogued resource has a publisher" ;
    schema:name "Catalogued resource publisher" ;
.

:provenance-properties-01
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "prov:wasDerivedFrom must indicate an IRI" ;
    sh:minCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path prov:wasDerivedFrom ;
    schema:name "Catalogued resource provenance property 01" ;
.

:provenance-properties-02
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "schema:citation must indicate a URL or a string" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype xsd:anyURI ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path schema:citation ;
    schema:name "Catalogued resource provenance property 02" ;
.

:provenance-properties-03
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "skos:historyNote must indicate a string, with or without language indicated" ;
    sh:minCount 1 ;
    sh:or (
        
        [
            sh:datatype rdf:langString ;
        ]
        
        [
            sh:datatype xsd:string ;
        ]
    ) ;
    sh:path skos:historyNote ;
    schema:name "Catalogued resource provenance property 03" ;
.

<https://linked.data.gov.au/org/dcceew>
    a schema:Organization ;
    schema:name "Department of Climate Change, energy, the Environment and Water" ;
    schema:url "https://www.dcceew.gov.au/"^^xsd:anyURI ;
.

ont:
    a owl:Ontology ;
    schema:creator <http://orcid.org/0000-0002-8742-7730> ;
    schema:dateCreated "2025-05-30"^^xsd:date ;
    schema:dateModified "2026-04-07"^^xsd:date ;
    schema:description "The Basic Catalogue Resource Profile validator" ;
    schema:hasPart
        :Requirement-CW-created ,
        :Requirement-CW-creator ,
        :Requirement-CW-desc ,
        :Requirement-CW-exists ,
        :Requirement-CW-history ,
        :Requirement-CW-license ,
        :Requirement-CW-modified ,
        :Requirement-CW-name ,
        :Requirement-CW-publisher ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "Basic Catalogue Resource Profile Validator" ;
    schema:publisher <https://linked.data.gov.au/org/dcceew> ;
    schema:version "4" ;
.
