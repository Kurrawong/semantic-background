PREFIX : <https://linked.data.gov.au/def/bdr-pr/sosa-validator/>
PREFIX ont: <https://linked.data.gov.au/def/bdr-pr/sosa-validator>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX schema: <https://schema.org/>
PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX sosa: <http://www.w3.org/ns/sosa/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:used-procedure-iri
    a sh:NodeShape ;
    rdfs:isDefinedBy ont: ;
    schema:description "Checks that the value for usedProcedure is an IRI" ;
    schema:name "Use Procedure IRI" ;
    sh:property :used-procedure-iri-property ;
    sh:targetSubjectsOf sosa:usedProcedure ;
.

:used-procedure-iri-property
    a sh:PropertyShape ;
    rdfs:isDefinedBy ont: ;
    sh:message "Objects for the predicate sosa:usedProcedure must be IRIs" ;
    schema:name "Use Procedure IRI property" ;
    sh:nodeKind sh:IRI ;
    sh:path sosa:usedProcedure ;
.

<https://linked.data.gov.au/org/ausbigg>
    a schema:Organization ;
    schema:name "Australian Biodiversity Information Governance Group" ;
    schema:url "https://github.com/AusBIGG/"^^xsd:anyURI ;
.

<https://linked.data.gov.au/org/bdr-team>
    a schema:Organization ;
    schema:name "BDR Team" ;
    schema:url "https://bdr.gov.au/"^^xsd:anyURI ;
.

ont:
    a owl:Ontology ;
    owl:versionIRI :1.0 ;
    owl:versionInfo "1.0" ;
    schema:copyrightNotice "(c) 2026 AusBIGG" ;
    schema:creator <https://linked.data.gov.au/org/bdr-team> ;
    schema:dateCreated "2024-09-23"^^xsd:date ;
    schema:dateModified "2025-04-07"^^xsd:date ;
    schema:description """This is a [Shapes Constraint Language (SHACL)](https://www.w3.org/TR/shacl/) file that specifies validation rules for testing RDF data claiming conformance to the W3C's Sensor, Observation, Sample, and Actuator (SOSA) ontology, as needed by the Biodiversity Data Repository (BDR)

Note that this is not an official SOSA validator, only a part-validator for elements of SOSA relevant to the BDR."""@en ;
    schema:hasPart :shape-01 ;
    schema:license <http://purl.org/NET/rdflicense/cc-by4.0> ;
    schema:name "BDR SOSA Validator" ;
    schema:publisher <https://linked.data.gov.au/org/ausbigg> ;
.
